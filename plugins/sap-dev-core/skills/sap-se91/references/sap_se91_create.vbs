' =============================================================================
' sap_se91_create.vbs  -  SAP GUI Scripting: Create new message class via SE91
'
' Generated by the sap-se91 skill.
' Attaches to an existing SAP GUI session, navigates to SE91, creates a new
' message class, sets the short text, saves, then populates messages from a
' tab-separated file and saves again.
'
' Messages file format (tab-separated, one per line):
'   000	Message text for number 000
'   001	Another message &1 with placeholder
'   050	Sparse numbering is fine
'
' Tokens replaced at run time:
'   %%MSG_CLASS%%        Message class name      e.g. "ZHKMSG01"
'   %%SHORT_TEXT%%       Short description        e.g. "My custom messages"
'   %%MESSAGES_FILE%%    Path to messages file    e.g. "{WORK_TEMP}\messages.txt"
'   %%PACKAGE%%          SAP package              e.g. "ZHKA001" (empty = local object)
'   %%TRANSPORT%%        Transport number          e.g. "S4DK940992" (empty = local object)
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const MSG_CLASS      = "%%MSG_CLASS%%"
Const SHORT_TEXT     = "%%SHORT_TEXT%%"
Const MESSAGES_FILE  = "%%MESSAGES_FILE%%"
Const SAP_PACKAGE    = "%%PACKAGE%%"
Const SAP_TRANSPORT  = "%%TRANSPORT%%"
Const SESSION_PATH   = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE91 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE91..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE91"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter message class name and press Create ------------------------
WScript.Echo "INFO: Creating message class: " & UCase(MSG_CLASS)
oSession.findById("wnd[0]/usr/ctxtRSDAG-ARBGB").Text = UCase(MSG_CLASS)
WScript.Sleep 300
oSession.findById("wnd[0]/usr/btnANLTASTE").press   ' Create
WScript.Sleep 2000

' Verify we are in the editor (Attributes tab)
' First check for language mismatch popup (can appear even on Create if system
' master language differs). Fingerprint the popup by ctxtRSETX-MASTERLANG
' (SAPLSETX) before pressing btnPUSH1, so we never misfire on some other popup
' that happens to have a btnPUSH1 (mirrors sap_se91_update.vbs).
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oLangPopup
            Set oLangPopup = Nothing
            Err.Clear
            Set oLangPopup = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oLangPopup Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") -- pressing 'Maint. in orig. lang.'."
                    oLangPopup.press
                    WScript.Sleep 2000
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' Language-independent editor-open check (per language_independence_rules.md):
' the SE91 initial screen exposes the name field ctxtRSDAG-ARBGB. If that ID
' still resolves after Create, we did NOT enter the editor -- the class likely
' already exists (or Create was refused). Title-text branching on "Initial" was
' English-only and misfired under JA/ZH logons.
Dim bStillOnInitial, oInitProbe
On Error Resume Next
Set oInitProbe = Nothing
Set oInitProbe = oSession.findById("wnd[0]/usr/ctxtRSDAG-ARBGB")
bStillOnInitial = (Err.Number = 0) And Not (oInitProbe Is Nothing)
Err.Clear
On Error GoTo 0
If bStillOnInitial Then
    WScript.Echo "ERROR: Still on Initial Screen. Message class may already exist." & vbCrLf & _
                 "       Status: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Quit 1
End If
WScript.Echo "INFO: Editor opened on Attributes tab."

' ------ 4. Set short text on Attributes tab ---------------------------------
Dim sAttrBase
sAttrBase = "wnd[0]/usr/tabsCONTROL1000/tabpHEAD/ssubSUB:SAPLWBMESSAGES:0102"
oSession.findById(sAttrBase & "/txtT100A-STEXT").Text = SHORT_TEXT
WScript.Sleep 300
WScript.Echo "INFO: Short text set to: " & SHORT_TEXT

' ------ 5. Save to create the message class ---------------------------------
WScript.Echo "INFO: Saving message class..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle transport / package popup (3-way pattern)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport specified
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
        ' Transport request dialog may appear
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 1000
        End If
    ElseIf SAP_PACKAGE <> "" And SAP_TRANSPORT = "" Then
        ' Case 3: Package only -- create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " creating new transport..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]/tbar[0]/btn[8]").press
            WScript.Sleep 1000
            oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(MSG_CLASS)
            oSession.findById("wnd[2]/tbar[0]/btn[0]").press
            WScript.Sleep 1000
            oSession.findById("wnd[1]/tbar[0]/btn[0]").press
            WScript.Sleep 1000
        End If
    Else
        ' Case 2: No package or $TMP -- local object
        WScript.Echo "INFO: Package/transport dialog - Local Object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 2000
    End If
End If

' Handle second popup if any
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Check for errors after header creation + object-directory assignment.
' Locale-independent verdict: gate on MessageType (E/A), never translated text
' (language_independence_rules.md). This makes BOTH the no-messages early exit
' (iMsgCount = 0 below) and the with-messages path fail closed when the class
' header itself did not persist -- e.g. a blocked transport, a lock, or an
' authorization failure (Audit P3).
Dim sStatus, sStatusType
sStatus = "" : sStatusType = ""
On Error Resume Next
sStatus     = oSession.findById("wnd[0]/sbar").Text
sStatusType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Status [" & sStatusType & "]: " & sStatus
If LCase(sStatusType) = "e" Or LCase(sStatusType) = "a" Then
    WScript.Echo "ERROR: Message class creation failed - " & sStatus
    WScript.Quit 1
End If

' ------ 6. Switch to Messages tab -------------------------------------------
WScript.Echo "INFO: Switching to Messages tab..."
oSession.findById("wnd[0]/usr/tabsCONTROL1000/tabpMESS").select
WScript.Sleep 2000

' Verify table is present
Dim sMsgBase, sTblBase, oTable
sMsgBase = "wnd[0]/usr/tabsCONTROL1000/tabpMESS/ssubSUB:SAPLWBMESSAGES:0101"
sTblBase = sMsgBase & "/tblSAPLWBMESSAGESCONTROL101"

On Error Resume Next
Set oTable = oSession.findById(sTblBase)
If Err.Number <> 0 Or oTable Is Nothing Then
    Err.Clear
    ' Table may need Enter press to initialize
    WScript.Echo "INFO: Table not visible, pressing Enter to initialize..."
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 2000
    Set oTable = oSession.findById(sTblBase)
    If Err.Number <> 0 Or oTable Is Nothing Then
        WScript.Echo "ERROR: Messages table not found after initialization."
        WScript.Quit 1
    End If
End If
Err.Clear
On Error GoTo 0

Dim iVisRows
iVisRows = oTable.VisibleRowCount
WScript.Echo "INFO: Table ready. VisibleRows=" & iVisRows

' ------ 7. Read messages file and populate table ----------------------------
Dim oFSO, oFile, sLine
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(MESSAGES_FILE) Then
    WScript.Echo "ERROR: Messages file not found: " & MESSAGES_FILE
    WScript.Quit 1
End If

' Read all messages into arrays.
' NOTE: We use ADODB.Stream with explicit Charset="utf-8" to decode the file
' correctly. FSO.OpenTextFile(... , False) reads bytes as the system code page
' (cp932 on Japanese Windows, cp1252 on Western), which mangles UTF-8 multi-
' byte sequences -- Japanese text comes out as mojibake on the SAP
' side. ADODB.Stream handles UTF-8 BOM auto-detection and decodes to Unicode
' that matches what SetText into the SAP GUI control expects.
Dim arrNums(), arrTexts()
Dim iMsgCount, sAll, arrLines, iL
iMsgCount = 0

Dim oStream
Set oStream = CreateObject("ADODB.Stream")
oStream.Type = 2                    ' adTypeText
oStream.Charset = "utf-8"
oStream.Open
oStream.LoadFromFile MESSAGES_FILE
sAll = oStream.ReadText
oStream.Close

sAll = Replace(sAll, vbCrLf, vbLf)
sAll = Replace(sAll, vbCr,   vbLf)
arrLines = Split(sAll, vbLf)

For iL = 0 To UBound(arrLines)
    sLine = arrLines(iL)
    If Len(Trim(sLine)) > 0 Then
        ' Accept BOTH 2-column and 3-column formats.
        '   2-col: <num>\t<text>             (canonical, per SKILL.md)
        '   3-col: <num>\t<type>\t<text>     (emitted by sap-docs-extract;
        '                                     <type> is one of E/W/I/A/S
        '                                     and is not stored in T100-TEXT)
        ' First col is always the number; last col is always the text.
        ' Without this, a 3-col line silently embeds a literal tab+type
        ' prefix into the message text and SAP saves 0 messages.
        Dim aCols, sNum, sText
        aCols = Split(sLine, vbTab)
        If UBound(aCols) >= 1 Then
            ReDim Preserve arrNums(iMsgCount)
            ReDim Preserve arrTexts(iMsgCount)
            sNum  = Trim(aCols(0))
            sText = Trim(aCols(UBound(aCols)))
            ' Strip leading non-digit chars (defensive: stray BOM, spaces).
            Do While Len(sNum) > 0 And (Asc(Left(sNum,1)) < 48 Or Asc(Left(sNum,1)) > 57)
                sNum = Mid(sNum, 2)
            Loop
            If Len(sNum) > 0 Then
                arrNums(iMsgCount) = CInt(sNum)
                arrTexts(iMsgCount) = sText
                iMsgCount = iMsgCount + 1
            End If
        End If
    End If
Next

WScript.Echo "INFO: Read " & iMsgCount & " messages from file."

If iMsgCount = 0 Then
    WScript.Echo "INFO: No messages to add. Message class created with short text only."
    WScript.Echo "SUCCESS: Message class " & UCase(MSG_CLASS) & " created in SAP."
    WScript.Quit 0
End If

' Populate table: scroll page by page
Dim iCurrentPos, i, iMsgNum, iPageStart, iVisRow
iCurrentPos = -1

For i = 0 To iMsgCount - 1
    iMsgNum = arrNums(i)
    iPageStart = Int(iMsgNum / iVisRows) * iVisRows

    ' Scroll to the correct page if needed
    If iPageStart <> iCurrentPos Then
        oTable.VerticalScrollbar.Position = iPageStart
        WScript.Sleep 500
        iCurrentPos = iPageStart
    End If

    iVisRow = iMsgNum - iPageStart

    On Error Resume Next
    oSession.findById(sTblBase & "/txtT100-TEXT[1," & iVisRow & "]").Text = arrTexts(i)
    If Err.Number <> 0 Then
        WScript.Echo "WARNING: Could not set message " & Right("000" & iMsgNum, 3) & ": " & Err.Description
        Err.Clear
    End If
    On Error GoTo 0
Next

' Press Enter to commit inline edits
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

WScript.Echo "INFO: Messages populated."

' ------ 8. Save messages ----------------------------------------------------
WScript.Echo "INFO: Saving messages..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle transport popup (3-way pattern)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport specified
        WScript.Echo "INFO: Transport dialog on save - transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And SAP_TRANSPORT = "" Then
        ' Case 3: Package only -- create new transport
        WScript.Echo "INFO: Transport dialog on save - creating new transport..."
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(MSG_CLASS)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -- local object
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 9. Final status check -----------------------------------------------
' Locale-independent verdict: branch on the status-bar MessageType code
' (S/W/E/I/A), never on translated text (language_independence_rules.md). A
' real save failure -- duplicate message number, locked message class, blocked
' transport, authorization failure, or an undismissed master-language popup --
' surfaces as MessageType E/A. The pre-fix code echoed the text and reported
' SUCCESS unconditionally, so a failed save read as success (Audit P3). Mirrors
' the gate already in sap_se91_change_props.vbs.
Dim sFinalMsg, sFinalType
sFinalMsg = "" : sFinalType = ""
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: SAP status [" & sFinalType & "]: " & sFinalMsg
If LCase(sFinalType) = "e" Or LCase(sFinalType) = "a" Then
    WScript.Echo "ERROR: Save failed - " & sFinalMsg
    WScript.Quit 1
End If

WScript.Echo "SUCCESS: Message class " & UCase(MSG_CLASS) & " created with " & iMsgCount & " messages in SAP."
WScript.Quit 0
