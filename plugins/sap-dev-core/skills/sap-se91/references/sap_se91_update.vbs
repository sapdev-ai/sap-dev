' =============================================================================
' sap_se91_update.vbs  -  SAP GUI Scripting: Update messages in existing class
'
' Generated by the sap-se91 skill.
' Attaches to an existing SAP GUI session, navigates to SE91, opens the
' message class in change mode, updates message texts from a tab-separated
' file, and saves.
'
' Messages file format (tab-separated, one per line):
'   000	Message text for number 000
'   001	Another message &1 with placeholder
'   050	Sparse numbering is fine
'
' Tokens replaced at run time:
'   %%MSG_CLASS%%        Message class name      e.g. "ZHKMSG01"
'   %%MESSAGES_FILE%%    Path to messages file    e.g. "{WORK_TEMP}\messages.txt"
'   %%PACKAGE%%          SAP package              e.g. "ZHKA001" (empty = local object)
'   %%TRANSPORT%%        Transport number          e.g. "S4DK940992" (empty = local object)
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const MSG_CLASS      = "%%MSG_CLASS%%"
Const MESSAGES_FILE  = "%%MESSAGES_FILE%%"
Const SAP_PACKAGE    = "%%PACKAGE%%"
Const SAP_TRANSPORT  = "%%TRANSPORT%%"
Const SESSION_PATH   = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE91 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE91..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE91"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter message class name and open in Change mode -----------------
WScript.Echo "INFO: Opening message class in change mode: " & UCase(MSG_CLASS)
oSession.findById("wnd[0]/usr/ctxtRSDAG-ARBGB").Text = UCase(MSG_CLASS)
oSession.findById("wnd[0]/usr/radRSDAG-MSGFLAG").select   ' Messages radio
WScript.Sleep 300
oSession.findById("wnd[0]/usr/btnMODTASTE").press   ' Change
WScript.Sleep 2000

' ------ 3a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged so
' we edit translations without overwriting the master language.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr (avoids misfiring
' on other popups that happen to have a btnPUSH1).
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") — pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' Verify we are in the editor
Dim sTitle
sTitle = oSession.findById("wnd[0]").Text
If InStr(sTitle, "Initial") > 0 Then
    WScript.Echo "ERROR: Message class not found or could not open." & vbCrLf & _
                 "       Status: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Quit 1
End If
WScript.Echo "INFO: Editor opened: " & sTitle

' Ensure we are on the Messages tab
Dim sTblBase, oTable
sTblBase = "wnd[0]/usr/tabsCONTROL1000/tabpMESS/ssubSUB:SAPLWBMESSAGES:0101/tblSAPLWBMESSAGESCONTROL101"

On Error Resume Next
Set oTable = oSession.findById(sTblBase)
If Err.Number <> 0 Or oTable Is Nothing Then
    Err.Clear
    WScript.Echo "INFO: Switching to Messages tab..."
    oSession.findById("wnd[0]/usr/tabsCONTROL1000/tabpMESS").select
    WScript.Sleep 1500
    Set oTable = oSession.findById(sTblBase)
    If Err.Number <> 0 Or oTable Is Nothing Then
        WScript.Echo "ERROR: Messages table not found."
        WScript.Quit 1
    End If
End If
Err.Clear
On Error GoTo 0

Dim iVisRows
iVisRows = oTable.VisibleRowCount
WScript.Echo "INFO: Table ready. VisibleRows=" & iVisRows

' ------ 4. Read messages file -----------------------------------------------
Dim oFSO, oFile, sLine
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(MESSAGES_FILE) Then
    WScript.Echo "ERROR: Messages file not found: " & MESSAGES_FILE
    WScript.Quit 1
End If

' Use ADODB.Stream with explicit Charset="utf-8" so Japanese / Chinese / any
' non-ASCII text in messages is decoded correctly. FSO.OpenTextFile(...,False)
' reads bytes as the system code page and mangles UTF-8 multi-byte sequences;
' the resulting mojibake (文字化け) goes into SAP via SetText.
' See sap_se91_create.vbs for the full rationale.
Dim arrNums(), arrTexts()
Dim iMsgCount, sAll, arrLines, iL
iMsgCount = 0

Dim oStream
Set oStream = CreateObject("ADODB.Stream")
oStream.Type = 2                    ' adTypeText
oStream.Charset = "utf-8"
oStream.Open
oStream.LoadFromFile MESSAGES_FILE
sAll = oStream.ReadText
oStream.Close

sAll = Replace(sAll, vbCrLf, vbLf)
sAll = Replace(sAll, vbCr,   vbLf)
arrLines = Split(sAll, vbLf)

For iL = 0 To UBound(arrLines)
    sLine = arrLines(iL)
    If Len(Trim(sLine)) > 0 Then
        ' Accept both 2-col (<num>\t<text>) and 3-col (<num>\t<type>\t<text>)
        ' formats. First col = number, last col = text. See sap_se91_create.vbs
        ' for the rationale.
        Dim aCols, sNum, sText
        aCols = Split(sLine, vbTab)
        If UBound(aCols) >= 1 Then
            ReDim Preserve arrNums(iMsgCount)
            ReDim Preserve arrTexts(iMsgCount)
            sNum  = Trim(aCols(0))
            sText = Trim(aCols(UBound(aCols)))
            Do While Len(sNum) > 0 And (Asc(Left(sNum,1)) < 48 Or Asc(Left(sNum,1)) > 57)
                sNum = Mid(sNum, 2)
            Loop
            If Len(sNum) > 0 Then
                arrNums(iMsgCount) = CInt(sNum)
                arrTexts(iMsgCount) = sText
                iMsgCount = iMsgCount + 1
            End If
        End If
    End If
Next

WScript.Echo "INFO: Read " & iMsgCount & " messages from file."

If iMsgCount = 0 Then
    WScript.Echo "ERROR: No messages found in file."
    WScript.Quit 1
End If

' ------ 5. Populate table: scroll page by page ------------------------------
' Use the direct findById path BUT re-acquire the table reference every
' iteration. The cell GuiTextField objects go stale after .Text assignment
' because the SAP TableControl re-renders sub-controls — direct addressing
' of [1,3]+ then fails with "control not found" even though the row IS
' visible. Re-acquiring oTable forces SAP GUI to recompute the binding.
Dim iCurrentPos, i, iMsgNum, iPageStart, iVisRow, sCellId
iCurrentPos = -1

For i = 0 To iMsgCount - 1
    iMsgNum = arrNums(i)
    iPageStart = Int(iMsgNum / iVisRows) * iVisRows

    ' Re-acquire table reference each iteration (defends against stale binding).
    On Error Resume Next
    Set oTable = oSession.findById(sTblBase)
    Err.Clear
    On Error GoTo 0

    ' Scroll to the correct page if needed
    If iPageStart <> iCurrentPos Then
        oTable.VerticalScrollbar.Position = iPageStart
        WScript.Sleep 500
        iCurrentPos = iPageStart
    End If

    iVisRow = iMsgNum - iPageStart

    On Error Resume Next
    sCellId = sTblBase & "/txtT100-TEXT[1," & iVisRow & "]"
    oSession.findById(sCellId).Text = arrTexts(i)
    If Err.Number <> 0 Then
        ' Fallback: use the TableControl GetCell API. More verbose but
        ' more robust on releases where the cell-id paths are unstable.
        Err.Clear
        Dim oCell
        Set oCell = oTable.GetCell(iVisRow, 1)
        If Not (oCell Is Nothing) Then
            oCell.Text = arrTexts(i)
        End If
        If Err.Number <> 0 Then
            WScript.Echo "WARNING: Could not set message " & Right("000" & iMsgNum, 3) & " (row " & iVisRow & "): " & Err.Description
            Err.Clear
        End If
    End If
    On Error GoTo 0

    ' Brief pause to let the grid commit the inline edit before next write.
    WScript.Sleep 100
Next

' Press Enter to commit inline edits
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

WScript.Echo "INFO: Messages updated."

' ------ 6. Save -------------------------------------------------------------
WScript.Echo "INFO: Saving..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle transport popup (3-way pattern)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport specified
        WScript.Echo "INFO: Transport dialog - package " & SAP_PACKAGE & " transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And SAP_TRANSPORT = "" Then
        ' Case 3: Package only — create new transport
        WScript.Echo "INFO: Transport dialog - package " & SAP_PACKAGE & " creating new transport..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]/tbar[0]/btn[8]").press
            WScript.Sleep 1000
            oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(MSG_CLASS)
            oSession.findById("wnd[2]/tbar[0]/btn[0]").press
            WScript.Sleep 1000
            oSession.findById("wnd[1]/tbar[0]/btn[0]").press
            WScript.Sleep 1000
        End If
    Else
        ' Case 2: No package or $TMP — local object
        WScript.Echo "INFO: Transport dialog - Local Object..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 7. Final status check -----------------------------------------------
Dim sFinalMsg
sFinalMsg = oSession.findById("wnd[0]/sbar").Text
WScript.Echo "INFO: SAP status: " & sFinalMsg

WScript.Echo "SUCCESS: Message class " & UCase(MSG_CLASS) & " updated with " & iMsgCount & " messages in SAP."
WScript.Quit 0
