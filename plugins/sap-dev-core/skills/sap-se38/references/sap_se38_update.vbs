' =============================================================================
' sap_se38_update.vbs  -  SAP GUI Scripting: Update existing ABAP program via SE38
'
' Generated by the sap-se38 skill.
' Attaches to an existing SAP GUI session, navigates to SE38, opens the
' program in change mode, uploads new source code, saves (Ctrl+S), runs
' syntax check (Ctrl+F2), and activates.
'
' Tokens replaced at run time:
'   %%PROGRAM_NAME%%       ABAP program name         e.g. "ZMYREPORT"
'   %%ABAP_SOURCE_FILE%%   Absolute path to .abap file
'   %%PACKAGE%%            SAP package               e.g. "ZHKA001" (empty = local object)
'   %%TRANSPORT%%          Transport number           e.g. "S4DK940992" (empty = local object)
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' If a step fails, use SAP Logon > Help > Scripting Recorder to re-record
' the correct ID for your system.
' =============================================================================

Option Explicit

Const PROGRAM_NAME     = "%%PROGRAM_NAME%%"
Const ABAP_SOURCE_FILE = "%%ABAP_SOURCE_FILE%%"
Const SAP_PACKAGE      = "%%PACKAGE%%"
Const SAP_TRANSPORT    = "%%TRANSPORT%%"
Const SESSION_PATH     = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession). Per language_independence_rules.md Rule 7: every
' multi-step write critical section (paste + save + activate) MUST wrap a
' session lock so the user can't steal focus mid-script.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE38 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE38..."
oSession.StartTransaction "SE38"
WScript.Sleep 1000

On Error Resume Next
Dim oProgField
Set oProgField = oSession.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM")
If Err.Number <> 0 Or oProgField Is Nothing Then
    WScript.Echo "ERROR: SE38 program name field not found (ID: wnd[0]/usr/ctxtRS38M-PROGRAMM)." & vbCrLf & _
                 "       Use Scripting Recorder to find the correct ID for your SAP version."
    WScript.Quit 1
End If
On Error GoTo 0

' ------ 3. Enter program name and open in change mode (btnCHAP) -------------
oProgField.Text = UCase(PROGRAM_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/radRS38M-FUNC_EDIT").select   ' Source Code radio
Err.Clear
On Error GoTo 0
WScript.Sleep 300

WScript.Echo "INFO: Opening program in change mode: " & UCase(PROGRAM_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnCHAP").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 3a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). This keeps TADIR-MASTERLANG unchanged
' so we edit translations without overwriting the master language. Triggered
' when sap_language differs from TADIR-MASTERLANG of the object.
' Fingerprint: ctxtRSETX-MASTERLANG is present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") — pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' Dismiss any other confirmation popup (info messages, etc.)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Verify we are in the ABAP editor
Dim oEditorShell, bInEditor
Set oEditorShell = Nothing
bInEditor = False
On Error Resume Next
Err.Clear
Set oEditorShell = oSession.findById("wnd[0]/usr/cntlEDITOR/shellcont/shell")
If Err.Number = 0 Then
    If Not (oEditorShell Is Nothing) Then
        bInEditor = True
    End If
End If
Err.Clear
On Error GoTo 0

If Not bInEditor Then
    WScript.Echo "ERROR: Could not open program in change mode." & vbCrLf & _
                 "       Check that the program exists and you have authorization."
    WScript.Quit 1
End If
WScript.Echo "INFO: Program opened in change mode."

' ------ 3b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S immediately after entering change mode to provoke any
' "Prompt for local Workbench request" popup. Three outcomes:
'   (a) Popup with TR field (ctxtKO008-TRKORR) → fill SAP_TRANSPORT, Enter.
'       Object is now locked to this TR; the real save later won't re-prompt.
'   (b) Some other popup (e.g. info "no changes") → Enter to dismiss.
'   (c) No popup → object is local ($TMP) or already locked to a modifiable TR.
' If a TR popup appears but SAP_TRANSPORT is empty, abort — the caller must
' resolve a TR first (see /sap-transport-request).
' Diagnostics on unexpected behaviour: TADIR-DEVCLASS ($* = local), E071 for
' object→TR linkage, E070-TRSTATUS for the linked TR's modifiable state.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = Nothing
    Err.Clear
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 Then
        If Not (oPreTR Is Nothing) Then
            ' Case (a) — TR popup
            If SAP_TRANSPORT = "" Then
                WScript.Echo "ERROR: SE38 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                             "       The object appears to be transportable but no TR was supplied." & vbCrLf & _
                             "       Resolve a modifiable TR via /sap-transport-request and re-run."
                WScript.Quit 1
            End If
            oPreTR.Text = SAP_TRANSPORT
            WScript.Echo "INFO: Pre-save TR popup detected — entering " & SAP_TRANSPORT & "."
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 1000
        Else
            ' Case (b) — some other popup
            WScript.Echo "INFO: Pre-save popup (no TR field) — pressing Enter to dismiss."
            oSession.ActiveWindow.sendVKey VKEY_ENTER
            WScript.Sleep 800
        End If
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) — pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    ' Case (c) — no popup
    WScript.Echo "INFO: No pre-save popup — object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 4. Upload source code via clipboard + SendKeys ---------------------
' See sap_se38_create.vbs Step 6 for the rationale (shell.Text is read-only
' on AbapEditor.1; the Upload menu opens a non-scriptable native dialog).
WScript.Echo "INFO: Uploading source file: " & ABAP_SOURCE_FILE

Dim oFSO
Set oFSO = CreateObject("Scripting.FileSystemObject")
If Not oFSO.FileExists(ABAP_SOURCE_FILE) Then
    WScript.Echo "ERROR: Source file not found: " & ABAP_SOURCE_FILE
    WScript.Quit 1
End If

' --- 4a. Read source text (UTF-8) into memory ---
Dim oSrcStream2, sSourceText2
On Error Resume Next
Set oSrcStream2 = CreateObject("ADODB.Stream")
oSrcStream2.Type = 2
oSrcStream2.Charset = "utf-8"
oSrcStream2.Open
oSrcStream2.LoadFromFile ABAP_SOURCE_FILE
sSourceText2 = oSrcStream2.ReadText
oSrcStream2.Close
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not read source file: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' --- 4b. Stage on Windows clipboard ---
Dim bClipOk2
bClipOk2 = False
On Error Resume Next
Dim oClipDO2
Set oClipDO2 = CreateObject("MSForms.DataObject")
If Err.Number = 0 Then
    oClipDO2.SetText sSourceText2
    oClipDO2.PutInClipboard
    If Err.Number = 0 Then bClipOk2 = True
End If
Err.Clear
On Error GoTo 0

If Not bClipOk2 Then
    ' clip.exe interprets stdin as OEM/ANSI unless it starts with a UTF-16 LE
    ' BOM (FF FE). Writing the temp file with Charset="utf-8" used to inject
    ' EF BB BF at the head of the editor (visible as garbage chars on
    ' Japanese-locale machines). Use UTF-16 LE so clip.exe stores the data
    ' directly as CF_UNICODETEXT with no spurious bytes.
    On Error Resume Next
    Dim sTmpClip2, oTmpStream2, oWshFallback2
    sTmpClip2 = ABAP_SOURCE_FILE & ".clip.txt"
    Set oTmpStream2 = CreateObject("ADODB.Stream")
    oTmpStream2.Type = 2
    oTmpStream2.Charset = "utf-16"
    oTmpStream2.Open
    oTmpStream2.WriteText sSourceText2
    oTmpStream2.SaveToFile sTmpClip2, 2
    oTmpStream2.Close
    Set oWshFallback2 = CreateObject("WScript.Shell")
    oWshFallback2.Run "cmd /c type """ & sTmpClip2 & """ | clip", 0, True
    If Err.Number = 0 Then bClipOk2 = True
    Err.Clear
    On Error GoTo 0
End If

If Not bClipOk2 Then
    WScript.Echo "ERROR: Could not place source on clipboard."
    WScript.Quit 1
End If

' --- Lock the SAP session UI for the paste + save + activate critical section ---
' Defence in depth (per language_independence_rules.md Rule 7):
'   - The AppActivate-loop below blocks EXTERNAL focus stealing (Outlook
'     toast, alt-tab, etc.) — without that, Ctrl+V could paste into
'     another app.
'   - LockSessionUI blocks INTERNAL input races (user clicking inside SAP
'     while the script is mid-paste) — without that, the user could
'     scroll, click another field, or open a tooltip mid-write.
' Released after Step 7. Every WScript.Quit between here and the release
' must call ReleaseSession first.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the paste+save+activate critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' --- 4c. Focus editor (with foreground guard) and paste via SendKeys ---
'
' SAFETY: Before sending Ctrl+A / Del / Ctrl+V we MUST guarantee the SAP GUI
' window is in the foreground. If another application has stolen focus
' (mouse click, alt-tab, notification toast, etc.) SendKeys will paste the
' ABAP source into THAT application instead — silently overwriting whatever
' the user was editing. To prevent this we:
'   1. Restore the main window if iconified (a minimised window can never
'      receive keystrokes via SendKeys).
'   2. Loop AppActivate up to 10 times (200 ms apart). AppActivate returns
'      True only when activation actually succeeded; if all retries fail
'      we abort BEFORE sending any keystroke.
'   3. SetFocus on the editor shell (places caret inside the AbapEditor).
'
' Note: AbapEditor.1 does NOT expose readable text/numberOfLines on this
' SAP GUI build (every read returns either the class name or err 438), so
' we cannot programmatically confirm the paste landed in the editor. The
' AppActivate loop + Iconified check is the primary defence; the
' subsequent syntax check (Ctrl+F2) will catch an empty editor before save.

Dim oWshSend2, sapTitle2
Set oWshSend2 = CreateObject("WScript.Shell")
sapTitle2 = oSession.findById("wnd[0]").Text

' Restore the window if iconified so the Z-order operations have something
' to work with (an iconified window cannot become foreground).
On Error Resume Next
If oSession.findById("wnd[0]").Iconified Then
    oSession.findById("wnd[0]").Restore
    WScript.Sleep 200
End If
oSession.findById("wnd[0]").Maximize
WScript.Sleep 100
Err.Clear
On Error GoTo 0

' Force SAP GUI to OS-level foreground via the dedicated sidecar. WshShell's
' AppActivate (used to live here in a 20-retry loop) is unreliable on
' Windows 7+ because SetForegroundWindow is suppressed for processes that
' don't already own the foreground — it returns success while Windows just
' flashes the taskbar button, and SAP stays behind. The sidecar uses the
' AttachThreadInput trick to bypass that suppression.
'
' If the sidecar reports anything other than FOREGROUND:OK we ABORT BEFORE
' SendKeys so the source never lands in the user's Notepad / VS Code /
' browser. Bug surfaced 2026-05-11.
Dim sFgGuardCmd2, nFgGuardRc2
sFgGuardCmd2 = "powershell -NoProfile -ExecutionPolicy Bypass -File """ & _
               "%%FOREGROUND_GUARD_PS1%%"" -TargetTitle """ & sapTitle2 & _
               """ -TimeoutSeconds 5"
nFgGuardRc2 = oWshSend2.Run(sFgGuardCmd2, 0, True)
If nFgGuardRc2 <> 0 Then
    WScript.Echo "ERROR: SAP GUI window is not the OS foreground window (sidecar exit " & nFgGuardRc2 & ")."
    WScript.Echo "       Aborting paste to prevent Ctrl+V from landing in another app (Notepad, VS Code, browser)."
    WScript.Echo "       Target window title: " & sapTitle2
    WScript.Echo "       Recovery: close or minimize the focus-stealing app, click on the SAP GUI window,"
    WScript.Echo "                then re-run this skill. Or set Windows ForegroundLockTimeout to 0."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

On Error Resume Next
oEditorShell.SetFocus
Err.Clear
On Error GoTo 0
WScript.Sleep 300

' Belt-and-suspenders clear-then-paste — see sap_se38_create.vbs for the
' full rationale. SendKeys "^a" alone has been observed to NOT select-all
' in AbapEditor.1 (Ctrl+A may be intercepted as a function-code action),
' which leaves the previous source intact and the paste appends. Update
' flow is less risky than create (no auto-template) but the same Ctrl+A
' unreliability exists. Three-layer clear: SAP-side sendVKey 26, then
' Windows ^{HOME} + ^+{END} (manual select-to-end), then ^a as final
' fallback. Bug surfaced 2026-05-11 evening on /sap-dev-init first
' deploy of ZCMRUPDATE_ADDON_TABLE.
' Wait sizing: update.vbs almost always operates on an editor pre-loaded
' with the previous version of the source (often hundreds of lines), so
' {DEL} on a "select-all" selection takes much longer than the original
' 300 ms allowed. If ^v fires before the editor finishes deleting, the
' new source interleaves with leftover content — leaving the tail of the
' previous version on the bottom of the editor (e.g. lines 653-656).
' Bug re-surfaced 2026-05-11 PM during ZMMRMAT032R01 redeploy iteration
' #2. Post-{DEL} wait is the load-bearing delay; other bumps add a few
' hundred ms of insurance against SendKeys keystroke drops on busy
' machines.
On Error Resume Next
oSession.findById("wnd[0]").sendVKey 26
WScript.Sleep 400
Err.Clear
On Error GoTo 0
oWshSend2.SendKeys "^{HOME}"
WScript.Sleep 200
oWshSend2.SendKeys "^+{END}"
WScript.Sleep 200
oWshSend2.SendKeys "^a"
WScript.Sleep 300
oWshSend2.SendKeys "{DEL}"
WScript.Sleep 1500
oWshSend2.SendKeys "^v"
WScript.Sleep 2500

WScript.Echo "INFO: Source code pasted into ABAP editor (foreground-guarded, 3-layer clear)."

' ------ 5. Save (Ctrl+S = VKey 11) -----------------------------------------
' Per design: paste -> Save (Ctrl+S) -> Check (Ctrl+F2) -> if no errors ->
' Activate (Ctrl+F3). Saving before the syntax check persists the freshly
' pasted source so a subsequent Check operates on the on-disk version.
' The pre-save in step 3b already locked the object to SAP_TRANSPORT, so
' this Save will not re-prompt for the TR. Defensively handle any popup
' (TR field, info dialog) by pressing Enter.
WScript.Echo "INFO: Saving (Ctrl+S)..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oSaveTR
    Set oSaveTR = Nothing
    Err.Clear
    Set oSaveTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oSaveTR Is Nothing) Then
        If SAP_TRANSPORT <> "" Then
            oSaveTR.Text = SAP_TRANSPORT
            WScript.Echo "INFO: Save TR popup — entering " & SAP_TRANSPORT & "."
        End If
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    Else
        Err.Clear
        WScript.Echo "INFO: Save popup (no TR field) — pressing Enter."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
    End If
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Saved."

' ------ 6. Syntax check (Ctrl+F2 = tbar[1]/btn[26]) ------------------------
' After pressing Check, syntax errors appear in a shell grid control at:
'   wnd[0]/shellcont/shell/shellcont[1]/shell
' This grid has columns: MSGTYPE, LINE, TEXT
' We read errors from this grid using getCellValue(row, column).
' The status bar (sbar) is unreliable when the AbapEditor is active.
WScript.Echo "INFO: Running syntax check..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 3000
Err.Clear
On Error GoTo 0

' Read syntax errors from the error grid (shellcont[1]/shell)
Dim oChkGrid, lChkRows, iChk
Dim sChkType, sChkLine, sChkText
Dim bHasErrors
Dim lErrCount
bHasErrors = False
lErrCount  = 0

On Error Resume Next
Set oChkGrid = oSession.findById("wnd[0]/shellcont/shell/shellcont[1]/shell")
If Err.Number = 0 And Not (oChkGrid Is Nothing) Then
    lChkRows = oChkGrid.RowCount
    Err.Clear
    If lChkRows > 0 Then
        WScript.Echo "INFO: " & lChkRows & " syntax finding(s) for program " & UCase(PROGRAM_NAME) & ":"
        For iChk = 0 To lChkRows - 1
            sChkType = oChkGrid.getCellValue(iChk, "MSGTYPE")
            sChkLine = oChkGrid.getCellValue(iChk, "LINE")
            sChkText = oChkGrid.getCellValue(iChk, "TEXT")
            If Err.Number <> 0 Then Err.Clear: Exit For
            WScript.Echo "  [" & sChkType & "] Line " & sChkLine & ": " & sChkText
            ' MSGTYPE values: "1" or "E" = Error, "2" or "W" = Warning.
            ' SAP also returns icon-codes like "@5C\QError@" / "@5D\QWarning@".
            If sChkType = "1" Or UCase(sChkType) = "E" _
               Or InStr(UCase(sChkType), "ERROR") > 0 Then
                bHasErrors = True
                lErrCount  = lErrCount + 1
            End If
        Next
        ' Distinct, parseable line so callers can detect "real errors" vs
        ' "warnings only" without re-parsing the per-finding text. Emit even
        ' when zero so the format is stable across runs.
        WScript.Echo "SYNTAX_ERRORS: " & lErrCount
    Else
        WScript.Echo "INFO: Syntax check passed — no findings."
        WScript.Echo "SYNTAX_ERRORS: 0"
    End If
Else
    ' Grid not found — fall back to status bar check
    Err.Clear
    Dim sSyntaxMsg, sSyntaxType
    sSyntaxMsg  = oSession.findById("wnd[0]/sbar").Text
    sSyntaxType = oSession.findById("wnd[0]/sbar").MessageType
    If sSyntaxType = "E" Then
        WScript.Echo "ERROR: Syntax check failed - " & sSyntaxMsg
        bHasErrors = True
    ElseIf sSyntaxMsg = "" Then
        ' Defensive abort — symmetric with sap_se38_create.vbs. Empty
        ' editor produces no findings grid AND no status-bar message;
        ' the prior pass-through ("Result unknown — continuing") would
        ' activate an empty program and produce a false-success.
        WScript.Echo "ERROR: Syntax check produced neither a findings grid nor a status-bar message."
        WScript.Echo "       This is the documented signature of an EMPTY editor — paste likely failed silently."
        WScript.Echo "       Refusing to activate to prevent a false-success. Recovery: re-run with the same arguments;"
        WScript.Echo "       if the source file is intentionally empty, add at least one comment line."
        bHasErrors = True
    Else
        WScript.Echo "INFO: Syntax check: [" & sSyntaxType & "] " & sSyntaxMsg
    End If
End If
Err.Clear
On Error GoTo 0

If bHasErrors Then
    WScript.Echo "ERROR: Syntax errors found. Fix errors and retry."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ 7. Activate (Ctrl+F3 = tbar[1]/btn[27]) ----------------------------
' Multiple popups can appear in sequence (e.g. "Inactive Objects for <user>"
' worklist), so loop and press ENTER until the main window is back.
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 2500

Dim iActPop
For iActPop = 1 To 5
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        WScript.Echo "INFO: Activation popup " & iActPop & ": " & oSession.findById("wnd[1]").Text
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 2000
    Else
        Exit For
    End If
Next
Err.Clear
On Error GoTo 0

' Handle SAPLSPO1 activation worklist screen (appears when multiple inactive objects exist)
On Error Resume Next
If oSession.Info.Program = "SAPLSPO1" Then
    WScript.Echo "INFO: Activation worklist (SAPLSPO1) detected — pressing Continue (btn[0])..."
    oSession.findById("wnd[0]/tbar[0]/btn[0]").press
    WScript.Sleep 5000
    ' If still on SAPLSPO1 or popup appeared, press Enter
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 2000
    End If
End If
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; Step 8 is read-only verification ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 8. Verify activation from SE38 initial screen ----------------------
' Navigate back to SE38 initial and try to run the program (F8). If the
' selection screen (screen 1000) or the program output appears, it is active.
WScript.Echo "INFO: Verifying activation..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSA38"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1500

oSession.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM").Text = UCase(PROGRAM_NAME)
oSession.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM").SetFocus
WScript.Sleep 300

' F8 = Execute
oSession.findById("wnd[0]").sendVKey 8
WScript.Sleep 3000

Dim sVerifyScreen, sVerifyProgram, sVerifyMsg, sVerifyType
sVerifyScreen  = CStr(oSession.Info.ScreenNumber)
sVerifyProgram = oSession.Info.Program
sVerifyMsg     = oSession.findById("wnd[0]/sbar").Text
sVerifyType    = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0

' Check if we reached the selection screen or program output
' Screen 1000 = selection screen (report works)
' Screen 120  = list output (report ran and produced output)
' If we get "is inactive" message, activation failed
If InStr(LCase(sVerifyMsg), "inactive") > 0 Or InStr(LCase(sVerifyMsg), "nicht aktiv") > 0 Then
    WScript.Echo "ERROR: Program " & UCase(PROGRAM_NAME) & " is still INACTIVE after activation attempt."
    WScript.Echo "       SAP message: [" & sVerifyType & "] " & sVerifyMsg
    WScript.Echo "       Check SE38 manually for activation errors."
    ' Navigate back to SE38
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE38"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Quit 1
End If

' Activation verification — see sap_se38_create.vbs for the full
' incident history. Summary: fail-closed on unknown screens, but also
' accept screen 101 (SE38/SA38 initial) when sbar has no error MessageType,
' because F8 can return there cleanly for instant-complete programs.
Dim bActivationVerified : bActivationVerified = False
If sVerifyScreen = "1000" Or sVerifyScreen = "120" Or sVerifyScreen = "200" Then
    bActivationVerified = True
    WScript.Echo "INFO: Program is active (reached screen " & sVerifyScreen & ")."
ElseIf sVerifyScreen = "101" And sVerifyType <> "E" And sVerifyType <> "A" Then
    bActivationVerified = True
    WScript.Echo "INFO: Program is active (SE38 initial screen 101, sbar type='" & sVerifyType & "' — no error)."
Else
    WScript.Echo "ERROR: Unexpected verification screen " & sVerifyScreen & " (program=" & sVerifyProgram & ", sbar type='" & sVerifyType & "'). Program activation could NOT be verified."
End If

' Navigate back to SE38 initial
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE38"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

' ------ 9. Final status report ------------------------------------------------
Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

' Clean up temp clipboard file (only the .clip.txt fallback, never the original)
On Error Resume Next
Dim sClipTmp2
sClipTmp2 = ABAP_SOURCE_FILE & ".clip.txt"
If oFSO.FileExists(sClipTmp2) Then oFSO.DeleteFile sClipTmp2
Err.Clear
On Error GoTo 0

If Not bActivationVerified Then
    WScript.Echo "ERROR: activation_uncertain — Program " & UCase(PROGRAM_NAME) & " was updated and the paste pipeline did not error, but post-activate verification did not reach an active SE38 screen (1000/120/200). The program may still be INACTIVE on the SAP side."
    WScript.Echo "       Recovery: open SE38 for " & UCase(PROGRAM_NAME) & " manually, inspect the activation log, fix any reported issues, then run /sap-activate-object PROGRAM " & UCase(PROGRAM_NAME) & "."
    WScript.Quit 1
End If

WScript.Echo "SUCCESS: Program " & UCase(PROGRAM_NAME) & " updated and activated in SAP."
WScript.Quit 0
