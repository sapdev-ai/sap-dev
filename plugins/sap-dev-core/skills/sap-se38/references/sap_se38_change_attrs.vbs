' =============================================================================
' sap_se38_change_attrs.vbs  -  SAP GUI Scripting: Change SE38 program ATTRIBUTES
'
' Generated by the sap-se38 skill.
' Attaches to an existing SAP GUI session, navigates to SE38, opens the
' program's Attributes screen (FUNC_HEAD radio + Change), and updates the
' Title, Status, and/or Type fields. After Save, handles a Workbench-request
' popup if SAP prompts for one.
'
' Tokens replaced at run time:
'   %%PROGRAM_NAME%%   ABAP program name        e.g. "ZHKTEST003"
'   %%TITLE%%          New title (max 70 chars). Empty = leave unchanged.
'   %%STATUS%%         New program status code. Empty = leave unchanged.
'                      Common codes (TRDIR-RSTAT):
'                        P = SAP Standard Production Program
'                        K = Customer Production Program
'                        S = System Program
'                        T = Test Program
'                        X = SAP Example Program
'   %%TYPE%%           New program type. Empty = leave unchanged.
'                      TRDIR-SUBC codes:
'                        1 = Executable program
'                        I = Include
'                        M = Module pool
'                        F = Function group
'                        K = Class definition
'                        S = Subroutine pool
'                        J = Interface pool
'   %%TRANSPORT%%      Transport request for the post-save TR popup.
'                      Empty when the object is local ($TMP) or already
'                      locked to a modifiable TR. If SAP prompts for a TR
'                      and this is empty, the script aborts.
'
' Recorded baseline (Record_SE38_ChangePGMTitleAndType.vbs):
'   /nse38 -> radRS38M-FUNC_HEAD -> ctxtRS38M-PROGRAMM -> btnCHAP
'   [optional wnd[1] SAPLSETX original-language popup -> btnPUSH1]
'   wnd[1]/usr/txtRS38M-REPTI = title
'   wnd[1]/usr/cmbTRDIR-RSTAT.key = "K"
'   wnd[1]/tbar[0]/btn[0]  (Save)
'   [optional wnd[1] TR popup -> ctxtKO008-TRKORR -> Enter]
' =============================================================================

Option Explicit

Const PROGRAM_NAME  = "%%PROGRAM_NAME%%"
Const NEW_TITLE     = "%%TITLE%%"
Const NEW_STATUS    = "%%STATUS%%"
Const NEW_TYPE      = "%%TYPE%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3

' Include shared helpers. Order matters: attach lib first so session-lock's
' pre-unlock popup sweep has a resolved session reference to read from.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE38 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE38..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE38"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

' --- Lock the SAP session UI for the attribute change + save critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the attribute change + save critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Select Attributes radio + program name + Change ------------------
On Error Resume Next
Dim oProgField, oRadioAttrs
Set oRadioAttrs = oSession.findById("wnd[0]/usr/radRS38M-FUNC_HEAD")
If Err.Number <> 0 Or oRadioAttrs Is Nothing Then
    WScript.Echo "ERROR: SE38 Attributes radio not found (wnd[0]/usr/radRS38M-FUNC_HEAD)."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
oRadioAttrs.select
Err.Clear

Set oProgField = oSession.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM")
If Err.Number <> 0 Or oProgField Is Nothing Then
    WScript.Echo "ERROR: SE38 program-name field not found (wnd[0]/usr/ctxtRS38M-PROGRAMM)."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
oProgField.Text = UCase(PROGRAM_NAME)
oRadioAttrs.setFocus
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Opening Attributes (Change) for: " & UCase(PROGRAM_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnCHAP").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 3a. Original-language popup (SAPLSETX, conditional) -----------------
' Only appears when logon language differs from TADIR-MASTERLANG.
' Press btnPUSH1 ("Maint. in orig. lang.") so we don't overwrite MASTERLANG.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLang
    Set oMasterLang = Nothing
    Err.Clear
    Set oMasterLang = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 And Not (oMasterLang Is Nothing) Then
        Dim oMaintBtn
        Err.Clear
        Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
        If Err.Number = 0 And Not (oMaintBtn Is Nothing) Then
            WScript.Echo "INFO: Original-language popup (MASTERLANG=" & _
                         oMasterLang.Text & ") - pressing 'Maint. in orig. lang.'."
            oMaintBtn.press
            WScript.Sleep 1500
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 4. Verify the Attributes dialog is open -----------------------------
Dim oTitleField, bInAttrDlg
bInAttrDlg = False
On Error Resume Next
Err.Clear
Set oTitleField = oSession.findById("wnd[1]/usr/txtRS38M-REPTI")
If Err.Number = 0 And Not (oTitleField Is Nothing) Then bInAttrDlg = True
Err.Clear
On Error GoTo 0

If Not bInAttrDlg Then
    WScript.Echo "ERROR: Attributes dialog (wnd[1]/usr/txtRS38M-REPTI) did not open." & vbCrLf & _
                 "       Check that the program exists and you have authorization."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Echo "INFO: Attributes dialog open."

' ------ 4a. Apply changes (only if value supplied) --------------------------
Dim sChanges
sChanges = ""

If NEW_TITLE <> "" Then
    On Error Resume Next
    oTitleField.Text = NEW_TITLE
    If Err.Number <> 0 Then
        WScript.Echo "ERROR: Could not set title: " & Err.Description
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
    sChanges = sChanges & " title='" & NEW_TITLE & "'"
End If

If NEW_STATUS <> "" Then
    On Error Resume Next
    Dim oStatusCmb
    Set oStatusCmb = oSession.findById("wnd[1]/usr/cmbTRDIR-RSTAT")
    If Err.Number = 0 And Not (oStatusCmb Is Nothing) Then
        oStatusCmb.setFocus
        oStatusCmb.Key = NEW_STATUS
        If Err.Number <> 0 Then
            WScript.Echo "ERROR: Invalid status code '" & NEW_STATUS & "': " & Err.Description
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        sChanges = sChanges & " status='" & NEW_STATUS & "'"
    Else
        WScript.Echo "ERROR: Status combobox not found (wnd[1]/usr/cmbTRDIR-RSTAT)."
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
End If

If NEW_TYPE <> "" Then
    On Error Resume Next
    Dim oTypeCmb
    Set oTypeCmb = oSession.findById("wnd[1]/usr/cmbTRDIR-SUBC")
    If Err.Number = 0 And Not (oTypeCmb Is Nothing) Then
        oTypeCmb.setFocus
        oTypeCmb.Key = NEW_TYPE
        If Err.Number <> 0 Then
            WScript.Echo "ERROR: Invalid type code '" & NEW_TYPE & "': " & Err.Description
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        sChanges = sChanges & " type='" & NEW_TYPE & "'"
    Else
        WScript.Echo "ERROR: Type combobox not found (wnd[1]/usr/cmbTRDIR-SUBC)."
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
End If

If sChanges = "" Then
    WScript.Echo "INFO: No attribute values supplied - nothing to change."
    WScript.Echo "INFO: Cancelling Attributes dialog."
    On Error Resume Next
    oSession.findById("wnd[1]").sendVKey 12   ' F12 = Cancel
    Err.Clear
    On Error GoTo 0
    WScript.Echo "DONE: NO_CHANGE"
    ReleaseSession oSession, wasLocked
    WScript.Quit 0
End If

WScript.Echo "INFO: Applying changes:" & sChanges

' ------ 5. Save (Enter on dialog toolbar) -----------------------------------
On Error Resume Next
oSession.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 5a. Optional Workbench-request popup --------------------------------
' SAP may now prompt for a TR via wnd[1]/usr/ctxtKO008-TRKORR.
' If supplied, fill it; otherwise abort with a clear message.
On Error Resume Next
Dim sLoop, iLoop
For iLoop = 1 To 3
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit For

    Dim oTrField
    Set oTrField = Nothing
    Err.Clear
    Set oTrField = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrField Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            On Error Resume Next
            oSession.findById("wnd[1]").sendVKey 12   ' Cancel
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        oTrField.Text = SAP_TRANSPORT
        WScript.Echo "INFO: TR popup - entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        ' Detect Error popup (e.g. lock errors)
        Dim sTitle, oM1, oM2, sM1, sM2
        sTitle = oSession.ActiveWindow.Text
        sM1 = "" : sM2 = ""
        Err.Clear
        Set oM1 = oSession.findById("wnd[1]/usr/txtMESSTXT1")
        If Err.Number = 0 And Not (oM1 Is Nothing) Then sM1 = oM1.Text
        Err.Clear
        Set oM2 = oSession.findById("wnd[1]/usr/txtMESSTXT2")
        If Err.Number = 0 And Not (oM2 Is Nothing) Then sM2 = oM2.Text
        Err.Clear
        If LCase(sTitle) = "error" Or InStr(LCase(sM1 & " " & sM2), "locked") > 0 Then
            WScript.Echo "ERROR: SAP popup [" & sTitle & "] " & Trim(sM1 & " " & sM2)
            On Error Resume Next
            oSession.findById("wnd[1]/tbar[0]/btn[12]").press
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById("wnd[1]").sendVKey 12
            End If
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        ' Other informational popup: press Enter
        WScript.Echo "INFO: Confirming popup [" & sTitle & "] - pressing Enter."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
Next
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; status bar read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 6. Read status bar --------------------------------------------------
Dim sBarText, sBarType
sBarText = ""
sBarType = ""
On Error Resume Next
sBarText = oSession.findById("wnd[0]/sbar").Text
sBarType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Status bar [" & sBarType & "]: " & sBarText
If LCase(sBarType) = "e" Or LCase(sBarType) = "a" Then
    WScript.Echo "ERROR: Save failed - " & sBarText
    WScript.Quit 1
End If

' ------ 7. Back to /n -------------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Attributes updated for " & UCase(PROGRAM_NAME) & "."
WScript.Quit 0
