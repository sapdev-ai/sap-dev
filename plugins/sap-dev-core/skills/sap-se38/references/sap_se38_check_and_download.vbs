' =============================================================================
' sap_se38_check_and_download.vbs  -  SAP GUI Scripting: Syntax-check ABAP
'                                     program and download source via SE38
'
' Generated by the sap-se38 skill (check-and-fix mode).
' Attaches to an existing SAP GUI session, navigates to SE38, opens the
' program in display mode, runs a syntax check (Ctrl+F2), reports any errors,
' then downloads the source code to a local file via GetLineText.
'
' Tokens replaced at run time:
'   %%PROGRAM_NAME%%   ABAP program name           e.g. "ZMYREPORT"
'   %%OUTPUT_FILE%%    Absolute path for downloaded source (UTF-16 LE)
'                      e.g. "C:\sap_dev_work\temp\ZMYREPORT_from_sap.txt"
'
' Output lines used by the SKILL.md PS1 wrapper:
'   SYNTAX_ERRORS: N error(s) found:   -- followed by  "  [T] Line N: ..." lines
'   RESULT: SYNTAX_ERRORS              -- end marker when errors exist
'   RESULT: SYNTAX_OK                  -- end marker when no errors
'   ERROR: ...                         -- fatal error (non-zero exit)
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const PROGRAM_NAME = "%%PROGRAM_NAME%%"
Const OUTPUT_FILE  = "%%OUTPUT_FILE%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER   = 0
Const VKEY_F3_BACK = 3

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
' Syntax-check grid locator (FindSyntaxErrorGrid) -- release-agnostic walk for
' the Ctrl+F2 result grid (shared sap_syntax_check_lib.vbs).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SYNTAX_CHECK_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE38 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE38..."
oSession.StartTransaction "SE38"
WScript.Sleep 1000

On Error Resume Next
Dim oProgField
Set oProgField = oSession.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM")
If Err.Number <> 0 Or oProgField Is Nothing Then
    WScript.Echo "ERROR: SE38 program name field not found (ID: wnd[0]/usr/ctxtRS38M-PROGRAMM)."
    WScript.Quit 1
End If
On Error GoTo 0

' ------ 3. Open program in display mode -------------------------------------
oProgField.Text = UCase(PROGRAM_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/radRS38M-FUNC_EDIT").select   ' Source Code radio
Err.Clear
On Error GoTo 0
WScript.Sleep 300

WScript.Echo "INFO: Opening program in display mode: " & UCase(PROGRAM_NAME)
oSession.findById("wnd[0]/usr/btnSHOP").press   ' Display
WScript.Sleep 1500

On Error Resume Next
' Dismiss any confirmation popup
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Verify we are in the ABAP editor
On Error Resume Next
Dim oEditorShell
Set oEditorShell = oSession.findById("wnd[0]/usr/cntlEDITOR/shellcont/shell")
Dim bInEditor
bInEditor = (Err.Number = 0) And Not (oEditorShell Is Nothing)
Err.Clear
On Error GoTo 0

If Not bInEditor Then
    WScript.Echo "ERROR: Could not open program: " & UCase(PROGRAM_NAME) & vbCrLf & _
                 "       Check that the program exists and you have authorization."
    WScript.Quit 1
End If
WScript.Echo "INFO: Program opened in display mode."

' ------ 4. Run syntax check (tbar[1]/btn[26] = Ctrl+F2) --------------------
WScript.Echo "INFO: Running syntax check..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 3000

' Dismiss any popup
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 500
End If
Err.Clear
On Error GoTo 0

' Read syntax errors from the error grid. The container PATH is release-specific
' (S/4 1909 = shellcont[1]/shell; ECC 6.0 nests it deeper at
' shellcont[2]/shell/shellcont[0]/shell), so locate it via FindSyntaxErrorGrid,
' which WALKS wnd[0]/shellcont for the GridView carrying a MSGTYPE column. A
' hardcoded path silently resolves to a different/empty grid on the other
' release -> RowCount 0 -> false "no findings" (the 2026-06-16 EC6/ER1 incident).
' Columns: MSGTYPE ("1"/"E"=Error, "2"/"W"=Warning), LINE, TEXT.
Dim oSyntaxGrid, nSyntaxRows, bSyntaxOK
bSyntaxOK = True

On Error Resume Next
Set oSyntaxGrid = FindSyntaxErrorGrid(oSession)
If Err.Number = 0 And Not (oSyntaxGrid Is Nothing) Then
    nSyntaxRows = oSyntaxGrid.RowCount
    Err.Clear
    If nSyntaxRows > 0 Then
        bSyntaxOK = False
        WScript.Echo "SYNTAX_ERRORS: " & (nSyntaxRows \ 2) & " error(s) found:"
        Dim iSynRow
        Dim sSynType, sSynLine, sSynText
        For iSynRow = 0 To nSyntaxRows - 1
            sSynType = ""
            sSynLine = ""
            sSynText = ""
            sSynType = SafeGetCell(oSyntaxGrid, iSynRow, "MSGTYPE")
            sSynLine = SafeGetCell(oSyntaxGrid, iSynRow, "LINE")
            sSynText = SafeGetCell(oSyntaxGrid, iSynRow, "TEXT")
            If sSynText <> "" Then
                If sSynLine <> "" Then
                    WScript.Echo "  Line " & sSynLine & ": " & sSynText
                Else
                    WScript.Echo "    -> " & sSynText
                End If
            End If
        Next
    Else
        WScript.Echo "INFO: Syntax check passed -- no findings."
    End If
Else
    Err.Clear
    ' Grid not found -- fall back to status bar
    Dim sSyntaxMsg, sSyntaxType
    sSyntaxMsg  = oSession.findById("wnd[0]/sbar").Text
    sSyntaxType = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear
    If sSyntaxType = "E" Then
        bSyntaxOK = False
        WScript.Echo "SYNTAX_ERRORS: Syntax check failed - " & sSyntaxMsg
    ElseIf sSyntaxMsg = "" Then
        WScript.Echo "INFO: Syntax check -- no findings (sbar empty, AbapEditor may swallow messages)."
    Else
        WScript.Echo "INFO: Syntax check passed."
    End If
End If
On Error GoTo 0

' ------ 5. Navigate back to SE38 and download source ------------------------
' Re-open in display mode -- syntax check may have moved to error list view
WScript.Echo "INFO: Downloading source code..."
On Error Resume Next
oSession.StartTransaction "SE38"
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM").Text = UCase(PROGRAM_NAME)
oSession.findById("wnd[0]/usr/radRS38M-FUNC_EDIT").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/btnSHOP").press   ' Display
WScript.Sleep 1500

' Dismiss any popup
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Read source via AbapEditor GetLineText (0-indexed)
On Error Resume Next
Dim oShell
Set oShell = oSession.findById("wnd[0]/usr/cntlEDITOR/shellcont/shell")
If Err.Number <> 0 Or oShell Is Nothing Then
    WScript.Echo "ERROR: Could not find AbapEditor shell (wnd[0]/usr/cntlEDITOR/shellcont/shell)."
    WScript.Quit 1
End If
Err.Clear

Dim oFSO
Set oFSO = CreateObject("Scripting.FileSystemObject")
Dim oFile
Set oFile = oFSO.CreateTextFile(OUTPUT_FILE, True, True)  ' Unicode = True -> UTF-16 LE

Dim i
For i = 0 To 9999
    Dim sLine
    sLine = oShell.GetLineText(i)
    If Err.Number <> 0 Then
        Err.Clear
        Exit For
    End If
    oFile.WriteLine sLine
Next
oFile.Close
On Error GoTo 0

WScript.Echo "INFO: Source downloaded to: " & OUTPUT_FILE

' ------ 6. Final result marker ----------------------------------------------
If Not bSyntaxOK Then
    WScript.Echo "RESULT: SYNTAX_ERRORS"
    WScript.Quit 0
End If

WScript.Echo "RESULT: SYNTAX_OK"
WScript.Quit 0
