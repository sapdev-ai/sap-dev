' =============================================================================
' sap_se51_layout_rebuild.vbs  -  SAP GUI Scripting: rebuild a dynpro's work
'                                 area into tidy "label + input field" lines via
'                                 SE51's ALPHANUMERIC Screen Painter.
'
' Generated by the sap-se51 skill. Live-tested S/4HANA 1909 / SAP GUI 7.70
' (S4D), logon EN, on screen ZHKTESTSE51001/9001 (2026-05-30).
'
' WHAT IT DOES
' -----------
' Clears every existing element on the screen, then lays out one
' "Text label (col 0) + Input/Output field (gap cell)" pair per line, top to
' bottom, then Saves and Activates. Use this when the user wants each field on
' its own line with a descriptive label (the common "make these proper input
' lines" request), rather than appending loose elements (see
' sap_se51_add_element.vbs).
'
' WHY A REBUILD (not in-place nudging)
' ------------------------------------
' In the alphanumeric editor "Edit Rows > Delete Line" removes a row and SHIFTS
' the rows below it up by one. Surgically moving a couple of elements therefore
' tends to collide with what's already there. Clearing the work area and
' rebuilding from a known-empty grid is deterministic and predictable.
'
' PLACEMENT MODEL (probe-verified)
' --------------------------------
'  * An element lands at the CURSOR cell. The create-dialog's FELD-LINE /
'    FELD-COLN fields are advisory and are REJECTED for I/O fields (err 613) —
'    do NOT rely on them for positioning.
'  * Work-area cells txt[col,row] exist ONLY at element boundaries, not at every
'    column. txt[0,row] always exists; arbitrary columns (txt[9,row]) usually do
'    NOT, so focusing them fails (err 619) and the create menu silently opens
'    nothing.
'  * After a Text label is created at txt[0,row], a NEW editable "gap" cell
'    txt[<labellen+1>,row] appears immediately to its right (e.g. label "BUKRS"
'    -> txt[6,2]). The input field is created by focusing THAT discovered cell.
'  * Hence per line: (1) Text label at txt[0,row]; (2) re-scan the row for the
'    new gap cell; (3) focus it and create the I/O field.
'
' PREREQUISITE — graphical editor must be OFF
' -------------------------------------------
' Only the alphanumeric editor (program SAPMSSY0, dynpro 120) is scriptable.
' Turn OFF SE51 > Utilities > Settings > "Graphical Layout Editor" (per-user).
' This script aborts NOT_ALPHANUMERIC if the graphical canvas opens instead.
'
' SAFETY — all-or-nothing
' -----------------------
' The screen is Saved+Activated ONLY if every planned element was created.
' On any shortfall the script backs out WITHOUT saving, leaving the live screen
' exactly as it was before the run.
'
' WARNING — a rebuild RECREATES EVERY ELEMENT from the line spec. Any element on
' the screen that you do NOT list is dropped. List the screen's existing fields
' too if they must be preserved (the calling skill should read the current
' element list first and confirm with the user what to keep).
'
' Tokens replaced at run time:
'   %%PROGRAM_NAME%%   Program / function pool   e.g. "ZHKTESTSE51001"
'   %%SCREEN_NUMBER%%  4-digit dynpro number     e.g. "9001"
'   %%TRANSPORT%%      Transport request          e.g. "S4DK941230" (empty=local)
'   %%PACKAGE%%        Package (ObjDirEntry fallback) e.g. "ZCMPKGV49"
'   %%LINESPEC_FILE%%  Tab-delimited line spec file (UTF-8)
'   %%LOG_FILE%%       Path for the run log
'
' Line-spec file format — one "label + input" line per row, TAB-separated,
' '#' lines ignored. Lines are placed on dynpro rows starting at START_ROW
' (default 2), one dynpro row apart:
'   LABEL <TAB> FIELDNAME <TAB> FIELDLEN
'     LABEL     = displayed label text (column 0)
'     FIELDNAME = I/O field name (placed in the gap cell to the label's right)
'     FIELDLEN  = I/O field length (characters)
' Optional 4th column overrides the dynpro row:
'   LABEL <TAB> FIELDNAME <TAB> FIELDLEN <TAB> ROW
'
' Output: human-readable log + a final parseable line:
'   SUCCESS: rebuilt <PROG> <DYNNR> with <n> line(s).
'   ERROR: <reason>
' =============================================================================

Option Explicit

Const PROGRAM_NAME  = "%%PROGRAM_NAME%%"
Const SCREEN_NUMBER = "%%SCREEN_NUMBER%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SAP_PACKAGE   = "%%PACKAGE%%"
Const LINESPEC_FILE = "%%LINESPEC_FILE%%"
Const LOG_FILE      = "%%LOG_FILE%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const START_ROW = 2     ' first dynpro line used for the first label+input pair

' ------ shared helpers ------------------------------------------------------
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

Dim oFSO, oLog
Set oFSO = CreateObject("Scripting.FileSystemObject")
Set oLog = oFSO.CreateTextFile(LOG_FILE, True)
Sub L(s) : oLog.WriteLine s : End Sub

Dim oSession
Dim created, planned
created = 0
planned = 0

' ------ 1. read line spec ---------------------------------------------------
If Not oFSO.FileExists(LINESPEC_FILE) Then
    L "ERROR: line-spec file not found: " & LINESPEC_FILE
    oLog.Close : WScript.Quit 1
End If
Dim oStream, sAll
Set oStream = CreateObject("ADODB.Stream")
oStream.Type = 2 : oStream.Charset = "utf-8" : oStream.Open
oStream.LoadFromFile LINESPEC_FILE
sAll = oStream.ReadText
oStream.Close

Dim aRaw, aSpec(), nSpec, i, ln
aRaw = Split(Replace(sAll, vbCr, ""), vbLf)
ReDim aSpec(UBound(aRaw))
nSpec = 0
For i = 0 To UBound(aRaw)
    ln = Trim(aRaw(i))
    If Len(ln) > 0 And Left(ln, 1) <> "#" Then
        aSpec(nSpec) = aRaw(i)
        nSpec = nSpec + 1
    End If
Next
If nSpec = 0 Then
    L "ERROR: line-spec file contained no rows."
    oLog.Close : WScript.Quit 1
End If
planned = nSpec * 2     ' each spec line = 1 label + 1 input
L "INFO: " & nSpec & " line(s) to build (" & planned & " elements)."

' ------ 2. attach + open layout change --------------------------------------
Set oSession = AttachSapSession(SESSION_PATH)
L "INFO: Session acquired."

oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE51"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1200
On Error Resume Next
oSession.findById("wnd[0]/usr/ctxtRS37A-DYNPROG").Text = UCase(PROGRAM_NAME)
oSession.findById("wnd[0]/usr/ctxtFELD-DYNNR").Text   = SCREEN_NUMBER
oSession.findById("wnd[0]/usr/radRS37A-FUNED").Select   ' Layout radio
If Err.Number <> 0 Then
    L "ERROR: SE51 initial screen fields not found: " & Err.Description
    oLog.Close : WScript.Quit 1
End If
Err.Clear
On Error GoTo 0
WScript.Sleep 300
oSession.findById("wnd[0]/usr/btnAENDERN").press
WScript.Sleep 3000

Dim g
On Error Resume Next
g = 0
Do While InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 And g < 3
    L "INFO: popup after change: " & oSession.findById("wnd[1]").Text
    oSession.findById("wnd[1]").sendVKey 0
    WScript.Sleep 700
    g = g + 1
Loop
Err.Clear
On Error GoTo 0

If oSession.Info.Program <> "SAPMSSY0" Then
    L "ERROR: NOT_ALPHANUMERIC — graphical Layout Editor opened (program=" & _
      oSession.Info.Program & "). Turn OFF SE51 > Utilities > Settings >"
    L "       'Graphical Layout Editor' for this user, then re-run."
    oLog.Close : WScript.Quit 1
End If
L "INFO: alphanumeric Screen Painter active (SAPMSSY0/" & oSession.Info.ScreenNumber & ")."

' ------ 3. clear all existing real elements (Delete Line) -------------------
Dim pass
For pass = 1 To 30
    Dim foundOne, ch, c, fid, ftxt
    foundOne = False
    On Error Resume Next
    Set ch = oSession.findById("wnd[0]/usr").Children
    For i = 0 To ch.Count - 1
        Set c = ch.ElementAt(i)
        If c.Type = "GuiLabel" Then
            fid = Replace(c.Id, "/app/con[0]/ses[0]/wnd[0]/usr/", "")
            ftxt = Trim(c.Text)
            If fid <> "lbl[0,0]" And Len(ftxt) > 0 Then
                c.SetFocus
                If Err.Number = 0 Then
                    oSession.findById("wnd[0]/mbar/menu[1]/menu[8]/menu[1]").select  ' Delete Line
                    WScript.Sleep 600
                    L "INFO: cleared line of " & fid & " = [" & ftxt & "]"
                    foundOne = True
                    Err.Clear
                    Exit For
                End If
                Err.Clear
            End If
        End If
    Next
    Err.Clear
    On Error GoTo 0
    If Not foundOne Then
        L "INFO: clear complete after pass " & pass
        Exit For
    End If
Next

' ------ 4. build each label+input line --------------------------------------
For i = 0 To nSpec - 1
    Dim parts, sLabel, sField, sLen, nRow
    parts = Split(aSpec(i), vbTab)
    sLabel = "" : sField = "" : sLen = ""
    If UBound(parts) >= 0 Then sLabel = Trim(parts(0))
    If UBound(parts) >= 1 Then sField = Trim(parts(1))
    If UBound(parts) >= 2 Then sLen   = Trim(parts(2))
    nRow = START_ROW + i
    If UBound(parts) >= 3 Then
        If IsNumeric(Trim(parts(3))) Then nRow = CLng(Trim(parts(3)))
    End If
    MakeLine sField, sLabel, sLen, nRow
Next

L "INFO: created " & created & " of " & planned & " elements."
If created < planned Then
    L "ERROR: not all elements created — backing out WITHOUT saving (live screen unchanged)."
    BackOutNoSave
    oLog.Close : WScript.Quit 1
End If

' ------ 5. Save + Activate ---------------------------------------------------
L "INFO: Saving..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/btn[11]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0
SavePopups "SAVE"

L "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 2500
Err.Clear
On Error GoTo 0
SavePopups "ACTIVATE"
On Error Resume Next
Dim a
a = 0
Do While InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 And a < 5
    L "INFO: activation popup: " & oSession.findById("wnd[1]").Text
    oSession.findById("wnd[1]").sendVKey 0
    WScript.Sleep 2000
    a = a + 1
Loop
Err.Clear
On Error GoTo 0

Dim sType, sMsg
On Error Resume Next
sMsg  = oSession.findById("wnd[0]/sbar").Text
sType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0
L "INFO: status bar [" & sType & "] " & sMsg
If sType = "E" Or sType = "A" Then
    L "ERROR: activation reported an error — " & sMsg
    oLog.Close : WScript.Quit 1
End If

L "SUCCESS: rebuilt " & UCase(PROGRAM_NAME) & " " & SCREEN_NUMBER & " with " & nSpec & " line(s)."
oLog.Close
WScript.Quit 0

' ===========================================================================
' MakeLine — Text label (col 0) + I/O field in the gap cell to its right.
Sub MakeLine(sFieldName, sLabel, sLen, nRow)
    If Not OpenCreate(0, "wnd[0]/usr/txt[0," & nRow & "]") Then
        L "WARNING: label dialog never opened on row " & nRow
        Exit Sub
    End If
    On Error Resume Next
    oSession.findById("wnd[1]/usr/txtFELD-STXT").Text = sLabel
    oSession.findById("wnd[1]/usr/txtFELD-LENG").Text = CStr(Len(sLabel))
    Err.Clear
    Refresh_Transfer
    On Error GoTo 0
    L "INFO: created label '" & sLabel & "' on row " & nRow
    created = created + 1

    Dim gapCell
    gapCell = FindGapCell(nRow)
    If gapCell = "" Then
        L "WARNING: no gap cell appeared on row " & nRow & " after label '" & sLabel & "'."
        Exit Sub
    End If

    If Not OpenCreate(1, "wnd[0]/usr/" & gapCell) Then
        L "WARNING: I/O dialog never opened on row " & nRow & " (gap " & gapCell & ")."
        Exit Sub
    End If
    On Error Resume Next
    If Len(sFieldName) > 0 Then oSession.findById("wnd[1]/usr/txtFELD-NAME").Text = sFieldName
    If Len(sLen) > 0       Then oSession.findById("wnd[1]/usr/txtFELD-LENG").Text = sLen
    Err.Clear
    Refresh_Transfer
    On Error GoTo 0
    L "INFO: created input '" & sFieldName & "' (len " & sLen & ") on row " & nRow & " at " & gapCell
    created = created + 1
End Sub

' First editable txt cell with col>0 on nRow (id-suffix like "txt[6,2]") or "".
Function FindGapCell(nRow)
    FindGapCell = ""
    On Error Resume Next
    Dim ch, j, c, idt, inside, comma, col
    Set ch = oSession.findById("wnd[0]/usr").Children
    For j = 0 To ch.Count - 1
        Set c = ch.ElementAt(j)
        If c.Type = "GuiTextField" Then
            idt = Replace(c.Id, "/app/con[0]/ses[0]/wnd[0]/usr/", "")
            If Left(idt, 4) = "txt[" And Right(idt, Len(CStr(nRow)) + 2) = "," & nRow & "]" Then
                inside = Mid(idt, 5)              ' "<col>,<row>]"
                comma = InStr(inside, ",")
                If comma > 1 Then
                    col = CLng(Left(inside, comma - 1))
                    If col > 0 Then
                        FindGapCell = idt
                        Exit For
                    End If
                End If
            End If
        End If
    Next
    Err.Clear
    On Error GoTo 0
End Function

' Focus cursorCell, open Create Element > item nMenu. True if create dialog opens.
' Retries focus+menu up to 3x (editor needs a beat after a prior Transfer).
Function OpenCreate(nMenu, cursorCell)
    OpenCreate = False
    Dim attempt, fe
    For attempt = 1 To 3
        On Error Resume Next
        oSession.findById(cursorCell).setFocus
        fe = Err.Number
        oSession.findById(cursorCell).caretPosition = 0
        Err.Clear
        On Error GoTo 0
        If fe <> 0 Then L "INFO: focus " & cursorCell & " err=" & fe & " (attempt " & attempt & ")"
        WScript.Sleep 300
        On Error Resume Next
        oSession.findById("wnd[0]/mbar/menu[1]/menu[2]/menu[" & nMenu & "]").select
        WScript.Sleep 1000
        Err.Clear
        On Error GoTo 0
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            OpenCreate = True
            Exit Function
        End If
        WScript.Sleep 400
    Next
End Function

Sub Refresh_Transfer()
    On Error Resume Next
    oSession.findById("wnd[1]/tbar[0]/btn[0]").press   ' Refresh/validate
    WScript.Sleep 600
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]/tbar[0]/btn[5]").press ' Transfer/place
        WScript.Sleep 800
    End If
    Err.Clear
    Dim guard
    guard = 0
    Do While InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 And guard < 3
        L "INFO: residual popup: " & oSession.findById("wnd[1]").Text & " -> F12"
        oSession.ActiveWindow.sendVKey 12
        WScript.Sleep 500
        guard = guard + 1
    Loop
    Err.Clear
    On Error GoTo 0
End Sub

Sub BackOutNoSave()
    On Error Resume Next
    Dim n
    oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE51"
    oSession.findById("wnd[0]").sendVKey 0
    WScript.Sleep 1200
    n = 0
    Do While InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 And n < 4
        oSession.findById("wnd[1]/usr/btnSPOP-OPTION2").press   ' No (discard)
        If Err.Number <> 0 Then Err.Clear : oSession.ActiveWindow.sendVKey 0
        WScript.Sleep 700
        n = n + 1
    Loop
    Err.Clear
    On Error GoTo 0
End Sub

' Walk the SAPLSTRD save chain: Object Directory Entry (ctxtTADIR-DEVCLASS,
' pkg prefilled) then transport-request prompt (ctxtKO008-TRKORR). Continue is
' tbar[0]/btn[8] with an Enter fallback. Dispatched by DDIC field (lang-neutral).
Sub SavePopups(sPhase)
    On Error Resume Next
    Dim n, AW
    n = 0
    Do While InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 And n < 8
        AW = oSession.ActiveWindow.Id
        Dim oTR : Set oTR = Nothing
        Set oTR = oSession.findById(AW & "/usr/ctxtKO008-TRKORR")
        If Err.Number = 0 And Not (oTR Is Nothing) Then
            If SAP_TRANSPORT = "" Then
                L "ERROR: " & sPhase & " prompted for a transport request but TRANSPORT is empty."
                L "       Resolve a modifiable TR via /sap-transport-request and re-run."
                oLog.Close : WScript.Quit 1
            End If
            If Trim(oTR.Text) = "" Then oTR.Text = SAP_TRANSPORT
            L "INFO: " & sPhase & " TR prompt -> " & SAP_TRANSPORT
            Err.Clear
            PressCont AW
        Else
            Err.Clear
            Dim oDev : Set oDev = Nothing
            Set oDev = oSession.findById(AW & "/usr/ctxtTADIR-DEVCLASS")
            If Err.Number = 0 And Not (oDev Is Nothing) Then
                If Trim(oDev.Text) = "" And SAP_PACKAGE <> "" Then oDev.Text = SAP_PACKAGE
                L "INFO: " & sPhase & " Object Directory Entry — package=" & oDev.Text
                Err.Clear
                PressCont AW
            Else
                Err.Clear
                L "INFO: " & sPhase & " popup '" & oSession.findById(AW).Text & "' -> Continue/Enter"
                PressCont AW
            End If
        End If
        WScript.Sleep 1200
        n = n + 1
    Loop
    Err.Clear
    On Error GoTo 0
End Sub

Sub PressCont(sWnd)
    On Error Resume Next
    Dim oB : Set oB = Nothing
    Set oB = oSession.findById(sWnd & "/tbar[0]/btn[8]")
    If Err.Number = 0 And Not (oB Is Nothing) Then
        oB.press
    Else
        Err.Clear
        oSession.findById(sWnd).sendVKey 0
    End If
    Err.Clear
    On Error GoTo 0
End Sub
