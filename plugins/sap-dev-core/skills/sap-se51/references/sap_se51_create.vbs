' =============================================================================
' sap_se51_create.vbs  -  SAP GUI Scripting: Create new screen via SE51
'
' Generated by the sap-se51 skill.
' Attaches to an existing SAP GUI session, navigates to SE51, creates a new
' screen (dynpro), sets attributes and short description, pastes flow logic
' from the Windows clipboard, saves, and activates.
'
' IMPORTANT: Must be run with wscript.exe (not cscript.exe) because it uses
'            AppActivate + SendKeys for clipboard paste into the ABAP editor.
'            Output is written to a log file, not stdout.
'
' Tokens replaced at run time:
'   %%PROGRAM_NAME%%       Program name           e.g. "SAPLZHKT05"
'   %%SCREEN_NUMBER%%      4-digit screen number  e.g. "0098"
'   %%SCREEN_SHORT_TEXT%%  Short description       e.g. "My test screen"
'   %%LOG_FILE%%           Path for output log     e.g. "{WORK_TEMP}\sap_se51_create.log"
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const PROGRAM_NAME     = "%%PROGRAM_NAME%%"
Const SCREEN_NUMBER    = "%%SCREEN_NUMBER%%"
Const SCREEN_SHORT_TEXT = "%%SCREEN_SHORT_TEXT%%"
Const LOG_FILE         = "%%LOG_FILE%%"
Const SESSION_PATH     = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

Dim oFSO, oLogFile
Set oFSO = CreateObject("Scripting.FileSystemObject")
Set oLogFile = oFSO.CreateTextFile(LOG_FILE, True)

Sub Log(sMsg)
    oLogFile.WriteLine sMsg
End Sub

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)
Log "INFO: Session acquired."

' ------ 2. Navigate to SE51 -------------------------------------------------
Log "INFO: Navigating to SE51..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE51"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

On Error Resume Next
Dim oProgField
Set oProgField = oSession.findById("wnd[0]/usr/ctxtRS37A-DYNPROG")
If Err.Number <> 0 Or oProgField Is Nothing Then
    Log "ERROR: SE51 program name field not found (ID: wnd[0]/usr/ctxtRS37A-DYNPROG)."
    oLogFile.Close
    WScript.Quit 1
End If
On Error GoTo 0

' ------ 3. Enter program/screen and press Create ----------------------------
oProgField.Text = UCase(PROGRAM_NAME)
oSession.findById("wnd[0]/usr/ctxtFELD-DYNNR").Text = SCREEN_NUMBER
oSession.findById("wnd[0]/usr/radRS37A-FUNLS").Select
WScript.Sleep 300

Log "INFO: Creating new screen: " & UCase(PROGRAM_NAME) & " / " & SCREEN_NUMBER
oSession.findById("wnd[0]/usr/btnANLEGEN").press
WScript.Sleep 2000

' ------ 4. Handle any popup -------------------------------------------------
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Log "INFO: Popup after Create: " & oSession.findById("wnd[1]").Text
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Verify we are in the Screen Painter editor
On Error Resume Next
Dim oTabStrip
Set oTabStrip = oSession.findById("wnd[0]/usr/tabsBS_TABSTR_CONTROL")
Dim bInEditor
bInEditor = (Err.Number = 0) And Not (oTabStrip Is Nothing)
Err.Clear
On Error GoTo 0

If Not bInEditor Then
    Log "ERROR: Could not reach Screen Painter editor after create." & vbCrLf & _
        "       Status: " & oSession.findById("wnd[0]/sbar").Text
    oLogFile.Close
    WScript.Quit 1
End If
Log "INFO: Screen created, now in Screen Painter."

' ------ 5. Set short description on Attributes tab --------------------------
oSession.findById("wnd[0]/usr/tabsBS_TABSTR_CONTROL/tabpHD").Select
WScript.Sleep 500

On Error Resume Next
oSession.findById("wnd[0]/usr/tabsBS_TABSTR_CONTROL/tabpHD/ssubBS_TABSTR_CONTROL_SUB:SAPLWBSCREEN:2150/txtRS37A-DTXT").Text = SCREEN_SHORT_TEXT
If Err.Number <> 0 Then
    Log "WARNING: Could not set short description: " & Err.Description
    Err.Clear
End If
On Error GoTo 0
Log "INFO: Short description set: " & SCREEN_SHORT_TEXT

' ------ 6. Paste flow logic from Windows clipboard --------------------------
oSession.findById("wnd[0]/usr/tabsBS_TABSTR_CONTROL/tabpLS").Select
WScript.Sleep 500

' Set focus on the ABAP editor control
Dim sEditorPath
sEditorPath = "wnd[0]/usr/tabsBS_TABSTR_CONTROL/tabpLS/" & _
    "ssubBS_TABSTR_CONTROL_SUB:SAPLWBSCREEN:2161/" & _
    "subEDITORSUBSCREEN:SAPLEDITOR_START:8430/" & _
    "cntlEDITOR/shellcont/shell"

On Error Resume Next
Dim oEditor
Set oEditor = oSession.findById(sEditorPath)
If Err.Number <> 0 Or oEditor Is Nothing Then
    Log "WARNING: Could not find flow logic editor at expected path."
    Err.Clear
End If
On Error GoTo 0

If Not (oEditor Is Nothing) Then
    oEditor.SetFocus
    WScript.Sleep 300
End If

' Bring the SAP window to OS foreground BEFORE pasting from clipboard.
' The clipboard must be set BEFORE running this script (by the PowerShell
' wrapper). Same foreground-guard pattern as sap_se38_create.vbs:
'   1. If iconified, .Restore (an iconified window can't take foreground).
'   2. .Maximize unconditionally (helps with stacked windows).
'   3. Run sap_gui_foreground_guard.ps1 — uses the AttachThreadInput Win32
'      trick to bypass Windows 7+'s SetForegroundWindow suppression.
'      WshShell.AppActivate (previously used here in a retry loop) is
'      unreliable: it returns success while Windows just flashes the
'      taskbar button, leaving SAP behind — SendKeys then lands in
'      Notepad / VS Code / browser. Bug surfaced 2026-05-11.
Dim oWSh, sTitle
Set oWSh = CreateObject("WScript.Shell")
sTitle = oSession.findById("wnd[0]").Text

On Error Resume Next
If oSession.findById("wnd[0]").Iconified Then
    oSession.findById("wnd[0]").Restore
    WScript.Sleep 300
End If
oSession.findById("wnd[0]").Maximize
WScript.Sleep 300
Err.Clear
On Error GoTo 0

Dim sFgGuardCmdSE51, nFgGuardRcSE51
sFgGuardCmdSE51 = "powershell -NoProfile -ExecutionPolicy Bypass -File """ & _
                  "%%FOREGROUND_GUARD_PS1%%"" -TargetTitle """ & sTitle & _
                  """ -TimeoutSeconds 5"
nFgGuardRcSE51 = oWSh.Run(sFgGuardCmdSE51, 0, True)
If nFgGuardRcSE51 <> 0 Then
    Log "ERROR: SAP GUI window is not the OS foreground window (sidecar exit " & nFgGuardRcSE51 & ")."
    Log "       Aborting paste to prevent Ctrl+V from landing in another app (Notepad, VS Code, browser)."
    Log "       Target window title: " & sTitle
    Log "       Recovery: close or minimize the focus-stealing app, click on the SAP GUI window,"
    Log "                then re-run this skill."
    WScript.Quit 1
End If

' Belt-and-suspenders clear-then-paste — see sap_se38_create.vbs Step 6c
' for the full incident-driven rationale. SendKeys "^a" alone is unreliable
' in the SAP screen editor (Ctrl+A may be rebound to a function code).
' Layers: SAP-side sendVKey 26, then Windows ^{HOME} + ^+{END}, then ^a as
' fallback, then ^v (which replaces the selected text — no explicit {DEL}
' needed in this editor variant).
On Error Resume Next
oSession.findById("wnd[0]").sendVKey 26
WScript.Sleep 150
Err.Clear
On Error GoTo 0
oWSh.SendKeys "^{HOME}"
WScript.Sleep 80
oWSh.SendKeys "^+{END}"
WScript.Sleep 80
oWSh.SendKeys "^a"
WScript.Sleep 200
oWSh.SendKeys "^v"
WScript.Sleep 1000

Log "INFO: Flow logic pasted from clipboard (3-layer clear)."

' ------ 7. Save (Ctrl+S / F11) ----------------------------------------------
Log "INFO: Saving..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle transport/save dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Log "INFO: Transport/save dialog - pressing Local Object or Enter..."
    Dim oLocalBtn
    Set oLocalBtn = oSession.findById("wnd[1]/tbar[0]/btn[7]")
    If Err.Number = 0 And Not (oLocalBtn Is Nothing) Then
        oLocalBtn.press
    Else
        Err.Clear
        oSession.ActiveWindow.sendVKey VKEY_ENTER
    End If
    WScript.Sleep 2000
End If

' Handle additional popup if it appears
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

Dim sSaveStatus
sSaveStatus = oSession.findById("wnd[0]/sbar").Text
Log "INFO: " & sSaveStatus

' ------ 8. Activate (Ctrl+F3 = tbar[1]/btn[27]) ----------------------------
Log "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 3000

' Handle "Inactive Objects" list popup — confirm with Enter to activate all
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Log "INFO: Inactive objects list - confirming activation..."
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 5000
End If

' Handle "Activation errors" popup (wnd[2])
If InStr(oSession.ActiveWindow.Id, "wnd[2]") > 0 Then
    Log "WARNING: Activation errors - pressing Activate anyway..."
    oSession.findById("wnd[2]/usr/btnBUTTON_1").press
    WScript.Sleep 3000
End If
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.findById("wnd[1]").sendVKey 12
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 9. Final status check -----------------------------------------------
Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    Log "WARNING: Activation may have errors - " & sFinalMsg
Else
    Log "INFO: SAP status: " & sFinalMsg
End If

Log "SUCCESS: Screen " & UCase(PROGRAM_NAME) & " " & SCREEN_NUMBER & " created and activated in SAP."
oLogFile.Close
WScript.Quit 0
