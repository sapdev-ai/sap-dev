'
' Run via: 32-bit cscript //NoLogo (SAP GUI Scripting COM requires 32-bit).
' Requires an active SAP GUI session positioned at SAP Easy Access.
'
' Parallel-safe session attach (Tier 3 contract) — DO NOT replace with
' oApp.Children(0). The wrapping SKILL.md sets $env:SAPDEV_SESSION_PATH to
' Get-SapCurrentSessionPath's return value, then substitutes %%SESSION_PATH%%
' (hint) and %%ATTACH_LIB_VBS%% (absolute path of sap_attach_lib.vbs) into
' this template. AttachSapSession resolves the target session in priority
' order: hint -> SAPDEV_SESSION_PATH env -> sole-connection default ->
' loud refusal. This is what keeps the script from driving a connection
' the operator did not pin to.
' =============================================================================
Option Explicit

Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' --- attach to the AI session's pinned SAP GUI session ----------------------
Dim oSess
Set oSess = AttachSapSession(SESSION_PATH)

' --- helper: dismiss a popup if one is open ---------------------------------
Function IsPopupOpen(sess)
    On Error Resume Next
    Dim w : Set w = sess.findById("wnd[1]", False)
    On Error GoTo 0
    IsPopupOpen = Not (w Is Nothing)
End Function

' --- helper: read status-bar MessageType (language-independent) -------------
Function StatusBarType(sess)
    On Error Resume Next
    Dim s : Set s = sess.findById("wnd[0]/sbar", False)
    On Error GoTo 0
    If s Is Nothing Then
        StatusBarType = ""
    Else
        StatusBarType = s.MessageType
    End If
End Function

' --- helper: select a row by matching a cell value (language-independent) ---
' Used for inactive-objects worklist popups where the row index changes
' depending on what other inactive objects coexist. Returns True on hit.
' NOTE: GuiTableControl has no GetCell(row, columnName) overload — GetCell takes
' integer (row, col) indices, and only the rows in the rendered band are
' scriptable. A cell findById id (txtWORK_ITEMS-<col>[col,visRow]) addresses the
' VISIBLE-relative row; getAbsoluteRow() takes the ABSOLUTE index. When the
' table is scrolled, absolute rows outside the rendered band raise err 613, so
' we page through the whole table via verticalScrollbar.position and guard every
' getAbsoluteRow call. Scan a few column positions since the visible column
' index varies.
Function SelectRowByCellValue(sess, tblId, columnName, cellValue)
    On Error Resume Next
    Dim tbl : Set tbl = sess.findById(tblId, False)
    On Error GoTo 0
    SelectRowByCellValue = False
    If tbl Is Nothing Then Exit Function
    Dim total, vis, top, i, jj, c, absIdx
    total = tbl.RowCount
    vis   = tbl.VisibleRowCount
    If vis <= 0 Then vis = 1
    top = 0
    Do While top < total
        On Error Resume Next
        tbl.verticalScrollbar.position = top      ' show absolute rows [top, top+vis)
        Set tbl = sess.findById(tblId, False)     ' re-resolve after scroll
        On Error GoTo 0
        If tbl Is Nothing Then Exit Function
        For i = 0 To vis - 1
            absIdx = top + i
            If absIdx >= total Then Exit For
            Set c = Nothing
            For jj = 0 To 9
                On Error Resume Next
                Set c = sess.findById(tblId & "/txtWORK_ITEMS-" & columnName & "[" & jj & "," & i & "]", False)
                On Error GoTo 0
                If Not c Is Nothing Then Exit For
            Next
            If Not c Is Nothing Then
                If Trim(c.Text) = Trim(cellValue) Then
                    On Error Resume Next
                    tbl.getAbsoluteRow(absIdx).Selected = True
                    On Error GoTo 0
                    SelectRowByCellValue = True
                    Exit Function
                End If
            End If
        Next
        top = top + vis
    Loop
End Function

' --- begin scenario actions -------------------------------------------------
{{ACTION_LINES}}
' --- end scenario actions ---------------------------------------------------

' Final status-bar check -- E or A means the last action failed even though no
' VBS exception was raised. Surface this rather than reporting false success.
Dim sbType : sbType = StatusBarType(oSess)
If sbType = "E" Or sbType = "A" Then
    WScript.Echo "ERROR: status-bar reported MessageType=" & sbType
    WScript.Quit 3
End If

WScript.Echo "DONE"
WScript.Quit 0
