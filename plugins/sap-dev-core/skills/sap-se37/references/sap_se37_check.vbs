' =============================================================================
' sap_se37_check.vbs  -  SAP GUI Scripting: Check if function module exists
'
' Generated by the sap-se37 skill.
' Attaches to an existing SAP GUI session, navigates to SE37,
' attempts Display, and checks if the Function Builder opens.
'
' Output: "EXIST" or "NOT_EXIST" (last line of stdout, parseable by skill).
'
' Tokens replaced at run time:
'   %%FM_NAME%%  Function module name  e.g. "ZHKFM_TEST001"
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const FM_NAME    = "%%FM_NAME%%"
Const VKEY_ENTER = 0

Dim oSAPGUI, oApplication, oSession
Dim oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApplication = oSAPGUI.GetScriptingEngine
If oApplication Is Nothing Then
    WScript.Echo "ERROR: Could not get SAP Scripting Engine."
    WScript.Quit 1
End If

Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApplication.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to SE37 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE37..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE37"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter FM name and click Display ----------------------------------
WScript.Echo "INFO: Checking function module: " & UCase(FM_NAME)
oSession.findById("wnd[0]/usr/ctxtRS38L-NAME").Text = UCase(FM_NAME)
oSession.findById("wnd[0]/usr/btnBUT3").press   ' Display
WScript.Sleep 2000

' ------ 4. Determine result -------------------------------------------------
' If the FM exists, the Function Builder editor opens with FUNC_TAB_STRIP.
' If it does not exist, we stay on the SE37 initial screen with a status message.
On Error Resume Next
Dim oTabStrip
Set oTabStrip = oSession.findById("wnd[0]/usr/tabsFUNC_TAB_STRIP")
Dim bFound
bFound = (Err.Number = 0 And Not (oTabStrip Is Nothing))
Err.Clear
On Error GoTo 0

If bFound Then
    WScript.Echo "INFO: Function module " & UCase(FM_NAME) & " exists."
    ' Navigate back to SE37 initial screen
    oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE37"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500
    WScript.Echo "EXIST"
Else
    Dim sStatus
    sStatus = oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "INFO: " & sStatus
    WScript.Echo "NOT_EXIST"
End If

WScript.Quit 0
