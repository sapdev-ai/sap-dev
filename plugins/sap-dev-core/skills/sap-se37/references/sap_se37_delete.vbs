' =============================================================================
' sap_se37_delete.vbs  -  SAP GUI Scripting: Delete function module via SE37
'
' Generated by the sap-se37 skill (Step 5f).
' Attaches to an existing SAP GUI session, navigates to SE37, enters the FM
' name, presses Delete (Shift+F2 = tbar[1]/btn[14]), confirms the
' "Delete object" popup with btnSPOP-OPTION1 (Yes), handles the optional
' post-delete transport-request popup, and verifies removal.
'
' Tokens replaced at run time:
'   %%FM_NAME%%        Function module name (UPPERCASE)  e.g. "Z_HKFM_TEST001"
'   %%TRANSPORT%%      Transport request for the post-delete TR popup. Optional.
'                       Empty when the FM is local ($TMP) or already locked to
'                       a modifiable TR. If the popup appears with TRANSPORT
'                       blank the script aborts so the caller can resolve a TR.
'
' Recording reference: C:\Temp\Record_SE37_Delete_01.vbs (S/4HANA 1909).
'
' Outputs (last line of stdout, parseable):
'   SUCCESS: Function module <FM> deleted.
'   ERROR:   ...
' =============================================================================

Option Explicit

Const FM_NAME       = "%%FM_NAME%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_SHIFT_F2 = 14

' Optional fill for the ECC6 "Create Object Directory Entry" (SAPLSTRD) popup.
' Empty / unsubstituted => accept SAP's pre-filled package (Continue), or press
' Local Object when the package field is required-empty. OBJDIR_LANG is the
' 1-character original language used only when filling an empty package field.
Dim OBJDIR_PKG  : OBJDIR_PKG  = "%%PACKAGE%%"
Dim OBJDIR_LANG : OBJDIR_LANG = "%%ORIG_LANG%%"
If Left(OBJDIR_PKG, 2)  = Chr(37) & Chr(37) Then OBJDIR_PKG  = ""
If Left(OBJDIR_LANG, 2) = Chr(37) & Chr(37) Then OBJDIR_LANG = ""
If OBJDIR_LANG = "" Then OBJDIR_LANG = "E"

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE37 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE37 to delete " & UCase(FM_NAME) & "..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE37"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter FM name ----------------------------------------------------
oSession.findById("wnd[0]/usr/ctxtRS38L-NAME").Text = UCase(FM_NAME)
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

' ------ Lock session for the delete + popup-confirm critical section ----
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the delete + popup-confirm critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 4. Press Delete (Shift+F2 / tbar[1]/btn[14]) ------------------------
WScript.Echo "INFO: Pressing Delete (Shift+F2)..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_SHIFT_F2

WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Delete: " & Err.Description
    WScript.Echo "       (FM may not exist on the initial screen, or button id differs on this release.)"
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 5. Walk the post-delete popup chain (locale-independent) ------------
' After Shift+F2 SAP can chain several modals depending on object + system:
'   * Yes/No confirm                          -> btnSPOP-OPTION1
'   * SAPLSETX original-vs-logon language      -> ctxtRSETX-MASTERLANG / btnPUSH1
'   * "Create Object Directory Entry"          -> ctxtKO007-L_DEVCLASS (ECC6;
'        raised when the directory entry must be (re)created on delete)
'   * Transport-request prompt                -> ctxtKO008-TRKORR
'   * "Delete object" confirm                  -> tbar[0]/btn[0] / Enter
' Dispatch by DDIC control id only (never title/text). Capped at 10 iterations.
Dim iPop, sActWnd, sActPrefix, posWnd, bHandled
Dim oML, oDevc, oObjLang, oTr, oYes, oCont
For iPop = 1 To 10
    sActWnd = ""
    On Error Resume Next
    sActWnd = oSession.ActiveWindow.Id
    On Error GoTo 0
    If sActWnd = "" Then Exit For
    If Right(sActWnd, 6) = "wnd[0]" Then Exit For
    posWnd = InStrRev(sActWnd, "/wnd[")
    If posWnd > 0 Then sActPrefix = Mid(sActWnd, posWnd + 1) Else sActPrefix = "wnd[1]"
    bHandled = False

    ' (a) SAPLSETX original-vs-logon-language popup.
    On Error Resume Next
    Set oML = Nothing
    Set oML = oSession.findById(sActPrefix & "/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 And Not (oML Is Nothing) Then
        oSession.findById(sActPrefix & "/usr/btnPUSH1").press
        WScript.Echo "INFO: SAPLSETX original-language popup on " & sActPrefix & " -- 'Maint. in orig. lang.'"
        WScript.Sleep 1500 : bHandled = True
    End If
    Err.Clear
    On Error GoTo 0

    ' (b) "Create Object Directory Entry" (SAPLSTRD / KO007) -- ECC6.
    If Not bHandled Then
        On Error Resume Next
        Set oDevc = Nothing
        Set oDevc = oSession.findById(sActPrefix & "/usr/ctxtKO007-L_DEVCLASS")
        If Err.Number = 0 And Not (oDevc Is Nothing) Then
            If oDevc.Text = "" And OBJDIR_PKG <> "" Then
                oDevc.Text = OBJDIR_PKG
                Set oObjLang = Nothing
                Set oObjLang = oSession.findById(sActPrefix & "/usr/ctxtKO007-L_MSTLANG")
                If Err.Number = 0 And Not (oObjLang Is Nothing) Then
                    If oObjLang.Text = "" Then oObjLang.Text = OBJDIR_LANG
                End If
                Err.Clear
                oSession.findById(sActPrefix & "/tbar[0]/btn[0]").press
                WScript.Echo "INFO: Object Directory Entry on " & sActPrefix & " -- package " & OBJDIR_PKG & ", Continue."
            ElseIf oDevc.Text = "" Then
                oSession.findById(sActPrefix & "/tbar[0]/btn[7]").press
                WScript.Echo "INFO: Object Directory Entry on " & sActPrefix & " -- empty package, none supplied; Local Object."
            Else
                oSession.findById(sActPrefix & "/tbar[0]/btn[0]").press
                WScript.Echo "INFO: Object Directory Entry on " & sActPrefix & " -- accepted pre-filled package, Continue."
            End If
            WScript.Sleep 1500 : bHandled = True
        End If
        Err.Clear
        On Error GoTo 0
    End If

    ' (c) Transport-request prompt.
    If Not bHandled Then
        On Error Resume Next
        Set oTr = Nothing
        Set oTr = oSession.findById(sActPrefix & "/usr/ctxtKO008-TRKORR")
        If Err.Number = 0 And Not (oTr Is Nothing) Then
            If SAP_TRANSPORT = "" Then
                WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty."
                WScript.Echo "       Resolve a TR via /sap-transport-request and re-run."
                ReleaseSession oSession, wasLocked
                WScript.Quit 1
            End If
            oTr.Text = SAP_TRANSPORT
            oSession.findById(sActPrefix).sendVKey VKEY_ENTER
            WScript.Echo "INFO: Filled transport " & SAP_TRANSPORT & " on " & sActPrefix & "."
            WScript.Sleep 1500 : bHandled = True
        End If
        Err.Clear
        On Error GoTo 0
    End If

    ' (d) Generic confirm: Yes -> popup Continue -> Enter.
    If Not bHandled Then
        On Error Resume Next
        Set oYes = Nothing
        Set oYes = oSession.findById(sActPrefix & "/usr/btnSPOP-OPTION1")
        If Err.Number = 0 And Not (oYes Is Nothing) Then
            oYes.press
            WScript.Echo "INFO: Confirmed popup " & iPop & " on " & sActPrefix & " (Yes)."
        Else
            Err.Clear
            Set oCont = Nothing
            Set oCont = oSession.findById(sActPrefix & "/tbar[0]/btn[0]")
            If Err.Number = 0 And Not (oCont Is Nothing) Then
                oCont.press
                WScript.Echo "INFO: Confirmed popup " & iPop & " on " & sActPrefix & " (Continue)."
            Else
                Err.Clear
                oSession.findById(sActPrefix).sendVKey VKEY_ENTER
                WScript.Echo "INFO: Confirmed popup " & iPop & " on " & sActPrefix & " (Enter)."
            End If
        End If
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 1200
    End If
Next
If iPop > 10 Then
    WScript.Echo "WARN: Popup loop hit cap; SAP may have left a modal on screen."
End If

' ------ 7. Verify deletion via Display --------------------------------------
' After delete, attempting Display should leave us on the SE37 initial screen
' with a status message like "Function module <FM> does not exist".
WScript.Echo "INFO: Verifying deletion (try Display)..."
oSession.findById("wnd[0]/usr/ctxtRS38L-NAME").Text = UCase(FM_NAME)
oSession.findById("wnd[0]/usr/btnBUT3").press   ' Display
WScript.Sleep 1500

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

' Release the session UI lock; status read is read-only.
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' Decision: if the Function Builder editor opened, deletion FAILED. Otherwise
' the FM is gone (status bar typically shows an error/info "does not exist").
On Error Resume Next
Dim oTabStrip : Set oTabStrip = Nothing
Set oTabStrip = oSession.findById("wnd[0]/usr/tabsFUNC_TAB_STRIP")
Dim bStillExists : bStillExists = (Err.Number = 0 And Not (oTabStrip Is Nothing))
Err.Clear
On Error GoTo 0

If bStillExists Then
    WScript.Echo "ERROR: FM still exists after delete. sbar=[" & sFinalType & "] " & sFinalMsg
    ' Back out of the Function Builder so the operator inherits a clean SE37 initial screen.
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE37"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Quit 1
End If

WScript.Echo "INFO: SAP status: [" & sFinalType & "] " & sFinalMsg
WScript.Echo "SUCCESS: Function module " & UCase(FM_NAME) & " deleted."
WScript.Quit 0
