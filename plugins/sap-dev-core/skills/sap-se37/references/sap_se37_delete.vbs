' =============================================================================
' sap_se37_delete.vbs  -  SAP GUI Scripting: Delete function module via SE37
'
' Generated by the sap-se37 skill (Step 5f).
' Attaches to an existing SAP GUI session, navigates to SE37, enters the FM
' name, presses Delete (Shift+F2 = tbar[1]/btn[14]), confirms the
' "Delete object" popup with btnSPOP-OPTION1 (Yes), handles the optional
' post-delete transport-request popup, and verifies removal.
'
' Tokens replaced at run time:
'   %%FM_NAME%%        Function module name (UPPERCASE)  e.g. "Z_HKFM_TEST001"
'   %%TRANSPORT%%      Transport request for the post-delete TR popup. Optional.
'                       Empty when the FM is local ($TMP) or already locked to
'                       a modifiable TR. If the popup appears with TRANSPORT
'                       blank the script aborts so the caller can resolve a TR.
'
' Recording reference: C:\Temp\Record_SE37_Delete_01.vbs (S/4HANA 1909).
'
' Outputs (last line of stdout, parseable):
'   SUCCESS: Function module <FM> deleted.
'   ERROR:   ...
' =============================================================================

Option Explicit

Const FM_NAME       = "%%FM_NAME%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_SHIFT_F2 = 14

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE37 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE37 to delete " & UCase(FM_NAME) & "..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE37"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter FM name ----------------------------------------------------
oSession.findById("wnd[0]/usr/ctxtRS38L-NAME").Text = UCase(FM_NAME)
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

' ------ Lock session for the delete + popup-confirm critical section ----
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the delete + popup-confirm critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 4. Press Delete (Shift+F2 / tbar[1]/btn[14]) ------------------------
WScript.Echo "INFO: Pressing Delete (Shift+F2)..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_SHIFT_F2

WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Delete: " & Err.Description
    WScript.Echo "       (FM may not exist on the initial screen, or button id differs on this release.)"
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 5. Confirm deletion popup -------------------------------------------
' SAP shows a confirmation popup ("Should the function module be deleted?")
' with two buttons: btnSPOP-OPTION1 (Yes) and btnSPOP-OPTION2 (No).
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oYes : Set oYes = Nothing
    Set oYes = oSession.findById("wnd[1]/usr/btnSPOP-OPTION1")
    If Err.Number = 0 And Not (oYes Is Nothing) Then
        WScript.Echo "INFO: Confirming deletion (Yes)..."
        oYes.press
        WScript.Sleep 1500
    Else
        Err.Clear
        WScript.Echo "INFO: Unknown popup on Delete -- pressing Enter."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1500
    End If
Else
    WScript.Echo "INFO: No confirmation popup appeared (FM may not exist)."
End If
Err.Clear
On Error GoTo 0

' ------ 6. Handle optional transport-request popup --------------------------
' If the FM was attached to a transportable package, SAP shows a
' "Prompt for local Workbench request" popup with ctxtKO008-TRKORR. Fill
' SAP_TRANSPORT and Enter. If TRANSPORT is empty, abort.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oTr : Set oTr = Nothing
    Set oTr = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTr Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty."
            WScript.Echo "       Resolve a TR via /sap-transport-request and re-run."
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Filling transport " & SAP_TRANSPORT & "..."
        oTr.Text = SAP_TRANSPORT
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1500
    Else
        Err.Clear
        ' Some other popup (e.g. error). Echo title for diagnostics and dismiss.
        WScript.Echo "INFO: Unexpected popup after delete: " & oSession.ActiveWindow.Text
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 7. Verify deletion via Display --------------------------------------
' After delete, attempting Display should leave us on the SE37 initial screen
' with a status message like "Function module <FM> does not exist".
WScript.Echo "INFO: Verifying deletion (try Display)..."
oSession.findById("wnd[0]/usr/ctxtRS38L-NAME").Text = UCase(FM_NAME)
oSession.findById("wnd[0]/usr/btnBUT3").press   ' Display
WScript.Sleep 1500

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

' Release the session UI lock; status read is read-only.
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' Decision: if the Function Builder editor opened, deletion FAILED. Otherwise
' the FM is gone (status bar typically shows an error/info "does not exist").
On Error Resume Next
Dim oTabStrip : Set oTabStrip = Nothing
Set oTabStrip = oSession.findById("wnd[0]/usr/tabsFUNC_TAB_STRIP")
Dim bStillExists : bStillExists = (Err.Number = 0 And Not (oTabStrip Is Nothing))
Err.Clear
On Error GoTo 0

If bStillExists Then
    WScript.Echo "ERROR: FM still exists after delete. sbar=[" & sFinalType & "] " & sFinalMsg
    ' Back out of the Function Builder so the operator inherits a clean SE37 initial screen.
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE37"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Quit 1
End If

WScript.Echo "INFO: SAP status: [" & sFinalType & "] " & sFinalMsg
WScript.Echo "SUCCESS: Function module " & UCase(FM_NAME) & " deleted."
WScript.Quit 0
