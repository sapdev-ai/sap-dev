' =============================================================================
' sap_se37_reassign_fugr.vbs  -  SAP GUI Scripting: Reassign FM to new
'                                 function group
'
' Generated by the sap-se37 skill.
' Attaches to an existing SAP GUI session, navigates to SE37, types the FM
' name on the initial screen, then presses Reassign (tbar[1]/btn[31]),
' fills the new function group in the dialog (wnd[1]/usr/ctxtRS38L_FUNC-AREA),
' presses Reassign (wnd[1]/tbar[0]/btn[0]), handles the post-reassign
' Workbench-request popup (per /sap-transport-request) and any info/error
' popup, then re-activates the FM (toolbar Activate = btn[27]) since
' reassign leaves the FM inactive.
'
' Tokens replaced at run time:
'   %%FM_NAME%%          Function module name      e.g. "Z_HKFM_TEST007"
'   %%NEW_FUNC_GROUP%%   Target function group     e.g. "ZHKFG02"
'   %%TRANSPORT%%        TR for the post-reassign TR popup. Empty when
'                        local ($TMP) or already locked to a modifiable TR.
'
' Preconditions (caller must verify):
'   - The FM is currently active (no inactive version pending).
'   - Both the old and the new function groups exist and are active.
'
' Recorded baselines:
'   Record_SE37_ChangeFunctionGroup.vbs / ChangeFunctionGroup2.vbs
'   /nse37 -> sendVKey 0 -> tbar[1]/btn[31] -> wnd[1]/usr/ctxtRS38L_FUNC-AREA
'   wnd[1]/tbar[0]/btn[0] (Reassign in dialog)
'   tbar[1]/btn[27] (Activate, optional follow-up)
' =============================================================================

Option Explicit

Const FM_NAME         = "%%FM_NAME%%"
Const NEW_FUNC_GROUP  = "%%NEW_FUNC_GROUP%%"
Const SAP_TRANSPORT   = "%%TRANSPORT%%"
Const SESSION_PATH    = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER  = 0

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

If FM_NAME = "" Then
    WScript.Echo "ERROR: FM_NAME is empty."
    WScript.Quit 1
End If
If NEW_FUNC_GROUP = "" Then
    WScript.Echo "ERROR: NEW_FUNC_GROUP is empty."
    WScript.Quit 1
End If

' ------ 2. Navigate to SE37 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE37..."
On Error Resume Next
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE37"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

' --- Lock the SAP session UI for the FM reassign + reactivate critical section ---
' Per Rule 7: LockSessionUI blocks user input races inside SAP. No OS-level
' foreground guard needed -- this flow only fills the Reassign dialog fields
' and presses buttons via the Scripting API (no clipboard, no SendKeys).
' Released after reactivation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the FM reassign + reactivate critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Enter FM name on initial screen ----------------------------------
WScript.Echo "INFO: Entering FM name: " & UCase(FM_NAME)
On Error Resume Next
Dim oFm
Err.Clear
Set oFm = oSession.findById("wnd[0]/usr/ctxtRS38L-NAME")
If Err.Number <> 0 Or oFm Is Nothing Then
    WScript.Echo "ERROR: SE37 initial screen field ctxtRS38L-NAME not found."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
oFm.Text = UCase(FM_NAME)
Err.Clear
On Error GoTo 0

' ------ 4. Press Reassign (tbar[1]/btn[31]) ---------------------------------
WScript.Echo "INFO: Pressing Reassign (tbar[1]/btn[31])..."
On Error Resume Next
Err.Clear
oSession.findById("wnd[0]/tbar[1]/btn[31]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' Verify Reassign dialog opened (wnd[1] with ctxtRS38L_FUNC-AREA)
Dim oNewFg
On Error Resume Next
Err.Clear
Set oNewFg = oSession.findById("wnd[1]/usr/ctxtRS38L_FUNC-AREA")
If Err.Number <> 0 Or oNewFg Is Nothing Then
    ' Maybe an early error popup (e.g. FM doesn't exist or is inactive)
    Dim sBar0, sBarT0
    sBar0 = "" : sBarT0 = ""
    Err.Clear
    sBar0 = oSession.findById("wnd[0]/sbar").Text
    sBarT0 = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear
    If sBar0 <> "" Then
        WScript.Echo "ERROR: Reassign dialog did not open. sbar [" & sBarT0 & "]: " & sBar0
    Else
        WScript.Echo "ERROR: Reassign dialog did not open (wnd[1]/usr/ctxtRS38L_FUNC-AREA not found)."
    End If
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Reassign dialog open."

' ------ 5. Fill new function group + press Reassign in dialog ---------------
WScript.Echo "INFO: New function group: " & UCase(NEW_FUNC_GROUP)
On Error Resume Next
oNewFg.Text = UCase(NEW_FUNC_GROUP)
oNewFg.setFocus
Err.Clear
oSession.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 5a. Optional Workbench-request / info / error popup loop -----------
On Error Resume Next
Dim iLoop
For iLoop = 1 To 4
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 And _
       InStr(oSession.ActiveWindow.Id, "wnd[2]") = 0 Then Exit For

    Dim sWin
    If InStr(oSession.ActiveWindow.Id, "wnd[2]") > 0 Then
        sWin = "wnd[2]"
    Else
        sWin = "wnd[1]"
    End If

    Dim oTrField
    Set oTrField = Nothing
    Err.Clear
    Set oTrField = oSession.findById(sWin & "/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrField Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            On Error Resume Next
            oSession.findById(sWin).sendVKey 12
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        oTrField.Text = SAP_TRANSPORT
        WScript.Echo "INFO: TR popup on " & sWin & " - entering " & SAP_TRANSPORT & "."
        oSession.findById(sWin).sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        Dim sTitle, oM1, oM2, sM1, sM2
        sTitle = oSession.ActiveWindow.Text
        sM1 = "" : sM2 = ""
        Err.Clear
        Set oM1 = oSession.findById(sWin & "/usr/txtMESSTXT1")
        If Err.Number = 0 And Not (oM1 Is Nothing) Then sM1 = oM1.Text
        Err.Clear
        Set oM2 = oSession.findById(sWin & "/usr/txtMESSTXT2")
        If Err.Number = 0 And Not (oM2 Is Nothing) Then sM2 = oM2.Text
        Err.Clear
        ' Fatal-popup classifier -- documented Rule-6 exception: the generic
        ' message popup (txtMESSTXT1..4 + OK) exposes no locale-stable
        ' control ID / MessageType / icon to branch on, so match the error
        ' title / lock wording across the product's declared logon languages
        ' (EN + ChrW-built JA/ZH, best-effort translations; source stays
        ' ASCII), same pattern as sap_atc_check_run_status.vbs.
        Dim sTtlLow : sTtlLow = LCase(sTitle)
        Dim sPopLow : sPopLow = LCase(sM1 & " " & sM2)
        Dim JA_LOCKED : JA_LOCKED = ChrW(&H30ED) & ChrW(&H30C3) & ChrW(&H30AF) ' rokku   = lock
        Dim ZH_LOCKED : ZH_LOCKED = ChrW(&H9501) & ChrW(&H5B9A)                ' suoding = locked
        Dim JA_ERRTTL : JA_ERRTTL = ChrW(&H30A8) & ChrW(&H30E9) & ChrW(&H30FC) ' eraa    = error
        Dim ZH_ERRTTL : ZH_ERRTTL = ChrW(&H9519) & ChrW(&H8BEF)                ' cuowu   = error
        Dim bFatalPopup : bFatalPopup = False
        If sTtlLow = "error" Or sTtlLow = JA_ERRTTL Or sTtlLow = ZH_ERRTTL Then bFatalPopup = True
        If InStr(sPopLow, "lock") > 0 Or InStr(sPopLow, JA_LOCKED) > 0 Or _
           InStr(sPopLow, ZH_LOCKED) > 0 Then bFatalPopup = True
        If bFatalPopup Then
            WScript.Echo "ERROR: SAP popup [" & sTitle & "] " & Trim(sM1 & " " & sM2)
            On Error Resume Next
            oSession.findById(sWin & "/tbar[0]/btn[12]").press
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById(sWin).sendVKey 12
            End If
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Confirming popup [" & sTitle & "] - pressing Enter."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
Next
Err.Clear
On Error GoTo 0

' ------ 6. Read status bar after reassign -----------------------------------
Dim sBarText, sBarType
sBarText = "" : sBarType = ""
On Error Resume Next
sBarText = oSession.findById("wnd[0]/sbar").Text
sBarType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Status bar after reassign [" & sBarType & "]: " & sBarText
If LCase(sBarType) = "e" Or LCase(sBarType) = "a" Then
    WScript.Echo "ERROR: Reassign failed - " & sBarText
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ 7. Re-activate the FM (reassign leaves it inactive) -----------------
' Make sure FM name is still in the initial screen field, then press
' the Activate toolbar button (tbar[1]/btn[27] = Ctrl+F3).
WScript.Echo "INFO: Re-activating FM after reassign..."
On Error Resume Next
Err.Clear
Set oFm = oSession.findById("wnd[0]/usr/ctxtRS38L-NAME")
If Err.Number = 0 And Not (oFm Is Nothing) Then
    If oFm.Text = "" Then oFm.Text = UCase(FM_NAME)
End If
Err.Clear
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 7a. Inactive-objects worklist popup (if shown) ----------------------
' Continue (btn[0]) ONLY: the popup is pre-filtered and the triggering FM
' (plus its function-group includes) is pre-selected, so Continue activates
' exactly them. Do NOT press Select All: on a shared DEV the worklist also
' lists other developers' unrelated inactive objects (EC2/DEV102: 500+) and
' Select All would co-activate every one. Matches the proven Continue-only
' model in sap_se37_update.vbs; never re-add Select All.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Err.Clear
    Dim oWlCont
    Set oWlCont = oSession.findById("wnd[1]/tbar[0]/btn[0]")
    If Err.Number = 0 And Not (oWlCont Is Nothing) Then
        WScript.Echo "INFO: Inactive-objects popup - Continue (pre-selected object only, no Select All)."
        oWlCont.press
        WScript.Sleep 1500
    Else
        Err.Clear
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1500
    End If
End If
Err.Clear
On Error GoTo 0

' Handle any further popups (TR, info)
On Error Resume Next
For iLoop = 1 To 3
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit For
    Dim oTrA
    Err.Clear
    Set oTrA = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrA Is Nothing) Then
        If SAP_TRANSPORT <> "" Then oTrA.Text = SAP_TRANSPORT
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
Next
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; final status bar read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 8. Read final status bar --------------------------------------------
sBarText = "" : sBarType = ""
On Error Resume Next
sBarText = oSession.findById("wnd[0]/sbar").Text
sBarType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Status bar after activate [" & sBarType & "]: " & sBarText
If LCase(sBarType) = "e" Or LCase(sBarType) = "a" Then
    WScript.Echo "ERROR: Activation after reassign failed - " & sBarText
    WScript.Quit 1
End If

' ------ 9. Back to /n -------------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: " & UCase(FM_NAME) & " reassigned to " & UCase(NEW_FUNC_GROUP) & " and activated."
WScript.Quit 0
