' =============================================================================
' sap_se37_change_attrs.vbs  -  SAP GUI Scripting: Change SE37 Function Module
'                                ATTRIBUTES (Short Text, Processing Type, ...)
'
' Generated by the sap-se37 skill.
' Attaches to an existing SAP GUI session, navigates to SE37, opens the
' function module in change mode (btnBUT4), selects the Attributes tab
' (tabpHEADER), updates the supplied fields, presses Save (Ctrl+S =
' wnd[0]/tbar[0]/btn[11]). Handles the optional original-language popup
' (only shown when logon language differs from MASTERLANG) and the
' optional post-save Workbench-request popup (per /sap-transport-request).
'
' Tokens replaced at run time:
'   %%FM_NAME%%          Function module name      e.g. "Z_HKFM_TEST007"
'   %%SHORT_TEXT%%       New short text. Empty = leave unchanged.
'   %%PROCESSING_TYPE%%  New processing type. Empty = leave unchanged.
'                          NORMAL   = Regular Function Module (radRS38L-NORMAL)
'                          REMOTE   = Remote-Enabled Module    (radRS38L-REMOTE)
'                          UPDATE   = Update Module            (radRS38L-VERBUCHER)
'   %%UPDATE_KIND%%      Sub-radio for Update Module. Empty when not UPDATE.
'                          UKIND1 = Start immediately
'                          UKIND2 = Start Delayed
'                          UKIND3 = Immediate start (not updateable)
'                          UKIND4 = Coll. run
'   %%TRANSPORT%%        TR for the post-save TR popup. Empty when local
'                        ($TMP) or already locked to a modifiable TR.
'
' Recorded baseline (Record_SE37_ChangeFMTitle.vbs):
'   /nse37 -> ctxtRS38L-NAME -> btnBUT4 (Change)
'   tabsFUNC_TAB_STRIP/tabpHEADER  (Attributes tab)
'   .../ssubSCREEN_HEADER:SAPLSFUNCTION_BUILDER:3030/txtTFTIT-STEXT  (short text)
'   wnd[0]/tbar[0]/btn[11]  (Save = Ctrl+S)
' =============================================================================

Option Explicit

Const FM_NAME           = "%%FM_NAME%%"
Const NEW_SHORT_TEXT    = "%%SHORT_TEXT%%"
Const NEW_PROC_TYPE     = "%%PROCESSING_TYPE%%"
Const NEW_UPDATE_KIND   = "%%UPDATE_KIND%%"
Const SAP_TRANSPORT     = "%%TRANSPORT%%"
Const SESSION_PATH      = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER     = 0
Const VKEY_F11_SAVE  = 11
Const HDR_BASE       = "wnd[0]/usr/tabsFUNC_TAB_STRIP/tabpHEADER/ssubSCREEN_HEADER:SAPLSFUNCTION_BUILDER:3030"

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE37 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE37..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE37"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

' --- Lock the SAP session UI for the FM attribute change + save critical section ---
' Per Rule 7: LockSessionUI blocks user input races inside SAP. No OS-level
' foreground guard needed -- this flow only sets attribute fields via the
' Scripting API (no clipboard, no SendKeys). Released after save.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the FM attribute change + save critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Enter FM name and press Change (btnBUT4) -------------------------
On Error Resume Next
Dim oNameField
Set oNameField = oSession.findById("wnd[0]/usr/ctxtRS38L-NAME")
If Err.Number <> 0 Or oNameField Is Nothing Then
    WScript.Echo "ERROR: SE37 FM name field not found (wnd[0]/usr/ctxtRS38L-NAME)."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
oNameField.Text = UCase(FM_NAME)
Err.Clear

WScript.Echo "INFO: Opening function module in change mode: " & UCase(FM_NAME)
oSession.findById("wnd[0]/usr/btnBUT4").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 3a. Original-language popup (SAPLSETX, conditional) -----------------
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLang
    Set oMasterLang = Nothing
    Err.Clear
    Set oMasterLang = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 And Not (oMasterLang Is Nothing) Then
        Dim oMaintBtn
        Err.Clear
        Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
        If Err.Number = 0 And Not (oMaintBtn Is Nothing) Then
            WScript.Echo "INFO: Original-language popup (MASTERLANG=" & _
                         oMasterLang.Text & ") - pressing 'Maint. in orig. lang.'."
            oMaintBtn.press
            WScript.Sleep 1500
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 4. Select the Attributes tab and verify ----------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsFUNC_TAB_STRIP/tabpHEADER").select
WScript.Sleep 600
Err.Clear

Dim oShortText, bInAttr
bInAttr = False
Err.Clear
Set oShortText = oSession.findById(HDR_BASE & "/txtTFTIT-STEXT")
If Err.Number = 0 And Not (oShortText Is Nothing) Then bInAttr = True
Err.Clear
On Error GoTo 0

If Not bInAttr Then
    WScript.Echo "ERROR: Could not reach SE37 Attributes tab. Function module may " & _
                 "not exist, may be locked by another user, or may be display-only."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Echo "INFO: Attributes tab open."

' ------ 4a. Apply changes ---------------------------------------------------
Dim sChanges
sChanges = ""

If NEW_SHORT_TEXT <> "" Then
    On Error Resume Next
    oShortText.Text = NEW_SHORT_TEXT
    If Err.Number <> 0 Then
        WScript.Echo "ERROR: Could not set short text: " & Err.Description
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
    sChanges = sChanges & " short_text='" & NEW_SHORT_TEXT & "'"
End If

If NEW_PROC_TYPE <> "" Then
    Dim sRadioId
    Select Case UCase(NEW_PROC_TYPE)
        Case "NORMAL" : sRadioId = HDR_BASE & "/radRS38L-NORMAL"
        Case "REMOTE" : sRadioId = HDR_BASE & "/radRS38L-REMOTE"
        Case "UPDATE" : sRadioId = HDR_BASE & "/radRS38L-VERBUCHER"
        Case Else
            WScript.Echo "ERROR: Invalid PROCESSING_TYPE '" & NEW_PROC_TYPE & _
                         "'. Use NORMAL, REMOTE, or UPDATE."
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
    End Select

    On Error Resume Next
    Dim oRadio
    Set oRadio = oSession.findById(sRadioId)
    If Err.Number <> 0 Or oRadio Is Nothing Then
        WScript.Echo "ERROR: Processing type radio not found: " & sRadioId
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    ' SetFocus before .select to ensure the radio gets keyboard focus and the
    ' field-change event fires. Without SetFocus, on S/4HANA 1909 the radio
    ' visually flips in the UI but the underlying field-change event does
    ' NOT fire -- Ctrl+S then saves the FM with TFDIR.FMODE unchanged from
    ' its prior value (typically blank = Regular). Observed 2026-05-12:
    ' change_attrs reported "SUCCESS: Attributes updated" and sbar showed
    ' "Saved", but TFDIR.FMODE remained blank and the FM still rejected
    ' RFC calls with "cannot be used for 'remote' calls".
    ' Follow-up sendVKey 0 (Enter) on wnd[0] commits the radio change
    ' before the save fires.
    oRadio.SetFocus
    WScript.Sleep 200
    oRadio.select
    WScript.Sleep 200
    oSession.findById("wnd[0]").sendVKey 0
    WScript.Sleep 300
    Err.Clear
    On Error GoTo 0
    sChanges = sChanges & " processing_type=" & UCase(NEW_PROC_TYPE)

    If UCase(NEW_PROC_TYPE) = "UPDATE" And NEW_UPDATE_KIND <> "" Then
        Dim sUKindId
        Select Case UCase(NEW_UPDATE_KIND)
            Case "UKIND1" : sUKindId = HDR_BASE & "/radRS38L-UKIND1"
            Case "UKIND2" : sUKindId = HDR_BASE & "/radRS38L-UKIND2"
            Case "UKIND3" : sUKindId = HDR_BASE & "/radRS38L-UKIND3"
            Case "UKIND4" : sUKindId = HDR_BASE & "/radRS38L-UKIND4"
            Case Else
                WScript.Echo "ERROR: Invalid UPDATE_KIND '" & NEW_UPDATE_KIND & _
                             "'. Use UKIND1, UKIND2, UKIND3, or UKIND4."
                ReleaseSession oSession, wasLocked
                WScript.Quit 1
        End Select
        On Error Resume Next
        Dim oUKind
        Set oUKind = oSession.findById(sUKindId)
        If Err.Number = 0 And Not (oUKind Is Nothing) Then
            oUKind.select
            sChanges = sChanges & " update_kind=" & UCase(NEW_UPDATE_KIND)
        Else
            WScript.Echo "ERROR: Update-kind radio not found: " & sUKindId
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        Err.Clear
        On Error GoTo 0
    End If
End If

If sChanges = "" Then
    WScript.Echo "INFO: No attribute values supplied - nothing to change."
    WScript.Echo "INFO: Backing out without saving (F3)."
    On Error Resume Next
    oSession.findById("wnd[0]").sendVKey 3   ' F3 = Back
    WScript.Sleep 800
    ' Possible "Data was changed" prompt -> No (don't save)
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        On Error Resume Next
        oSession.findById("wnd[1]/usr/btnSPOP-OPTION2").press
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById("wnd[1]").sendVKey 12
        End If
        Err.Clear
    End If
    On Error GoTo 0
    WScript.Echo "DONE: NO_CHANGE"
    ReleaseSession oSession, wasLocked
    WScript.Quit 0
End If

WScript.Echo "INFO: Applying changes:" & sChanges

' ------ 5. Save (Ctrl+S = wnd[0]/tbar[0]/btn[11]) ---------------------------
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/btn[11]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 5a. Optional Workbench-request popup --------------------------------
On Error Resume Next
Dim iLoop
For iLoop = 1 To 3
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit For

    Dim oTrField
    Set oTrField = Nothing
    Err.Clear
    Set oTrField = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrField Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            On Error Resume Next
            oSession.findById("wnd[1]").sendVKey 12
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        oTrField.Text = SAP_TRANSPORT
        WScript.Echo "INFO: TR popup - entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        ' Detect Error popup (e.g. lock errors)
        Dim sTitle, oM1, oM2, sM1, sM2
        sTitle = oSession.ActiveWindow.Text
        sM1 = "" : sM2 = ""
        Err.Clear
        Set oM1 = oSession.findById("wnd[1]/usr/txtMESSTXT1")
        If Err.Number = 0 And Not (oM1 Is Nothing) Then sM1 = oM1.Text
        Err.Clear
        Set oM2 = oSession.findById("wnd[1]/usr/txtMESSTXT2")
        If Err.Number = 0 And Not (oM2 Is Nothing) Then sM2 = oM2.Text
        Err.Clear
        ' Fatal-popup classifier -- documented Rule-6 exception: the generic
        ' message popup (txtMESSTXT1..4 + OK) exposes no locale-stable
        ' control ID / MessageType / icon to branch on, so match the error
        ' title / lock wording across the product's declared logon languages
        ' (EN + ChrW-built JA/ZH, best-effort translations; source stays
        ' ASCII), same pattern as sap_atc_check_run_status.vbs.
        Dim sTtlLow : sTtlLow = LCase(sTitle)
        Dim sPopLow : sPopLow = LCase(sM1 & " " & sM2)
        Dim JA_LOCKED : JA_LOCKED = ChrW(&H30ED) & ChrW(&H30C3) & ChrW(&H30AF) ' rokku   = lock
        Dim ZH_LOCKED : ZH_LOCKED = ChrW(&H9501) & ChrW(&H5B9A)                ' suoding = locked
        Dim JA_ERRTTL : JA_ERRTTL = ChrW(&H30A8) & ChrW(&H30E9) & ChrW(&H30FC) ' eraa    = error
        Dim ZH_ERRTTL : ZH_ERRTTL = ChrW(&H9519) & ChrW(&H8BEF)                ' cuowu   = error
        Dim bFatalPopup : bFatalPopup = False
        If sTtlLow = "error" Or sTtlLow = JA_ERRTTL Or sTtlLow = ZH_ERRTTL Then bFatalPopup = True
        If InStr(sPopLow, "lock") > 0 Or InStr(sPopLow, JA_LOCKED) > 0 Or _
           InStr(sPopLow, ZH_LOCKED) > 0 Then bFatalPopup = True
        If bFatalPopup Then
            WScript.Echo "ERROR: SAP popup [" & sTitle & "] " & Trim(sM1 & " " & sM2)
            On Error Resume Next
            oSession.findById("wnd[1]/tbar[0]/btn[12]").press
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById("wnd[1]").sendVKey 12
            End If
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Confirming popup [" & sTitle & "] - pressing Enter."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
Next
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; status bar read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 6. Read status bar --------------------------------------------------
Dim sBarText, sBarType
sBarText = "" : sBarType = ""
On Error Resume Next
sBarText = oSession.findById("wnd[0]/sbar").Text
sBarType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Status bar [" & sBarType & "]: " & sBarText
If LCase(sBarType) = "e" Or LCase(sBarType) = "a" Then
    WScript.Echo "ERROR: Save failed - " & sBarText
    WScript.Quit 1
End If

' ------ 7. Activate when PROCESSING_TYPE was changed -----------------------
' Save alone does NOT flush TFDIR.FMODE on S/4HANA 1909 -- the new processing
' type is held in the inactive workspace until activation, and remote-RFC
' callers still see the OLD FMODE value via RPY_FUNCTIONMODULE_READ_NEW /
' direct TFDIR query. Without Activate, the change_attrs flow reports
' "SUCCESS: Saved" but the FM is functionally unchanged (the canonical
' symptom: external RFC calls still fail with "Function module X cannot be
' used for 'remote' calls" despite the SE37 Attributes tab radio showing
' Remote-Enabled). Observed + fixed 2026-05-12.
' SHORT_TEXT-only or UPDATE_KIND-only changes also persist via activation
' for safety, so we run Activate unconditionally whenever any attribute
' was changed. Activation is idempotent on a clean FM.
If sChanges <> "" Then
    WScript.Echo "INFO: Activating to flush attribute change to TFDIR..."
    On Error Resume Next
    oSession.findById("wnd[0]/tbar[1]/btn[27]").press   ' Ctrl+F3 Activate
    WScript.Sleep 3000
    Err.Clear
    ' Dismiss inactive-objects worklist if it appears. Continue (btn[0]) ONLY:
    ' the popup is pre-filtered and the triggering FM (plus its function-group
    ' includes) is pre-selected, so Continue activates exactly them. Do NOT
    ' send sendVKey 26 (Ctrl+A = Select All): on a shared DEV the worklist
    ' also lists other developers' unrelated inactive objects (EC2/DEV102:
    ' 500+) and Select All would co-activate every one. Matches the proven
    ' Continue-only model in sap_se37_update.vbs; never re-add Select All.
    Dim iActPop
    For iActPop = 1 To 5
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit For
        WScript.Echo "INFO:   Activate popup wnd[1]: " & oSession.ActiveWindow.Text
        Err.Clear
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById("wnd[1]").sendVKey 0  ' fallback Enter
        End If
        WScript.Sleep 1500
        Err.Clear
    Next
    On Error GoTo 0

    Dim sActText, sActType
    sActText = "" : sActType = ""
    On Error Resume Next
    sActText = oSession.findById("wnd[0]/sbar").Text
    sActType = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear
    On Error GoTo 0
    WScript.Echo "INFO: Activate status [" & sActType & "]: " & sActText
    If LCase(sActType) = "e" Or LCase(sActType) = "a" Then
        WScript.Echo "ERROR: Activation failed - " & sActText
        WScript.Echo "       Saved attributes will not reach TFDIR until activation succeeds."
        WScript.Quit 1
    End If
End If

' ------ 7. Back to /n -------------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Attributes updated for " & UCase(FM_NAME) & "."
WScript.Quit 0
