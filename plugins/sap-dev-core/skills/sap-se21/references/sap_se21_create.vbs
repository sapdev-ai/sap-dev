' =============================================================================
' sap_se21_create.vbs  -  SAP GUI Scripting: Create SAP package via SE21
'
' Generated by the sap-se21 skill.
' Attaches to an existing SAP GUI session, navigates to SE21, creates a new
' development package, fills in description, and assigns the transport request
' supplied by the caller (already resolved via /sap-transport-request).
'
' Tokens replaced at run time:
'   %%PACKAGE%%       Package name              e.g. "ZHKPKG00004"
'   %%DESCRIPTION%%   Short description         e.g. "sap-dev test package"
'   %%TRANSPORT%%     Modifiable TR number      e.g. "S4DK941110"
'                     (resolved by /sap-transport-request - never blank for
'                     transportable Z*/Y* packages)
'
' Component IDs verified on SAP GUI 7.60 / S/4HANA 1909.
' Recording reference: C:\Temp\Record_SE21_CreateNewPackage.vbs
' If a step fails, use SAP Logon > Help > Scripting Recorder to re-record.
' =============================================================================

Option Explicit

Const PKG_NAME    = "%%PACKAGE%%"
Const PKG_DESC    = "%%DESCRIPTION%%"
Const PKG_TR      = "%%TRANSPORT%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER  = 0
Const VKEY_SAVE   = 11
Const VKEY_BACK   = 3

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE21 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE21..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE21"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1500

If oSession.Info.Program <> "SAPLPB_ENTRY" Then
    WScript.Echo "ERROR: Did not reach SE21 initial screen. Got PROG=" & _
                 oSession.Info.Program & " DYNPRO=" & oSession.Info.ScreenNumber
    WScript.Quit 1
End If

' --- Lock the SAP session UI for the package create + TR popup critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the package create + TR popup critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Enter package name and press Create ------------------------------
WScript.Echo "INFO: Entering package name " & PKG_NAME & "..."
On Error Resume Next
oSession.findById("wnd[0]/usr/radPBENSCREEN-CHECKPACK").Select
Err.Clear
oSession.findById("wnd[0]/usr/ctxtPBENSCREEN-PACKNAME").Text = PKG_NAME
On Error GoTo 0

oSession.findById("wnd[0]/usr/btnCREATE").Press
WScript.Sleep 2000

' If the package already exists, SAP shows a status message and stays on the
' initial screen.
If oSession.Info.Program = "SAPLPB_ENTRY" Then
    Dim sbarType, sbarText
    sbarType = oSession.findById("wnd[0]/sbar").MessageType
    sbarText = oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "ERROR: Stayed on initial screen. sbar(" & sbarType & ")=" & sbarText
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ 4. Fill description popup (wnd[1]) and Save -------------------------
On Error Resume Next
Dim oDescField
Set oDescField = oSession.findById("wnd[1]/usr/txtSCOMPKDTLN-CTEXT")
If Err.Number <> 0 Or oDescField Is Nothing Then
    WScript.Echo "ERROR: Description popup field SCOMPKDTLN-CTEXT not found at wnd[1]."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
On Error GoTo 0

WScript.Echo "INFO: Filling description..."
oDescField.Text = PKG_DESC
WScript.Sleep 200
oSession.findById("wnd[1]/tbar[0]/btn[0]").Press   ' Continue (Enter) - the only confirm button on this popup
WScript.Sleep 1500

' ------ 5. Handle transport-request popup (wnd[1] with KO008-TRKORR) --------
' On this build, after Save the description popup closes and a TR-prompt
' popup appears at wnd[1] containing ctxtKO008-TRKORR.
On Error Resume Next
Dim oTrField, trWnd, i
trWnd = -1
For i = 1 To 2
    Set oTrField = Nothing
    Set oTrField = oSession.findById("wnd[" & i & "]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrField Is Nothing) Then
        trWnd = i
        Exit For
    End If
    Err.Clear
Next
On Error GoTo 0

If trWnd < 0 Then
    WScript.Echo "WARN: TR-prompt popup not detected. Package may have been saved as local."
Else
    If PKG_TR = "" Then
        WScript.Echo "ERROR: TR popup appeared but no TRANSPORT was supplied. " & _
                     "Caller must resolve TR via /sap-transport-request first."
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    WScript.Echo "INFO: Assigning TR " & PKG_TR & " (popup at wnd[" & trWnd & "])..."
    oSession.findById("wnd[" & trWnd & "]/usr/ctxtKO008-TRKORR").Text = PKG_TR
    oSession.findById("wnd[" & trWnd & "]/tbar[0]/btn[0]").Press   ' Continue
    WScript.Sleep 1500

    ' --- Drain any follow-up popups (e.g. "Create Task" / sub-task confirmation) ---
    ' On freshly-created TRs, SAP shows a Create-Task popup right after the
    ' TR-assignment popup, asking whether to create a sub-task under the
    ' current user. The default action is "Yes" -> press Enter (btn[0] /
    ' VKEY 0). If we don't accept it here, session_lock's pre-unlock
    ' F12-sweep will cancel it, leaving the package linked to the TR
    ' header but without the task -- which fails downstream object
    ' registration on this build. Drain up to 3 chained popups; each
    ' Enter accepts whatever default SAP proposes.
    Dim iDrain, sDrainId
    On Error Resume Next
    For iDrain = 1 To 3
        sDrainId = oSession.ActiveWindow.Id
        If Err.Number <> 0 Then
            Err.Clear
            Exit For
        End If
        If Right(sDrainId, 6) = "wnd[0]" Then Exit For
        WScript.Echo "INFO: Post-TR popup " & iDrain & " at " & sDrainId & " -- pressing Enter (accept default)."
        oSession.ActiveWindow.sendVKey 0   ' Enter / Continue / Yes
        If Err.Number <> 0 Then Err.Clear
        WScript.Sleep 1000
    Next
    On Error GoTo 0
End If

' --- Release the session UI lock; result read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 6. Verify final state ----------------------------------------------
Dim finalProg, finalSbarType, finalSbarText
finalProg     = oSession.Info.Program
finalSbarType = oSession.findById("wnd[0]/sbar").MessageType
finalSbarText = oSession.findById("wnd[0]/sbar").Text

WScript.Echo "INFO: FinalScreen=" & finalProg & "/" & oSession.Info.ScreenNumber
WScript.Echo "INFO: sbar(" & finalSbarType & ")=" & finalSbarText

If finalSbarType = "E" Or finalSbarType = "A" Then
    WScript.Echo "ERROR: Package creation failed."
    WScript.Quit 1
End If

If finalProg <> "SAPLPB_PACKAGE" Then
    WScript.Echo "WARN: Did not land on SAPLPB_PACKAGE/Change Package screen. " & _
                 "Verify manually via SE16N on TDEVC."
End If

' ------ 7. Back out to SAP Easy Access --------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

WScript.Echo "RESULT: PACKAGE_CREATED: " & PKG_NAME
