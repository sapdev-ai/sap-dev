' =============================================================================
' sap_se16n.vbs  -  SAP GUI Scripting: Query a table via SE16N and download as TSV
'
' Generated by the sap-se16n skill.
'
' Flow:
'   1. Attach to existing SAP GUI session
'   2. Open SE16N, enter table name
'   3. Read PARAMS_FILE (tab-delimited spec — see below)
'   4. For each FILTER row: locate the field by FIELDNAME (loop the field
'      selection table control, scrolling as needed) and set value(s).
'      Single value -> ctxtGS_SELFIELDS-LOW
'      Multiple values -> btnPUSH (multi-select popup) + GS_MULTI_SELECT-LOW
'   5. For each SELECT row: ensure that field's MARK (output) checkbox is on,
'      and uncheck all unlisted fields. If no SELECT rows are given, leave the
'      default (all marks on).
'   6. Press F8 (tbar[1]/btn[8]) to execute
'   7. Detect "No values found" status / popup. If empty -> write OUTPUT_FILE
'      with header line "NO_DATA" and quit. Else -> ALV menu "&MB_EXPORT" /
'      "&PC", pick "Spreadsheet" radio (tab-delimited text), save to OUTPUT_FILE.
'   8. Echo "ROWS=<n>" or "ROWS=0 (NO_DATA)" on the last line.
'
' Tokens replaced at run time:
'   %%TABLE_NAME%%   target table, e.g. "T001"
'   %%PARAMS_FILE%%  path to a tab-delimited file with this format:
'                       SELECT
'                       LAND1
'                       WAERS
'                       FILTER
'                       LAND1<TAB>IN<TAB>CN<TAB>JP
'                       WAERS<TAB>EQ<TAB>CNY
'                    Sections are introduced by the literal lines "SELECT" and
'                    "FILTER". Either section may be empty or omitted.
'                    Operators (column 2 of FILTER rows): EQ, NE, GT, LT, GE,
'                    LE, BT (between LOW..HIGH), NB (not between), CP (pattern),
'                    NP (not pattern), IN (multi-value).
'   %%OUTPUT_FILE%%  absolute path of the resulting tab-delimited file, e.g.
'                    "C:\sap_dev_work\temp\se16n_T001.txt"
'
' Component IDs recorded from SAP GUI on S/4HANA. Selection-criteria table
' control = tblSAPLSE16NSELFIELDS_TC. Visible columns:
'   col 0  txtGS_SELFIELDS-SCRTEXT_M    Fld name
'   col 1  btnOPTION                    Operator icon
'   col 2  ctxtGS_SELFIELDS-LOW         Fr.Value
'   col 3  ctxtGS_SELFIELDS-HIGH        To value
'   col 4  btnPUSH                      Multi-select icon
'   col 5  chkGS_SELFIELDS-MARK         Output checkbox
'   col 6  txtGS_SELFIELDS-FIELDNAME    Technical name
' =============================================================================

Option Explicit

Const TABLE_NAME  = "%%TABLE_NAME%%"
Const PARAMS_FILE = "%%PARAMS_FILE%%"
Const OUTPUT_FILE = "%%OUTPUT_FILE%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER  = 0
Const VKEY_F4     = 4
Const VKEY_F8     = 8

Const TC_PATH     = "wnd[0]/usr/tblSAPLSE16NSELFIELDS_TC"
Const COL_SCRTEXT = 0
Const COL_LOW     = 2
Const COL_HIGH    = 3
Const COL_BTNPUSH = 4
Const COL_MARK    = 5
Const COL_FIELD   = 6

' Include shared attach helper. Provides AttachSapSession(sHint) which
' resolves the target session by explicit hint -> SAPDEV_SESSION_PATH
' env var -> first-session-of-first-connection legacy default. Handles
' all error paths internally (WScript.Echo + Quit).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

Dim oSession
Dim oFSO, oTS, sLine
Dim sMode, i, j

' Filter / select storage
Dim aFilters() : ReDim aFilters(100, 99)   ' (rowIdx, 0=field 1=op 2..N=values)
Dim nFilters : nFilters = 0
Dim aSelectFields() : ReDim aSelectFields(200)
Dim nSelect : nSelect = 0
Dim aFilterValueCount() : ReDim aFilterValueCount(100)

' ----------------------------------------------------------------------------
' 1. Attach to SAP GUI session (via shared attach helper)
' ----------------------------------------------------------------------------
Set oSession = AttachSapSession(SESSION_PATH)

' ----------------------------------------------------------------------------
' 2. Read PARAMS_FILE
' ----------------------------------------------------------------------------
Set oFSO = CreateObject("Scripting.FileSystemObject")
If Not oFSO.FileExists(PARAMS_FILE) Then
    WScript.Echo "ERROR: Params file not found: " & PARAMS_FILE
    WScript.Quit 1
End If

Set oTS = oFSO.OpenTextFile(PARAMS_FILE, 1, False, -2)   ' system default codepage
sMode = ""
Do While Not oTS.AtEndOfStream
    sLine = oTS.ReadLine
    If Len(Trim(sLine)) = 0 Then
        ' skip blanks
    ElseIf UCase(Trim(sLine)) = "SELECT" Then
        sMode = "SELECT"
    ElseIf UCase(Trim(sLine)) = "FILTER" Then
        sMode = "FILTER"
    ElseIf sMode = "SELECT" Then
        aSelectFields(nSelect) = UCase(Trim(sLine))
        nSelect = nSelect + 1
    ElseIf sMode = "FILTER" Then
        Dim parts : parts = Split(sLine, vbTab)
        ' Need at least field + op. Value column may be empty (e.g. "STRKORR EQ ''")
        ' which is treated as a deliberate empty-string filter — useful for finding
        ' rows where a field is blank.
        If UBound(parts) >= 1 Then
            aFilters(nFilters, 0) = UCase(Trim(parts(0)))   ' field
            aFilters(nFilters, 1) = UCase(Trim(parts(1)))   ' op
            Dim k, vCount : vCount = 0
            For k = 2 To UBound(parts)
                ' Preserve trailing empty values too (don't trim away "EQ ''")
                aFilters(nFilters, 2 + vCount) = parts(k)
                vCount = vCount + 1
            Next
            ' If no value columns at all, record one empty-string value so the
            ' single-value path below sets the LOW field to "".
            If vCount = 0 Then
                aFilters(nFilters, 2) = ""
                vCount = 1
            End If
            aFilterValueCount(nFilters) = vCount
            nFilters = nFilters + 1
        End If
    End If
Loop
oTS.Close
WScript.Echo "INFO: Loaded " & nFilters & " filter(s), " & nSelect & " select field(s)."

' ----------------------------------------------------------------------------
' 3. Open SE16N + enter table name
' ----------------------------------------------------------------------------
oSession.findById("wnd[0]").maximize

' Dismiss any leftover modal popups (e.g. "Log Off?", "Data will be lost") so
' the session is at a known state before issuing /nse16n.
DismissModals

oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nse16n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 800

oSession.findById("wnd[0]/usr/ctxtGD-TAB").text = UCase(TABLE_NAME)
oSession.findById("wnd[0]/usr/ctxtGD-TAB").setFocus
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1200

' ----------------------------------------------------------------------------
' 4. Apply FILTERs
' ----------------------------------------------------------------------------
Dim f, vRow, value, idx
For f = 0 To nFilters - 1
    Dim fldName, op, valCount
    fldName = aFilters(f, 0)
    op      = aFilters(f, 1)
    valCount = aFilterValueCount(f)

    vRow = FindRowByFieldName(fldName)
    If vRow < 0 Then
        WScript.Echo "ERROR: Field " & fldName & " not found in table " & TABLE_NAME
        WScript.Quit 1
    End If
    WScript.Echo "INFO: Filter " & fldName & " " & op & " (" & valCount & " value(s)) at row " & vRow

    ' Skip non-editable fields (e.g. AS4TEXT on E070, long-text fields on many
    ' tables). SE16N renders these rows greyed-out: the LOW cell, the operator
    ' button, and the multi-select button all report Changeable=False.
    ' Continue with the remaining filters so the query can still run; mark the
    ' field as an output column so the user can post-filter the result file.
    If Not IsRowEditable(vRow) Then
        WScript.Echo "WARN: Field " & fldName & " is not editable in SE16N for table " & _
            TABLE_NAME & " (greyed-out row). Skipping this filter — apply it as a " & _
            "post-filter on the output file."
        EnsureSelectField fldName
    Else

    If (op = "BT" Or op = "NB") And valCount = 2 Then
        ' Range filter set inline on the criteria row: LOW (col 2) + HIGH (col 3)
        ' SE16N implicitly switches the operator to BT when both LOW and HIGH are
        ' filled. For NB the caller must pre-flip via the operator picker (not yet
        ' supported here); falling back to BT semantics is the safe behaviour.
        oSession.findById(TC_PATH & "/ctxtGS_SELFIELDS-LOW[" & COL_LOW & "," & vRow & "]").text = aFilters(f, 2)
        oSession.findById(TC_PATH & "/ctxtGS_SELFIELDS-HIGH[" & COL_HIGH & "," & vRow & "]").text = aFilters(f, 3)
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
        WScript.Sleep 200
    ElseIf op = "IN" Or valCount > 1 Then
        ' Multi-select via btnPUSH
        oSession.findById(TC_PATH & "/btnPUSH[" & COL_BTNPUSH & "," & vRow & "]").press
        WScript.Sleep 1200
        ' Fill multi-select popup. The popup is tabbed (Single Vals / Ranges /
        ' Exclude Single / Exclude Ranges). For IN/multi-value EQ we use the
        ' default Single Values tab which exposes the same tblSAPLSE16NMULTI_TC
        ' table control with LOW (col 1) and HIGH (col 2) cells.
        For j = 0 To valCount - 1
            value = aFilters(f, 2 + j)
            On Error Resume Next
            ' Scroll the multi popup if needed
            If j >= 8 Then
                oSession.findById("wnd[1]/usr/tblSAPLSE16NMULTI_TC").verticalScrollbar.position = j - 7
            End If
            Dim popupRow : popupRow = j
            If j >= 8 Then popupRow = 7
            oSession.findById("wnd[1]/usr/tblSAPLSE16NMULTI_TC/ctxtGS_MULTI_SELECT-LOW[1," & popupRow & "]").text = value
            Err.Clear
            On Error GoTo 0
        Next
        ' Validate entered values first (Enter in the popup toolbar)
        On Error Resume Next
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 400
        ' Apply (Copy) - try btn[8] (Copy / Execute), fall back to F8 then Enter
        On Error Resume Next
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById("wnd[1]").sendVKey 8
        End If
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById("wnd[1]").sendVKey 0
        End If
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 700
    Else
        ' Single value. Domain-typed fields render LOW as ctxtGS_SELFIELDS-LOW
        ' (GuiCTextField); plain text fields (e.g. AS4TEXT, STEXT) render as
        ' txtGS_SELFIELDS-LOW (GuiTextField); some short fields render as
        ' cmbGS_SELFIELDS-LOW (GuiComboBox). Try all known prefixes; if all
        ' fail, scan the table-control children for any *GS_SELFIELDS-LOW[col,row]*
        ' match.
        If valCount >= 1 Then
            value = aFilters(f, 2)
            If Not SetLowCellRobust(vRow, value) Then
                WScript.Echo "ERROR: Field " & fldName & " at row " & vRow & " does not accept filter input " & _
                    "(SAP rejects direct entry and provides no multi-select button). " & _
                    "This is a SE16N limitation for long-text / non-selectable fields. " & _
                    "Pick a different filter field."
                WScript.Quit 1
            End If
        End If
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
        WScript.Sleep 200
    End If
    End If   ' end editable-row guard
Next

' ----------------------------------------------------------------------------
' 5. Apply SELECT (output marks)
' ----------------------------------------------------------------------------
If nSelect > 0 Then
    ' Walk the entire field list. For each visible row, read FIELDNAME and set
    ' MARK on iff that field is in aSelectFields, else off.
    Dim tbl, maxScroll, pageSize, scrollPos, visibleRows, r, sName, isWanted
    Set tbl = oSession.findById(TC_PATH)
    ' verticalScrollbar can be missing on tables that fit on one page (e.g. a
    ' filter table with very few rows). Read with error trap and default
    ' to a single-page walk in that case.
    maxScroll = 0
    pageSize  = 0
    On Error Resume Next
    maxScroll = tbl.verticalScrollbar.maximum
    pageSize  = tbl.verticalScrollbar.pageSize
    Err.Clear
    On Error GoTo 0
    If pageSize <= 0 Then pageSize = 14   ' typical SE16N page
    scrollPos = 0
    Do
        On Error Resume Next
        tbl.verticalScrollbar.position = scrollPos
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 80
        For r = 0 To pageSize - 1
            On Error Resume Next
            sName = ""
            sName = oSession.findById(TC_PATH & "/txtGS_SELFIELDS-FIELDNAME[" & COL_FIELD & "," & r & "]").text
            If Err.Number = 0 And Len(Trim(sName)) > 0 Then
                isWanted = False
                For i = 0 To nSelect - 1
                    If UCase(Trim(sName)) = aSelectFields(i) Then isWanted = True : Exit For
                Next
                Err.Clear
                oSession.findById(TC_PATH & "/chkGS_SELFIELDS-MARK[" & COL_MARK & "," & r & "]").selected = isWanted
                Err.Clear
            End If
            On Error GoTo 0
        Next
        If scrollPos >= maxScroll Then Exit Do
        scrollPos = scrollPos + pageSize
        If scrollPos > maxScroll Then scrollPos = maxScroll
    Loop
End If

' ----------------------------------------------------------------------------
' 6. Execute (F8)
' ----------------------------------------------------------------------------
WScript.Echo "INFO: Executing SE16N query on " & TABLE_NAME
oSession.findById("wnd[0]/tbar[1]/btn[8]").press
WScript.Sleep 1500

' ----------------------------------------------------------------------------
' 7. Detect no-data vs result list
' ----------------------------------------------------------------------------
Dim sStatus, sStatusType, hasResult
hasResult = False

On Error Resume Next
sStatus = oSession.findById("wnd[0]/sbar").Text
If Err.Number <> 0 Then sStatus = "" : Err.Clear
sStatusType = oSession.findById("wnd[0]/sbar").MessageType
If Err.Number <> 0 Then sStatusType = "" : Err.Clear

' Check for the result ALV
Dim oResult : Set oResult = Nothing
Set oResult = oSession.findById("wnd[0]/usr/cntlRESULT_LIST/shellcont/shell")
If Err.Number = 0 And Not (oResult Is Nothing) Then hasResult = True
Err.Clear
On Error GoTo 0

If Not hasResult Then
    WScript.Echo "INFO: No result ALV. Status bar = [" & sStatusType & "] " & sStatus
    ' Write a marker file so caller can detect cleanly
    Dim oOut
    Set oOut = oFSO.CreateTextFile(OUTPUT_FILE, True, False)
    oOut.WriteLine "NO_DATA" & vbTab & sStatus
    oOut.Close
    WScript.Echo "ROWS=0 (NO_DATA)"
    WScript.Quit 0
End If

' ----------------------------------------------------------------------------
' 8. Export ALV -> Spreadsheet (tab-delimited text file)
' ----------------------------------------------------------------------------
Dim sPath, sFile, slashPos
slashPos = InStrRev(OUTPUT_FILE, "\")
If slashPos = 0 Then
    WScript.Echo "ERROR: OUTPUT_FILE must be an absolute Windows path: " & OUTPUT_FILE
    WScript.Quit 1
End If
sPath = Left(OUTPUT_FILE, slashPos)        ' includes trailing backslash
sFile = Mid(OUTPUT_FILE, slashPos + 1)

' Delete any pre-existing output so we know it came from this run
On Error Resume Next
If oFSO.FileExists(OUTPUT_FILE) Then oFSO.DeleteFile OUTPUT_FILE, True
Err.Clear
On Error GoTo 0

oResult.pressToolbarContextButton "&MB_EXPORT"
WScript.Sleep 400
oResult.selectContextMenuItem "&PC"
WScript.Sleep 800

' Format dialog (SAPLSPO5:0150). Each format is a radio at radSPOPLI-SELFLAG[col,0]
' where col is the format index. Walk 0..6, read each radio's .Text label, and pick
' the tab-delimited variant. Confirmed on S/4HANA 1909:
'   [0,0]=Unconverted  [1,0]=Text with Tabs  [2,0]=Rich text format
'   [3,0]=HTML Format  [4,0]=In the clipboard
WScript.Sleep 500
Dim radio, radioFound, labelText, basePath, colIdx
radioFound = False
Dim basePaths(1)
basePaths(0) = "wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150"
basePaths(1) = "wnd[1]/usr/sub:SAPLSPO5:0150"
Dim bp
For Each bp In basePaths
    For colIdx = 0 To 6
        On Error Resume Next
        Set radio = Nothing
        Set radio = oSession.findById(bp & "/radSPOPLI-SELFLAG[" & colIdx & ",0]")
        labelText = ""
        If Err.Number = 0 And Not (radio Is Nothing) Then labelText = radio.Text
        Err.Clear
        On Error GoTo 0
        If Len(labelText) > 0 Then
            ' Tab-delimited variants across releases / locales:
            '   "Text with Tabs"     S/4HANA 1909+
            '   "Spreadsheet"        ECC, older
            '   "Tabellenkalkulation"  DE
            ' Substring "Tab" matches "Text with Tabs" and "Tabellen..." both.
            ' For locales whose label contains neither "Tab" nor "preadsheet",
            ' the [1,0] fallback below catches the conventional position.
            If InStr(1, labelText, "Tab",   1) > 0 _
               Or InStr(1, labelText, "preadsheet", 1) > 0 Then
                radio.select
                radioFound = True
                WScript.Echo "INFO: Selected tab-delimited radio at [" & colIdx & ",0] (label=" & labelText & ")"
                Exit For
            End If
        End If
    Next
    If radioFound Then Exit For
Next
If Not radioFound Then
    ' Fallback: try the conventional [1,0] (Text with Tabs on most modern releases)
    On Error Resume Next
    oSession.findById("wnd[1]/usr/subSUBSCREEN_STEPLOOP:SAPLSPO5:0150/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]").select
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById("wnd[1]/usr/sub:SAPLSPO5:0150/radSPOPLI-SELFLAG[1,0]").select
    End If
    Err.Clear
    On Error GoTo 0
    WScript.Echo "WARN: Tab-delimited label not located; selected fallback index [1,0]."
End If
oSession.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 600

' File path / name dialog
oSession.findById("wnd[1]/usr/ctxtDY_PATH").text = sPath
oSession.findById("wnd[1]/usr/ctxtDY_FILENAME").text = sFile
oSession.findById("wnd[1]").sendVKey VKEY_ENTER
WScript.Sleep 1500

' Wait for the file to materialize (give SAP up to ~10 s)
Dim attempts : attempts = 0
Do While Not oFSO.FileExists(OUTPUT_FILE) And attempts < 20
    WScript.Sleep 500
    attempts = attempts + 1
Loop

If Not oFSO.FileExists(OUTPUT_FILE) Then
    WScript.Echo "ERROR: Output file was not created: " & OUTPUT_FILE
    WScript.Quit 1
End If

' Count rows (data rows = total lines - header - any decoration)
Dim oCnt, lineCount, rawLine
Set oCnt = oFSO.OpenTextFile(OUTPUT_FILE, 1, False, -2)
lineCount = 0
Do While Not oCnt.AtEndOfStream
    rawLine = oCnt.ReadLine
    If Len(Trim(rawLine)) > 0 Then lineCount = lineCount + 1
Loop
oCnt.Close

Dim dataRows
dataRows = lineCount - 1   ' subtract header
If dataRows < 0 Then dataRows = 0

WScript.Echo "INFO: Output written to " & OUTPUT_FILE & " (" & lineCount & " non-empty lines)"
WScript.Echo "ROWS=" & dataRows
WScript.Quit 0

' =============================================================================
' Helper: locate a row in tblSAPLSE16NSELFIELDS_TC by its FIELDNAME (col 6).
' Scrolls through the table control. Returns the visible row index after
' scrolling the row into view (so caller can address LOW/HIGH/btnPUSH cells
' on that visible row), or -1 if not found.
' =============================================================================
Function FindRowByFieldName(byval target)
    Dim tbl, maxScroll, pageSize, scrollPos, r, sName
    Set tbl = oSession.findById(TC_PATH)
    ' verticalScrollbar can be missing on tables that fit on one page (e.g. a
    ' filter table with very few rows). Read with error trap and default
    ' to a single-page walk in that case.
    maxScroll = 0
    pageSize  = 0
    On Error Resume Next
    maxScroll = tbl.verticalScrollbar.maximum
    pageSize  = tbl.verticalScrollbar.pageSize
    Err.Clear
    On Error GoTo 0
    If pageSize <= 0 Then pageSize = 14
    target = UCase(Trim(target))
    scrollPos = 0
    Do
        On Error Resume Next
        tbl.verticalScrollbar.position = scrollPos
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 60
        For r = 0 To pageSize - 1
            On Error Resume Next
            sName = ""
            sName = oSession.findById(TC_PATH & "/txtGS_SELFIELDS-FIELDNAME[" & COL_FIELD & "," & r & "]").text
            If Err.Number = 0 And UCase(Trim(sName)) = target Then
                Err.Clear
                On Error GoTo 0
                FindRowByFieldName = r
                Exit Function
            End If
            Err.Clear
            On Error GoTo 0
        Next
        If scrollPos >= maxScroll Then Exit Do
        scrollPos = scrollPos + pageSize
        If scrollPos > maxScroll Then scrollPos = maxScroll
    Loop
    FindRowByFieldName = -1
End Function

' =============================================================================
' Helper: dismiss any leftover modal popups (wnd[1], wnd[2], ...).
' Strategy:
'   1. If a SPOP-OPTION2 ("No"/"Cancel") button exists, press it.
'   2. Else send F12 (cancel) to that window.
'   3. Repeat up to a few times in case popups stack.
' =============================================================================
Sub DismissModals
    Dim attempt, idx, oWnd, oCancelBtn
    For attempt = 1 To 5
        Dim anyDismissed : anyDismissed = False
        For idx = 5 To 1 Step -1   ' close inner popups first
            On Error Resume Next
            Set oWnd = Nothing
            Set oWnd = oSession.findById("wnd[" & idx & "]")
            If Err.Number = 0 And Not (oWnd Is Nothing) Then
                Err.Clear
                Set oCancelBtn = Nothing
                Set oCancelBtn = oSession.findById("wnd[" & idx & "]/usr/btnSPOP-OPTION2")
                If Err.Number = 0 And Not (oCancelBtn Is Nothing) Then
                    Err.Clear
                    oCancelBtn.press
                Else
                    Err.Clear
                    oWnd.sendVKey 12   ' F12 = Cancel
                End If
                anyDismissed = True
                WScript.Sleep 300
            End If
            Err.Clear
            On Error GoTo 0
        Next
        If Not anyDismissed Then Exit Sub
    Next
End Sub

' =============================================================================
' Helper: set the LOW cell on a criteria row, robust to control-type variation
' (GuiCTextField / GuiTextField / GuiComboBox). On failure, falls back to the
' btnPUSH multi-select popup (some fields, e.g. AS4TEXT on E070, reject direct
' LOW input with Err 613 even though the cell exists and has MaxLength > 0).
' Returns True on success, False on failure.
' =============================================================================
Function SetLowCellRobust(byval vRow, byval value)
    Dim prefixes, p, ok, child, wantedSuffix
    prefixes = Array("ctxt", "txt", "cmb")
    ok = False
    For Each p In prefixes
        On Error Resume Next
        oSession.findById(TC_PATH & "/" & p & "GS_SELFIELDS-LOW[" & COL_LOW & "," & vRow & "]").text = value
        If Err.Number = 0 Then
            ok = True
            Err.Clear
            On Error GoTo 0
            Exit For
        End If
        Err.Clear
        On Error GoTo 0
    Next

    If Not ok Then
        ' Enumerate table-control children for any matching ID suffix.
        wantedSuffix = "GS_SELFIELDS-LOW[" & COL_LOW & "," & vRow & "]"
        On Error Resume Next
        For Each child In oSession.findById(TC_PATH).Children
            If Right(child.Id, Len(wantedSuffix)) = wantedSuffix Then
                child.text = value
                If Err.Number = 0 Then
                    ok = True
                    Exit For
                End If
                Err.Clear
            End If
        Next
        On Error GoTo 0
    End If

    If Not ok Then
        ' Final fallback: route via btnPUSH multi-select popup (works for fields
        ' where SAP disables direct LOW entry, e.g. AS4TEXT on E070).
        On Error Resume Next
        oSession.findById(TC_PATH & "/btnPUSH[" & COL_BTNPUSH & "," & vRow & "]").press
        WScript.Sleep 1000
        If Err.Number = 0 Then
            Err.Clear
            oSession.findById("wnd[1]/usr/tblSAPLSE16NMULTI_TC/ctxtGS_MULTI_SELECT-LOW[1,0]").text = value
            If Err.Number = 0 Then
                Err.Clear
                ' Validate (Enter), then Copy (F8 / btn[8])
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 300
                Err.Clear
                oSession.findById("wnd[1]/tbar[0]/btn[8]").press
                WScript.Sleep 500
                If Err.Number = 0 Then ok = True
            End If
        End If
        Err.Clear
        On Error GoTo 0
    End If

    SetLowCellRobust = ok
End Function

' =============================================================================
' Helper: detect whether a criteria row is editable. Non-editable rows (e.g.
' AS4TEXT on E070, long-text fields on many tables) render greyed-out: the
' LOW cell, the operator button, and the multi-select button all report
' Changeable=False. We treat the row as editable if at least one of those
' controls is Changeable=True.
' =============================================================================
Function IsRowEditable(byval vRow)
    Dim editable, ids, i, oCtrl
    editable = False
    ids = Array( _
        TC_PATH & "/ctxtGS_SELFIELDS-LOW[" & COL_LOW & "," & vRow & "]", _
        TC_PATH & "/txtGS_SELFIELDS-LOW[" & COL_LOW & "," & vRow & "]", _
        TC_PATH & "/cmbGS_SELFIELDS-LOW[" & COL_LOW & "," & vRow & "]", _
        TC_PATH & "/btnPUSH[" & COL_BTNPUSH & "," & vRow & "]", _
        TC_PATH & "/btnOPTION[1," & vRow & "]" _
    )
    For i = 0 To UBound(ids)
        On Error Resume Next
        Set oCtrl = Nothing
        Set oCtrl = oSession.findById(ids(i))
        If Err.Number = 0 And Not (oCtrl Is Nothing) Then
            Err.Clear
            If oCtrl.Changeable Then
                editable = True
                Exit For
            End If
        End If
        Err.Clear
        On Error GoTo 0
    Next
    IsRowEditable = editable
End Function

' =============================================================================
' Helper: ensure a field name appears in aSelectFields. Used when a non-editable
' filter is skipped — we add the field to the SELECT list so the user can
' post-filter the output file.
' =============================================================================
Sub EnsureSelectField(byval fldName)
    Dim i, upper
    upper = UCase(Trim(fldName))
    For i = 0 To nSelect - 1
        If aSelectFields(i) = upper Then Exit Sub
    Next
    aSelectFields(nSelect) = upper
    nSelect = nSelect + 1
End Sub


