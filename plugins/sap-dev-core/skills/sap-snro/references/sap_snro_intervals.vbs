' =============================================================================
' sap_snro_intervals.vbs  -  SAP GUI Scripting: Maintain number range intervals
'
' Generated by the sap-snro skill.
' Attaches to an existing SAP GUI session, navigates to SNRO, opens the NRO,
' presses the "Number Ranges" button (btnINTV) which transitions into the
' SNUM intervals editor, then for each line in the intervals file:
'   - Presses Insert (btnINS / btn[6])
'   - Fills NR / FROMNUMBER / TONUMBER / EXT
'   - Presses Enter
' Finally saves (F11) and exits. Intervals (NRIV) are client-dependent and
' not transportable; SAP normally does not raise a TR popup here, but a
' customising-change popup may appear and is dismissed with Enter.
'
' Tokens replaced at run time:
'   %%NRO_NAME%%        NRO name (UPPERCASE)            e.g. "ZMM_0004"
'   %%INTERVALS_FILE%%  Tab-separated file              e.g. "{WORK_TEMP}\ZMM_0004_intervals.txt"
'
' Intervals file format (tab-separated, one interval per line):
'   <NR>\t<FROMNUMBER>\t<TONUMBER>\t<EXT>
'   01	0000000001	0099999999	
'   02	0100000000	0199999999	X
' EXT = "X" for external numbering, blank for internal (default).
' =============================================================================

Option Explicit

Const NRO_NAME       = "%%NRO_NAME%%"
Const INTERVALS_FILE = "%%INTERVALS_FILE%%"
Const SESSION_PATH   = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F5_INS   = 5
Const VKEY_F11_SAVE = 11
Const VKEY_F3_BACK  = 3

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach (via shared attach helper) -------------------------------
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Read intervals file ---------------------------------------------
Dim oFSO, oFile, sAll
Set oFSO = CreateObject("Scripting.FileSystemObject")
If Not oFSO.FileExists(INTERVALS_FILE) Then
    WScript.Echo "ERROR: Intervals file not found: " & INTERVALS_FILE
    WScript.Quit 1
End If

Set oFile = oFSO.OpenTextFile(INTERVALS_FILE, 1, False, -2)   ' -2 = system default; tries Unicode if BOM
sAll = ""
If Not oFile.AtEndOfStream Then sAll = oFile.ReadAll
oFile.Close

' Strip UTF-8 BOM if any
If Len(sAll) >= 3 Then
    If Asc(Mid(sAll,1,1)) = 239 And Asc(Mid(sAll,2,1)) = 187 And Asc(Mid(sAll,3,1)) = 191 Then
        sAll = Mid(sAll, 4)
    End If
End If
sAll = Replace(sAll, vbCrLf, vbLf)
sAll = Replace(sAll, vbCr,   vbLf)

Dim arrLines, iL, sLine, arrFields
Dim arrNR(), arrFrom(), arrTo(), arrExt()
Dim iCnt
iCnt = 0
arrLines = Split(sAll, vbLf)
For iL = 0 To UBound(arrLines)
    sLine = arrLines(iL)
    If Len(Trim(sLine)) > 0 Then
        arrFields = Split(sLine, vbTab)
        If UBound(arrFields) >= 2 Then
            ReDim Preserve arrNR(iCnt)
            ReDim Preserve arrFrom(iCnt)
            ReDim Preserve arrTo(iCnt)
            ReDim Preserve arrExt(iCnt)
            arrNR(iCnt)   = Trim(arrFields(0))
            arrFrom(iCnt) = Trim(arrFields(1))
            arrTo(iCnt)   = Trim(arrFields(2))
            If UBound(arrFields) >= 3 Then
                arrExt(iCnt) = Trim(arrFields(3))
            Else
                arrExt(iCnt) = ""
            End If
            iCnt = iCnt + 1
        End If
    End If
Next

WScript.Echo "INFO: Read " & iCnt & " interval(s) from file."
If iCnt = 0 Then
    WScript.Echo "ERROR: No valid interval rows in file."
    WScript.Quit 1
End If

' ------ 3. Navigate to SNRO ----------------------------------------------
WScript.Echo "INFO: Navigating to SNRO..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSNRO"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 4. Open NRO and click Number Ranges (btnINTV) -------------------
WScript.Echo "INFO: Opening NRO " & UCase(NRO_NAME) & " and pressing Number Ranges..."
oSession.findById("wnd[0]/usr/ctxtNRIV-OBJECT").Text = UCase(NRO_NAME)
WScript.Sleep 200

On Error Resume Next
oSession.findById("wnd[0]/usr/btnINTV").press
If Err.Number <> 0 Then
    Err.Clear
    ' Some releases use a different button id for Number Ranges; try the
    ' application toolbar variants.
    oSession.findById("wnd[0]/tbar[1]/btn[6]").press
    If Err.Number <> 0 Then
        WScript.Echo "ERROR: Could not press Number Ranges button. Status: " & _
                     oSession.findById("wnd[0]/sbar").Text
        WScript.Quit 1
    End If
End If
On Error GoTo 0
WScript.Sleep 1500

Dim sTitle
sTitle = oSession.findById("wnd[0]").Text
WScript.Echo "INFO: " & sTitle

' On the intervals overview screen press Change Intervals (btn[16] in the
' application toolbar of SAPMSNUM, or "Change Intervals" function key F6).
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[16]").press
If Err.Number <> 0 Then
    Err.Clear
    oSession.findById("wnd[0]").sendVKey 6   ' F6 -- Change Intervals
End If
On Error GoTo 0
WScript.Sleep 1500

' Possible "intervals are client-dependent" info popup
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 800
End If
Err.Clear
On Error GoTo 0

' ------ 5. Insert each interval -----------------------------------------
Dim i
For i = 0 To iCnt - 1
    WScript.Echo "INFO: Inserting interval " & arrNR(i) & " " & arrFrom(i) & "-" & arrTo(i) & _
                 " ext=[" & arrExt(i) & "]"

    ' Press Insert Interval (Shift+F1 = VKEY 1, or btn[6] in toolbar)
    On Error Resume Next
    oSession.findById("wnd[0]/tbar[1]/btn[6]").press
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById("wnd[0]").sendVKey 1   ' Shift+F1 -- Insert interval
    End If
    On Error GoTo 0
    WScript.Sleep 1000

    ' Fill the popup fields. Standard ids on SAPMSNUM screen 0150:
    '   wnd[1]/usr/txtRV60S-NRRANG_NR    (NR key)
    '   wnd[1]/usr/txtRV60S-NRRANG_FROM  (FROMNUMBER)
    '   wnd[1]/usr/txtRV60S-NRRANG_TO    (TONUMBER)
    '   wnd[1]/usr/chkRV60S-NRRANG_EXT   (External flag)
    On Error Resume Next
    oSession.findById("wnd[1]/usr/txtRV60S-NRRANG_NR").Text   = arrNR(i)
    oSession.findById("wnd[1]/usr/txtRV60S-NRRANG_FROM").Text = arrFrom(i)
    oSession.findById("wnd[1]/usr/txtRV60S-NRRANG_TO").Text   = arrTo(i)
    If UCase(arrExt(i)) = "X" Then
        oSession.findById("wnd[1]/usr/chkRV60S-NRRANG_EXT").Selected = True
    End If
    If Err.Number <> 0 Then
        Err.Clear
        ' Fallback: insert directly into the interval table on the main screen
        ' (some SNUM releases inline-edit instead of a popup). Skip -- recommend
        ' running /sap-gui-object-details to discover ids.
        WScript.Echo "WARNING: Insert popup field ids not found -- release may differ. Try /sap-gui-object-details."
    End If
    On Error GoTo 0

    ' Press Enter to confirm
    On Error Resume Next
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    Else
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    End If
    On Error GoTo 0
    WScript.Sleep 800

    ' Some releases prompt twice (year popup if the NRO has the to-year flag)
    On Error Resume Next
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 600
    End If
    On Error GoTo 0
Next

' ------ 6. Save ----------------------------------------------------------
WScript.Echo "INFO: Saving intervals..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

' Possible info popup ("Number range transport not possible" / "Changes saved")
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 800
End If
Err.Clear
On Error GoTo 0

Dim sStatus
sStatus = ""
On Error Resume Next
sStatus = oSession.findById("wnd[0]/sbar").Text
On Error GoTo 0
WScript.Echo "INFO: Status: " & sStatus

If InStr(LCase(sStatus), "error") > 0 _
   Or InStr(LCase(sStatus), "overlap") > 0 _
   Or InStr(LCase(sStatus), "not saved") > 0 Then
    WScript.Echo "ERROR: Save failed. Status: " & sStatus
    WScript.Quit 1
End If

On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/btn[15]").press
WScript.Sleep 400
oSession.findById("wnd[0]/tbar[0]/btn[15]").press
WScript.Sleep 400
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Intervals saved for " & UCase(NRO_NAME) & "."
WScript.Quit 0
