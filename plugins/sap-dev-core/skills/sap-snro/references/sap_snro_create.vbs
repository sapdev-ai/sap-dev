' =============================================================================
' sap_snro_create.vbs  -  SAP GUI Scripting: Create Number Range Object via SNRO
'
' Generated by the sap-snro skill.
' Attaches to an existing SAP GUI session, navigates to SNRO, presses
' Display (which surfaces "object does not exist" in the status bar),
' then Insert to switch into create mode. Fills the header attributes,
' saves, handles the package/transport popup, and exits.
'
' Recorded reference (S/4HANA 1909, SAP GUI 7.60):
'   /nSNRO -> NRIV-OBJECT -> btnDISPLAY -> sbar.doubleClick -> btnINSERT
'   TNROT-TXTSHORT, TNROT-TXT
'   tabsNUMMERNKREIS/tabpNUMMERNKREIS_FC1/.../TNRO-DOMLEN
'   tabsNUMMERNKREIS/tabpNUMMERNKREIS_FC1/.../TNRO-PERCENTAGE
'   sendVKey 0; FC2 visit; FC3 visit; btn[11] save
'   wnd[1] KO007-L_DEVCLASS package -> Enter -> KO008-TRKORR transport -> Enter
'
' Tokens replaced at run time:
'   %%NRO_NAME%%     NRO name (max 10 chars)        e.g. "ZMM_0004"
'   %%SHORT_TEXT%%   TNROT-TXTSHORT (max 20 chars)  e.g. "MM SEQ004"
'   %%LONG_TEXT%%    TNROT-TXT      (max 60 chars)  e.g. "MM Sequence 004"
'   %%DOMLEN%%       Domain + length, e.g.          "NUMC15"
'   %%PERCENTAGE%%   Warning % (e.g. "10.0")
'   %%PACKAGE%%      SAP package; empty = $TMP local object
'   %%TRANSPORT%%    Transport request; empty = no TR (local or auto)
' =============================================================================

Option Explicit

Const NRO_NAME    = "%%NRO_NAME%%"
Const SHORT_TEXT  = "%%SHORT_TEXT%%"
Const LONG_TEXT   = "%%LONG_TEXT%%"
Const DOMLEN      = "%%DOMLEN%%"
Const PERCENTAGE  = "%%PERCENTAGE%%"
Const SAP_PACKAGE = "%%PACKAGE%%"
Const SAP_TRANSP  = "%%TRANSPORT%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F11_SAVE = 11
Const VKEY_F3_BACK  = 3

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SNRO -------------------------------------------------
WScript.Echo "INFO: Navigating to SNRO..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSNRO"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter NRO name and Display first --------------------------------
WScript.Echo "INFO: Creating NRO: " & UCase(NRO_NAME)
oSession.findById("wnd[0]/usr/ctxtNRIV-OBJECT").Text = UCase(NRO_NAME)
WScript.Sleep 200
oSession.findById("wnd[0]/usr/btnDISPLAY").press
WScript.Sleep 1500

' If a popup appeared (some releases ask "Create object?"), confirm it.
On Error Resume Next
Dim oPopup
Set oPopup = oSession.findById("wnd[1]")
If Err.Number = 0 And Not (oPopup Is Nothing) Then
    Err.Clear
    oSession.findById("wnd[1]/tbar[0]/btn[0]").press   ' Yes / Continue
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' If we are now in display of an existing NRO, abort — caller must use Update.
Dim sTitle
sTitle = oSession.findById("wnd[0]").Text
If InStr(LCase(sTitle), "display") > 0 Or InStr(LCase(sTitle), "change") > 0 Then
    WScript.Echo "ERROR: NRO " & UCase(NRO_NAME) & " already exists. Use the update flow instead."
    WScript.Quit 1
End If

' Otherwise SNRO sat on the initial screen with status "does not exist".
' Press Insert (btnINSERT) to switch into create mode.
WScript.Echo "INFO: Pressing Insert (Create mode)..."
On Error Resume Next
oSession.findById("wnd[0]/usr/btnINSERT").press
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Insert button not available. Status: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Quit 1
End If
On Error GoTo 0
WScript.Sleep 1500

' ------ 4. Fill header attributes ------------------------------------------
WScript.Echo "INFO: Filling short text: " & SHORT_TEXT
oSession.findById("wnd[0]/usr/txtTNROT-TXTSHORT").Text = SHORT_TEXT
WScript.Sleep 200

Dim sLong
If LONG_TEXT = "" Then
    sLong = SHORT_TEXT
Else
    sLong = LONG_TEXT
End If
WScript.Echo "INFO: Filling long text: " & sLong
oSession.findById("wnd[0]/usr/txtTNROT-TXT").Text = sLong
WScript.Sleep 200

' Tab subscreen base (NUMMERNKREIS_FC1)
Dim sFc1
sFc1 = "wnd[0]/usr/tabsNUMMERNKREIS/tabpNUMMERNKREIS_FC1/ssubNUMMERNKREIS_SCA:SAPLSNR2:1201"

WScript.Echo "INFO: Filling domain (length): " & DOMLEN
On Error Resume Next
oSession.findById(sFc1 & "/txtTNRO-DOMLEN").Text = DOMLEN
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not set TNRO-DOMLEN at " & sFc1 & "/txtTNRO-DOMLEN — " & Err.Description
    WScript.Quit 1
End If
On Error GoTo 0
WScript.Sleep 200

If PERCENTAGE <> "" Then
    WScript.Echo "INFO: Filling warning percentage: " & PERCENTAGE
    On Error Resume Next
    oSession.findById(sFc1 & "/txtTNRO-PERCENTAGE").Text = PERCENTAGE
    If Err.Number <> 0 Then
        Err.Clear
        WScript.Echo "WARNING: Could not set TNRO-PERCENTAGE — leaving default."
    End If
    On Error GoTo 0
    WScript.Sleep 200
End If

' Press Enter to validate domain / percentage
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 800

' Visit FC2 / FC3 tabs to mimic recorded sequence (some releases require this
' so that all tabs are initialised before save). Best-effort — ignore if a tab
' is not present in this release.
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsNUMMERNKREIS/tabpNUMMERNKREIS_FC2").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/tabsNUMMERNKREIS/tabpNUMMERNKREIS_FC3").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/tabsNUMMERNKREIS/tabpNUMMERNKREIS_FC1").select
WScript.Sleep 300
Err.Clear
On Error GoTo 0

' ------ 5. Save -----------------------------------------------------------
WScript.Echo "INFO: Saving NRO..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

' ------ 6. Package + transport popup (3-way pattern) ---------------------
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And SAP_TRANSP <> "" Then
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSP & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSP
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 1000
        End If
    ElseIf SAP_PACKAGE <> "" And SAP_TRANSP = "" Then
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & ", creating new TR..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]/tbar[0]/btn[8]").press   ' Create request
            WScript.Sleep 1000
            On Error Resume Next
            oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = "NRO " & UCase(NRO_NAME)
            oSession.findById("wnd[2]/tbar[0]/btn[0]").press
            WScript.Sleep 1000
            oSession.findById("wnd[1]/tbar[0]/btn[0]").press
            WScript.Sleep 1000
            On Error GoTo 0
        End If
    Else
        WScript.Echo "INFO: Package/transport dialog — pressing Local Object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1500
    End If
End If

' Handle a possible follow-up popup (warning / info)
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 800
End If
Err.Clear
On Error GoTo 0

' ------ 7. Read status bar -----------------------------------------------
Dim sStatus
sStatus = ""
On Error Resume Next
sStatus = oSession.findById("wnd[0]/sbar").Text
On Error GoTo 0
WScript.Echo "INFO: Status: " & sStatus

If InStr(LCase(sStatus), "error") > 0 _
   Or InStr(LCase(sStatus), "not saved") > 0 _
   Or InStr(LCase(sStatus), "cannot") > 0 Then
    WScript.Echo "ERROR: Save failed. Status: " & sStatus
    WScript.Quit 1
End If

' Back out to initial screen
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/btn[15]").press   ' F3 back
WScript.Sleep 500
oSession.findById("wnd[0]/tbar[0]/btn[15]").press   ' F3 back to initial
WScript.Sleep 500
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Number Range Object " & UCase(NRO_NAME) & " created."
WScript.Quit 0
