' =============================================================================
' sap_se19_check.vbs  -  SAP GUI Scripting: Check if Enhancement Implementation exists
'
' Generated by the sap-se19 skill.
' Attaches to an existing SAP GUI session, navigates to SE19,
' attempts Display for a New BAdI Enhancement Implementation, and checks
' if the Implementation Detail screen opens.
'
' Output: "EXIST" or "NOT_EXIST" (last line of stdout, parseable by skill).
'
' Tokens replaced at run time:
'   %%ENH_IMPL_NAME%%  Enhancement Implementation name  e.g. "ZHK_BADI_PO_001"
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const ENH_IMPL_NAME = "%%ENH_IMPL_NAME%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default
Const VKEY_ENTER    = 0

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE19 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE19..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE19"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter Enhancement Implementation name and click Display ----------
WScript.Echo "INFO: Checking Enhancement Implementation: " & UCase(ENH_IMPL_NAME)
oSession.findById("wnd[0]/usr/radG_IS_NEW_1").Select
oSession.findById("wnd[0]/usr/ctxtG_ENHNAME").Text = UCase(ENH_IMPL_NAME)
oSession.findById("wnd[0]/usr/btnPUSHBUTTON_DISPLAY_TEXT").Press
WScript.Sleep 2000

' ------ 4. Determine result -------------------------------------------------
' If it exists, the title changes to
'   "Enhancement Implementation <name> Display"
' If it does not exist, we stay on the SE19 initial screen.
Dim sTitle
sTitle = oSession.findById("wnd[0]").Text

If InStr(1, sTitle, "Enhancement Implementation", vbTextCompare) > 0 And _
   InStr(1, sTitle, UCase(ENH_IMPL_NAME), vbTextCompare) > 0 Then
    WScript.Echo "INFO: Enhancement Implementation " & UCase(ENH_IMPL_NAME) & " exists."
    ' Navigate back to SE19 initial screen
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE19"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500
    WScript.Echo "EXIST"
Else
    Dim sStatus
    sStatus = oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "INFO: " & sStatus
    WScript.Echo "NOT_EXIST"
End If

WScript.Quit 0
