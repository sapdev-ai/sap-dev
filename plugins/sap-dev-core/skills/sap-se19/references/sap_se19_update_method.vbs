' =============================================================================
' sap_se19_update_method.vbs  -  SAP GUI Scripting: Update BAdI implementing
'                                class source via SE24
'
' Generated by the sap-se19 skill.
' Attaches to an existing SAP GUI session, navigates to SE24, opens the
' implementing class in source-code-based view (change mode), uploads new
' source code, saves, and activates.
'
' The source file must contain the COMPLETE class source code including
' CLASS ... DEFINITION and CLASS ... IMPLEMENTATION sections.
'
' Tokens replaced at run time:
'   %%IMPL_CLASS%%          Implementing class name    e.g. "ZCL_IM_ZHK_PO_001"
'   %%ABAP_SOURCE_FILE%%    Absolute path to .abap file with full class source
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const IMPL_CLASS       = "%%IMPL_CLASS%%"
Const ABAP_SOURCE_FILE = "%%ABAP_SOURCE_FILE%%"

Const VKEY_ENTER       = 0
Const VKEY_F11_SAVE    = 11
Const VKEY_F12_CANCEL  = 12

Dim oSAPGUI, oApplication, oSession
Dim oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApplication = oSAPGUI.GetScriptingEngine
If oApplication Is Nothing Then
    WScript.Echo "ERROR: Could not get SAP Scripting Engine."
    WScript.Quit 1
End If

Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApplication.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to SE24 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE24..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE24"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

On Error Resume Next
Dim oClassField
Set oClassField = oSession.findById("wnd[0]/usr/ctxtSEOCLASS-CLSNAME")
If Err.Number <> 0 Or oClassField Is Nothing Then
    WScript.Echo "ERROR: SE24 class name field not found (ID: wnd[0]/usr/ctxtSEOCLASS-CLSNAME)."
    WScript.Quit 1
End If
On Error GoTo 0

' ------ 3. Enter class name and open in change mode -------------------------
oClassField.Text = UCase(IMPL_CLASS)
WScript.Sleep 300

WScript.Echo "INFO: Opening class in change mode: " & UCase(IMPL_CLASS)
oSession.findById("wnd[0]/usr/btnPUSH_CHANGE").Press
WScript.Sleep 2000

' Dismiss any info popup
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 4. Detect source-code-based view ------------------------------------
Dim bSourceView
bSourceView = False

On Error Resume Next
Dim oStatusField
Set oStatusField = oSession.findById("wnd[0]/usr/txtDY0400_STATUS")
If Err.Number = 0 And Not (oStatusField Is Nothing) Then
    bSourceView = True
End If
Err.Clear
On Error GoTo 0

If Not bSourceView Then
    On Error Resume Next
    Dim oTabStrip
    Set oTabStrip = oSession.findById("wnd[0]/usr/tabsCTS")
    Dim bFormView
    bFormView = (Err.Number = 0 And Not (oTabStrip Is Nothing))
    Err.Clear
    On Error GoTo 0

    If Not bFormView Then
        WScript.Echo "ERROR: Could not open class in change mode." & vbCrLf & _
                     "       Check that the class exists and you have authorization."
        WScript.Quit 1
    End If

    WScript.Echo "ERROR: Class is in form-based view. Source-code-based view is required for upload." & vbCrLf & _
                 "       Open SE24, go to Utilities > Settings > Display tab, and select 'Source Code-Based' view." & vbCrLf & _
                 "       Then re-run this script."
    WScript.Quit 1
End If

WScript.Echo "INFO: Class opened in source-code-based change mode."

' ------ 5. Verify source file exists ----------------------------------------
Dim oFSO
Set oFSO = CreateObject("Scripting.FileSystemObject")
If Not oFSO.FileExists(ABAP_SOURCE_FILE) Then
    WScript.Echo "ERROR: Source file not found: " & ABAP_SOURCE_FILE
    WScript.Quit 1
End If

' ------ 6. Upload source: Utilities > More Utilities > Upload/Download > Upload
WScript.Echo "INFO: Uploading source file: " & ABAP_SOURCE_FILE

On Error Resume Next
oSession.findById("wnd[0]/mbar/menu[3]/menu[9]/menu[2]/menu[0]").Select
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not open Upload menu (menu[3]/menu[9]/menu[2]/menu[0])." & vbCrLf & _
                 "       Use Scripting Recorder to find the correct menu path."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0
WScript.Sleep 2000

' Handle "Save before upload" dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim sDlgTitle
    sDlgTitle = oSession.findById("wnd[1]").Text
    If InStr(sDlgTitle, "Save") > 0 Then
        WScript.Echo "INFO: Save before upload dialog — pressing No..."
        oSession.findById("wnd[1]/usr/btnBUTTON_2").Press
        WScript.Sleep 2000
    End If
End If
Err.Clear
On Error GoTo 0

' Fill in the upload file dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim iSlash, sDir, sFile
    iSlash = InStrRev(ABAP_SOURCE_FILE, "\")
    sDir   = Left(ABAP_SOURCE_FILE, iSlash)
    sFile  = Mid(ABAP_SOURCE_FILE, iSlash + 1)

    oSession.findById("wnd[1]/usr/ctxtDY_PATH").Text     = sDir
    oSession.findById("wnd[1]/usr/ctxtDY_FILENAME").Text = sFile
    WScript.Sleep 300
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 3000
Else
    WScript.Echo "ERROR: Upload file dialog did not appear." & vbCrLf & _
                 "       SAP GUI Security settings may be blocking access." & vbCrLf & _
                 "       Go to SAP Logon > Options > Security > set 'Open file' to Allow."
    WScript.Quit 1
End If

If Err.Number <> 0 Then
    WScript.Echo "ERROR: Upload dialog interaction failed: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' Check upload status
Dim sUploadStatus
sUploadStatus = oSession.findById("wnd[0]/sbar").Text
WScript.Echo "INFO: Upload result: " & sUploadStatus

If InStr(sUploadStatus, "bytes passed") = 0 Then
    WScript.Echo "ERROR: Upload may have failed. Status: " & sUploadStatus
    WScript.Quit 1
End If

' ------ 7. Save (Ctrl+S / F11) ----------------------------------------------
WScript.Echo "INFO: Saving..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle transport dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Transport dialog — pressing Local Object or Enter..."
    Dim oLocalBtn
    Set oLocalBtn = oSession.findById("wnd[1]/tbar[0]/btn[7]")
    If Err.Number = 0 And Not (oLocalBtn Is Nothing) Then
        oLocalBtn.Press
    Else
        Err.Clear
        oSession.ActiveWindow.sendVKey VKEY_ENTER
    End If
    WScript.Sleep 2000
End If
Err.Clear
On Error GoTo 0

Dim sSaveStatus
sSaveStatus = oSession.findById("wnd[0]/sbar").Text
WScript.Echo "INFO: Save result: " & sSaveStatus

' ------ 8. Activate (Ctrl+F3 = tbar[1]/btn[27]) ----------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").Press
WScript.Sleep 3000

' Handle "Inactive Objects" list popup
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Inactive objects list — confirming activation..."
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 5000
End If

' Handle "Activation errors" popup
If InStr(oSession.ActiveWindow.Id, "wnd[2]") > 0 Then
    WScript.Echo "WARNING: Activation errors — pressing Activate anyway..."
    oSession.findById("wnd[2]/usr/btnBUTTON_1").Press
    WScript.Sleep 3000
End If
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.findById("wnd[1]").sendVKey VKEY_F12_CANCEL
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 9. Final status check ------------------------------------------------
Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

On Error Resume Next
Dim sFinalEditorStatus
sFinalEditorStatus = oSession.findById("wnd[0]/usr/txtDY0400_STATUS").Text
WScript.Echo "INFO: Class status: " & sFinalEditorStatus
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Class " & UCase(IMPL_CLASS) & " updated and activated in SAP."
WScript.Quit 0
