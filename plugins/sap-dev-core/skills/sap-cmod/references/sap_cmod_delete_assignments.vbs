' =============================================================================
' sap_cmod_delete_assignments.vbs  -  SAP GUI Scripting: Remove SAP enhancement
'                                     assignments from a CMOD project (by value)
'
' Generated by the sap-cmod skill.
' Attaches to a SAP GUI session, navigates to CMOD, selects the Enhancement-
' assignments sub-object (radMODF-CHAK), opens the project in change mode
' (btnPAEND), then for each requested enhancement:
'   * scans the EXITNAME rows to find the one whose VALUE matches (never a
'     hardcoded index), focuses it, and presses Delete row (tbar[1]/btn[33]);
'   * re-scans from the top for the next target, because remaining rows shift
'     up after each deletion.
' Then saves and handles the optional TR popup.
'
' Tokens replaced at run time:
'   %%PROJECT_NAME%%   CMOD project name (UPPERCASE, max 8)
'   %%ENHANCEMENTS%%   Pipe-separated enhancement names to remove
'   %%TRANSPORT%%      TR for the post-save popup. Optional; empty for $TMP.
'
' Recording reference: C:\Temp\Record_CMOD_DeleteAssignments.vbs +
'   C:\Temp\sap_screen_dump_CMOD_SAPLSMOD_100.txt (S/4HANA 1909).
'   tbar[1]/btn[33] = "Delete row (Ctrl+F9)".
'
' Outputs (parseable):
'   STATUS_TYPE: <S|W|E|I|A>   STATUS_TEXT: <text>
'   SUCCESS: ... | ERROR: ...
' =============================================================================

Option Explicit

Const PROJECT_NAME  = "%%PROJECT_NAME%%"
Const ENHANCEMENTS  = "%%ENHANCEMENTS%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"

Const VKEY_ENTER = 0
Const VKEY_SAVE  = 11
Const MAX_ROW    = 16

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

Function RowId(i)
    RowId = "wnd[0]/usr/sub:SAPLSMOD:0100/ctxtMOD0-EXITNAME[" & i & ",0]"
End Function

Function RowText(i)
    Dim o : Set o = oSession.findById(RowId(i), False)
    If o Is Nothing Then
        RowText = "<<NOROW>>"
    Else
        RowText = UCase(Trim(o.Text))
    End If
End Function

' ------ Navigate, select Enhancement assignments, open in change mode -------
WScript.Echo "INFO: Removing enhancements from CMOD project " & UCase(PROJECT_NAME) & "..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 800
oSession.findById("wnd[0]/usr/ctxtMOD0-NAME").Text = UCase(PROJECT_NAME)
oSession.findById("wnd[0]/usr/radMODF-CHAK").select
oSession.findById("wnd[0]/usr/btnPAEND").press
WScript.Sleep 1500

If oSession.findById(RowId(0), False) Is Nothing Then
    WScript.Echo "STATUS_TYPE: " & oSession.findById("wnd[0]/sbar").MessageType
    WScript.Echo "STATUS_TEXT: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "ERROR: Did not reach the enhancement-assignment screen (EXITNAME[0,0] not found). Does the project exist?"
    WScript.Quit 1
End If

Dim wasLocked : wasLocked = TryLockSession(oSession)

' ------ Delete each requested enhancement by value --------------------------
Dim arr : arr = Split(ENHANCEMENTS, "|")
Dim k, sEnh, i, hit, removed
removed = 0
For k = 0 To UBound(arr)
    sEnh = UCase(Trim(arr(k)))
    If Len(sEnh) > 0 Then
        hit = -1
        For i = 0 To MAX_ROW
            If RowText(i) = sEnh Then hit = i : Exit For
        Next
        If hit = -1 Then
            WScript.Echo "WARN: " & sEnh & " not found among current assignments -- skipped."
        Else
            oSession.findById(RowId(hit)).setFocus
            WScript.Echo "INFO: Deleting " & sEnh & " (row " & hit & ")..."
            oSession.findById("wnd[0]/tbar[1]/btn[33]").press   ' Delete row (Ctrl+F9)
            WScript.Sleep 700
            removed = removed + 1
        End If
    End If
Next

If removed = 0 Then
    WScript.Echo "INFO: Nothing removed (no matching assignments)."
    ReleaseSession oSession, wasLocked
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Echo "SUCCESS: No change -- none of the requested enhancements were assigned to " & UCase(PROJECT_NAME) & "."
    WScript.Quit 0
End If

' ------ Save ----------------------------------------------------------------
WScript.Echo "INFO: Saving..."
oSession.findById("wnd[0]").sendVKey VKEY_SAVE
WScript.Sleep 1500

' ------ Handle optional transport-request popup -----------------------------
Dim oPop : Set oPop = oSession.findById("wnd[1]", False)
If Not (oPop Is Nothing) Then
    Dim oTr : Set oTr = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR", False)
    If Not (oTr Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty."
            WScript.Echo "       Resolve a TR via /sap-transport-request and re-run."
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Filling transport " & SAP_TRANSPORT & "..."
        oTr.Text = SAP_TRANSPORT
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        WScript.Echo "INFO: Dismissing popup after save (Enter)..."
        oPop.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
End If

' ------ Read status ---------------------------------------------------------
Dim sMsg, sType
sMsg  = oSession.findById("wnd[0]/sbar").Text
sType = oSession.findById("wnd[0]/sbar").MessageType
WScript.Echo "STATUS_TYPE: " & sType
WScript.Echo "STATUS_TEXT: " & sMsg

ReleaseSession oSession, wasLocked

If sType = "E" Or sType = "A" Then
    WScript.Echo "ERROR: Save reported [" & sType & "] " & sMsg
    WScript.Quit 1
End If

oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER

WScript.Echo "SUCCESS: Removed " & removed & " enhancement(s) from " & UCase(PROJECT_NAME) & " (project now inactive -- run activate to re-activate)."
WScript.Quit 0
