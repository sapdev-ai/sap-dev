' =============================================================================
' sap_cmod_add_assignments.vbs  -  SAP GUI Scripting: Assign SAP enhancements
'                                  to an existing CMOD project (position-aware)
'
' Generated by the sap-cmod skill.
' Attaches to a SAP GUI session, navigates to CMOD, selects the Enhancement-
' assignments sub-object (radMODF-CHAK), opens the project in change mode
' (btnPAEND), then for each requested enhancement:
'   * skips it if it is ALREADY assigned (scan EXITNAME rows by value), and
'   * otherwise writes it into the FIRST EMPTY row — never a hardcoded index.
' Then validates (Enter), saves, and handles the optional TR popup.
'
' Tokens replaced at run time:
'   %%PROJECT_NAME%%   CMOD project name (UPPERCASE, max 8)
'   %%ENHANCEMENTS%%   Pipe-separated enhancement names e.g. "CNEX0001|CNEX0002"
'   %%TRANSPORT%%      TR for the post-save popup. Optional; empty for $TMP.
'
' Recording reference: C:\Temp\Record_CMOD_AddAssignments.vbs +
'   C:\Temp\sap_screen_dump_CMOD_SAPLSMOD_100.txt (S/4HANA 1909).
'
' Outputs (parseable):
'   STATUS_TYPE: <S|W|E|I|A>   STATUS_TEXT: <text>
'   SUCCESS: ... | ERROR: ...
' =============================================================================

Option Explicit

Const PROJECT_NAME  = "%%PROJECT_NAME%%"
Const ENHANCEMENTS  = "%%ENHANCEMENTS%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"

Const VKEY_ENTER = 0
Const VKEY_SAVE  = 11
Const MAX_ROW    = 16   ' visible EXITNAME rows are [0..16] on SAPLSMOD/0100

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

Function RowId(i)
    RowId = "wnd[0]/usr/sub:SAPLSMOD:0100/ctxtMOD0-EXITNAME[" & i & ",0]"
End Function

' Returns the current text of row i, or the special value "<<NOROW>>" if the
' row control does not exist (past the visible grid).
Function RowText(i)
    Dim o : Set o = oSession.findById(RowId(i), False)
    If o Is Nothing Then
        RowText = "<<NOROW>>"
    Else
        RowText = UCase(Trim(o.Text))
    End If
End Function

' ------ Navigate, select Enhancement assignments, open in change mode -------
WScript.Echo "INFO: Adding enhancements to CMOD project " & UCase(PROJECT_NAME) & "..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 800
oSession.findById("wnd[0]/usr/ctxtMOD0-NAME").Text = UCase(PROJECT_NAME)
oSession.findById("wnd[0]/usr/radMODF-CHAK").select   ' Enhancement assignments
oSession.findById("wnd[0]/usr/btnPAEND").press        ' Change
WScript.Sleep 1500

' ------ Confirm we reached the assignment screen ----------------------------
If oSession.findById(RowId(0), False) Is Nothing Then
    WScript.Echo "STATUS_TYPE: " & oSession.findById("wnd[0]/sbar").MessageType
    WScript.Echo "STATUS_TEXT: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "ERROR: Did not reach the enhancement-assignment screen (EXITNAME[0,0] not found). Does the project exist?"
    WScript.Quit 1
End If

Dim wasLocked : wasLocked = TryLockSession(oSession)

' ------ Assign each requested enhancement into the first empty row ----------
Dim arr : arr = Split(ENHANCEMENTS, "|")
Dim k, sEnh, i, placed, added
added = 0
For k = 0 To UBound(arr)
    sEnh = UCase(Trim(arr(k)))
    If Len(sEnh) > 0 Then
        ' Already assigned?
        Dim dup : dup = False
        For i = 0 To MAX_ROW
            If RowText(i) = sEnh Then dup = True : Exit For
        Next
        If dup Then
            WScript.Echo "INFO: " & sEnh & " already assigned — skipped."
        Else
            ' Find first empty row.
            placed = -1
            For i = 0 To MAX_ROW
                If RowText(i) = "" Then placed = i : Exit For
            Next
            If placed = -1 Then
                WScript.Echo "ERROR: No empty row in [0.." & MAX_ROW & "] to add " & sEnh & " (grid full / needs scroll)."
                ReleaseSession oSession, wasLocked
                WScript.Quit 1
            End If
            oSession.findById(RowId(placed)).Text = sEnh
            oSession.findById(RowId(placed)).setFocus
            WScript.Echo "INFO: Added " & sEnh & " at row " & placed & "."
            added = added + 1
            ' Validate immediately so MEMTEXT fills and the next free row is real.
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 600
        End If
    End If
Next

If added = 0 Then
    WScript.Echo "INFO: Nothing to add (all requested enhancements already assigned)."
    ReleaseSession oSession, wasLocked
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Echo "SUCCESS: No change — enhancements already present on " & UCase(PROJECT_NAME) & "."
    WScript.Quit 0
End If

' ------ Check for validation error before saving ----------------------------
Dim sType : sType = oSession.findById("wnd[0]/sbar").MessageType
If sType = "E" Or sType = "A" Then
    WScript.Echo "STATUS_TYPE: " & sType
    WScript.Echo "STATUS_TEXT: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "ERROR: Enhancement validation failed (invalid enhancement name?)."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ Save ----------------------------------------------------------------
WScript.Echo "INFO: Saving assignments..."
oSession.findById("wnd[0]").sendVKey VKEY_SAVE
WScript.Sleep 1500

' ------ Handle optional transport-request popup -----------------------------
Dim oPop : Set oPop = oSession.findById("wnd[1]", False)
If Not (oPop Is Nothing) Then
    Dim oTr : Set oTr = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR", False)
    If Not (oTr Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty."
            WScript.Echo "       Resolve a TR via /sap-transport-request and re-run."
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Filling transport " & SAP_TRANSPORT & "..."
        oTr.Text = SAP_TRANSPORT
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        WScript.Echo "INFO: Dismissing popup after save (Enter)..."
        oPop.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
End If

' ------ Read status ---------------------------------------------------------
Dim sMsg
sMsg  = oSession.findById("wnd[0]/sbar").Text
sType = oSession.findById("wnd[0]/sbar").MessageType
WScript.Echo "STATUS_TYPE: " & sType
WScript.Echo "STATUS_TEXT: " & sMsg

ReleaseSession oSession, wasLocked

If sType = "E" Or sType = "A" Then
    WScript.Echo "ERROR: Save reported [" & sType & "] " & sMsg
    WScript.Quit 1
End If

oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER

WScript.Echo "SUCCESS: Added " & added & " enhancement(s) to " & UCase(PROJECT_NAME) & " (project now inactive — run activate to re-activate)."
WScript.Quit 0
