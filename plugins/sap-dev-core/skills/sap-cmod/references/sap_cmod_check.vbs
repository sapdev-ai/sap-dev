' =============================================================================
' sap_cmod_check.vbs  -  SAP GUI Scripting: Check if CMOD project exists
'
' Generated by the sap-cmod skill.
' Attaches to an existing SAP GUI session, navigates to CMOD,
' attempts Display, and checks if the project attributes screen opens.
'
' Output: "EXIST" or "NOT_EXIST" (last line of stdout, parseable by skill).
'
' Tokens replaced at run time:
'   %%PROJECT_NAME%%  CMOD project name  e.g. "ZHKPJ001"
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const PROJECT_NAME = "%%PROJECT_NAME%%"
Const VKEY_ENTER   = 0

Dim oSAPGUI, oApplication, oSession
Dim oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApplication = oSAPGUI.GetScriptingEngine
If oApplication Is Nothing Then
    WScript.Echo "ERROR: Could not get SAP Scripting Engine."
    WScript.Quit 1
End If

Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApplication.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to CMOD -------------------------------------------------
WScript.Echo "INFO: Navigating to CMOD..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter project name and click Display -----------------------------
WScript.Echo "INFO: Checking project: " & UCase(PROJECT_NAME)
oSession.findById("wnd[0]/usr/ctxtMOD0-NAME").Text = UCase(PROJECT_NAME)
oSession.findById("wnd[0]/usr/btnPANZ").press   ' Display button
WScript.Sleep 2000

' ------ 4. Determine result -------------------------------------------------
' If the project exists, the Attributes screen opens with title containing project name.
' If it does not exist, we stay on the initial screen with a status bar error.
Dim sTitle, sStatus, sStatusType
sTitle = oSession.findById("wnd[0]").Text
sStatus = oSession.findById("wnd[0]/sbar").Text
sStatusType = oSession.findById("wnd[0]/sbar").MessageType

If InStr(sTitle, "Attributes") > 0 And InStr(sTitle, UCase(PROJECT_NAME)) > 0 Then
    WScript.Echo "INFO: Enhancement project " & UCase(PROJECT_NAME) & " exists."
    ' Navigate back to CMOD initial screen
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500
    WScript.Echo "EXIST"
Else
    WScript.Echo "INFO: " & sStatus
    WScript.Echo "NOT_EXIST"
End If

WScript.Quit 0
