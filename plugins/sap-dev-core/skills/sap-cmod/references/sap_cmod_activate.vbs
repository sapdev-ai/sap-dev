' =============================================================================
' sap_cmod_activate.vbs  -  SAP GUI Scripting: Activate a CMOD enhancement project
'
' Generated by the sap-cmod skill.
' Attaches to an existing SAP GUI session, navigates to CMOD, enters the
' project name, and activates it (Ctrl+F3 / VKey 27 on the initial screen).
'
' Tokens replaced at run time:
'   %%PROJECT_NAME%%   CMOD project name (UPPERCASE, max 8)   e.g. "ZHKPJ001"
'
' Recording reference: C:\Temp\Record_CMOD_ActivateProject.vbs (S/4HANA 1909).
' Verify activation via MODATTR-STATUS = 'A' (sap_cmod_query.ps1).
'
' Outputs (parseable):
'   STATUS_TYPE: <S|W|E|I|A>   STATUS_TEXT: <text>
'   SUCCESS: ... | ERROR: ...
' =============================================================================

Option Explicit

Const PROJECT_NAME = "%%PROJECT_NAME%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_ACTIVATE = 27   ' Ctrl+F3

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ Navigate to CMOD + enter project ------------------------------------
WScript.Echo "INFO: Activating CMOD project " & UCase(PROJECT_NAME) & "..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 800
oSession.findById("wnd[0]/usr/ctxtMOD0-NAME").Text = UCase(PROJECT_NAME)
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

Dim wasLocked : wasLocked = TryLockSession(oSession)

' ------ Activate (Ctrl+F3) --------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_ACTIVATE
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not send Activate: " & Err.Description
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ Dismiss any confirmation / activation-log popup ---------------------
Dim oPop
Set oPop = oSession.findById("wnd[1]", False)
If Not (oPop Is Nothing) Then
    WScript.Echo "INFO: Confirming popup after Activate..."
    oPop.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If

' ------ Read status ---------------------------------------------------------
Dim sMsg, sType
sMsg  = oSession.findById("wnd[0]/sbar").Text
sType = oSession.findById("wnd[0]/sbar").MessageType
WScript.Echo "STATUS_TYPE: " & sType
WScript.Echo "STATUS_TEXT: " & sMsg

ReleaseSession oSession, wasLocked

If sType = "E" Or sType = "A" Then
    WScript.Echo "ERROR: Activation reported [" & sType & "] " & sMsg
    WScript.Quit 1
End If

' Return to a clean Easy-Access screen for safe handover.
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER

WScript.Echo "SUCCESS: Enhancement project " & UCase(PROJECT_NAME) & " activated (verify MODATTR-STATUS=A)."
WScript.Quit 0
