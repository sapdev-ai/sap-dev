' =============================================================================
' sap_cmod_create.vbs  -  SAP GUI Scripting: Create a CMOD enhancement project
'                         (project header + short text)
'
' Generated by the sap-cmod skill.
' Attaches to a SAP GUI session, navigates to CMOD, creates a new enhancement
' project, sets its short text, saves, and resolves the package / transport
' popup. Enhancement assignment is a SEPARATE step -- the skill chains
' sap_cmod_add_assignments.vbs afterwards (single, well-tested assign path).
'
' Tokens replaced at run time:
'   %%PROJECT_NAME%%   CMOD project name (UPPERCASE, max 8)   e.g. "ZHKPJ001"
'   %%SHORT_TEXT%%     Project short description
'   %%PACKAGE%%        Target package. Blank or "$*" => Local object ($TMP).
'   %%TRANSPORT%%      TR for transportable packages. Required when PACKAGE is
'                       transportable; ignored for $TMP.
'
' Recording references: original sap_cmod_create.vbs +
'   C:\Temp\Record_CMOD_*.vbs (S/4HANA 1909).
'
' Outputs (parseable):
'   STATUS_TYPE: <S|W|E|I|A>   STATUS_TEXT: <text>
'   SUCCESS: ... | ERROR: ...
' =============================================================================

Option Explicit

Const PROJECT_NAME  = "%%PROJECT_NAME%%"
Const SHORT_TEXT    = "%%SHORT_TEXT%%"
Const SAP_PACKAGE   = "%%PACKAGE%%"
Const SAP_TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH  = "%%SESSION_PATH%%"

Const VKEY_ENTER = 0
Const VKEY_SAVE  = 11

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

Function IsLocalPkg(p)
    p = Trim(p)
    IsLocalPkg = (p = "" Or Left(p, 1) = "$")
End Function

' ------ Navigate to CMOD + enter project + Create ---------------------------
WScript.Echo "INFO: Creating CMOD project " & UCase(PROJECT_NAME) & "..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 800
oSession.findById("wnd[0]/usr/ctxtMOD0-NAME").Text = UCase(PROJECT_NAME)

On Error Resume Next
oSession.findById("wnd[0]/usr/btn%#AUTOTEXT001").press   ' Create
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Create (btn%#AUTOTEXT001): " & Err.Description
    WScript.Echo "       The Create button id is generated and can differ by release -- re-check with /sap-gui-inspect."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ Confirm we reached the Attributes screen (component presence) --------
Dim oText : Set oText = oSession.findById("wnd[0]/usr/txtMOD0-MODTEXT", False)
If oText Is Nothing Then
    WScript.Echo "STATUS_TYPE: " & oSession.findById("wnd[0]/sbar").MessageType
    WScript.Echo "STATUS_TEXT: " & oSession.findById("wnd[0]/sbar").Text
    WScript.Echo "ERROR: Did not reach the Attributes screen (txtMOD0-MODTEXT not found). Project may already exist."
    WScript.Quit 1
End If

Dim wasLocked : wasLocked = TryLockSession(oSession)

' ------ Short text + Save ---------------------------------------------------
oText.Text = SHORT_TEXT
WScript.Echo "INFO: Short text = " & SHORT_TEXT
oSession.findById("wnd[0]").sendVKey VKEY_SAVE
WScript.Sleep 1500

' ------ Resolve the Create-Object-Directory-Entry (package) popup -----------
Dim oPop : Set oPop = oSession.findById("wnd[1]", False)
If Not (oPop Is Nothing) Then
    If IsLocalPkg(SAP_PACKAGE) Then
        ' Local object button on the SAPLSTRD create dialog.
        Dim oLocal : Set oLocal = oSession.findById("wnd[1]/tbar[0]/btn[7]", False)
        If Not (oLocal Is Nothing) Then
            WScript.Echo "INFO: Assigning to Local object ($TMP)..."
            oLocal.press
        Else
            WScript.Echo "INFO: Local-object button not found; pressing Enter."
            oPop.sendVKey VKEY_ENTER
        End If
        WScript.Sleep 1200
    Else
        ' Transportable: fill the package field, continue, then the TR popup.
        Dim oPkg : Set oPkg = oSession.findById("wnd[1]/usr/ctxtTADIR-DEVCLASS", False)
        If oPkg Is Nothing Then Set oPkg = oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS", False)
        If oPkg Is Nothing Then
            WScript.Echo "ERROR: Could not find the package field on the directory-entry popup."
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Package = " & SAP_PACKAGE
        oPkg.Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press   ' Continue
        WScript.Sleep 1200
        ' Transport-request popup
        Dim oTr : Set oTr = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR", False)
        If Not (oTr Is Nothing) Then
            If SAP_TRANSPORT = "" Then
                WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty."
                WScript.Echo "       Resolve a TR via /sap-transport-request and re-run."
                ReleaseSession oSession, wasLocked
                WScript.Quit 1
            End If
            WScript.Echo "INFO: Filling transport " & SAP_TRANSPORT & "..."
            oTr.Text = SAP_TRANSPORT
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 1200
        End If
    End If
End If

' ------ Dismiss any trailing popup ------------------------------------------
Set oPop = oSession.findById("wnd[1]", False)
If Not (oPop Is Nothing) Then
    oPop.sendVKey VKEY_ENTER
    WScript.Sleep 800
End If

' ------ Read status ---------------------------------------------------------
Dim sMsg, sType
sMsg  = oSession.findById("wnd[0]/sbar").Text
sType = oSession.findById("wnd[0]/sbar").MessageType
WScript.Echo "STATUS_TYPE: " & sType
WScript.Echo "STATUS_TEXT: " & sMsg

ReleaseSession oSession, wasLocked

If sType = "E" Or sType = "A" Then
    WScript.Echo "ERROR: Create/save reported [" & sType & "] " & sMsg
    WScript.Quit 1
End If

oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER

WScript.Echo "SUCCESS: Enhancement project " & UCase(PROJECT_NAME) & " created."
WScript.Quit 0
