' =============================================================================
' sap_cmod_create.vbs  -  SAP GUI Scripting: Create CMOD project and assign
'                         SAP enhancements
'
' Generated by the sap-cmod skill.
' Attaches to an existing SAP GUI session, navigates to CMOD, creates a new
' enhancement project, sets its short text, assigns one or more SAP
' enhancements, and saves.
'
' Tokens replaced at run time:
'   %%PROJECT_NAME%%   CMOD project name          e.g. "ZHKPJ001"
'   %%SHORT_TEXT%%      Project short description   e.g. "Custom route determination"
'   %%ENHANCEMENTS%%   Pipe-separated enhancement names  e.g. "0VRF0001|AMPL0001"
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const PROJECT_NAME = "%%PROJECT_NAME%%"
Const SHORT_TEXT   = "%%SHORT_TEXT%%"
Const ENHANCEMENTS = "%%ENHANCEMENTS%%"

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

Dim oSAPGUI, oApplication, oSession
Dim oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApplication = oSAPGUI.GetScriptingEngine
If oApplication Is Nothing Then
    WScript.Echo "ERROR: Could not get SAP Scripting Engine."
    WScript.Quit 1
End If

Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApplication.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to CMOD -------------------------------------------------
WScript.Echo "INFO: Navigating to CMOD..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nCMOD"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Enter project name and press Create ------------------------------
WScript.Echo "INFO: Creating project: " & UCase(PROJECT_NAME)
oSession.findById("wnd[0]/usr/ctxtMOD0-NAME").Text = UCase(PROJECT_NAME)
oSession.findById("wnd[0]/usr/btn%#AUTOTEXT001").press   ' Create button
WScript.Sleep 2000

' Check we reached the Attributes screen
Dim sTitle, sStatus, sStatusType
sTitle = oSession.findById("wnd[0]").Text
sStatus = oSession.findById("wnd[0]/sbar").Text
sStatusType = oSession.findById("wnd[0]/sbar").MessageType

If InStr(sTitle, "Attributes") = 0 Then
    WScript.Echo "ERROR: Did not reach Attributes screen. Title: " & sTitle
    WScript.Echo "ERROR: Status: " & sStatus
    WScript.Quit 1
End If
WScript.Echo "INFO: Attributes screen reached."

' ------ 4. Fill short text --------------------------------------------------
oSession.findById("wnd[0]/usr/txtMOD0-MODTEXT").Text = SHORT_TEXT
WScript.Echo "INFO: Short text = " & SHORT_TEXT

' ------ 5. Save (creates the project) --------------------------------------
WScript.Echo "INFO: Saving project..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle Object Directory Entry / Transport popup
On Error Resume Next
Dim oPop
Set oPop = oSession.findById("wnd[1]")
If Err.Number = 0 And Not (oPop Is Nothing) Then
    WScript.Echo "INFO: Transport dialog: " & oPop.Text
    Dim oLocalBtn
    Set oLocalBtn = oPop.findById("tbar[0]/btn[7]")
    If Err.Number = 0 And Not (oLocalBtn Is Nothing) Then
        WScript.Echo "INFO: Assigning to Local Object ($TMP)..."
        oLocalBtn.press
    Else
        Err.Clear
        oPop.sendVKey VKEY_ENTER
    End If
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Handle second popup if any
On Error Resume Next
Set oPop = oSession.findById("wnd[1]")
If Err.Number = 0 And Not (oPop Is Nothing) Then
    oPop.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

sStatus = oSession.findById("wnd[0]/sbar").Text
sStatusType = oSession.findById("wnd[0]/sbar").MessageType
If sStatusType = "E" Then
    WScript.Echo "ERROR: Save failed: " & sStatus
    WScript.Quit 1
End If
WScript.Echo "INFO: Project saved: " & sStatus

' ------ 6. Navigate to Enhancement assignments ------------------------------
WScript.Echo "INFO: Opening Enhancement assignments..."
oSession.findById("wnd[0]/tbar[1]/btn[23]").press   ' Enhancement assignments
WScript.Sleep 2000

sTitle = oSession.findById("wnd[0]").Text
If InStr(sTitle, "SAP Enhancements") = 0 Then
    WScript.Echo "ERROR: Did not reach Enhancement assignments screen. Title: " & sTitle
    WScript.Quit 1
End If
WScript.Echo "INFO: Enhancement assignments screen reached."

' ------ 7. Assign enhancements ----------------------------------------------
Dim arrEnhance
arrEnhance = Split(ENHANCEMENTS, "|")

Dim iEnh
For iEnh = 0 To UBound(arrEnhance)
    Dim sEnhName
    sEnhName = Trim(arrEnhance(iEnh))
    If Len(sEnhName) > 0 Then
        WScript.Echo "INFO: Assigning enhancement: " & sEnhName & " (row " & iEnh & ")"
        oSession.findById("wnd[0]/usr/sub:SAPLSMOD:0100/ctxtMOD0-EXITNAME[" & iEnh & ",0]").Text = sEnhName
    End If
Next

' Press Enter to validate
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 2000

sStatus = oSession.findById("wnd[0]/sbar").Text
sStatusType = oSession.findById("wnd[0]/sbar").MessageType
If sStatusType = "E" Then
    WScript.Echo "ERROR: Enhancement assignment failed: " & sStatus
    WScript.Quit 1
End If

' Verify descriptions were populated
For iEnh = 0 To UBound(arrEnhance)
    Dim sDesc
    On Error Resume Next
    sDesc = oSession.findById("wnd[0]/usr/sub:SAPLSMOD:0100/txtMOD0-MEMTEXT[" & iEnh & ",14]").Text
    Err.Clear
    On Error GoTo 0
    If Len(sDesc) > 0 Then
        WScript.Echo "INFO:   " & Trim(arrEnhance(iEnh)) & " = " & sDesc
    End If
Next

' ------ 8. Save enhancement assignments ------------------------------------
WScript.Echo "INFO: Saving enhancement assignments..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle transport popup
On Error Resume Next
Set oPop = oSession.findById("wnd[1]")
If Err.Number = 0 And Not (oPop Is Nothing) Then
    WScript.Echo "INFO: Transport dialog..."
    Set oLocalBtn = oPop.findById("tbar[0]/btn[7]")
    If Err.Number = 0 And Not (oLocalBtn Is Nothing) Then
        oLocalBtn.press
    Else
        Err.Clear
        oPop.sendVKey VKEY_ENTER
    End If
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

sStatus = oSession.findById("wnd[0]/sbar").Text
sStatusType = oSession.findById("wnd[0]/sbar").MessageType
If sStatusType = "E" Then
    WScript.Echo "ERROR: Save failed: " & sStatus
    WScript.Quit 1
End If

WScript.Echo "INFO: " & sStatus

' Navigate back to clean state
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

WScript.Echo "SUCCESS: Enhancement project " & UCase(PROJECT_NAME) & " created with " & (UBound(arrEnhance) + 1) & " enhancement(s) assigned."
WScript.Quit 0
