' =============================================================================
' sap_se11_view_create.vbs  -  SAP GUI Scripting: Create view in SE11
'
' Generated by the sap-se11 skill.
' Navigates to SE11, creates a new view (Database/Projection/Maintenance/Help),
' adds base tables, join conditions, view fields, saves, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%          View name             e.g. "ZVITEM"
'   %%OBJECT_DESCRIPTION%%   Short description     e.g. "Item View"
'   %%VIEW_TYPE%%            D=Database, P=Projection, M=Maintenance, H=Help
'   %%DEFINITION_FILE%%      Absolute path to tab-delimited definition
'
' Definition file format (tab-delimited, multi-section):
'   TABLES
'   TABLE	ORDER
'   ZTABLE1	1
'   ZTABLE2	2
'   JOIN_CONDITIONS
'   TABLE1	FIELD1	TABLE2	FIELD2
'   ZTABLE1	MANDT	ZTABLE2	MANDT
'   ZTABLE1	DOCNR	ZTABLE2	DOCNR
'   VIEW_FIELDS
'   TABLE	FIELD
'   ZTABLE1	MANDT
'   ZTABLE1	DOCNR
'   ZTABLE2	DESCRIPTION
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' =============================================================================

Option Explicit

Const OBJECT_NAME        = "%%OBJECT_NAME%%"
Const OBJECT_DESCRIPTION = "%%OBJECT_DESCRIPTION%%"
Const VIEW_TYPE          = "%%VIEW_TYPE%%"
Const DEFINITION_FILE    = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE        = "%%PACKAGE%%"
Const SAP_TRANSPORT      = "%%TRANSPORT%%"
Const SESSION_PATH       = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default
Const POST_ACTIVATE_VERIFY_PS1 = "%%POST_ACTIVATE_VERIFY_PS1%%"   ' empty = skip verify

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%POST_ACTIVATE_VERIFY_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile read below accept UTF-8 inputs from upstream tools
' (sap-docs-extract, the Write tool, hand-authored TSVs) -- full docstring
' in sap_se11_table_create.vbs. Always returns a UTF-16 LE path so callers
' must open the result with mode -1.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and create view ---------------------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-VIMA").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-VIMA_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Creating view: " & UCase(OBJECT_NAME)
oSession.findById("wnd[0]/usr/btnPUSHADD").press
WScript.Sleep 1500

' --- Lock the SAP session UI for the fill view fields + save + activate critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the fill view fields + save + activate critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Handle view type popup -------------------------------------------
' When creating a view, SAP shows a popup to select the view type
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: View type popup detected - selecting type: " & VIEW_TYPE
    Select Case UCase(VIEW_TYPE)
        Case "D"
            oSession.findById("wnd[1]/usr/radRAD_DB").select
        Case "P"
            oSession.findById("wnd[1]/usr/radRAD_PROJ").select
        Case "M"
            oSession.findById("wnd[1]/usr/radRAD_MAINT").select
        Case "H"
            oSession.findById("wnd[1]/usr/radRAD_HELP").select
        Case Else
            WScript.Echo "WARNING: Unknown view type '" & VIEW_TYPE & "', defaulting to Database"
            oSession.findById("wnd[1]/usr/radRAD_DB").select
    End Select
    If Err.Number <> 0 Then
        WScript.Echo "WARNING: Could not select view type radio: " & Err.Description
        Err.Clear
    End If
    WScript.Sleep 300
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

' ------ 4. Fill description -------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/txtDD25L-DDTEXT").Text = OBJECT_DESCRIPTION
If Err.Number <> 0 Then
    Err.Clear
    oSession.findById("wnd[0]/usr/txtDD25V-DDTEXT").Text = OBJECT_DESCRIPTION
End If
Err.Clear
On Error GoTo 0

' ------ 5. Parse definition file into sections ------------------------------
Dim oFSO, oFile, sLine
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

Dim arrTables()
Dim arrJoins()
Dim arrViewFields()
Dim iTableCount, iJoinCount, iFieldCount
iTableCount = 0 : iJoinCount = 0 : iFieldCount = 0

Dim sSection, aFields
sSection = ""

Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
Do While Not oFile.AtEndOfStream
    sLine = Trim(oFile.ReadLine)
    If sLine = "" Then
        ' skip blank lines
    ElseIf UCase(sLine) = "TABLES" Then
        sSection = "TABLES"
    ElseIf UCase(sLine) = "JOIN_CONDITIONS" Then
        sSection = "JOINS"
    ElseIf UCase(sLine) = "VIEW_FIELDS" Then
        sSection = "FIELDS"
    Else
        aFields = Split(sLine, vbTab)
        Select Case sSection
            Case "TABLES"
                If UBound(aFields) >= 0 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrTables(iTableCount)
                    arrTables(iTableCount) = Trim(aFields(0))
                    iTableCount = iTableCount + 1
                End If
            Case "JOINS"
                If UBound(aFields) >= 3 And UCase(Trim(aFields(0))) <> "TABLE1" Then
                    ReDim Preserve arrJoins(iJoinCount)
                    arrJoins(iJoinCount) = Trim(aFields(0)) & vbTab & Trim(aFields(1)) & vbTab & Trim(aFields(2)) & vbTab & Trim(aFields(3))
                    iJoinCount = iJoinCount + 1
                End If
            Case "FIELDS"
                If UBound(aFields) >= 1 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrViewFields(iFieldCount)
                    arrViewFields(iFieldCount) = Trim(aFields(0)) & vbTab & Trim(aFields(1))
                    iFieldCount = iFieldCount + 1
                End If
        End Select
    End If
Loop
oFile.Close

WScript.Echo "INFO: Parsed " & iTableCount & " tables, " & iJoinCount & " joins, " & iFieldCount & " view fields."

' ------ 6. Tables tab -- Add base tables -------------------------------------
WScript.Echo "INFO: Adding base tables..."
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD26/tabpTABLES").select
WScript.Sleep 500
Err.Clear

Dim iRow, sTabBase
sTabBase = "wnd[0]/usr/tabsTABSTRIP_DD26/tabpTABLES/ssubSS_TABLES:SAPLSD31:"

Dim i
For i = 0 To iTableCount - 1
    iRow = i
    ' Try different sub-screen numbers for the table name field
    oSession.findById(sTabBase & "0801/tblSAPLSD31TC_TABLE_TAB/ctxtDD26S-TABNAME[0," & iRow & "]").Text = UCase(arrTables(i))
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById(sTabBase & "0601/tblSAPLSD31TC_TABLE_TAB/ctxtDD26S-TABNAME[0," & iRow & "]").Text = UCase(arrTables(i))
    End If
    If Err.Number <> 0 Then
        WScript.Echo "WARNING: Could not set table at row " & iRow & ": " & Err.Description
        Err.Clear
    Else
        WScript.Echo "INFO:   Table " & (i+1) & ": " & UCase(arrTables(i))
    End If
    WScript.Sleep 200
    
    ' Press Enter to validate and make next row available
    If i < iTableCount - 1 Then
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
        WScript.Sleep 500
    End If
Next
Err.Clear

' Press Enter to validate all tables
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
On Error GoTo 0

' ------ 7. Join Conditions tab (for Database views with >1 table) -----------
If iJoinCount > 0 Then
    WScript.Echo "INFO: Setting join conditions..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD26/tabpJOIN").select
    WScript.Sleep 500
    
    Dim sJoinBase, aJoinFields
    sJoinBase = "wnd[0]/usr/tabsTABSTRIP_DD26/tabpJOIN/ssubSS_JOIN:SAPLSD31:"
    
    For i = 0 To iJoinCount - 1
        aJoinFields = Split(arrJoins(i), vbTab)
        iRow = i
        
        ' Fill join condition fields
        oSession.findById(sJoinBase & "0901/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-LTAB[0," & iRow & "]").Text = UCase(aJoinFields(0))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sJoinBase & "0601/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-LTAB[0," & iRow & "]").Text = UCase(aJoinFields(0))
        End If
        oSession.findById(sJoinBase & "0901/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-LFIELDNAME[1," & iRow & "]").Text = UCase(aJoinFields(1))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sJoinBase & "0601/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-LFIELDNAME[1," & iRow & "]").Text = UCase(aJoinFields(1))
        End If
        oSession.findById(sJoinBase & "0901/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-RTAB[2," & iRow & "]").Text = UCase(aJoinFields(2))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sJoinBase & "0601/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-RTAB[2," & iRow & "]").Text = UCase(aJoinFields(2))
        End If
        oSession.findById(sJoinBase & "0901/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-RFIELDNAME[3," & iRow & "]").Text = UCase(aJoinFields(3))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sJoinBase & "0601/tblSAPLSD31TC_JOIN_TAB/ctxtDD28S-RFIELDNAME[3," & iRow & "]").Text = UCase(aJoinFields(3))
        End If
        
        If Err.Number <> 0 Then
            WScript.Echo "WARNING: Could not set join at row " & iRow & ": " & Err.Description
            Err.Clear
        End If
        WScript.Sleep 200
        
        If i < iJoinCount - 1 Then
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 500
        End If
    Next
    
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    Err.Clear
    On Error GoTo 0
End If

' ------ 8. View Fields tab -- Add fields to the view -------------------------
If iFieldCount > 0 Then
    WScript.Echo "INFO: Adding view fields..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD26/tabpFIELDS").select
    WScript.Sleep 500
    
    Dim sFieldBase, aVFFields
    sFieldBase = "wnd[0]/usr/tabsTABSTRIP_DD26/tabpFIELDS/ssubSS_FIELDS:SAPLSD31:"
    
    For i = 0 To iFieldCount - 1
        aVFFields = Split(arrViewFields(i), vbTab)
        iRow = i
        
        ' Table name column
        oSession.findById(sFieldBase & "0601/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-TABNAME[0," & iRow & "]").Text = UCase(aVFFields(0))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sFieldBase & "0801/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-TABNAME[0," & iRow & "]").Text = UCase(aVFFields(0))
        End If
        ' Field name column
        oSession.findById(sFieldBase & "0601/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-FIELDNAME[1," & iRow & "]").Text = UCase(aVFFields(1))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sFieldBase & "0801/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-FIELDNAME[1," & iRow & "]").Text = UCase(aVFFields(1))
        End If
        
        If Err.Number <> 0 Then
            WScript.Echo "WARNING: Could not set view field at row " & iRow & ": " & Err.Description
            Err.Clear
        End If
        WScript.Sleep 200
        
        ' Scroll grid periodically
        If (iRow + 1) Mod 14 = 0 And i < iFieldCount - 1 Then
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 500
        End If
    Next
    
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    Err.Clear
    On Error GoTo 0
End If

' ------ 9. Check (Ctrl+F2) before saving ------------------------------------
WScript.Echo "INFO: Checking view consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

' Handle "Save object?" popup (view check requires save first)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim sChkDiag1
    sChkDiag1 = ""
    sChkDiag1 = oSession.findById("wnd[1]/usr/txtSPOP-DIAGNOSE1").Text
    If Err.Number <> 0 Then sChkDiag1 = "" : Err.Clear
    If InStr(sChkDiag1, "saved") > 0 Then
        WScript.Echo "INFO: Check requires save - pressing Yes..."
        oSession.findById("wnd[1]/usr/btnSPOP-OPTION1").press
        WScript.Sleep 2000
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
                oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
                oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
            ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
                oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
                oSession.findById("wnd[1]/tbar[0]/btn[8]").press
                WScript.Sleep 1000
                oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
                oSession.findById("wnd[2]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
            Else
                oSession.findById("wnd[1]/tbar[0]/btn[7]").press
                WScript.Sleep 1000
            End If
        End If
    Else
        Err.Clear
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0

If oSession.Info.Program = "SAPMSSY0" Then
    WScript.Echo "INFO: Reading check log..."
    Dim bCheckError
    bCheckError = False
    Dim sCheckErrors
    sCheckErrors = ""
    On Error Resume Next
    Dim oChkUsr, oChkChild, sChkText
    Set oChkUsr = oSession.findById("wnd[0]/usr")
    If Err.Number = 0 Then
        For Each oChkChild In oChkUsr.Children
            sChkText = ""
            sChkText = oChkChild.Text
            If Err.Number <> 0 Then sChkText = "" : Err.Clear
            If InStr(sChkText, "resulted in errors") > 0 Or _
               InStr(sChkText, "is inconsistent") > 0 Then
                bCheckError = True
            End If
            If sChkText <> "" Then
                Dim sChkId
                sChkId = oChkChild.Id
                If Err.Number <> 0 Then sChkId = "" : Err.Clear
                If InStr(sChkId, "lbl[13,") > 0 Then
                    sCheckErrors = sCheckErrors & sChkText & vbCrLf
                End If
            End If
        Next
    End If
    Err.Clear
    On Error GoTo 0

    oSession.findById("wnd[0]").sendVKey VKEY_F3_BACK
    WScript.Sleep 1000

    If bCheckError Then
        WScript.Echo "ERROR: Check found errors:"
        WScript.Echo sCheckErrors
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    Else
        WScript.Echo "INFO: Check passed."
    End If
Else
    Dim sChkSbarMsg, sChkSbarType
    On Error Resume Next
    sChkSbarMsg  = oSession.findById("wnd[0]/sbar").Text
    sChkSbarType = oSession.findById("wnd[0]/sbar").MessageType
    On Error GoTo 0
    If sChkSbarType = "E" Then
        WScript.Echo "ERROR: Check failed - " & sChkSbarMsg
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    WScript.Echo "INFO: Check passed."
End If

' ------ 10. Save (F11) --- (may be already saved by Check) -------------------
WScript.Echo "INFO: Saving view..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Saved."

' ------ 10. Activate (Ctrl+F3) -----------------------------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 3000
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; final-status read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Or sFinalType = "A" Then
    WScript.Echo "ERROR: Activation failed (sbar Type=" & sFinalType & ") - " & sFinalMsg
    WScript.Quit 1
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

' Post-activate RFC verify (Phase 4.3 -- mandatory per SKILL.md Step 5d).
PostActivateVerifyOrFail POST_ACTIVATE_VERIFY_PS1, "VIEW", OBJECT_NAME

WScript.Echo "SUCCESS: View " & UCase(OBJECT_NAME) & " created and activated in SAP."
WScript.Quit 0
