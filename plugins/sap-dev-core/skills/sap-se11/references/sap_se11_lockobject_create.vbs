' =============================================================================
' sap_se11_lockobject_create.vbs  -  SAP GUI Scripting: Create lock object in SE11
'
' Generated by the sap-se11 skill.
' Navigates to SE11, creates a new lock object with primary table, lock mode,
' optional secondary tables, and lock arguments, saves, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%          Lock object name      e.g. "EZMYLOCK"
'   %%OBJECT_DESCRIPTION%%   Short description     e.g. "Lock for custom table"
'   %%DEFINITION_FILE%%      Absolute path to tab-delimited definition
'
' Definition file format (tab-delimited, multi-section):
'   PRIMARY_TABLE	ZTABLE
'   LOCK_MODE	E
'   SECONDARY_TABLES
'   TABLE
'   ZTABLE2
'   LOCK_ARGUMENTS
'   TABLE	FIELD
'   ZTABLE	MANDT
'   ZTABLE	BUKRS
'
' LOCK_MODE: E=Write lock, S=Read lock, X=Exclusive lock
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' =============================================================================

Option Explicit

Const OBJECT_NAME        = "%%OBJECT_NAME%%"
Const OBJECT_DESCRIPTION = "%%OBJECT_DESCRIPTION%%"
Const DEFINITION_FILE    = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE        = "%%PACKAGE%%"
Const SAP_TRANSPORT      = "%%TRANSPORT%%"

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared session-lock helpers (TryLockSession / ReleaseSession).
' Per language_independence_rules.md Rule 7.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile read below accept UTF-8 inputs from upstream tools
' (sap-docs-extract, the Write tool, hand-authored TSVs) — full docstring
' in sap_se11_table_create.vbs. Always returns a UTF-16 LE path so callers
' must open the result with mode -1.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

Dim oSAPGUI, oApplication, oSession
Dim oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApplication = oSAPGUI.GetScriptingEngine
If oApplication Is Nothing Then
    WScript.Echo "ERROR: Could not get SAP Scripting Engine."
    WScript.Quit 1
End If

Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApplication.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to SE11 and create lock object --------------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-ENQU").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-ENQU_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Creating lock object: " & UCase(OBJECT_NAME)
oSession.findById("wnd[0]/usr/btnPUSHADD").press
WScript.Sleep 1500

' --- Lock the SAP session UI for the fill lock-object fields + save + activate critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the fill lock-object fields + save + activate critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Fill description -------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/txtDD25L-DDTEXT").Text = OBJECT_DESCRIPTION
If Err.Number <> 0 Then
    Err.Clear
    oSession.findById("wnd[0]/usr/txtDD25E-DDTEXT").Text = OBJECT_DESCRIPTION
End If
If Err.Number <> 0 Then
    WScript.Echo "WARNING: Could not set description: " & Err.Description
    Err.Clear
End If
On Error GoTo 0

' ------ 4. Parse definition file --------------------------------------------
Dim oFSO, oFile, sLine, aFields
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

Dim sPrimaryTable, sLockMode
sPrimaryTable = "" : sLockMode = ""

Dim arrSecTables()
Dim arrLockArgs()
Dim iSecCount, iArgCount
iSecCount = 0 : iArgCount = 0

Dim sSection
sSection = "HEADER"

Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
Do While Not oFile.AtEndOfStream
    sLine = Trim(oFile.ReadLine)
    If sLine = "" Then
        ' skip
    ElseIf UCase(sLine) = "SECONDARY_TABLES" Then
        sSection = "SECONDARY"
    ElseIf UCase(sLine) = "LOCK_ARGUMENTS" Then
        sSection = "LOCKARGS"
    Else
        aFields = Split(sLine, vbTab)
        Select Case sSection
            Case "HEADER"
                If UBound(aFields) >= 1 Then
                    Select Case UCase(Trim(aFields(0)))
                        Case "PRIMARY_TABLE"
                            sPrimaryTable = Trim(aFields(1))
                        Case "LOCK_MODE"
                            sLockMode = UCase(Trim(aFields(1)))
                    End Select
                End If
            Case "SECONDARY"
                If UBound(aFields) >= 0 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrSecTables(iSecCount)
                    arrSecTables(iSecCount) = Trim(aFields(0))
                    iSecCount = iSecCount + 1
                End If
            Case "LOCKARGS"
                If UBound(aFields) >= 1 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrLockArgs(iArgCount)
                    arrLockArgs(iArgCount) = Trim(aFields(0)) & vbTab & Trim(aFields(1))
                    iArgCount = iArgCount + 1
                End If
        End Select
    End If
Loop
oFile.Close

WScript.Echo "INFO: Primary table: " & sPrimaryTable & ", Lock mode: " & sLockMode
WScript.Echo "INFO: Secondary tables: " & iSecCount & ", Lock arguments: " & iArgCount

' ------ 5. Tables tab — Fill primary table and lock mode --------------------
WScript.Echo "INFO: Setting primary table..."
On Error Resume Next

' Navigate to Tables tab
oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD25/tabpTABLES").select
WScript.Sleep 500

Dim sTabBase
sTabBase = "wnd[0]/usr/tabsTABSTRIP_DD25/tabpTABLES/ssubSS_TABLES:SAPLSD31:"

' Primary table in first row
oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0,0]").Text = UCase(sPrimaryTable)
If Err.Number <> 0 Then
    Err.Clear
    oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0,0]").Text = UCase(sPrimaryTable)
End If

' Lock mode dropdown
If sLockMode <> "" Then
    oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/cmbDD26E-ENQMODE[1,0]").Key = sLockMode
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/cmbDD26E-ENQMODE[1,0]").Key = sLockMode
    End If
End If

If Err.Number <> 0 Then
    WScript.Echo "WARNING: Could not set primary table/lock mode: " & Err.Description
    Err.Clear
End If

oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 6. Add secondary tables (if any) ------------------------------------
Dim i, iRow
If iSecCount > 0 Then
    WScript.Echo "INFO: Adding secondary tables..."
    For i = 0 To iSecCount - 1
        iRow = i + 1   ' Row 0 is primary table
        oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0," & iRow & "]").Text = UCase(arrSecTables(i))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0," & iRow & "]").Text = UCase(arrSecTables(i))
        End If
        If Err.Number <> 0 Then
            WScript.Echo "WARNING: Could not add secondary table at row " & iRow & ": " & Err.Description
            Err.Clear
        Else
            WScript.Echo "INFO:   Secondary table: " & UCase(arrSecTables(i))
        End If
        WScript.Sleep 200
        
        If (iRow + 1) Mod 14 = 0 Then
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 300
        End If
    Next
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 7. Lock Arguments tab — Fill lock parameters -------------------------
If iArgCount > 0 Then
    WScript.Echo "INFO: Setting lock arguments..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD25/tabpLOCKARGS").select
    WScript.Sleep 500
    
    Dim sArgBase, aArgFields
    sArgBase = "wnd[0]/usr/tabsTABSTRIP_DD25/tabpLOCKARGS/ssubSS_LOCKARGS:SAPLSD31:"
    
    For i = 0 To iArgCount - 1
        aArgFields = Split(arrLockArgs(i), vbTab)
        iRow = i
        
        ' Table name
        oSession.findById(sArgBase & "0901/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-TABNAME[0," & iRow & "]").Text = UCase(aArgFields(0))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sArgBase & "0601/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-TABNAME[0," & iRow & "]").Text = UCase(aArgFields(0))
        End If
        ' Field name
        oSession.findById(sArgBase & "0901/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-FIELDNAME[1," & iRow & "]").Text = UCase(aArgFields(1))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sArgBase & "0601/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-FIELDNAME[1," & iRow & "]").Text = UCase(aArgFields(1))
        End If
        
        If Err.Number <> 0 Then
            WScript.Echo "WARNING: Could not set lock argument at row " & iRow & ": " & Err.Description
            Err.Clear
        Else
            WScript.Echo "INFO:   Lock argument: " & UCase(aArgFields(0)) & "-" & UCase(aArgFields(1))
        End If
        WScript.Sleep 200
        
        If (iRow + 1) Mod 14 = 0 Then
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 300
        End If
    Next
    
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    Err.Clear
    On Error GoTo 0
End If

' ------ 8. Check (Ctrl+F2) before saving ------------------------------------
WScript.Echo "INFO: Checking lock object consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "ERROR: Check failed - " & sCheckMsg
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Echo "INFO: Check passed."

' ------ 9. Save (F11) -------------------------------------------------------
WScript.Echo "INFO: Saving lock object..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Saved."

' ------ 9. Activate (Ctrl+F3) -----------------------------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 3000
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; final-status read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

WScript.Echo "SUCCESS: Lock object " & UCase(OBJECT_NAME) & " created and activated in SAP."
WScript.Quit 0
