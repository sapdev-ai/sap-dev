' =============================================================================
' sap_se11_view_update.vbs  -  SAP GUI Scripting: Update view in SE11
'
' Generated by the sap-se11 skill.
' Opens an existing view in Change mode, updates tables, join conditions,
' and view fields from the definition file, saves, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%      View name             e.g. "ZVITEM"
'   %%DEFINITION_FILE%%  Absolute path to tab-delimited definition
'
' Definition file format (same as create — see sap_se11_view_create.vbs)
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' =============================================================================

Option Explicit

Const OBJECT_NAME     = "%%OBJECT_NAME%%"
Const DEFINITION_FILE = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE     = "%%PACKAGE%%"
Const SAP_TRANSPORT   = "%%TRANSPORT%%"

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile read below accept UTF-8 inputs from upstream tools
' (sap-docs-extract, the Write tool, hand-authored TSVs) — full docstring
' in sap_se11_table_create.vbs. Always returns a UTF-16 LE path so callers
' must open the result with mode -1.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

Dim oSAPGUI, oApplication, oSession
Dim oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApplication = oSAPGUI.GetScriptingEngine
If oApplication Is Nothing Then
    WScript.Echo "ERROR: Could not get SAP Scripting Engine."
    WScript.Quit 1
End If

Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApplication.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to SE11 and open view in Change mode --------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-VIMA").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-VIMA_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Opening view in Change mode: " & UCase(OBJECT_NAME)
oSession.findById("wnd[0]/usr/btnPUSHEDIT").press
WScript.Sleep 1500

' ------ 2a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") — pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 2b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S to provoke any "Prompt for local Workbench request" popup.
' (a) wnd[1] with ctxtKO008-TRKORR → fill SAP_TRANSPORT, Enter.
' (b) Other popup → Enter to dismiss.
' (c) No popup → object is local ($TMP) or already locked to a modifiable TR.
' Diagnostics: TADIR-DEVCLASS, E071, E070-TRSTATUS.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oPreTR Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SE11 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            WScript.Quit 1
        End If
        oPreTR.Text = SAP_TRANSPORT
        WScript.Echo "INFO: Pre-save TR popup detected — entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) — pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    WScript.Echo "INFO: No pre-save popup — object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 3. Parse definition file into sections ------------------------------
Dim oFSO, oFile, sLine
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If

Dim arrTables()
Dim arrJoins()
Dim arrViewFields()
Dim iTableCount, iJoinCount, iFieldCount
iTableCount = 0 : iJoinCount = 0 : iFieldCount = 0

Dim sSection, aFields
sSection = ""

Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
Do While Not oFile.AtEndOfStream
    sLine = Trim(oFile.ReadLine)
    If sLine = "" Then
        ' skip blank lines
    ElseIf UCase(sLine) = "TABLES" Then
        sSection = "TABLES"
    ElseIf UCase(sLine) = "JOIN_CONDITIONS" Then
        sSection = "JOINS"
    ElseIf UCase(sLine) = "VIEW_FIELDS" Then
        sSection = "FIELDS"
    Else
        aFields = Split(sLine, vbTab)
        Select Case sSection
            Case "TABLES"
                If UBound(aFields) >= 0 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrTables(iTableCount)
                    arrTables(iTableCount) = Trim(aFields(0))
                    iTableCount = iTableCount + 1
                End If
            Case "JOINS"
                If UBound(aFields) >= 3 And UCase(Trim(aFields(0))) <> "TABLE1" Then
                    ReDim Preserve arrJoins(iJoinCount)
                    arrJoins(iJoinCount) = Trim(aFields(0)) & vbTab & Trim(aFields(1)) & vbTab & Trim(aFields(2)) & vbTab & Trim(aFields(3))
                    iJoinCount = iJoinCount + 1
                End If
            Case "FIELDS"
                If UBound(aFields) >= 1 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrViewFields(iFieldCount)
                    arrViewFields(iFieldCount) = Trim(aFields(0)) & vbTab & Trim(aFields(1))
                    iFieldCount = iFieldCount + 1
                End If
        End Select
    End If
Loop
oFile.Close

WScript.Echo "INFO: Parsed " & iTableCount & " tables, " & iJoinCount & " joins, " & iFieldCount & " view fields."

' ------ 4. Tables tab — Scan existing + add new tables -----------------------
WScript.Echo "INFO: Updating base tables..."
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD26/tabpTABLES").select
WScript.Sleep 500

' Scan existing tables
Dim dictExistingTables
Set dictExistingTables = CreateObject("Scripting.Dictionary")
dictExistingTables.CompareMode = 1  ' Case-insensitive

Dim sTabBase, sExistVal, iScanRow
sTabBase = "wnd[0]/usr/tabsTABSTRIP_DD26/tabpTABLES/ssubSS_TABLES:SAPLSD31:"
iScanRow = 0

Do While True
    sExistVal = ""
    Err.Clear
    sExistVal = oSession.findById(sTabBase & "0801/tblSAPLSD31TC_TABLE_TAB/ctxtDD26S-TABNAME[0," & iScanRow & "]").Text
    If Err.Number <> 0 Then
        Err.Clear
        sExistVal = oSession.findById(sTabBase & "0601/tblSAPLSD31TC_TABLE_TAB/ctxtDD26S-TABNAME[0," & iScanRow & "]").Text
        If Err.Number <> 0 Then
            Err.Clear
            Exit Do
        End If
    End If
    If Trim(sExistVal) = "" Then Exit Do
    dictExistingTables(UCase(Trim(sExistVal))) = True
    iScanRow = iScanRow + 1
    If iScanRow Mod 14 = 0 Then
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
        WScript.Sleep 300
    End If
Loop

Dim iNextRow, i
iNextRow = iScanRow

For i = 0 To iTableCount - 1
    If Not dictExistingTables.Exists(UCase(arrTables(i))) Then
        oSession.findById(sTabBase & "0801/tblSAPLSD31TC_TABLE_TAB/ctxtDD26S-TABNAME[0," & iNextRow & "]").Text = UCase(arrTables(i))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sTabBase & "0601/tblSAPLSD31TC_TABLE_TAB/ctxtDD26S-TABNAME[0," & iNextRow & "]").Text = UCase(arrTables(i))
        End If
        If Err.Number = 0 Then
            WScript.Echo "INFO:   Added table: " & UCase(arrTables(i))
            iNextRow = iNextRow + 1
        Else
            WScript.Echo "WARNING: Could not add table " & UCase(arrTables(i)) & ": " & Err.Description
            Err.Clear
        End If
        WScript.Sleep 200
        If iNextRow Mod 14 = 0 Then
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 300
        End If
    Else
        WScript.Echo "INFO:   Table already exists: " & UCase(arrTables(i))
    End If
Next

oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

' ------ 5. View Fields tab — Scan existing + add new fields ------------------
If iFieldCount > 0 Then
    WScript.Echo "INFO: Updating view fields..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD26/tabpFIELDS").select
    WScript.Sleep 500
    
    Dim dictExistingFields
    Set dictExistingFields = CreateObject("Scripting.Dictionary")
    dictExistingFields.CompareMode = 1
    
    Dim sFieldBase, sExistTab, sExistFld
    sFieldBase = "wnd[0]/usr/tabsTABSTRIP_DD26/tabpFIELDS/ssubSS_FIELDS:SAPLSD31:"
    iScanRow = 0
    
    Do While True
        sExistTab = "" : sExistFld = ""
        Err.Clear
        sExistFld = oSession.findById(sFieldBase & "0601/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-FIELDNAME[1," & iScanRow & "]").Text
        If Err.Number <> 0 Then
            Err.Clear
            sExistFld = oSession.findById(sFieldBase & "0801/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-FIELDNAME[1," & iScanRow & "]").Text
            If Err.Number <> 0 Then
                Err.Clear
                Exit Do
            End If
        End If
        If Trim(sExistFld) = "" Then Exit Do
        
        sExistTab = oSession.findById(sFieldBase & "0601/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-TABNAME[0," & iScanRow & "]").Text
        If Err.Number <> 0 Then
            Err.Clear
            sExistTab = oSession.findById(sFieldBase & "0801/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-TABNAME[0," & iScanRow & "]").Text
            Err.Clear
        End If
        
        dictExistingFields(UCase(Trim(sExistTab)) & "~" & UCase(Trim(sExistFld))) = True
        iScanRow = iScanRow + 1
        If iScanRow Mod 14 = 0 Then
            oSession.findById("wnd[0]").sendVKey VKEY_ENTER
            WScript.Sleep 300
        End If
    Loop
    
    iNextRow = iScanRow
    Dim aVFFields, sKey
    
    For i = 0 To iFieldCount - 1
        aVFFields = Split(arrViewFields(i), vbTab)
        sKey = UCase(aVFFields(0)) & "~" & UCase(aVFFields(1))
        
        If Not dictExistingFields.Exists(sKey) Then
            oSession.findById(sFieldBase & "0601/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-TABNAME[0," & iNextRow & "]").Text = UCase(aVFFields(0))
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById(sFieldBase & "0801/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-TABNAME[0," & iNextRow & "]").Text = UCase(aVFFields(0))
            End If
            oSession.findById(sFieldBase & "0601/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-FIELDNAME[1," & iNextRow & "]").Text = UCase(aVFFields(1))
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById(sFieldBase & "0801/tblSAPLSD31TC_FIELD_TAB/ctxtDD27S-FIELDNAME[1," & iNextRow & "]").Text = UCase(aVFFields(1))
            End If
            
            If Err.Number = 0 Then
                WScript.Echo "INFO:   Added field: " & UCase(aVFFields(0)) & "-" & UCase(aVFFields(1))
                iNextRow = iNextRow + 1
            Else
                WScript.Echo "WARNING: Could not add field " & sKey & ": " & Err.Description
                Err.Clear
            End If
            WScript.Sleep 200
            If iNextRow Mod 14 = 0 Then
                oSession.findById("wnd[0]").sendVKey VKEY_ENTER
                WScript.Sleep 300
            End If
        Else
            WScript.Echo "INFO:   Field already exists: " & sKey
        End If
    Next
    
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    Err.Clear
    On Error GoTo 0
End If

' ------ 6. Check (Ctrl+F2) before saving ------------------------------------
WScript.Echo "INFO: Checking view consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

' Handle "Save object?" popup (view check requires save first)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim sChkDiag1
    sChkDiag1 = ""
    sChkDiag1 = oSession.findById("wnd[1]/usr/txtSPOP-DIAGNOSE1").Text
    If Err.Number <> 0 Then sChkDiag1 = "" : Err.Clear
    If InStr(sChkDiag1, "saved") > 0 Then
        WScript.Echo "INFO: Check requires save - pressing Yes..."
        oSession.findById("wnd[1]/usr/btnSPOP-OPTION1").press
        WScript.Sleep 2000
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
                oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
                oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
            ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
                oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
                oSession.findById("wnd[1]/tbar[0]/btn[8]").press
                WScript.Sleep 1000
                oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
                oSession.findById("wnd[2]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
                oSession.findById("wnd[1]/tbar[0]/btn[0]").press
                WScript.Sleep 1000
            Else
                oSession.findById("wnd[1]/tbar[0]/btn[7]").press
                WScript.Sleep 1000
            End If
        End If
    Else
        Err.Clear
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0

If oSession.Info.Program = "SAPMSSY0" Then
    WScript.Echo "INFO: Reading check log..."
    Dim bCheckError
    bCheckError = False
    Dim sCheckErrors
    sCheckErrors = ""
    On Error Resume Next
    Dim oChkUsr, oChkChild, sChkText
    Set oChkUsr = oSession.findById("wnd[0]/usr")
    If Err.Number = 0 Then
        For Each oChkChild In oChkUsr.Children
            sChkText = ""
            sChkText = oChkChild.Text
            If Err.Number <> 0 Then sChkText = "" : Err.Clear
            If InStr(sChkText, "resulted in errors") > 0 Or _
               InStr(sChkText, "is inconsistent") > 0 Then
                bCheckError = True
            End If
            If sChkText <> "" Then
                Dim sChkId
                sChkId = oChkChild.Id
                If Err.Number <> 0 Then sChkId = "" : Err.Clear
                If InStr(sChkId, "lbl[13,") > 0 Then
                    sCheckErrors = sCheckErrors & sChkText & vbCrLf
                End If
            End If
        Next
    End If
    Err.Clear
    On Error GoTo 0

    oSession.findById("wnd[0]").sendVKey VKEY_F3_BACK
    WScript.Sleep 1000

    If bCheckError Then
        WScript.Echo "ERROR: Check found errors:"
        WScript.Echo sCheckErrors
        WScript.Quit 1
    Else
        WScript.Echo "INFO: Check passed."
    End If
Else
    Dim sChkSbarMsg, sChkSbarType
    On Error Resume Next
    sChkSbarMsg  = oSession.findById("wnd[0]/sbar").Text
    sChkSbarType = oSession.findById("wnd[0]/sbar").MessageType
    On Error GoTo 0
    If sChkSbarType = "E" Then
        WScript.Echo "ERROR: Check failed - " & sChkSbarMsg
        WScript.Quit 1
    End If
    WScript.Echo "INFO: Check passed."
End If

' ------ 7. Save (F11) --- (may be already saved by Check) --------------------
WScript.Echo "INFO: Saving view..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Saved."

' ------ 7. Activate (Ctrl+F3) -----------------------------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 3000
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

WScript.Echo "SUCCESS: View " & UCase(OBJECT_NAME) & " updated and activated in SAP."
WScript.Quit 0
