' =============================================================================
' sap_se11_structure_create.vbs  -  SAP GUI Scripting: Create structure in SE11
'
' Generated by the sap-se11 skill.
' Navigates to SE11, creates a new structure under the "Data type" radio,
' handles sub-type popup (chooses "Structure"), fills components from
' definition file, saves, activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%          Structure name        e.g. "ZSSTRUCT001"
'   %%OBJECT_DESCRIPTION%%   Short description     e.g. "My Structure"
'   %%DEFINITION_FILE%%      Absolute path to tab-delimited component list
'
' Definition file format (tab-delimited, first line is header):
'   COMPONENT	DATAELEMENT	DATATYPE	LENGTH	DECIMALS	DESCRIPTION
'   BUKRS	BUKRS				Company Code
'   WERKS	WERKS_D				Plant
'   CUSTOM1		CHAR	20		Custom Field
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' =============================================================================

Option Explicit

Const OBJECT_NAME        = "%%OBJECT_NAME%%"
Const OBJECT_DESCRIPTION = "%%OBJECT_DESCRIPTION%%"
Const DEFINITION_FILE    = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE        = "%%PACKAGE%%"
Const SAP_TRANSPORT      = "%%TRANSPORT%%"
' Enhancement category to set BEFORE Activate so SAP doesn't warn / pop up.
' Accepted: NOT_EXTENSIBLE (default), FLAT, FLAT_NUMERIC, DEEP. See
' sap_se11_set_enh_category.vbs for the full mapping.
Const ENH_CATEGORY       = "%%ENHANCEMENT_CATEGORY%%"
Const SESSION_PATH       = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default
Const POST_ACTIVATE_VERIFY_PS1 = "%%POST_ACTIVATE_VERIFY_PS1%%"   ' empty = skip verify

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%POST_ACTIVATE_VERIFY_VBS%%", 1).ReadAll()

' Include SE11-local enhancement-category helper (SetEnhancementCategory).
' Used after Save and before Activate so the activation step doesn't
' surface the "Structure is not flagged for any enhancement category"
' warning popup.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ENH_CATEGORY_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile(..., -1) reads below accept UTF-8 inputs from
' upstream tools (sap-docs-extract, the Write tool, hand-authored TSVs)
' as well as the legacy UTF-16 LE format. Full docstring in
' sap_se11_table_create.vbs.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and create structure ----------------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-DDTYPE").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-DDTYPE_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Creating structure: " & UCase(OBJECT_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnPUSHADD").press
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Create button: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 3. Handle sub-type popup - select Structure -------------------------
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Sub-type popup detected - selecting Structure..."
    oSession.findById("wnd[1]/usr/radD_100-STRU").select
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById("wnd[1]/usr/radRSDD_STTB-DTEFLAG_ST").select
    End If
    WScript.Sleep 300
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

' --- Lock the SAP session UI for the fill structure fields + save + activate critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the fill structure fields + save + activate critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 4. Fill description -------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/txtDD02D-DDTEXT").Text = OBJECT_DESCRIPTION
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not fill structure description."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 5. Switch to Components tab and fill from definition file -----------
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsTAB_STRIP/tabpDEF").select
WScript.Sleep 500
Err.Clear
On Error GoTo 0

Dim oFSO, oFile, sLine, aFields
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ---- Pre-validate definition file: reject direct DATATYPE without DATAELEMENT ----
'
' SAP GUI Scripting cannot drive DD03P-DATATYPE / -LENG / -DECIMALS in the
' structure components grid: those columns are Changeable=False regardless
' of the row's REFTYPE combobox or the "Component Type" toolbar button.
' Verified live with /sap-gui-inspect on S/4HANA 1909.
'
' If we let the row through, the GUI silently drops the type, the structure
' is saved with a typeless component, and activation later fails with a
' "Check Structure" popup that the operator never sees (the post-activate
' lock-release sweep dismisses it via F12).
'
' Catch it here, before any GUI input, with a clear remediation message.
Dim oValFile, sValLine, aValFields, iValRow, sValComp, sValDE, sValDT
Set oValFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
If Not oValFile.AtEndOfStream Then oValFile.ReadLine ' header
iValRow = 0
Do While Not oValFile.AtEndOfStream
    sValLine = oValFile.ReadLine
    If Trim(sValLine) <> "" Then
        aValFields = Split(sValLine, vbTab)
        sValComp = "" : sValDE = "" : sValDT = ""
        If UBound(aValFields) >= 0 Then sValComp = Trim(aValFields(0))
        If UBound(aValFields) >= 1 Then sValDE   = Trim(aValFields(1))
        If UBound(aValFields) >= 2 Then sValDT   = Trim(aValFields(2))
        If sValComp <> "" _
           And Left(sValComp, 1) <> "." _
           And sValDE = "" And sValDT <> "" Then
            WScript.Echo "ERROR: Component '" & sValComp & "' (row " & iValRow & ") uses direct DATATYPE='" & sValDT & "'."
            WScript.Echo "       SAP GUI Scripting cannot fill the DD03P-DATATYPE column (Changeable=False)."
            WScript.Echo "       Predefine a data element via /sap-se11 DATAELEMENT and reference it"
            WScript.Echo "       in the DATAELEMENT (col 2) of this row, then re-run."
            oValFile.Close
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        iValRow = iValRow + 1
    End If
Loop
oValFile.Close

Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)

' Skip header
If Not oFile.AtEndOfStream Then oFile.ReadLine

Dim iRow, sCompName, sDataElement, sDataType, sLength, sDecimals, sDescription
Dim sGridBase
sGridBase = "wnd[0]/usr/tabsTAB_STRIP/tabpDEF/ssubTS_SCREEN:SAPLSD41:2301/tblSAPLSD41TC0"

' --- Version-aware column index resolution ---
' The structure components grid has different column layouts across SAP releases.
' Observed:
'   S/4HANA   : FIELDNAME=0, ROLLNAME=2, DATATYPE=3, LENG=4, DECIMALS=5, DDTEXT=7
'   ECC       : FIELDNAME=0, ROLLNAME=4, DATATYPE=5, LENG=6, DECIMALS=7, DDTEXT=8
'                   (extra columns: KEYFLAG=1, NOTNULL=2, F_REFTYPE combo=3, GROUPNAME=9)
' Resolve dynamically by probing column indices 0..15 for each known field name.
' This avoids hard-coded version branches and is forward-compatible.
Dim COL_FIELDNAME, COL_ROLLNAME, COL_DATATYPE, COL_LENG, COL_DECIMALS, COL_DDTEXT
COL_FIELDNAME = ResolveGridCol(oSession, sGridBase, "txt",  "DD03P_D-FIELDNAME")
COL_ROLLNAME  = ResolveGridCol(oSession, sGridBase, "ctxt", "DD03P_D-ROLLNAME")
COL_DATATYPE  = ResolveGridCol(oSession, sGridBase, "txt",  "DD02D-DATATYPE")
COL_LENG      = ResolveGridCol(oSession, sGridBase, "txt",  "DD03P_D-LENG")
COL_DECIMALS  = ResolveGridCol(oSession, sGridBase, "txt",  "DD03P_D-DECIMALS")
COL_DDTEXT    = ResolveGridCol(oSession, sGridBase, "txt",  "DD03P_D-DDTEXT")
WScript.Echo "INFO: Grid columns resolved: FIELDNAME=" & COL_FIELDNAME & " ROLLNAME=" & COL_ROLLNAME & " DATATYPE=" & COL_DATATYPE & " LENG=" & COL_LENG & " DECIMALS=" & COL_DECIMALS & " DDTEXT=" & COL_DDTEXT
If COL_FIELDNAME < 0 Or COL_ROLLNAME < 0 Then
    WScript.Echo "ERROR: Could not locate FIELDNAME or ROLLNAME column in grid. Layout differs from known SAP releases."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

iRow = 0
Do While Not oFile.AtEndOfStream
    sLine = oFile.ReadLine
    If Trim(sLine) = "" Then
        ' skip
    Else
        aFields = Split(sLine, vbTab)
        sCompName    = ""
        sDataElement = ""
        sDataType    = ""
        sLength      = ""
        sDecimals    = ""
        sDescription = ""

        If UBound(aFields) >= 0 Then sCompName    = Trim(aFields(0))
        If UBound(aFields) >= 1 Then sDataElement = Trim(aFields(1))
        If UBound(aFields) >= 2 Then sDataType    = Trim(aFields(2))
        If UBound(aFields) >= 3 Then sLength      = Trim(aFields(3))
        If UBound(aFields) >= 4 Then sDecimals    = Trim(aFields(4))
        If UBound(aFields) >= 5 Then sDescription = Trim(aFields(5))

        If sCompName <> "" Then
            WScript.Echo "INFO: Adding component [" & iRow & "]: " & sCompName

            On Error Resume Next
            oSession.findById(sGridBase & "/txtDD03P_D-FIELDNAME[" & COL_FIELDNAME & "," & iRow & "]").Text = UCase(sCompName)

            If sDataElement <> "" Then
                oSession.findById(sGridBase & "/ctxtDD03P_D-ROLLNAME[" & COL_ROLLNAME & "," & iRow & "]").Text = UCase(sDataElement)
            Else
                If sDataType <> "" And COL_DATATYPE >= 0 Then
                    oSession.findById(sGridBase & "/txtDD02D-DATATYPE[" & COL_DATATYPE & "," & iRow & "]").Text = UCase(sDataType)
                End If
                If sLength <> "" And COL_LENG >= 0 Then
                    oSession.findById(sGridBase & "/txtDD03P_D-LENG[" & COL_LENG & "," & iRow & "]").Text = sLength
                End If
                If sDecimals <> "" And COL_DECIMALS >= 0 Then
                    oSession.findById(sGridBase & "/txtDD03P_D-DECIMALS[" & COL_DECIMALS & "," & iRow & "]").Text = sDecimals
                End If
                If sDescription <> "" And COL_DDTEXT >= 0 Then
                    oSession.findById(sGridBase & "/txtDD03P_D-DDTEXT[" & COL_DDTEXT & "," & iRow & "]").Text = sDescription
                End If
            End If

            If Err.Number <> 0 Then
                WScript.Echo "WARNING: Error filling component row " & iRow & ": " & Err.Description
                Err.Clear
            End If
            On Error GoTo 0

            iRow = iRow + 1
            If iRow Mod 23 = 0 Then
                oSession.findById("wnd[0]").sendVKey VKEY_ENTER
                WScript.Sleep 500
            End If
        End If
    End If
Loop
oFile.Close

WScript.Echo "INFO: " & iRow & " components added."

' ------ 5b. Set Enhancement Category (matches operator recording 2026-05-11)
'
' Reference: C:\Temp\Record_SE11_EnhancementCategory_03.vbs
'
' The recording's canonical sequence on S/4HANA 1909 JA:
'   1. Fill description
'   2. Fill component (ROLLNAME cell, with setFocus + caretPosition)
'   3. menu[4]/menu[7]   <- click Extras > Enhancement Category
'   4. wnd[1]/tbar[0]/btn[0].press   <- ONE info popup ("not classified")
'   5. wnd[1]/usr/radDESED7-R_FINAL.select   <- now on radio dialog
'   6. wnd[1]/tbar[0]/btn[0].press   <- Copy commits selection
'   7. sendVKey 11   <- Save (Ctrl+S)
'
' Critical observations from the recording vs prior failed test:
'   - No trailing sendVKey VKEY_ENTER after the last component (the
'     auto-validate triggers an extra info popup that prevents the menu
'     click from reaching the radio dialog).
'   - The setFocus + caretPosition on the last component's ROLLNAME cell
'     puts SAP into the same state the recording captured.
'
' Set focus on the last component's ROLLNAME cell to match the recording's
' starting state before menu click. The grid path is the same one used by
' the component-fill loop above.
On Error Resume Next
Dim sLastRowFocus
sLastRowFocus = sGridBase & "/ctxtDD03P_D-ROLLNAME[" & COL_ROLLNAME & "," & (iRow - 1) & "]"
oSession.findById(sLastRowFocus).SetFocus
Err.Clear
On Error GoTo 0

Call SetEnhancementCategory(oSession, ENH_CATEGORY, SAP_TRANSPORT)

' ------ 6. Check (Ctrl+F2) before saving ------------------------------------
WScript.Echo "INFO: Checking structure consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "ERROR: Check failed - " & sCheckMsg
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Echo "INFO: Check passed."

' Dismiss any info/warning popup that check may have produced
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Dismissing check popup..."
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 800
End If
On Error GoTo 0

' ------ 7. Save (F11) -------------------------------------------------------
WScript.Echo "INFO: Saving structure..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
If Err.Number <> 0 Then
    Err.Clear
    ' Fallback: try Save toolbar button
    oSession.findById("wnd[0]/tbar[0]/btn[11]").press
End If
On Error GoTo 0
WScript.Sleep 1500

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Saved."

' ------ 7. Activate (Ctrl+F3) -----------------------------------------------
'
' Activation can trigger up to three chained popups, in arbitrary order on
' different SAP releases:
'   (a) Information popup - press Enter
'   (b) Enhancement Category popup - select radRSDD_STTB-ENHCAT_2 + Enter
'   (c) Check Structure popup with an error list - we MUST echo its content
'       before clearing it, otherwise the operator gets a useless "Action
'       was canceled" with no explanation. The post-activate RFC verifier
'       (Step 5d) will still flag the failure, but echoing the popup gives
'       the operator something actionable to work with.
'
' We loop up to 5 times, echoing each popup's title + status bar text +
' visible label text, and dispatching by component ID:
'   - Enhancement Category: radRSDD_STTB-ENHCAT_2 present -> select + Enter
'   - Check Structure / inconsistency popup: echo, then sendVKey 12 (Cancel)
'   - Anything else: sendVKey 0 (Enter) as best-effort dismiss
'
WScript.Echo "INFO: Activating..."
On Error Resume Next
' BUGFIX (sap-dev-init 2026-05-11): pressing tbar[1]/btn[27] silently no-ops on
' some S/4HANA 1909 sessions (JA & EN) when the editor focus is on the field
' grid. The Save action seems to leave focus where Activate-button click is
' swallowed but Ctrl+F3 (sendVKey 27) is always honoured. Use sendVKey for
' robustness; functionally equivalent on every release.
oSession.findById("wnd[0]").sendVKey 27
WScript.Sleep 3000

' Loop handles up to 6 chained popups, in any order. Identification is by
' DDIC component ID per language_independence_rules.md (titles below are
' for diagnostics only):
'
'   (a) Create Object Directory Entry (KO007) - wnd[N]/usr/ctxtKO007-L_DEVCLASS
'       -> Save (btn[0]) to commit TADIR registration. Package was already
'          set during the save flow earlier; this dialog just confirms.
'   (b) Enhancement Category - wnd[N]/usr/radRSDD_STTB-ENHCAT_2
'       -> select 'Cannot Be Enhanced' + Enter.
'   (c) Warning during activation - wnd[N] (no specific DDIC marker; SAPLSPO1
'       message popup) - Enter dismisses; activation proceeds.
'   (d) Anything else - Enter once; if still present, Cancel (F12).
Dim iAct, sActWin, sActTitle, sSbarTxt, sSbarType, sActWnd
For iAct = 1 To 6
    sActWin = oSession.ActiveWindow.Id
    If Right(sActWin, 6) = "wnd[0]" Then Exit For

    ' Find the popup window prefix (everything up to and including the wnd[N] segment).
    ' We need this because the popup may be wnd[1] OR wnd[2] (chained popups).
    sActWnd = sActWin
    Dim posWnd : posWnd = InStrRev(sActWnd, "/wnd[")
    If posWnd > 0 Then sActWnd = Mid(sActWnd, posWnd + 1)  ' yields "wnd[N]"
    sActWnd = "wnd[" & Mid(sActWnd, 5)  ' normalise

    sActTitle = oSession.ActiveWindow.Text
    If Err.Number <> 0 Then sActTitle = "(unreadable)" : Err.Clear
    sSbarTxt  = oSession.findById("wnd[0]/sbar").Text
    sSbarType = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear

    WScript.Echo "INFO: Activate popup " & iAct & " on " & sActWin & _
                 " title='" & sActTitle & "'" & _
                 " sbar='" & sSbarTxt & "' (type=" & sSbarType & ")"

    ' (a) Create Object Directory Entry?
    Err.Clear
    Dim ko007 : Set ko007 = Nothing
    Set ko007 = oSession.findById(sActWnd & "/usr/ctxtKO007-L_DEVCLASS")
    If Err.Number = 0 And Not (ko007 Is Nothing) Then
        ' Fill package + transport if non-local. The activate-time ODE dialog
        ' does NOT inherit the values from the save-time ODE dialog -- it
        ' opens with empty fields and sbar warns "Assign a package" if we
        ' just press Save. Re-fill explicitly.
        If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" Then
            WScript.Echo "INFO:   -> Create Object Directory Entry; filling package " & SAP_PACKAGE & "."
            ko007.Text = SAP_PACKAGE
            oSession.findById(sActWnd & "/tbar[0]/btn[0]").press
            WScript.Sleep 1000
            Err.Clear
            If SAP_TRANSPORT <> "" Then
                Dim ko008 : Set ko008 = Nothing
                Set ko008 = oSession.findById(sActWnd & "/usr/ctxtKO008-TRKORR")
                If Err.Number = 0 And Not (ko008 Is Nothing) Then
                    WScript.Echo "INFO:   -> Filling transport " & SAP_TRANSPORT & "."
                    ko008.Text = SAP_TRANSPORT
                    oSession.findById(sActWnd & "/tbar[0]/btn[0]").press
                    WScript.Sleep 1200
                End If
                Err.Clear
            End If
        Else
            WScript.Echo "INFO:   -> Create Object Directory Entry ($TMP); pressing Local Object."
            oSession.findById(sActWnd & "/tbar[0]/btn[7]").press
            WScript.Sleep 1200
        End If
        Err.Clear
    Else
        Err.Clear
        ' (b) Enhancement Category?
        Dim ehc : Set ehc = Nothing
        Set ehc = oSession.findById(sActWnd & "/usr/radRSDD_STTB-ENHCAT_2")
        If Err.Number = 0 And Not (ehc Is Nothing) Then
            WScript.Echo "INFO:   -> Enhancement Category; selecting 'Cannot Be Enhanced'."
            ehc.select
            oSession.findById(sActWnd).sendVKey 0
            WScript.Sleep 1200
            Err.Clear
        Else
            Err.Clear
            ' (c1) 3-button SPOP popup (Yes/No/Cancel) -- most often the
            '      "Warning during activation -- display activation log?" popup.
            '      Detect via btnSPOP-OPTION2 + btnSPOP-OPTION3 both present.
            '      Press OPTION2 (No) to SKIP the log viewer and continue
            '      activation. Answering Yes here opens a log sub-window that
            '      blocks the script. (The activation log is still captured
            '      separately by sap_activation_log.vbs after this loop if
            '      sbar.MessageType ends up E/A, so we don't lose diagnostics.)
            Dim oSpop2 : Set oSpop2 = Nothing
            Dim oSpop3 : Set oSpop3 = Nothing
            Set oSpop2 = oSession.findById(sActWnd & "/usr/btnSPOP-OPTION2")
            Set oSpop3 = oSession.findById(sActWnd & "/usr/btnSPOP-OPTION3")
            If Err.Number = 0 And Not (oSpop2 Is Nothing) And Not (oSpop3 Is Nothing) Then
                WScript.Echo "INFO:   -> 3-button SPOP popup (Yes/No/Cancel); pressing OPTION2 (No) to skip activation log."
                oSpop2.press
                WScript.Sleep 1500
                Err.Clear
            Else
                Err.Clear
                ' (c2) 2-button SPOP popup (e.g. "Check Structure: activate
                '      inconsistent changes?"). Detect via btnSPOP-OPTION1 only
                '      (no OPTION3). Press OPTION1 (Yes) -- Enter alone does
                '      nothing on these popups because no button has default
                '      focus; sbar would show "Choose a valid function".
                Dim oSpopYes : Set oSpopYes = Nothing
                Set oSpopYes = oSession.findById(sActWnd & "/usr/btnSPOP-OPTION1")
                If Err.Number = 0 And Not (oSpopYes Is Nothing) Then
                    WScript.Echo "INFO:   -> 2-button SPOP popup; pressing OPTION1 (Yes)."
                    oSpopYes.press
                    WScript.Sleep 1500
                    Err.Clear
                Else
                    Err.Clear
                    ' (d) Generic informational popup -- Enter; if persistent, Cancel.
                    WScript.Echo "INFO:   -> unknown popup, sending Enter."
                    oSession.findById(sActWnd).sendVKey 0
                    WScript.Sleep 1000
                    Err.Clear
                    If oSession.ActiveWindow.Id = "/app/con[0]/ses[0]/" & sActWnd Then
                        WScript.Echo "INFO:      popup persisted; sending Cancel (F12)."
                        oSession.findById(sActWnd).sendVKey 12
                        WScript.Sleep 1000
                        Err.Clear
                    End If
                End If
            End If
        End If
    End If
Next
On Error GoTo 0

' --- Release the session UI lock; final-status read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Or sFinalType = "A" Then
    WScript.Echo "ERROR: Activation failed (sbar Type=" & sFinalType & ") - " & sFinalMsg
    WScript.Quit 1
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

' Phase 4.3: SUCCESS_GUI replaced by the actual post-activate RFC verify.
' Previous design printed SUCCESS_GUI and left the verify to the orchestrator,
' which nothing wired -- so a "Action was canceled" sbar with non-E MessageType
' (lock-release sweep dismissing a popup) propagated as success. Now the
' verify runs inline; INACTIVE/MISSING fail-closed here.
PostActivateVerifyOrFail POST_ACTIVATE_VERIFY_PS1, "STRUCTURE", OBJECT_NAME

WScript.Echo "SUCCESS: Structure " & UCase(OBJECT_NAME) & " created and activated in SAP."
WScript.Quit 0

' --- Helper: ResolveGridCol -------------------------------------------------
' Probes a SAP GUI table-control grid for the column index that hosts a given
' field name (DDIC component path, e.g. "DD03P_D-ROLLNAME"). Iterates column
' indices 0..15 at row 0 and returns the first one that resolves via
' findById. Returns -1 if the field is not present in the grid (e.g. when a
' release has dropped or renamed the column).
'
' Why this helper exists: SAP renumbers grid columns between releases. The
' SE11 structure components grid layout differs between S/4HANA and
' ECC (see "Version-aware column index resolution" comment block above).
' Hard-coded indices break the moment a different release is targeted.
' Probing is cheap (cached at run start) and keeps the VBS forward-compatible.
Function ResolveGridCol(oSess, sGrid, sPrefix, sName)
    Dim col, sId, oCell
    For col = 0 To 15
        On Error Resume Next
        Set oCell = Nothing
        sId = sGrid & "/" & sPrefix & sName & "[" & col & ",0]"
        Set oCell = oSess.findById(sId)
        On Error GoTo 0
        If Not (oCell Is Nothing) Then
            ResolveGridCol = col
            Exit Function
        End If
    Next
    ResolveGridCol = -1
End Function
