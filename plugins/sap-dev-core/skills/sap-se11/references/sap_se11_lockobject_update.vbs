' =============================================================================
' sap_se11_lockobject_update.vbs  -  SAP GUI Scripting: Update lock object in SE11
'
' Generated by the sap-se11 skill.
' Opens an existing lock object in Change mode, updates tables, lock mode,
' and lock arguments from definition file, saves, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%      Lock object name      e.g. "EZMYLOCK"
'   %%DEFINITION_FILE%%  Absolute path to tab-delimited definition
'
' Definition file format (same as create -- see sap_se11_lockobject_create.vbs)
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' =============================================================================

Option Explicit

Const OBJECT_NAME     = "%%OBJECT_NAME%%"
Const DEFINITION_FILE = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE     = "%%PACKAGE%%"
Const SAP_TRANSPORT   = "%%TRANSPORT%%"
Const SESSION_PATH    = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile read below accept UTF-8 inputs from upstream tools
' (sap-docs-extract, the Write tool, hand-authored TSVs) -- full docstring
' in sap_se11_table_create.vbs. Always returns a UTF-16 LE path so callers
' must open the result with mode -1.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and open lock object in Change mode --------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-ENQU").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-ENQU_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Opening lock object in Change mode: " & UCase(OBJECT_NAME)
oSession.findById("wnd[0]/usr/btnPUSHEDIT").press
WScript.Sleep 1500

' ------ 2a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") -- pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' ------ 2b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S to provoke any "Prompt for local Workbench request" popup.
' (a) wnd[1] with ctxtKO008-TRKORR -> fill SAP_TRANSPORT, Enter.
' (b) Other popup -> Enter to dismiss.
' (c) No popup -> object is local ($TMP) or already locked to a modifiable TR.
' Diagnostics: TADIR-DEVCLASS, E071, E070-TRSTATUS.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oPreTR Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SE11 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            WScript.Quit 1
        End If
        oPreTR.Text = SAP_TRANSPORT
        WScript.Echo "INFO: Pre-save TR popup detected -- entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) -- pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    WScript.Echo "INFO: No pre-save popup -- object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 3. Parse definition file --------------------------------------------
Dim oFSO, oFile, sLine, aFields
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If

Dim sPrimaryTable, sLockMode
sPrimaryTable = "" : sLockMode = ""

Dim arrSecTables()
Dim arrLockArgs()
Dim iSecCount, iArgCount
iSecCount = 0 : iArgCount = 0

Dim sSection
sSection = "HEADER"

Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
Do While Not oFile.AtEndOfStream
    sLine = Trim(oFile.ReadLine)
    If sLine = "" Then
        ' skip
    ElseIf UCase(sLine) = "SECONDARY_TABLES" Then
        sSection = "SECONDARY"
    ElseIf UCase(sLine) = "LOCK_ARGUMENTS" Then
        sSection = "LOCKARGS"
    Else
        aFields = Split(sLine, vbTab)
        Select Case sSection
            Case "HEADER"
                If UBound(aFields) >= 1 Then
                    Select Case UCase(Trim(aFields(0)))
                        Case "PRIMARY_TABLE"
                            sPrimaryTable = Trim(aFields(1))
                        Case "LOCK_MODE"
                            sLockMode = UCase(Trim(aFields(1)))
                    End Select
                End If
            Case "SECONDARY"
                If UBound(aFields) >= 0 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrSecTables(iSecCount)
                    arrSecTables(iSecCount) = Trim(aFields(0))
                    iSecCount = iSecCount + 1
                End If
            Case "LOCKARGS"
                If UBound(aFields) >= 1 And UCase(Trim(aFields(0))) <> "TABLE" Then
                    ReDim Preserve arrLockArgs(iArgCount)
                    arrLockArgs(iArgCount) = Trim(aFields(0)) & vbTab & Trim(aFields(1))
                    iArgCount = iArgCount + 1
                End If
        End Select
    End If
Loop
oFile.Close

WScript.Echo "INFO: Primary table: " & sPrimaryTable & ", Lock mode: " & sLockMode
WScript.Echo "INFO: Secondary tables: " & iSecCount & ", Lock arguments: " & iArgCount

' ------ 4. Tables tab -- Update primary table and lock mode -------------------
WScript.Echo "INFO: Updating tables..."
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD25/tabpTABLES").select
WScript.Sleep 500

Dim sTabBase
sTabBase = "wnd[0]/usr/tabsTABSTRIP_DD25/tabpTABLES/ssubSS_TABLES:SAPLSD31:"

' Update primary table
If sPrimaryTable <> "" Then
    oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0,0]").Text = UCase(sPrimaryTable)
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0,0]").Text = UCase(sPrimaryTable)
    End If
End If

' Update lock mode
If sLockMode <> "" Then
    oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/cmbDD26E-ENQMODE[1,0]").Key = sLockMode
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/cmbDD26E-ENQMODE[1,0]").Key = sLockMode
    End If
End If

' Scan existing secondary tables
Dim dictExistingTables
Set dictExistingTables = CreateObject("Scripting.Dictionary")
dictExistingTables.CompareMode = 1

Dim iScanRow, sExistVal
iScanRow = 1  ' Start from row 1 (row 0 is primary)

Do While True
    sExistVal = ""
    Err.Clear
    sExistVal = oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0," & iScanRow & "]").Text
    If Err.Number <> 0 Then
        Err.Clear
        sExistVal = oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0," & iScanRow & "]").Text
        If Err.Number <> 0 Then
            Err.Clear
            Exit Do
        End If
    End If
    If Trim(sExistVal) = "" Then Exit Do
    dictExistingTables(UCase(Trim(sExistVal))) = True
    iScanRow = iScanRow + 1
Loop

' Add new secondary tables
Dim i, iRow, iNextRow
iNextRow = iScanRow

For i = 0 To iSecCount - 1
    If Not dictExistingTables.Exists(UCase(arrSecTables(i))) Then
        oSession.findById(sTabBase & "0801/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0," & iNextRow & "]").Text = UCase(arrSecTables(i))
        If Err.Number <> 0 Then
            Err.Clear
            oSession.findById(sTabBase & "0601/tblSAPLSD31TC_ENQTAB_TAB/ctxtDD26E-TABNAME[0," & iNextRow & "]").Text = UCase(arrSecTables(i))
        End If
        If Err.Number = 0 Then
            WScript.Echo "INFO:   Added secondary table: " & UCase(arrSecTables(i))
            iNextRow = iNextRow + 1
        Else
            WScript.Echo "WARNING: Could not add " & UCase(arrSecTables(i)) & ": " & Err.Description
            Err.Clear
        End If
        WScript.Sleep 200
    Else
        WScript.Echo "INFO:   Secondary table already exists: " & UCase(arrSecTables(i))
    End If
Next

oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

' ------ 5. Lock Arguments tab -----------------------------------------------
If iArgCount > 0 Then
    WScript.Echo "INFO: Updating lock arguments..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTABSTRIP_DD25/tabpLOCKARGS").select
    WScript.Sleep 500
    
    Dim sArgBase, aArgFields
    sArgBase = "wnd[0]/usr/tabsTABSTRIP_DD25/tabpLOCKARGS/ssubSS_LOCKARGS:SAPLSD31:"
    
    ' Scan existing lock arguments
    Dim dictExistingArgs
    Set dictExistingArgs = CreateObject("Scripting.Dictionary")
    dictExistingArgs.CompareMode = 1
    iScanRow = 0
    
    Do While True
        Dim sExTab, sExFld
        sExTab = "" : sExFld = ""
        Err.Clear
        sExFld = oSession.findById(sArgBase & "0901/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-FIELDNAME[1," & iScanRow & "]").Text
        If Err.Number <> 0 Then
            Err.Clear
            sExFld = oSession.findById(sArgBase & "0601/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-FIELDNAME[1," & iScanRow & "]").Text
            If Err.Number <> 0 Then
                Err.Clear
                Exit Do
            End If
        End If
        If Trim(sExFld) = "" Then Exit Do
        
        sExTab = oSession.findById(sArgBase & "0901/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-TABNAME[0," & iScanRow & "]").Text
        If Err.Number <> 0 Then
            Err.Clear
            sExTab = oSession.findById(sArgBase & "0601/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-TABNAME[0," & iScanRow & "]").Text
            Err.Clear
        End If
        
        dictExistingArgs(UCase(Trim(sExTab)) & "~" & UCase(Trim(sExFld))) = True
        iScanRow = iScanRow + 1
    Loop
    
    iNextRow = iScanRow
    
    For i = 0 To iArgCount - 1
        aArgFields = Split(arrLockArgs(i), vbTab)
        Dim sKey
        sKey = UCase(aArgFields(0)) & "~" & UCase(aArgFields(1))
        
        If Not dictExistingArgs.Exists(sKey) Then
            oSession.findById(sArgBase & "0901/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-TABNAME[0," & iNextRow & "]").Text = UCase(aArgFields(0))
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById(sArgBase & "0601/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-TABNAME[0," & iNextRow & "]").Text = UCase(aArgFields(0))
            End If
            oSession.findById(sArgBase & "0901/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-FIELDNAME[1," & iNextRow & "]").Text = UCase(aArgFields(1))
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById(sArgBase & "0601/tblSAPLSD31TC_ENQARG_TAB/ctxtDD27E-FIELDNAME[1," & iNextRow & "]").Text = UCase(aArgFields(1))
            End If
            
            If Err.Number = 0 Then
                WScript.Echo "INFO:   Added lock argument: " & sKey
                iNextRow = iNextRow + 1
            Else
                WScript.Echo "WARNING: Could not add lock argument " & sKey & ": " & Err.Description
                Err.Clear
            End If
            WScript.Sleep 200
        Else
            WScript.Echo "INFO:   Lock argument already exists: " & sKey
        End If
    Next
    
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    Err.Clear
    On Error GoTo 0
End If

' ------ 6. Check (Ctrl+F2) before saving ------------------------------------
WScript.Echo "INFO: Checking lock object consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "ERROR: Check failed - " & sCheckMsg
    WScript.Quit 1
End If
WScript.Echo "INFO: Check passed."

' ------ 7. Save (F11) -------------------------------------------------------
WScript.Echo "INFO: Saving lock object..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Saved."

' ------ 7. Activate (Ctrl+F3) -----------------------------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 3000
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

WScript.Echo "SUCCESS: Lock object " & UCase(OBJECT_NAME) & " updated and activated in SAP."
WScript.Quit 0
