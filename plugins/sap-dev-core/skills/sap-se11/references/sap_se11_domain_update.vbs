' =============================================================================
' sap_se11_domain_update.vbs  -  SAP GUI Scripting: Update domain in SE11
'
' Generated by the sap-se11 skill.
' Attaches to an existing SAP GUI session, opens domain in change mode,
' updates definition properties and optional fixed values from definition file,
' saves, checks, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%          Domain name           e.g. "ZDOM_STATUS"
'   %%OBJECT_DESCRIPTION%%   New description        (empty = no change)
'   %%DEFINITION_FILE%%      Absolute path to tab-delimited definition
'   %%PACKAGE%%              SAP package (empty = $TMP)
'   %%TRANSPORT%%            Transport request number (empty = local or new)
'
' Definition file format (tab-delimited):
'   Line 1 (header):  DATATYPE	LENGTH	DECIMALS	SIGN	LOWERCASE	OUTPUT_LENGTH	CONV_ROUTINE
'   Line 2 (values):  CHAR	10
'   Line 3 (separator): FIXED_VALUES   (literal text, marks start of fixed values)
'   Line 4 (header):  VALUE	DESCRIPTION
'   Line 5+:           A	Active
'                      I	Inactive
'
' Component IDs recorded from SAP S/4HANA 1909 system.
' =============================================================================

Option Explicit

Const OBJECT_NAME          = "%%OBJECT_NAME%%"
Const OBJECT_DESCRIPTION   = "%%OBJECT_DESCRIPTION%%"
Const DEFINITION_FILE      = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE          = "%%PACKAGE%%"
Const SAP_TRANSPORT        = "%%TRANSPORT%%"
Const SESSION_PATH         = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' Valid DATATYPE values for domains
Const VALID_DATATYPES = "ACCP,CHAR,CLNT,CUKY,CURR,DATN,DATS,DEC,DECFLOAT16,DECFLOAT34,DF16_DEC,DF16_RAW,DF16_SCL,DF34_DEC,DF34_RAW,DF34_SCL,FLTP,GEOM_EWKB,INT1,INT2,INT4,INT8,LANG,LCHR,LRAW,NUMC,PREC,QUAN,RAW,RAWSTRING,SSTRING,TIMN,TIMS,UNIT,UTCLONG,VARC"

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile(..., -1) reads below accept UTF-8 inputs from
' upstream tools (sap-docs-extract, the Write tool, hand-authored TSVs)
' as well as the legacy UTF-16 LE format. Full docstring in
' sap_se11_table_create.vbs.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ========== Validation helper ==========
Function ValidateTypeRules(sType, sLen, sDec, sSign)
    Dim nLen, nDec, nFixedLen, nMinLen, nMaxLen, nMaxDec
    ValidateTypeRules = ""

    ' --- Fixed-length types ---
    nFixedLen = 0
    Select Case sType
        Case "INT1"   : nFixedLen = 3
        Case "INT2"   : nFixedLen = 5
        Case "INT4"   : nFixedLen = 10
        Case "INT8"   : nFixedLen = 19
        Case "DECFLOAT16", "DF16_RAW", "DF16_SCL" : nFixedLen = 16
        Case "DECFLOAT34", "DF34_RAW", "DF34_SCL" : nFixedLen = 34
        Case "DATN", "DATS" : nFixedLen = 8
        Case "TIMN", "TIMS" : nFixedLen = 6
        Case "ACCP"   : nFixedLen = 6
        Case "UTCLONG" : nFixedLen = 27
        Case "CLNT"   : nFixedLen = 3
        Case "LANG"   : nFixedLen = 1
        Case "CUKY"   : nFixedLen = 5
        Case "PREC"   : nFixedLen = 2
    End Select

    If nFixedLen > 0 Then
        If sLen <> "" Then
            If Not IsNumeric(sLen) Then
                ValidateTypeRules = sType & ": LENGTH must be numeric, got '" & sLen & "'"
                Exit Function
            End If
            If CLng(sLen) <> nFixedLen Then
                ValidateTypeRules = sType & ": LENGTH must be " & nFixedLen & ", got " & sLen
                Exit Function
            End If
        End If
        If sType = "FLTP" Then
            If sDec <> "" And sDec <> "16" Then
                ValidateTypeRules = "FLTP: DECIMALS must be blank or 16, got '" & sDec & "'"
                Exit Function
            End If
        Else
            If sDec <> "" Then
                ValidateTypeRules = sType & ": DECIMALS must be blank, got '" & sDec & "'"
                Exit Function
            End If
        End If
        If sType = "INT1" And UCase(sSign) = "X" Then
            ValidateTypeRules = "INT1: SIGN is not allowed"
            Exit Function
        End If
        Exit Function
    End If

    ' --- Variable-length types ---
    nMinLen = 0 : nMaxLen = 0 : nMaxDec = -1
    Select Case sType
        Case "DEC"      : nMinLen = 1   : nMaxLen = 31    : nMaxDec = 14
        Case "DF16_DEC" : nMinLen = 1   : nMaxLen = 15    : nMaxDec = 14
        Case "DF34_DEC" : nMinLen = 1   : nMaxLen = 31    : nMaxDec = 14
        Case "CURR"     : nMinLen = 1   : nMaxLen = 31    : nMaxDec = 14
        Case "QUAN"     : nMinLen = 1   : nMaxLen = 31    : nMaxDec = 14
        Case "CHAR"     : nMinLen = 1   : nMaxLen = 30000
        Case "LCHR"     : nMinLen = 256 : nMaxLen = 32000
        Case "SSTRING"  : nMinLen = 1   : nMaxLen = 1333
        Case "STRING"   : nMinLen = 256 : nMaxLen = 99999
        Case "RAW"      : nMinLen = 1   : nMaxLen = 32000
        Case "LRAW"     : nMinLen = 256 : nMaxLen = 32000
        Case "RAWSTRING" : nMinLen = 256 : nMaxLen = 99999
        Case "NUMC"     : nMinLen = 1   : nMaxLen = 255
        Case "UNIT"     : nMinLen = 2   : nMaxLen = 3
        Case "VARC"     : nMinLen = 1   : nMaxLen = 99999
        Case "GEOM_EWKB"
            Exit Function
    End Select

    If nMinLen > 0 Then
        If sLen = "" Then
            ValidateTypeRules = sType & ": LENGTH is required (range " & nMinLen & "-" & nMaxLen & ")"
            Exit Function
        End If
        If Not IsNumeric(sLen) Then
            ValidateTypeRules = sType & ": LENGTH must be numeric, got '" & sLen & "'"
            Exit Function
        End If
        nLen = CLng(sLen)
        If nLen < nMinLen Or nLen > nMaxLen Then
            ValidateTypeRules = sType & ": LENGTH must be " & nMinLen & "-" & nMaxLen & ", got " & nLen
            Exit Function
        End If

        If nMaxDec >= 0 Then
            If sDec <> "" Then
                If Not IsNumeric(sDec) Then
                    ValidateTypeRules = sType & ": DECIMALS must be numeric, got '" & sDec & "'"
                    Exit Function
                End If
                nDec = CLng(sDec)
                Dim nEffMax
                nEffMax = nLen
                If nEffMax > nMaxDec Then nEffMax = nMaxDec
                If nDec < 0 Or nDec > nEffMax Then
                    ValidateTypeRules = sType & ": DECIMALS must be 0-" & nEffMax & " (max " & nMaxDec & "), got " & nDec
                    Exit Function
                End If
            End If
        Else
            If sDec <> "" Then
                ValidateTypeRules = sType & ": DECIMALS must be blank, got '" & sDec & "'"
                Exit Function
            End If
        End If

        If UCase(sSign) = "X" Then
            Select Case sType
                Case "DEC", "CURR", "QUAN"
                    ' allowed
                Case Else
                    ValidateTypeRules = sType & ": SIGN is not allowed"
                    Exit Function
            End Select
        End If
        Exit Function
    End If
End Function

' ------ 0. Pre-flight: validate definition file before connecting to SAP ----
Dim oPFSO, oPFile, sPLine, aPProps
Dim sPDataType, sPLength, sPDecimals, sPSign, sValErr
Set oPFSO = CreateObject("Scripting.FileSystemObject")
If Not oPFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If
Set oPFile = oPFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
If Not oPFile.AtEndOfStream Then oPFile.ReadLine  ' skip header line
sPDataType = "" : sPLength = "" : sPDecimals = "" : sPSign = ""
If Not oPFile.AtEndOfStream Then
    sPLine = oPFile.ReadLine
    aPProps = Split(sPLine, vbTab)
    If UBound(aPProps) >= 0 Then sPDataType = UCase(Trim(aPProps(0)))
    If UBound(aPProps) >= 1 Then sPLength   = Trim(aPProps(1))
    If UBound(aPProps) >= 2 Then sPDecimals = Trim(aPProps(2))
    If UBound(aPProps) >= 3 Then sPSign     = Trim(aPProps(3))
End If
oPFile.Close

If sPDataType = "" Then
    WScript.Echo "ERROR: DATATYPE is empty in definition file."
    WScript.Quit 1
End If
If InStr("," & VALID_DATATYPES & ",", "," & sPDataType & ",") = 0 Then
    WScript.Echo "ERROR: Invalid DATATYPE '" & sPDataType & "'."
    WScript.Echo "INFO: Allowed values: " & VALID_DATATYPES
    WScript.Quit 1
End If

sValErr = ValidateTypeRules(sPDataType, sPLength, sPDecimals, sPSign)
If sValErr <> "" Then
    WScript.Echo "ERROR: " & sValErr
    WScript.Quit 1
End If
WScript.Echo "INFO: DATATYPE '" & sPDataType & "' validated OK."

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and open domain in change mode ------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-DOMA").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-DOMA_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Opening domain in change mode: " & UCase(OBJECT_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnPUSHEDIT").press
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Change button: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 2a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") -- pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' Dismiss any popups after opening change mode
Dim nPopupLoop
On Error Resume Next
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

' ------ 2b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S to provoke any "Prompt for local Workbench request" popup.
' (a) wnd[1] with ctxtKO008-TRKORR -> fill SAP_TRANSPORT, Enter.
' (b) Other popup -> Enter to dismiss.
' (c) No popup -> object is local ($TMP) or already locked to a modifiable TR.
' Diagnostics: TADIR-DEVCLASS, E071, E070-TRSTATUS.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oPreTR Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SE11 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            WScript.Quit 1
        End If
        oPreTR.Text = SAP_TRANSPORT
        WScript.Echo "INFO: Pre-save TR popup detected -- entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) -- pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    WScript.Echo "INFO: No pre-save popup -- object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 3. Update description and definition properties ---------------------
If OBJECT_DESCRIPTION <> "" Then
    On Error Resume Next
    oSession.findById("wnd[0]/usr/txtDD01D-DDTEXT").Text = OBJECT_DESCRIPTION
    Err.Clear
    On Error GoTo 0
    WScript.Echo "INFO: Description updated to: " & OBJECT_DESCRIPTION
End If

' Read definition file
Dim oFSO, oFile, sLine, aProps
Set oFSO = CreateObject("Scripting.FileSystemObject")
Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)

' Skip header
If Not oFile.AtEndOfStream Then oFile.ReadLine

' Property values
Dim sDataType, sLength, sDecimals, sOutputLen, sConvRoutine, sLowercase, sSign
sDataType = "" : sLength = "" : sDecimals = "" : sOutputLen = ""
sConvRoutine = "" : sLowercase = "" : sSign = ""

If Not oFile.AtEndOfStream Then
    sLine = oFile.ReadLine
    aProps = Split(sLine, vbTab)
    If UBound(aProps) >= 0 Then sDataType    = Trim(aProps(0))
    If UBound(aProps) >= 1 Then sLength      = Trim(aProps(1))
    If UBound(aProps) >= 2 Then sDecimals    = Trim(aProps(2))
    If UBound(aProps) >= 3 Then sSign        = Trim(aProps(3))
    If UBound(aProps) >= 4 Then sLowercase   = Trim(aProps(4))
    If UBound(aProps) >= 5 Then sOutputLen   = Trim(aProps(5))
    If UBound(aProps) >= 6 Then sConvRoutine = Trim(aProps(6))
End If

On Error Resume Next
Dim sDefBase
sDefBase = "wnd[0]/usr/tabsTAB_STRIP/tabpTAB1/ssubTS_SCREEN:SAPLSD11:1201/"
If sDataType <> "" Then oSession.findById(sDefBase & "ctxtDD01D-DATATYPE").Text = UCase(sDataType)
If sLength <> "" Then oSession.findById(sDefBase & "txtDD01D-LENG").Text = sLength
If sDecimals <> "" Then oSession.findById(sDefBase & "txtDD01D-DECIMALS").Text = sDecimals
If sOutputLen <> "" Then oSession.findById(sDefBase & "txtDD01D-OUTPUTLEN").Text = sOutputLen
If sConvRoutine <> "" Then oSession.findById(sDefBase & "txtDD01D-CONVEXIT").Text = UCase(sConvRoutine)
If UCase(sLowercase) = "X" Then oSession.findById(sDefBase & "chkDD01D-LOWERCASE").Selected = True
If UCase(sSign) = "X" Then oSession.findById(sDefBase & "chkDD01D-SIGNFLAG").Selected = True
Err.Clear
On Error GoTo 0

' Press Enter and dismiss all popups
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

On Error Resume Next
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0
WScript.Echo "INFO: Domain definition properties updated."

' ------ 4. Update fixed values (if present) ---------------------------------
Dim bHasFixedValues, aFields
bHasFixedValues = False

Do While Not oFile.AtEndOfStream
    sLine = oFile.ReadLine
    If UCase(Trim(sLine)) = "FIXED_VALUES" Then
        bHasFixedValues = True
        Exit Do
    End If
Loop

If bHasFixedValues Then
    WScript.Echo "INFO: Updating fixed values..."

    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTAB_STRIP/tabpTAB2").select
    WScript.Sleep 500
    Err.Clear
    On Error GoTo 0

    ' Skip header
    If Not oFile.AtEndOfStream Then oFile.ReadLine

    Dim iValRow, sValue, sValDesc
    Dim sValGridBase
    sValGridBase = "wnd[0]/usr/tabsTAB_STRIP/tabpTAB2/ssubTS_SCREEN:SAPLSD11:1202/tblSAPLSD11TC0"

    iValRow = 0
    Do While Not oFile.AtEndOfStream
        sLine = oFile.ReadLine
        If Trim(sLine) = "" Then
            ' skip empty lines
        Else
            aFields = Split(sLine, vbTab)
            sValue = "" : sValDesc = ""
            If UBound(aFields) >= 0 Then sValue   = Trim(aFields(0))
            If UBound(aFields) >= 1 Then sValDesc = Trim(aFields(1))

            If sValue <> "" Then
                WScript.Echo "INFO: Setting fixed value [" & iValRow & "]: " & sValue & " = " & sValDesc

                On Error Resume Next
                oSession.findById(sValGridBase & "/txtDD07D-DOMVALUE[1," & iValRow & "]").Text = sValue
                If sValDesc <> "" Then
                    oSession.findById(sValGridBase & "/txtDD07D-DDTEXT[2," & iValRow & "]").Text = sValDesc
                End If
                Err.Clear
                On Error GoTo 0

                iValRow = iValRow + 1
                If iValRow Mod 14 = 0 Then
                    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
                    WScript.Sleep 300
                End If
            End If
        End If
    Loop

    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500

    ' Dismiss popups after fixed values
    On Error Resume Next
    For nPopupLoop = 1 To 10
        WScript.Sleep 500
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 500
            Err.Clear
        Else
            Err.Clear
            Exit For
        End If
    Next
    On Error GoTo 0

    WScript.Echo "INFO: " & iValRow & " fixed values set."
End If

oFile.Close

' ------ 5. Save (Ctrl+S) ---------------------------------------------------
WScript.Echo "INFO: Saving domain..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

' Handle package/transport dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Domain saved."

' ------ 6. Check (Ctrl+F2) after save --------------------------------------
WScript.Echo "INFO: Checking domain consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "WARNING: Check found issues - " & sCheckMsg
Else
    WScript.Echo "INFO: Check passed."
End If

' Dismiss any popup that appeared during check (e.g. "Object checked" info popup)
On Error Resume Next
For nPopupLoop = 1 To 5
    WScript.Sleep 400
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 400
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

' ------ 7. Activate (Ctrl+F3) ----------------------------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey 27
WScript.Sleep 3000

' Robust activation popup handler (handles ODE, 3-button SPOP, 2-button SPOP).
' SPOP with 3 buttons = "Warning during activation: display activation log?"
' -> Press OPTION2 (No) to skip log viewer and let activation continue.
' SPOP with 2 buttons = generic activation confirmation -> Press OPTION1 (Yes).
' ODE (KO007) = Object Directory Entry -> fill package + transport from script constants.
Dim iActLoop, sActWin2, sActWnd2, posWnd2
For iActLoop = 1 To 8
    sActWin2 = oSession.ActiveWindow.Id
    If Right(sActWin2, 6) = "wnd[0]" Then Exit For

    posWnd2 = InStrRev(sActWin2, "/wnd[")
    If posWnd2 > 0 Then
        sActWnd2 = Mid(sActWin2, posWnd2 + 1)
    Else
        sActWnd2 = sActWin2
    End If
    Dim bPos2 : bPos2 = InStr(sActWnd2, "/")
    If bPos2 > 0 Then sActWnd2 = Left(sActWnd2, bPos2 - 1)

    Dim sActTitle2 : sActTitle2 = ""
    Err.Clear
    sActTitle2 = oSession.ActiveWindow.Text
    Err.Clear
    WScript.Echo "INFO: Activation popup " & iActLoop & " on " & sActWnd2 & " title='" & sActTitle2 & "'"

    Dim ko007a : Set ko007a = Nothing
    Err.Clear
    Set ko007a = oSession.findById(sActWnd2 & "/usr/ctxtKO007-L_DEVCLASS")
    If Err.Number = 0 And Not (ko007a Is Nothing) Then
        If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" Then
            WScript.Echo "INFO:   -> ODE popup; filling package " & SAP_PACKAGE
            ko007a.Text = SAP_PACKAGE
            oSession.findById(sActWnd2 & "/tbar[0]/btn[0]").press
            WScript.Sleep 1000
            Err.Clear
            If SAP_TRANSPORT <> "" Then
                Dim ko008a : Set ko008a = Nothing
                Set ko008a = oSession.findById(sActWnd2 & "/usr/ctxtKO008-TRKORR")
                If Err.Number = 0 And Not (ko008a Is Nothing) Then
                    ko008a.Text = SAP_TRANSPORT
                    oSession.findById(sActWnd2 & "/tbar[0]/btn[0]").press
                    WScript.Sleep 1200
                End If
            End If
            Err.Clear
        Else
            WScript.Echo "INFO:   -> ODE popup; pressing Local Object"
            oSession.findById(sActWnd2 & "/tbar[0]/btn[7]").press
            WScript.Sleep 1200
        End If
        Err.Clear
    Else
        Err.Clear
        Dim oS2 : Set oS2 = Nothing
        Dim oS3 : Set oS3 = Nothing
        Set oS2 = oSession.findById(sActWnd2 & "/usr/btnSPOP-OPTION2")
        Set oS3 = oSession.findById(sActWnd2 & "/usr/btnSPOP-OPTION3")
        If Err.Number = 0 And Not (oS2 Is Nothing) And Not (oS3 Is Nothing) Then
            WScript.Echo "INFO:   -> 3-button SPOP; pressing OPTION2 (No/Skip log)"
            oS2.press
            WScript.Sleep 1500
            Err.Clear
        Else
            Err.Clear
            Dim oS1 : Set oS1 = Nothing
            Set oS1 = oSession.findById(sActWnd2 & "/usr/btnSPOP-OPTION1")
            If Err.Number = 0 And Not (oS1 Is Nothing) Then
                WScript.Echo "INFO:   -> 2-button SPOP; pressing OPTION1"
                oS1.press
                WScript.Sleep 1000
                Err.Clear
            Else
                Err.Clear
                WScript.Echo "INFO:   -> Generic popup; pressing Enter"
                oSession.findById(sActWnd2).sendVKey VKEY_ENTER
                WScript.Sleep 800
                Err.Clear
            End If
        End If
    End If
    WScript.Sleep 600
Next
On Error GoTo 0

' ------ 8. Final status -----------------------------------------------------
Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Or sFinalType = "A" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

WScript.Echo "SUCCESS: Domain " & UCase(OBJECT_NAME) & " updated and activated in SAP."
WScript.Quit 0
