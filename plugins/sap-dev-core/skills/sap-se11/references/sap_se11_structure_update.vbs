' =============================================================================
' sap_se11_structure_update.vbs  -  SAP GUI Scripting: Update structure in SE11
'
' Generated by the sap-se11 skill.
' Opens structure in change mode. Appends new components from the definition
' file AND migrates an existing field's data element in place when the def
' names a different ROLLNAME for it (read-back verified). Then checks, saves,
' activates, and RFC-verifies the active version before reporting SUCCESS.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%      Structure name        e.g. "ZSSTRUCT001"
'   %%DEFINITION_FILE%%  Absolute path to tab-delimited component list
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' =============================================================================

Option Explicit

Const OBJECT_NAME     = "%%OBJECT_NAME%%"
Const DEFINITION_FILE = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE     = "%%PACKAGE%%"
Const SAP_TRANSPORT   = "%%TRANSPORT%%"
' Enhancement category to set BEFORE Activate so SAP doesn't warn / pop up.
' Accepted: NOT_EXTENSIBLE (default), FLAT, FLAT_NUMERIC, DEEP. See
' sap_se11_set_enh_category.vbs for the full mapping.
Const ENH_CATEGORY    = "%%ENHANCEMENT_CATEGORY%%"
Const SESSION_PATH    = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default
Const POST_ACTIVATE_VERIFY_PS1 = "%%POST_ACTIVATE_VERIFY_PS1%%"   ' empty = skip verify

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' Include SE11-local enhancement-category helper (SetEnhancementCategory).
' Used after Save and before Activate so the activation step doesn't
' surface "Structure is not flagged for any enhancement category".
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ENH_CATEGORY_VBS%%", 1).ReadAll()

' Include shared post-activate RFC verify helper (PostActivateVerifyOrFail).
' Gates SUCCESS on the active DDIC version after Activate -- catches a
' non-activated update that the GUI status bar reported as success.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%POST_ACTIVATE_VERIFY_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile(..., -1) reads below accept UTF-8 inputs from
' upstream tools (sap-docs-extract, the Write tool, hand-authored TSVs)
' as well as the legacy UTF-16 LE format. Full docstring in
' sap_se11_table_create.vbs.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and open in change mode -------------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-DDTYPE").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-DDTYPE_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Opening structure in change mode: " & UCase(OBJECT_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnPUSHEDIT").press
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Change button: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 2a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") -- pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 2b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S to provoke any "Prompt for local Workbench request" popup.
' (a) wnd[1] with ctxtKO008-TRKORR -> fill SAP_TRANSPORT, Enter.
' (b) Other popup -> Enter to dismiss.
' (c) No popup -> object is local ($TMP) or already locked to a modifiable TR.
' Diagnostics: TADIR-DEVCLASS, E071, E070-TRSTATUS.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oPreTR Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SE11 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            WScript.Quit 1
        End If
        oPreTR.Text = SAP_TRANSPORT
        WScript.Echo "INFO: Pre-save TR popup detected -- entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) -- pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    WScript.Echo "INFO: No pre-save popup -- object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 3. Switch to Components tab -----------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsTAB_STRIP/tabpDEF").select
WScript.Sleep 500
Err.Clear
On Error GoTo 0

' ------ 4. Find existing components -----------------------------------------
Dim sGridBase
sGridBase = "wnd[0]/usr/tabsTAB_STRIP/tabpDEF/ssubTS_SCREEN:SAPLSD41:2301/tblSAPLSD41TC0"

' ------ 4pre. Pre-read def: existing field -> wanted data element ------------
' Built BEFORE the scan so the scan can migrate an existing field's data
' element in place (fix 2026-06-22). Keyed by UPPER(component name). Only rows
' that name a DATAELEMENT (col 2) and are not includes (".*") are eligible;
' direct-type changes on an existing field stay unsupported (DD03P-DATATYPE/
' LENG are Changeable=False -- enforced by the pre-validate guard below).
Dim dictDefDE, oDEFso, oDEFile, sDELine, aDEFlds, sDEComp, sDEde
Set dictDefDE = CreateObject("Scripting.Dictionary")
Set oDEFso = CreateObject("Scripting.FileSystemObject")
If oDEFso.FileExists(DEFINITION_FILE) Then
    Set oDEFile = oDEFso.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
    If Not oDEFile.AtEndOfStream Then oDEFile.ReadLine ' header
    Do While Not oDEFile.AtEndOfStream
        sDELine = oDEFile.ReadLine
        If Trim(sDELine) <> "" Then
            aDEFlds = Split(sDELine, vbTab)
            sDEComp = "" : sDEde = ""
            If UBound(aDEFlds) >= 0 Then sDEComp = Trim(aDEFlds(0))
            If UBound(aDEFlds) >= 1 Then sDEde   = Trim(aDEFlds(1))
            If sDEComp <> "" And Left(sDEComp, 1) <> "." And sDEde <> "" Then
                If Not dictDefDE.Exists(UCase(sDEComp)) Then dictDefDE.Add UCase(sDEComp), sDEde
            End If
        End If
    Loop
    oDEFile.Close
End If

Dim iRow, sExistingName, sExistingRoll, dictExisting
Dim iModified, iModFailed, sScanKey, sWantDE2, sBackDE2
Set dictExisting = CreateObject("Scripting.Dictionary")
iModified = 0
iModFailed = 0

iRow = 0
Do
    On Error Resume Next
    sExistingName = ""
    sExistingName = oSession.findById(sGridBase & "/txtDD03P_D-FIELDNAME[0," & iRow & "]").Text
    If Err.Number <> 0 Then
        Err.Clear
        On Error GoTo 0
        Exit Do
    End If
    sExistingRoll = ""
    sExistingRoll = oSession.findById(sGridBase & "/ctxtDD03P_D-ROLLNAME[2," & iRow & "]").Text
    Err.Clear
    On Error GoTo 0

    If Trim(sExistingName) = "" Then Exit Do
    sScanKey = UCase(Trim(sExistingName))
    dictExisting.Add sScanKey, True

    ' --- In-place data-element migration (fix 2026-06-22) -------------------
    ' Previously this scan only catalogued existing components; the def loop
    ' below then SKIPPED every existing component, so an existing field's data
    ' element could NEVER change -- the update printed SUCCESS while silently
    ' keeping the old data element. Now: if the def names a different data
    ' element for this existing field, overwrite its ROLLNAME cell HERE, while
    ' iRow is a live, valid grid index (paging-safe), then read the cell back
    ' to confirm the change actually took.
    If dictDefDE.Exists(sScanKey) Then
        sWantDE2 = Trim(dictDefDE(sScanKey))
        If sWantDE2 <> "" And UCase(sWantDE2) <> UCase(Trim(sExistingRoll)) Then
            On Error Resume Next
            oSession.findById(sGridBase & "/ctxtDD03P_D-ROLLNAME[2," & iRow & "]").Text = UCase(sWantDE2)
            sBackDE2 = ""
            sBackDE2 = oSession.findById(sGridBase & "/ctxtDD03P_D-ROLLNAME[2," & iRow & "]").Text
            If Err.Number <> 0 Then
                WScript.Echo "ERROR: Could not modify data element of existing component '" & sExistingName & "' (row " & iRow & "): " & Err.Description
                iModFailed = iModFailed + 1
                Err.Clear
            ElseIf UCase(Trim(sBackDE2)) <> UCase(sWantDE2) Then
                WScript.Echo "ERROR: Data-element change for '" & sExistingName & "' did not take (cell shows '" & sBackDE2 & "', wanted '" & UCase(sWantDE2) & "')."
                iModFailed = iModFailed + 1
            Else
                WScript.Echo "INFO: Migrated existing component " & sExistingName & ": data element " & Trim(sExistingRoll) & " -> " & UCase(sWantDE2)
                iModified = iModified + 1
            End If
            On Error GoTo 0
        End If
    End If

    iRow = iRow + 1
    If iRow Mod 23 = 0 Then
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
        WScript.Sleep 300
    End If
Loop

Dim iStartRow
iStartRow = iRow
WScript.Echo "INFO: Found " & iStartRow & " existing components."

' ------ 5. Read definition file and append new components -------------------
Dim oFSO, oFile, sLine, aFields
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If

' Pre-validate: reject rows that supply DATATYPE without DATAELEMENT.
' DD03P-DATATYPE / -LENG / -DECIMALS columns of the structure components
' grid are Changeable=False via SAP GUI Scripting -- see structure_create
' for full diagnosis. Catch the unsupported shape before any GUI input.
Dim oUVal, sULine, aUFlds, iURow, sUComp, sUDE, sUDT
Set oUVal = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
If Not oUVal.AtEndOfStream Then oUVal.ReadLine ' header
iURow = 0
Do While Not oUVal.AtEndOfStream
    sULine = oUVal.ReadLine
    If Trim(sULine) <> "" Then
        aUFlds = Split(sULine, vbTab)
        sUComp = "" : sUDE = "" : sUDT = ""
        If UBound(aUFlds) >= 0 Then sUComp = Trim(aUFlds(0))
        If UBound(aUFlds) >= 1 Then sUDE   = Trim(aUFlds(1))
        If UBound(aUFlds) >= 2 Then sUDT   = Trim(aUFlds(2))
        If sUComp <> "" _
           And Left(sUComp, 1) <> "." _
           And sUDE = "" And sUDT <> "" Then
            WScript.Echo "ERROR: Component '" & sUComp & "' (row " & iURow & ") uses direct DATATYPE='" & sUDT & "'."
            WScript.Echo "       SAP GUI Scripting cannot fill DD03P-DATATYPE (Changeable=False)."
            WScript.Echo "       Define a data element via /sap-se11 DATAELEMENT and reference it"
            WScript.Echo "       in the DATAELEMENT column (col 2) of this row."
            oUVal.Close
            WScript.Quit 1
        End If
        iURow = iURow + 1
    End If
Loop
oUVal.Close

Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
If Not oFile.AtEndOfStream Then oFile.ReadLine  ' skip header

Dim iAdded, sCompName, sDataElement, sDataType, sLength, sDecimals, sDescription
iAdded = 0

Do While Not oFile.AtEndOfStream
    sLine = oFile.ReadLine
    If Trim(sLine) = "" Then
        ' skip
    Else
        aFields = Split(sLine, vbTab)
        sCompName = "" : sDataElement = "" : sDataType = "" : sLength = "" : sDecimals = "" : sDescription = ""

        If UBound(aFields) >= 0 Then sCompName    = Trim(aFields(0))
        If UBound(aFields) >= 1 Then sDataElement = Trim(aFields(1))
        If UBound(aFields) >= 2 Then sDataType    = Trim(aFields(2))
        If UBound(aFields) >= 3 Then sLength      = Trim(aFields(3))
        If UBound(aFields) >= 4 Then sDecimals    = Trim(aFields(4))
        If UBound(aFields) >= 5 Then sDescription = Trim(aFields(5))

        If sCompName <> "" Then
            If dictExisting.Exists(UCase(sCompName)) Then
                ' Existing component. Any data-element migration was already
                ' applied in-place during the component scan above; nothing to
                ' append here. (Direct-type changes on an existing field remain
                ' unsupported -- DD03P-DATATYPE/LENG are Changeable=False.)
            Else
                On Error Resume Next
                oSession.findById(sGridBase & "/txtDD03P_D-FIELDNAME[0," & iRow & "]").Text = UCase(sCompName)

                If sDataElement <> "" Then
                    oSession.findById(sGridBase & "/ctxtDD03P_D-ROLLNAME[2," & iRow & "]").Text = UCase(sDataElement)
                Else
                    If sDataType <> "" Then oSession.findById(sGridBase & "/txtDD02D-DATATYPE[3," & iRow & "]").Text = UCase(sDataType)
                    If sLength <> "" Then oSession.findById(sGridBase & "/txtDD03P_D-LENG[4," & iRow & "]").Text = sLength
                    If sDecimals <> "" Then oSession.findById(sGridBase & "/txtDD03P_D-DECIMALS[5," & iRow & "]").Text = sDecimals
                    If sDescription <> "" Then oSession.findById(sGridBase & "/txtDD03P_D-DDTEXT[7," & iRow & "]").Text = sDescription
                End If

                If Err.Number <> 0 Then
                    WScript.Echo "WARNING: Error at row " & iRow & ": " & Err.Description
                    Err.Clear
                End If
                On Error GoTo 0

                iRow = iRow + 1
                iAdded = iAdded + 1
                If iRow Mod 23 = 0 Then
                    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
                    WScript.Sleep 500
                End If
            End If
        End If
    End If
Loop
oFile.Close

' Note: NO trailing sendVKey VKEY_ENTER here. The recording
' Record_SE11_EnhancementCategory_03.vbs (2026-05-11) confirms the menu
' flow only opens the radio dialog cleanly when no auto-validate has
' fired since the last edit. Inserting Enter triggers an extra info
' popup that breaks the Extras > Enhancement Category sequence.
WScript.Sleep 500
WScript.Echo "INFO: " & iAdded & " new component(s) added, " & iModified & " existing data element(s) migrated in place."

' ------ 5b. Set Enhancement Category (matches recording 2026-05-11) -------
' Run RIGHT AFTER component fill (with setFocus on last ROLLNAME), BEFORE
' Check and BEFORE Save. See sap_se11_structure_create.vbs Step 5b for the
' full recording-based rationale. Same applies to update mode: the menu
' flow only works in the unsaved, un-validated edit state.
On Error Resume Next
Dim sFocusUpd
' Hard-coded column 2 -- matches the component-fill loop above which writes to ROLLNAME[2,r].
sFocusUpd = sGridBase & "/ctxtDD03P_D-ROLLNAME[2," & (iRow - 1) & "]"
oSession.findById(sFocusUpd).SetFocus
Err.Clear
On Error GoTo 0

Call SetEnhancementCategory(oSession, ENH_CATEGORY, SAP_TRANSPORT)

' ------ 6. Check (Ctrl+F2) before saving ------------------------------------
WScript.Echo "INFO: Checking structure consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "ERROR: Check failed - " & sCheckMsg
    WScript.Quit 1
End If
WScript.Echo "INFO: Check passed."

' ------ 7. Save (F11) -------------------------------------------------------
' If no new components were added the structure is not dirty; Save is
' disabled and sendVKey 11 raises "virtual key is not enabled". Tolerate it.
WScript.Echo "INFO: Saving..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
If Err.Number <> 0 Then
    WScript.Echo "INFO: Save skipped (no pending changes): " & Err.Description
    Err.Clear
End If
On Error GoTo 0
WScript.Sleep 1500

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0

' Enhancement Category was already set at Step 5b, before Check and Save.

' ------ 7. Activate (Ctrl+F3) -----------------------------------------------
WScript.Echo "INFO: Activating..."
On Error Resume Next
' BUGFIX (sap-dev-init 2026-05-11): tbar[1]/btn[27].press silently no-ops on
' some S/4HANA 1909 sessions when editor focus is on the field grid. Ctrl+F3
' (sendVKey 27) is always honoured.
oSession.findById("wnd[0]").sendVKey 27
WScript.Sleep 3000

' Activation popup loop. Handles the chained-modals case the operator
' showed 2026-05-11: Enhancement Category radio -> "Warning during
' activation -- display log?" 3-button popup -> optional info popup.
' See sap_se11_structure_create.vbs for the full per-popup rationale.
Dim oSuPop2, oSuPop3, oSuPop1, oSuEhc, iSuPop
For iSuPop = 1 To 6
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit For

    ' (a) Enhancement Category radio dialog (Cannot Be Enhanced default).
    Set oSuEhc = Nothing
    Set oSuEhc = oSession.findById("wnd[1]/usr/radRSDD_STTB-ENHCAT_2")
    If Err.Number = 0 And Not (oSuEhc Is Nothing) Then
        WScript.Echo "INFO: wnd[1] Enhancement Category dialog; selecting 'Cannot Be Enhanced'."
        oSuEhc.select
        WScript.Sleep 300
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1500
        Err.Clear
    Else
        Err.Clear
        ' (b) 3-button SPOP popup (Yes/No/Cancel) -- usually "display
        '     activation log?". Press OPTION2 (No) to skip.
        Set oSuPop2 = Nothing
        Set oSuPop3 = Nothing
        Set oSuPop2 = oSession.findById("wnd[1]/usr/btnSPOP-OPTION2")
        Set oSuPop3 = oSession.findById("wnd[1]/usr/btnSPOP-OPTION3")
        If Err.Number = 0 And Not (oSuPop2 Is Nothing) And Not (oSuPop3 Is Nothing) Then
            WScript.Echo "INFO: wnd[1] 3-button SPOP popup; pressed OPTION2 (No)."
            oSuPop2.press
            WScript.Sleep 1500
        Else
            Err.Clear
            ' (c) 2-button SPOP popup (Yes/No). Press OPTION1 (Yes).
            Set oSuPop1 = Nothing
            Set oSuPop1 = oSession.findById("wnd[1]/usr/btnSPOP-OPTION1")
            If Err.Number = 0 And Not (oSuPop1 Is Nothing) Then
                WScript.Echo "INFO: wnd[1] 2-button SPOP popup; pressed OPTION1 (Yes)."
                oSuPop1.press
                WScript.Sleep 1500
            Else
                Err.Clear
                ' (d) Generic info popup. ENTER.
                oSession.ActiveWindow.sendVKey VKEY_ENTER
                WScript.Sleep 1500
            End If
        End If
    End If
    Err.Clear
Next
Err.Clear
On Error GoTo 0

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

' ------ 8. Honest reporting: requested data-element migrations --------------
' If the def asked to change an existing field's data element but the cell
' overwrite did not stick, FAIL loudly instead of printing SUCCESS. This is
' the 2026-06-22 silent false-success ("Skipping existing component" while the
' field kept its old data element).
If iModFailed > 0 Then
    WScript.Echo "ERROR: Structure " & UCase(OBJECT_NAME) & " update did NOT apply " & iModFailed & _
                 " requested data-element change(s); the structure was not migrated as specified."
    WScript.Quit 1
End If

' ------ 9. Post-activate RFC verify (fail-closed on INACTIVE/MISSING) -------
' An UPDATE leaves the prior ACTIVE version in place, so a check that only
' asks "does an active version exist" cannot detect a non-activated update.
' PostActivateVerifyOrFail (via sap_se11_post_activate_verify.ps1) treats any
' pending (non-active) DDIC version as a failure.
PostActivateVerifyOrFail POST_ACTIVATE_VERIFY_PS1, "STRUCTURE", OBJECT_NAME

WScript.Echo "SUCCESS: Structure " & UCase(OBJECT_NAME) & " updated and activated in SAP."
WScript.Quit 0
