' =============================================================================
' sap_se11_check.vbs  -  SAP GUI Scripting: Check if DDIC object exists in SE11
'
' Generated by the sap-se11 skill.
' Attaches to an existing SAP GUI session, navigates to SE11, selects the
' appropriate object type radio button, enters the object name, and attempts
' Display to determine if the object exists.
'
' Output: "EXIST" or "NOT_EXIST" (last line of stdout, parseable by skill).
'
' Tokens replaced at run time:
'   %%OBJECT_TYPE%%   SE11 object type: TABLE, VIEW, DATATYPE, TYPEGROUP,
'                     DOMAIN, SEARCHHELP, LOCKOBJECT
'   %%OBJECT_NAME%%   DDIC object name  e.g. "ZTABLE001"
'
' SE11 radio-button component IDs (SAP S4D / S/4HANA):
'   Database table : wnd[0]/usr/radRSRD1-TBMA
'   View           : wnd[0]/usr/radRSRD1-VIMA
'   Data type      : wnd[0]/usr/radRSRD1-DDTYPE
'   Type Group     : wnd[0]/usr/radRSRD1-TYMA
'   Domain         : wnd[0]/usr/radRSRD1-DOMA
'   Search help    : wnd[0]/usr/radRSRD1-SHMA
'   Lock object    : wnd[0]/usr/radRSRD1-ENQU
'
' Name input field IDs:
'   Database table : wnd[0]/usr/ctxtRSRD1-TBMA_VAL
'   View           : wnd[0]/usr/ctxtRSRD1-VIMA_VAL
'   Data type      : wnd[0]/usr/ctxtRSRD1-DDTYPE_VAL
'   Type Group     : wnd[0]/usr/ctxtRSRD1-TYMA_VAL
'   Domain         : wnd[0]/usr/ctxtRSRD1-DOMA_VAL
'   Search help    : wnd[0]/usr/ctxtRSRD1-SHMA_VAL
'   Lock object    : wnd[0]/usr/ctxtRSRD1-ENQU_VAL
'
' Component IDs recorded from SAP S4D system (S/4HANA).
' If a step fails, use SAP Logon > Help > Scripting Recorder to re-record
' the correct ID for your system.
' =============================================================================

Option Explicit

Const OBJECT_TYPE  = "%%OBJECT_TYPE%%"
Const OBJECT_NAME  = "%%OBJECT_NAME%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default
Const VKEY_ENTER   = 0
Const VKEY_F3      = 3

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nse11"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Map object type to radio button and name field -------------------
Dim sRadioId, sNameId
Select Case UCase(OBJECT_TYPE)
    Case "TABLE"
        sRadioId = "wnd[0]/usr/radRSRD1-TBMA"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-TBMA_VAL"
    Case "VIEW"
        sRadioId = "wnd[0]/usr/radRSRD1-VIMA"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-VIMA_VAL"
    Case "DATATYPE"
        sRadioId = "wnd[0]/usr/radRSRD1-DDTYPE"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-DDTYPE_VAL"
    Case "TYPEGROUP"
        sRadioId = "wnd[0]/usr/radRSRD1-TYMA"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-TYMA_VAL"
    Case "DOMAIN"
        sRadioId = "wnd[0]/usr/radRSRD1-DOMA"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-DOMA_VAL"
    Case "SEARCHHELP"
        sRadioId = "wnd[0]/usr/radRSRD1-SHMA"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-SHMA_VAL"
    Case "LOCKOBJECT"
        sRadioId = "wnd[0]/usr/radRSRD1-ENQU"
        sNameId  = "wnd[0]/usr/ctxtRSRD1-ENQU_VAL"
    Case Else
        WScript.Echo "ERROR: Unknown object type '" & OBJECT_TYPE & "'." & vbCrLf & _
                     "       Valid types: TABLE, VIEW, DATATYPE, TYPEGROUP, DOMAIN, SEARCHHELP, LOCKOBJECT"
        WScript.Quit 1
End Select

' ------ 4. Select radio button and enter object name ------------------------
On Error Resume Next
oSession.findById(sRadioId).select
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not select radio button (" & sRadioId & ")." & vbCrLf & _
                 "       Component IDs may differ on your system. Use Scripting Recorder."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0
WScript.Sleep 300

On Error Resume Next
oSession.findById(sNameId).Text = UCase(OBJECT_NAME)
oSession.findById(sNameId).setFocus
oSession.findById(sNameId).caretPosition = Len(OBJECT_NAME)
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not fill object name field (" & sNameId & ")."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 5. Press Display button (btnPUSHSHOW) -------------------------------
WScript.Echo "INFO: Checking if " & UCase(OBJECT_TYPE) & " '" & UCase(OBJECT_NAME) & "' exists..."
On Error Resume Next
oSession.findById("wnd[0]/usr/btnPUSHSHOW").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 6. Parse status bar to determine existence --------------------------
Dim sMsgText, sMsgType
On Error Resume Next
sMsgText = oSession.findById("wnd[0]/sbar").Text
sMsgType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0

' If we navigated into the object display, it exists
' If the status bar shows an error (E) or we are still on initial screen, it doesn't
Dim bStillOnInitial
On Error Resume Next
Dim oInitCheck
Set oInitCheck = oSession.findById(sNameId)
bStillOnInitial = (Err.Number = 0) And Not (oInitCheck Is Nothing)
Err.Clear
On Error GoTo 0

If bStillOnInitial Then
    ' If the SE11 initial screen's name field still resolves, we did NOT navigate
    ' into the object's display screen. SE11 leaves us on the initial screen for
    ' "object not found" regardless of status-bar message type or logon language.
    ' Title-based fallback was English-only and produced false-positive EXIST
    ' under JA logons (e.g. "ABAP Dictionary: Initial Screen" rendered in Japanese) -- violation of
    ' language_independence_rules.md (no .Text/title branching).
    If sMsgType = "E" Then
        WScript.Echo "INFO: Object " & UCase(OBJECT_NAME) & " not found. Status: " & sMsgText
    Else
        WScript.Echo "INFO: Object " & UCase(OBJECT_NAME) & " not found (still on initial screen)."
    End If
    WScript.Echo "NOT_EXIST"
Else
    WScript.Echo "INFO: Object " & UCase(OBJECT_NAME) & " found - navigated to display."
    ' Go back to SE11 initial screen
    oSession.findById("wnd[0]").sendVKey VKEY_F3
    WScript.Sleep 500
    WScript.Echo "EXIST"
End If

WScript.Quit 0
