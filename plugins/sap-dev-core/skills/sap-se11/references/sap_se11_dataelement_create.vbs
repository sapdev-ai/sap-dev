' =============================================================================
' sap_se11_dataelement_create.vbs  -  SAP GUI Scripting: Create data element
'
' Generated by the sap-se11 skill.
' Attaches to an existing SAP GUI session, navigates to SE11, creates a new
' data element, sets domain reference and field labels from definition file,
' saves, checks, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%          Data element name     e.g. "ZDTEL_STATUS"
'   %%OBJECT_DESCRIPTION%%   Short description     e.g. "Status Data Element"
'   %%DEFINITION_FILE%%      Absolute path to tab-delimited definition
'   %%PACKAGE%%              SAP package (empty = $TMP)
'   %%TRANSPORT%%            Transport request number (empty = local or new)
'
' Definition file format (tab-delimited, one row per data element):
'   Line 1 (header):  DOMNAME	LABEL_SHORT	LABEL_MEDIUM	LABEL_LONG	LABEL_HEADING
'   Line 2 (values):  BUKRS	Company	Company Code	Company Code	Company Code
'
' Component IDs recorded from SAP S/4HANA 1909 system.
' =============================================================================

Option Explicit

Const OBJECT_NAME        = "%%OBJECT_NAME%%"
Const OBJECT_DESCRIPTION = "%%OBJECT_DESCRIPTION%%"
Const DEFINITION_FILE    = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE        = "%%PACKAGE%%"
Const SAP_TRANSPORT      = "%%TRANSPORT%%"
Const SESSION_PATH       = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default
Const POST_ACTIVATE_VERIFY_PS1 = "%%POST_ACTIVATE_VERIFY_PS1%%"   ' empty = skip verify

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%POST_ACTIVATE_VERIFY_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile(..., -1) reads below accept UTF-8 inputs from
' upstream tools (sap-docs-extract, the Write tool, hand-authored TSVs)
' as well as the legacy UTF-16 LE format. Full docstring in
' sap_se11_table_create.vbs.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ------ 0. Pre-flight: validate definition file --------------------------------
Dim oPFSO, oPFile, sPLine, aPProps, sPDomName
Set oPFSO = CreateObject("Scripting.FileSystemObject")
If Not oPFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If
Set oPFile = oPFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)
If Not oPFile.AtEndOfStream Then oPFile.ReadLine  ' skip header
sPDomName = ""
If Not oPFile.AtEndOfStream Then
    sPLine = oPFile.ReadLine
    aPProps = Split(sPLine, vbTab)
    If UBound(aPProps) >= 0 Then sPDomName = Trim(aPProps(0))
End If
oPFile.Close

If sPDomName = "" Then
    WScript.Echo "ERROR: DOMNAME is empty in definition file."
    WScript.Quit 1
End If
WScript.Echo "INFO: Domain reference '" & sPDomName & "' validated OK."

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) --------
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and create data element -----------------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

' Select Data type radio and enter name
oSession.findById("wnd[0]/usr/radRSRD1-DDTYPE").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-DDTYPE_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

' Press Create
WScript.Echo "INFO: Creating data element: " & UCase(OBJECT_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnPUSHADD").press
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Create button: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' --- Lock the SAP session UI for the fill data element fields + save + activate critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the fill data element fields + save + activate critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Handle sub-type popup (Data element / Structure / Table Type) --------
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Sub-type popup detected - selecting Data element..."
    oSession.findById("wnd[1]/usr/radD_100-DTEL").select
    WScript.Sleep 300
    oSession.findById("wnd[1]/tbar[0]/btn[0]").press
    WScript.Sleep 1500
End If
Err.Clear
On Error GoTo 0

' ------ 4. Fill description -----------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/txtDD04D-DDTEXT").Text = OBJECT_DESCRIPTION
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not fill data element description."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 5. Read definition file and fill Data Type + Field Labels ---------------
Dim oFSO, oFile, sLine, aFields
Set oFSO = CreateObject("Scripting.FileSystemObject")
Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)

' Skip header
If Not oFile.AtEndOfStream Then oFile.ReadLine

' Read values line
Dim sDomName, sLabelShort, sLabelMedium, sLabelLong, sLabelHeading
sDomName = "" : sLabelShort = "" : sLabelMedium = "" : sLabelLong = "" : sLabelHeading = ""

If Not oFile.AtEndOfStream Then
    sLine = oFile.ReadLine
    aFields = Split(sLine, vbTab)
    If UBound(aFields) >= 0 Then sDomName       = Trim(aFields(0))
    If UBound(aFields) >= 1 Then sLabelShort    = Trim(aFields(1))
    If UBound(aFields) >= 2 Then sLabelMedium   = Trim(aFields(2))
    If UBound(aFields) >= 3 Then sLabelLong     = Trim(aFields(3))
    If UBound(aFields) >= 4 Then sLabelHeading  = Trim(aFields(4))
End If
oFile.Close

' Fill Data Type tab - Domain reference
WScript.Echo "INFO: Setting domain reference: " & sDomName
Dim sTypeBase
sTypeBase = "wnd[0]/usr/tabsTS/tabpTYPE/ssubSUB_DATA:SAPLSD51:1002/"
On Error Resume Next
oSession.findById(sTypeBase & "ctxtDD04D-DOMNAME").Text = UCase(sDomName)
Err.Clear
On Error GoTo 0

oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500

' Dismiss popups after Enter
Dim nPopupLoop
On Error Resume Next
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

' Fill Field Labels tab
If sLabelShort <> "" Or sLabelMedium <> "" Or sLabelLong <> "" Or sLabelHeading <> "" Then
    WScript.Echo "INFO: Setting field labels..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTS/tabpTEXT").select
    WScript.Sleep 500
    Err.Clear
    On Error GoTo 0

    Dim sLblBase
    sLblBase = "wnd[0]/usr/tabsTS/tabpTEXT/ssubSUB_DATA:SAPLSD51:1003/"
    On Error Resume Next
    If sLabelShort <> "" Then
        oSession.findById(sLblBase & "txtDD04D-SCRTEXT_S").Text = sLabelShort
    End If
    If sLabelMedium <> "" Then
        oSession.findById(sLblBase & "txtDD04D-SCRTEXT_M").Text = sLabelMedium
    End If
    If sLabelLong <> "" Then
        oSession.findById(sLblBase & "txtDD04D-SCRTEXT_L").Text = sLabelLong
    End If
    If sLabelHeading <> "" Then
        oSession.findById(sLblBase & "txtDD04D-REPTEXT").Text = sLabelHeading
    End If
    Err.Clear
    On Error GoTo 0

    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500

    ' Dismiss popups after label entry
    On Error Resume Next
    For nPopupLoop = 1 To 10
        WScript.Sleep 500
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 500
            Err.Clear
        Else
            Err.Clear
            Exit For
        End If
    Next
    On Error GoTo 0
End If
WScript.Echo "INFO: Data element definition properties set."

' ------ 6. Save (Ctrl+S) -------------------------------------------------------
WScript.Echo "INFO: Saving data element..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

' Handle package/transport dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Data element saved."

' ------ 7. Check (Ctrl+F2) after save ------------------------------------------
WScript.Echo "INFO: Checking data element consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

' Dismiss check result popup if any (any modal window level >= 1)
Dim sChkWndId, nChkWndIdx
On Error Resume Next
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    sChkWndId = oSession.ActiveWindow.Id
    If InStr(sChkWndId, "wnd[") > 0 And InStr(sChkWndId, "wnd[0]") = 0 Then
        nChkWndIdx = Mid(sChkWndId, InStr(sChkWndId, "wnd[") + 4, 1)
        oSession.findById("wnd[" & nChkWndIdx & "]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "WARNING: Check found issues - " & sCheckMsg
Else
    WScript.Echo "INFO: Check passed."
End If

' ------ 8. Activate (Ctrl+F3) --------------------------------------------------
WScript.Echo "INFO: Activating..."
oSession.findById("wnd[0]/tbar[1]/btn[27]").press
WScript.Sleep 2000

' Dismiss all activation popups (any modal window level >= 1)
Dim sActiveWndId, nWndIdx
On Error Resume Next
For nPopupLoop = 1 To 20
    WScript.Sleep 500
    sActiveWndId = oSession.ActiveWindow.Id
    If InStr(sActiveWndId, "wnd[") > 0 And InStr(sActiveWndId, "wnd[0]") = 0 Then
        ' Extract window index and send Enter to dismiss
        nWndIdx = Mid(sActiveWndId, InStr(sActiveWndId, "wnd[") + 4, 1)
        WScript.Echo "INFO: Dismissing activation popup wnd[" & nWndIdx & "]..."
        oSession.findById("wnd[" & nWndIdx & "]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

' --- Release the session UI lock; final status is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 9. Final status ---------------------------------------------------------
Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Or sFinalType = "A" Then
    WScript.Echo "ERROR: Activation failed (sbar Type=" & sFinalType & ") - " & sFinalMsg
    WScript.Quit 1
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

' Post-activate RFC verify (Phase 4.3 — mandatory per SKILL.md Step 5d).
PostActivateVerifyOrFail POST_ACTIVATE_VERIFY_PS1, "DATAELEMENT", OBJECT_NAME

WScript.Echo "SUCCESS: Data element " & UCase(OBJECT_NAME) & " created and activated in SAP."
WScript.Quit 0
