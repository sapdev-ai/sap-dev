' =============================================================================
' sap_se11_table_update.vbs  -  SAP GUI Scripting: Update database table in SE11
'
' Generated by the sap-se11 skill.
' Attaches to an existing SAP GUI session, navigates to SE11, opens the table
' in change mode, appends new fields from definition file (skips existing),
' saves, checks, and activates.
'
' Tokens replaced at run time:
'   %%OBJECT_NAME%%      Table name            e.g. "ZTABLE001"
'   %%DEFINITION_FILE%%  Absolute path to tab-delimited field definitions
'   %%PACKAGE%%          SAP package (empty = $TMP)
'   %%TRANSPORT%%        Transport request number (empty = local or new)
'
' Definition file format (tab-delimited, first line is header):
'   FIELDNAME	KEY	INITIAL	DATAELEMENT	ReferenceTable	Ref.Field
'   NEWFIELD			ZDTEL_AMT	ZHKTBL001	WAERK
'
' The script appends new fields after the last existing field row. Existing
' fields with the same name are skipped (not overwritten).
'
' Component IDs recorded from SAP S/4HANA 1909 system.
' =============================================================================

Option Explicit

Const OBJECT_NAME     = "%%OBJECT_NAME%%"
Const DEFINITION_FILE = "%%DEFINITION_FILE%%"
Const SAP_PACKAGE     = "%%PACKAGE%%"
Const SAP_TRANSPORT   = "%%TRANSPORT%%"
' Enhancement category to set BEFORE Activate so SAP doesn't warn / pop up.
' Accepted: NOT_EXTENSIBLE (default), FLAT, FLAT_NUMERIC, DEEP. See
' sap_se11_set_enh_category.vbs for the full mapping.
Const ENH_CATEGORY    = "%%ENHANCEMENT_CATEGORY%%"
Const SESSION_PATH    = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' Include shared activation-log capture (CaptureActivationLog /
' ExtractTopActivationError). Used after Activate (Ctrl+F3) when
' sbar.MessageType = "E" or "A" to write the SE11 activation log to a
' local file so the operator sees the *specific* failure (e.g. which
' field is missing a reference table) instead of just "refer to log".
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ACTIVATION_LOG_VBS%%", 1).ReadAll()

' Include SE11-local enhancement-category helper (SetEnhancementCategory).
' Used after Save and before Activate so the activation step doesn't
' surface "Table is not flagged for any enhancement category".
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ENH_CATEGORY_VBS%%", 1).ReadAll()

' UTF-8/16 BOM-detect text-encoding helper.
' Lets the OpenTextFile(..., -1) reads below accept UTF-8 inputs from
' upstream tools (sap-docs-extract, the Write tool, hand-authored TSVs)
' as well as the legacy UTF-16 LE format. Full docstring in
' sap_se11_table_create.vbs.
Function EnsureUnicodeFile(sSrcPath)
    Dim oFSOLocal, oBin, aBytes, b1, b2, oIn, sText, oOut, sTempPath, sCharset
    Set oFSOLocal = CreateObject("Scripting.FileSystemObject")
    Set oBin = CreateObject("ADODB.Stream") : oBin.Type = 1 : oBin.Open
    oBin.LoadFromFile sSrcPath
    aBytes = oBin.Read(2) : oBin.Close
    b1 = 0 : b2 = 0
    If LenB(aBytes) >= 1 Then b1 = AscB(MidB(aBytes, 1, 1))
    If LenB(aBytes) >= 2 Then b2 = AscB(MidB(aBytes, 2, 1))
    If b1 = &HFF And b2 = &HFE Then EnsureUnicodeFile = sSrcPath : Exit Function
    sCharset = "utf-8"
    If b1 = &HFE And b2 = &HFF Then sCharset = "utf-16BE"
    Set oIn = CreateObject("ADODB.Stream")
    oIn.Type = 2 : oIn.Charset = sCharset : oIn.Open
    oIn.LoadFromFile sSrcPath
    sText = oIn.ReadText : oIn.Close
    sTempPath = oFSOLocal.GetSpecialFolder(2) & "\sap_def_" & _
                oFSOLocal.GetTempName() & ".txt"
    Set oOut = CreateObject("ADODB.Stream")
    oOut.Type = 2 : oOut.Charset = "unicode" : oOut.Open
    oOut.WriteText sText
    oOut.SaveToFile sTempPath, 2
    oOut.Close
    EnsureUnicodeFile = sTempPath
End Function

' ------ 0. Pre-flight: validate definition file --------------------------------
Dim oPFSO
Set oPFSO = CreateObject("Scripting.FileSystemObject")
If Not oPFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If
WScript.Echo "INFO: Definition file validated OK."

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) --------
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE11 and open table in change mode -----------------------
WScript.Echo "INFO: Navigating to SE11..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE11"
oSession.findById("wnd[0]").sendVKey 0
WScript.Sleep 1000

oSession.findById("wnd[0]/usr/radRSRD1-TBMA").select
WScript.Sleep 300
oSession.findById("wnd[0]/usr/ctxtRSRD1-TBMA_VAL").Text = UCase(OBJECT_NAME)
WScript.Sleep 300

' Press Change button
WScript.Echo "INFO: Opening table in change mode: " & UCase(OBJECT_NAME)
On Error Resume Next
oSession.findById("wnd[0]/usr/btnPUSHEDIT").press
WScript.Sleep 1500
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Could not press Change button: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 2a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged so
' we can edit translations without overwriting the master language.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") -- pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' Dismiss popups
Dim nPopupLoop
On Error Resume Next
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

' ------ 2b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S immediately after entering change mode to provoke any
' "Prompt for local Workbench request" popup. Outcomes:
'   (a) wnd[1] with field ctxtKO008-TRKORR -> fill SAP_TRANSPORT, Enter.
'   (b) Other popup -> Enter to dismiss.
'   (c) No popup -> object is local ($TMP) or already locked to a modifiable TR.
' If a TR popup appears but SAP_TRANSPORT is empty, abort.
' Diagnostics: TADIR-DEVCLASS, E071, E070-TRSTATUS.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oPreTR Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SE11 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            WScript.Quit 1
        End If
        oPreTR.Text = SAP_TRANSPORT
        WScript.Echo "INFO: Pre-save TR popup detected -- entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) -- pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    WScript.Echo "INFO: No pre-save popup -- object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 3. Switch to Fields tab -------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/usr/tabsTAB_STRIP/tabpDEF").select
WScript.Sleep 500
Err.Clear
On Error GoTo 0

' ------ 4. Find the first empty row in the grid ---------------------------------
Dim sGridBase, sRefBase
sGridBase = "wnd[0]/usr/tabsTAB_STRIP/tabpDEF/ssubTS_SCREEN:SAPLSD41:2201/tblSAPLSD41TC0"
sRefBase  = "wnd[0]/usr/tabsTAB_STRIP/tabpREFF/ssubTS_SCREEN:SAPLSD41:2103/tblSAPLSD41TC0"

' Scan rows to find existing fields and first empty slot
Dim iRow, sExistingName
Dim dictExisting
Set dictExisting = CreateObject("Scripting.Dictionary")

iRow = 0
Do
    On Error Resume Next
    sExistingName = ""
    sExistingName = oSession.findById(sGridBase & "/txtDD03D-FIELDNAME[0," & iRow & "]").Text
    If Err.Number <> 0 Then
        Err.Clear
        On Error GoTo 0
        Exit Do
    End If
    Err.Clear
    On Error GoTo 0

    If Trim(sExistingName) = "" Then
        Exit Do
    End If
    dictExisting.Add UCase(Trim(sExistingName)), True
    iRow = iRow + 1

    ' Scroll if needed (22 visible rows)
    If iRow Mod 22 = 0 Then
        oSession.findById("wnd[0]").sendVKey VKEY_ENTER
        WScript.Sleep 300
    End If
Loop

Dim iStartRow
iStartRow = iRow
WScript.Echo "INFO: Found " & iStartRow & " existing fields. Appending new fields from row " & iStartRow & "."

' ------ 5. Read definition file and append new fields ---------------------------
Dim oFSO, oFile, sLine, aFields
Set oFSO = CreateObject("Scripting.FileSystemObject")
Set oFile = oFSO.OpenTextFile(EnsureUnicodeFile(DEFINITION_FILE), 1, False, -1)

' Skip header line
If Not oFile.AtEndOfStream Then oFile.ReadLine

' Arrays to store reference data
Dim arrRefTable(100), arrRefField(100), arrRefRow(100), nRefCount
nRefCount = 0

Dim iAdded
iAdded = 0

Do While Not oFile.AtEndOfStream
    sLine = oFile.ReadLine
    If Trim(sLine) = "" Then
        ' skip empty lines
    Else
        aFields = Split(sLine, vbTab)
        Dim sFieldName, sKey, sInitial, sDataElement, sRefTable, sRefField
        sFieldName   = ""
        sKey         = ""
        sInitial     = ""
        sDataElement = ""
        sRefTable    = ""
        sRefField    = ""

        If UBound(aFields) >= 0 Then sFieldName   = Trim(aFields(0))
        If UBound(aFields) >= 1 Then sKey         = Trim(aFields(1))
        If UBound(aFields) >= 2 Then sInitial     = Trim(aFields(2))
        If UBound(aFields) >= 3 Then sDataElement = Trim(aFields(3))
        If UBound(aFields) >= 4 Then sRefTable    = Trim(aFields(4))
        If UBound(aFields) >= 5 Then sRefField    = Trim(aFields(5))

        If sFieldName <> "" Then
            ' Skip if field already exists
            If dictExisting.Exists(UCase(sFieldName)) Then
                WScript.Echo "INFO: Skipping existing field: " & sFieldName
            Else
                WScript.Echo "INFO: Adding field [" & iRow & "]: " & sFieldName

                On Error Resume Next
                oSession.findById(sGridBase & "/txtDD03D-FIELDNAME[0," & iRow & "]").Text = UCase(sFieldName)
                If UCase(sKey) = "X" Then
                    oSession.findById(sGridBase & "/chkDD03P-KEYFLAG[1," & iRow & "]").Selected = True
                End If
                If UCase(sInitial) = "X" Then
                    oSession.findById(sGridBase & "/chkDD03P-NOTNULL[2," & iRow & "]").Selected = True
                End If
                If sDataElement <> "" Then
                    oSession.findById(sGridBase & "/ctxtDD03D-ROLLNAME[3," & iRow & "]").Text = UCase(sDataElement)
                End If
                Err.Clear
                On Error GoTo 0

                ' Store reference data for later
                If sRefTable <> "" And sRefField <> "" Then
                    arrRefTable(nRefCount) = sRefTable
                    arrRefField(nRefCount) = sRefField
                    arrRefRow(nRefCount) = iRow
                    nRefCount = nRefCount + 1
                End If

                iRow = iRow + 1
                iAdded = iAdded + 1

                If iRow Mod 22 = 0 Then
                    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
                    WScript.Sleep 500
                End If
            End If
        End If
    End If
Loop
oFile.Close

' Note: NO trailing sendVKey VKEY_ENTER here. The recording
' Record_SE11_EnhancementCategory_03.vbs (2026-05-11) shows the menu
' flow needs the editor in an un-auto-validated state to open the
' radio dialog cleanly. Inserting Enter triggers extra info popups.
WScript.Sleep 500

WScript.Echo "INFO: " & iAdded & " new fields added."

' ------ 5b. Set Enhancement Category (matches recording 2026-05-11) -------
' Run RIGHT AFTER field fill, BEFORE Save and BEFORE Check. See
' sap_se11_structure_create.vbs Step 5b for the full recording-based
' rationale. setFocus on the last added field's ROLLNAME cell to mirror
' the recording's "focus on last row" state before menu click.
On Error Resume Next
If iAdded > 0 Then
    oSession.findById(sGridBase & "/ctxtDD03D-ROLLNAME[3," & (iRow - 1) & "]").SetFocus
End If
Err.Clear
On Error GoTo 0

Call SetEnhancementCategory(oSession, ENH_CATEGORY, SAP_TRANSPORT)

' ------ 5c. Fill Reference tab (if any new fields have reference table/field) ---
If nRefCount > 0 Then
    WScript.Echo "INFO: Setting reference table/field entries..."
    On Error Resume Next
    oSession.findById("wnd[0]/usr/tabsTAB_STRIP/tabpREFF").select
    WScript.Sleep 500
    Err.Clear
    On Error GoTo 0

    ' Detect Currency/Quantity Fields tab column layout. Two layouts seen:
    '   Layout A (older):  [Short Desc, Field, DTEL, Type, RefTable, RefField]
    '                      -> REFTABLE at column 4, REFFIELD at column 5
    '   Layout B (newer):  [Field, DTEL, Type, RefTable, RefField, Short Desc]
    '                      -> REFTABLE at column 3, REFFIELD at column 4
    ' The DDIC field name is identical on both -- only the column index
    ' differs. Probe column 4 first using the FIRST ref row; if absent,
    ' fall back to column 3. See sap_se11_table_create.vbs for the same
    ' probe -- kept symmetric.
    Dim nColRefTab : nColRefTab = 4
    Dim nColRefFld : nColRefFld = 5
    Dim nProbeRow : nProbeRow = arrRefRow(0)
    On Error Resume Next
    Dim oProbe : Set oProbe = Nothing
    Set oProbe = oSession.findById(sRefBase & "/txtDD03P_D-REFTABLE[4," & nProbeRow & "]")
    If Err.Number <> 0 Or oProbe Is Nothing Then
        Err.Clear
        Set oProbe = Nothing
        Set oProbe = oSession.findById(sRefBase & "/txtDD03P_D-REFTABLE[3," & nProbeRow & "]")
        If Err.Number = 0 And Not (oProbe Is Nothing) Then
            nColRefTab = 3
            nColRefFld = 4
            WScript.Echo "INFO: Currency/Qty layout B detected -- REFTABLE col 3, REFFIELD col 4 (Short Desc at end)."
        Else
            WScript.Echo "WARN: Could not probe Currency/Qty column layout -- using default cols 4/5. Rows may not write."
        End If
        Err.Clear
    Else
        WScript.Echo "INFO: Currency/Qty layout A detected -- REFTABLE col 4, REFFIELD col 5 (Short Desc first)."
    End If
    On Error GoTo 0

    Dim iRef
    For iRef = 0 To nRefCount - 1
        On Error Resume Next
        oSession.findById(sRefBase & "/txtDD03P_D-REFTABLE[" & nColRefTab & "," & arrRefRow(iRef) & "]").Text = UCase(arrRefTable(iRef))
        oSession.findById(sRefBase & "/txtDD03P_D-REFFIELD[" & nColRefFld & "," & arrRefRow(iRef) & "]").Text = UCase(arrRefField(iRef))
        Err.Clear
        On Error GoTo 0
        WScript.Echo "INFO: Ref [" & arrRefRow(iRef) & "]: " & arrRefTable(iRef) & "." & arrRefField(iRef)
    Next

    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500

    On Error Resume Next
    For nPopupLoop = 1 To 10
        WScript.Sleep 500
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Sleep 500
            Err.Clear
        Else
            Err.Clear
            Exit For
        End If
    Next
    On Error GoTo 0
End If

' ------ 6. Save (Ctrl+S) -------------------------------------------------------
WScript.Echo "INFO: Saving table..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500

' Handle package/transport dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    If SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT <> "" Then
        ' Case 1: Both package and transport provided
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " with transport " & SAP_TRANSPORT & "..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR").Text = SAP_TRANSPORT
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    ElseIf SAP_PACKAGE <> "" And UCase(SAP_PACKAGE) <> "$TMP" And SAP_TRANSPORT = "" Then
        ' Case 3: Package provided, no transport -> create new transport
        WScript.Echo "INFO: Assigning to package " & SAP_PACKAGE & " (creating new transport)..."
        oSession.findById("wnd[1]/usr/ctxtKO007-L_DEVCLASS").Text = SAP_PACKAGE
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[8]").press
        WScript.Sleep 1000
        oSession.findById("wnd[2]/usr/txtKO013-AS4TEXT").Text = UCase(OBJECT_NAME)
        oSession.findById("wnd[2]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
        oSession.findById("wnd[1]/tbar[0]/btn[0]").press
        WScript.Sleep 1000
    Else
        ' Case 2: No package or $TMP -> Local Object
        WScript.Echo "INFO: Saving as local object ($TMP)..."
        oSession.findById("wnd[1]/tbar[0]/btn[7]").press
        WScript.Sleep 1000
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Echo "INFO: Table saved."

' ------ 7. Check (Ctrl+F2) -----------------------------------------------------
WScript.Echo "INFO: Checking table consistency..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 2000

' Dismiss check popups
On Error Resume Next
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 500
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

Dim sCheckMsg, sCheckType
On Error Resume Next
sCheckMsg  = oSession.findById("wnd[0]/sbar").Text
sCheckType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sCheckType = "E" Then
    WScript.Echo "WARNING: Check found issues - " & sCheckMsg
Else
    WScript.Echo "INFO: Check passed."
End If

' Enhancement Category was already set at Step 5b, BEFORE Save and Check.

' ------ 8. Activate (Ctrl+F3) --------------------------------------------------
WScript.Echo "INFO: Activating..."
' BUGFIX (sap-dev-init 2026-05-11): tbar[1]/btn[27].press silently no-ops on
' some S/4HANA 1909 sessions when editor focus is on the field grid. Ctrl+F3
' (sendVKey 27) is always honoured.
oSession.findById("wnd[0]").sendVKey 27
WScript.Sleep 2000

' Dismiss all activation popups. See sap_se11_table_create.vbs for the
' full 3-button vs 2-button rationale.
On Error Resume Next
Dim oUTblPop2, oUTblPop3, oUTblPop1
For nPopupLoop = 1 To 10
    WScript.Sleep 500
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        Set oUTblPop2 = Nothing
        Set oUTblPop3 = Nothing
        Set oUTblPop2 = oSession.findById("wnd[1]/usr/btnSPOP-OPTION2")
        Set oUTblPop3 = oSession.findById("wnd[1]/usr/btnSPOP-OPTION3")
        If Err.Number = 0 And Not (oUTblPop2 Is Nothing) And Not (oUTblPop3 Is Nothing) Then
            oUTblPop2.press
            WScript.Echo "INFO: wnd[1] 3-button SPOP popup; pressed OPTION2 (No) to skip activation log."
            WScript.Sleep 800
        Else
            Err.Clear
            Set oUTblPop1 = Nothing
            Set oUTblPop1 = oSession.findById("wnd[1]/usr/btnSPOP-OPTION1")
            If Err.Number = 0 And Not (oUTblPop1 Is Nothing) Then
                oUTblPop1.press
                WScript.Echo "INFO: wnd[1] 2-button SPOP popup; pressed OPTION1 (Yes)."
                WScript.Sleep 800
            Else
                Err.Clear
                oSession.findById("wnd[1]").sendVKey VKEY_ENTER
                WScript.Sleep 500
            End If
        End If
        Err.Clear
    Else
        Err.Clear
        Exit For
    End If
Next
On Error GoTo 0

' ------ 9. Final status ---------------------------------------------------------
Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Or sFinalType = "A" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
    Dim sLogPath, sTopErr
    sLogPath = CaptureActivationLog(oSession, OBJECT_NAME, "%%TEMP_DIR%%", _
                                    VKEY_ENTER, VKEY_F3_BACK)
    If Len(sLogPath) > 0 Then
        WScript.Echo "INFO: Activation log saved to: " & sLogPath
        sTopErr = ExtractTopActivationError(sLogPath)
        If Len(sTopErr) > 0 Then
            WScript.Echo "ACTIVATION_ERROR: " & sTopErr
        End If
    Else
        WScript.Echo "INFO: Activation log could not be captured automatically -- open SE11 and use Utilities > Activation Log."
    End If
    WScript.Echo "FAILED: Table " & UCase(OBJECT_NAME) & " was NOT activated. See activation log above."
    WScript.Quit 1
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

WScript.Echo "SUCCESS: Table " & UCase(OBJECT_NAME) & " updated and activated in SAP."
WScript.Quit 0
