' =============================================================================
' sap_se24_change_props.vbs  -  SAP GUI Scripting: Change SE24 Class Properties
'                                (Description, Program Status, Category, ...)
'
' Generated by the sap-se24 skill.
' Attaches to an existing SAP GUI session, navigates to SE24, opens the class
' in CHANGE mode, opens the Properties dialog (Goto > Properties), toggles the
' dialog into change mode, updates the supplied fields (found BY NAME so the
' subscreen container path can drift across releases), presses Continue, then
' Saves and (best-effort) Activates so the change is persisted. Handles the
' conditional original-language popup and the post-save / post-activate
' Workbench-request + inactive-objects popups.
'
' Why this rewrite (2026-06-07, re-recorded live on S/4HANA 2022 form/source):
'   The previous version opened the class in DISPLAY then toggled the *dialog*
'   to change. On S/4HANA 1909 the post-toggle field failed to re-resolve and
'   the flow aborted "Properties dialog disappeared"; on S/4HANA 2022 the
'   description was never reached. The working pattern (verified live S4H 2022,
'   RFC-confirmed in SEOCLASSTX) mirrors /sap-se38 + /sap-se37 change-attrs:
'   open the object in CHANGE mode FIRST (so the class is locked for edit),
'   THEN open Goto > Properties -- the dialog opens display-only, so we still
'   press the Display<->Change toggle (wnd[1]/tbar[0]/btn[25]) and RE-RESOLVE
'   the field afterwards; with the class already locked the toggle succeeds and
'   the field stays resolvable. Then real Save (VKey 11) + Activate (VKey 27).
'
'   Per-class VIEW handling: SE24 remembers a Source-Code-Based vs Form-Based
'   view per user/class (Utilities > Settings > Class Builder >
'   "Source-Code-Based Class Builder" = chkRSEUMOD-NEW_EDITOR). On S/4HANA 2022
'   the Goto > Properties dialog (and editable properties) only exist in the
'   SOURCE-based editor (SAPLSEO_CLASS_EDITOR / screen 400). The form-based tool
'   (SAPLSEOD / screen 2000) exposes the Properties tab READ-ONLY and has no
'   Goto > Properties. So when a class opens form-based, this script normalises
'   the view to source-based for the operation and RESTORES the prior setting
'   afterwards (guaranteed restore on every exit path).
'
' Tokens replaced at run time:
'   %%CLASS_NAME%%   Class name                 e.g. "ZCL_IM_ZHK_PO_001"
'   %%DESCRIPTION%%  New description (max 60). Empty = leave unchanged.
'   %%STATUS%%       New program status (VSEOCLASS-RSTAT). Empty = unchanged.
'                       P = SAP Standard Production
'                       K = Customer Production
'                       S = System Class
'                       T = Test Class
'                       X = SAP Example
'   %%CATEGORY%%     Class category (VSEOCLASS-CLSCATEG). Empty = unchanged.
'                       0 = General object type (other codes per SE24 dropdown)
'   %%TRANSPORT%%    TR for the post-save/activate TR popup. Empty when local
'                    ($TMP) or already locked to a modifiable TR.
'
' Verified-live IDs (S/4HANA 2022, SAP GUI 7.70):
'   /nSE24 -> ctxtSEOCLASS-CLSNAME -> Enter -> btnPUSH_CHANGE
'   source-based change editor = SAPLSEO_CLASS_EDITOR screen 400
'   Goto > Properties           = wnd[0]/mbar/menu[2]/menu[2]
'   dialog field (by name)      = VSEOCLASS-DESCRIPT (GuiTextField),
'                                 VSEOCLASS-RSTAT / VSEOCLASS-CLSCATEG (GuiComboBox)
'   dialog Display<->Change     = wnd[1]/tbar[0]/btn[25]  (Ctrl+F1)
'   dialog Continue             = wnd[1]/tbar[0]/btn[0]
'   Save = VKey 11 ; Activate = VKey 27
'   Settings: Utilities>Settings = wnd[0]/mbar/menu[3]/menu[0]; Class Builder
'             tab = tabp0250; view checkbox name = RSEUMOD-NEW_EDITOR
' =============================================================================

Option Explicit

Const CLASS_NAME       = "%%CLASS_NAME%%"
Const NEW_DESCRIPTION  = "%%DESCRIPTION%%"
Const NEW_STATUS       = "%%STATUS%%"
Const NEW_CATEGORY     = "%%CATEGORY%%"
Const SAP_TRANSPORT    = "%%TRANSPORT%%"
Const SESSION_PATH     = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER     = 0
Const VKEY_SAVE      = 11
Const VKEY_CANCEL    = 12
Const VKEY_ACTIVATE  = 27

Dim oSession
Dim wasLocked
Dim bViewRestore : bViewRestore = False
Dim sPriorView   : sPriorView   = ""    ' "True"/"False" prior NEW_EDITOR state

' Module-level scratch for the recursive find-by-name walker.
Dim gFB_found, gFB_id, gFB_chg, gFB_name, gFB_typeSub

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' --------------------------------------------------------------------------
' Helpers
' --------------------------------------------------------------------------

' Does a control exist at the given id?
Function HasControl(sId)
    HasControl = False
    On Error Resume Next
    Dim x : Set x = Nothing
    Set x = oSession.findById(sId)
    If Err.Number = 0 And Not (x Is Nothing) Then HasControl = True
    Err.Clear : On Error GoTo 0
End Function

' Recursive find of a control by DDIC field Name + type substring. Returns the
' control id (or "" if not found). Robust against subscreen-container drift.
Function FindByName(oRoot, sName, sTypeSub)
    gFB_found = False : gFB_id = "" : gFB_chg = False
    gFB_name = sName : gFB_typeSub = sTypeSub
    If oRoot Is Nothing Then FindByName = "" : Exit Function
    FB_Walk oRoot, 0
    FindByName = gFB_id
End Function

Sub FB_Walk(o, depth)
    On Error Resume Next
    If gFB_found Then Exit Sub
    Dim nm, ty
    nm = o.Name : ty = o.Type
    If Err.Number = 0 Then
        If nm = gFB_name And InStr(ty, gFB_typeSub) > 0 Then
            gFB_found = True : gFB_id = o.Id : gFB_chg = o.Changeable
            Exit Sub
        End If
    End If
    Err.Clear
    Dim ch
    If depth < 14 Then
        For Each ch In o.Children
            FB_Walk ch, depth + 1
            If gFB_found Then Exit Sub
        Next
    End If
    Err.Clear
    On Error GoTo 0
End Sub

' Dismiss the conditional SAPLSETX original-language popup (logon lang <>
' TADIR-MASTERLANG). Presses btnPUSH1 ("Maint. in orig. lang.") to preserve
' MASTERLANG. Only acts when the MASTERLANG field is present.
Sub HandleOrigLangPopup()
    On Error Resume Next
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
        Dim oML : Set oML = Nothing
        Err.Clear
        Set oML = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
        If Err.Number = 0 And Not (oML Is Nothing) Then
            Dim oBtn : Set oBtn = Nothing
            Err.Clear
            Set oBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 And Not (oBtn Is Nothing) Then
                WScript.Echo "INFO: Original-language popup (MASTERLANG=" & _
                             oML.Text & ") - pressing 'Maint. in orig. lang.'."
                oBtn.press
                WScript.Sleep 1500
            End If
        End If
    End If
    Err.Clear
    On Error GoTo 0
End Sub

' Drain up to nMax modal popups after Save / Activate. Fills a TR popup
' (ctxtKO008-TRKORR) with SAP_TRANSPORT; aborts on Error/locked; presses Enter
' on anything else (inactive-objects worklist, info popups). Returns "" on OK
' else a blocking-popup message.
Function DrainPopups(nMax)
    DrainPopups = ""
    Dim i
    For i = 1 To nMax
        If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit Function
        On Error Resume Next
        Dim oTr : Set oTr = Nothing
        Err.Clear
        Set oTr = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
        If Err.Number = 0 And Not (oTr Is Nothing) Then
            If SAP_TRANSPORT = "" Then
                oSession.findById("wnd[1]").sendVKey VKEY_CANCEL
                DrainPopups = "SAP prompted for a transport request but TRANSPORT is empty. Resolve a modifiable TR via /sap-transport-request and re-run."
                Err.Clear : On Error GoTo 0
                Exit Function
            End If
            oTr.Text = SAP_TRANSPORT
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
            WScript.Echo "INFO: TR popup - entering " & SAP_TRANSPORT & "."
        Else
            Dim sTitle, oM1, oM2, sM1, sM2
            sTitle = oSession.ActiveWindow.Text
            sM1 = "" : sM2 = ""
            Err.Clear
            Set oM1 = oSession.findById("wnd[1]/usr/txtMESSTXT1")
            If Err.Number = 0 And Not (oM1 Is Nothing) Then sM1 = oM1.Text
            Err.Clear
            Set oM2 = oSession.findById("wnd[1]/usr/txtMESSTXT2")
            If Err.Number = 0 And Not (oM2 Is Nothing) Then sM2 = oM2.Text
            Err.Clear
            If InStr(LCase(sM1 & " " & sM2), "locked") > 0 Then
                oSession.findById("wnd[1]").sendVKey VKEY_CANCEL
                DrainPopups = "SAP popup [" & sTitle & "] " & Trim(sM1 & " " & sM2)
                Err.Clear : On Error GoTo 0
                Exit Function
            End If
            WScript.Echo "INFO: Confirming popup [" & sTitle & "] - pressing Enter."
            oSession.ActiveWindow.sendVKey VKEY_ENTER
        End If
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 1000
    Next
End Function

' Open the class in SE24 change mode. Returns True if the change editor opened.
Function OpenClassChange()
    OpenClassChange = False
    On Error Resume Next
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE24"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    Err.Clear
    Dim oName : Set oName = Nothing
    Set oName = oSession.findById("wnd[0]/usr/ctxtSEOCLASS-CLSNAME")
    If Err.Number <> 0 Or oName Is Nothing Then Err.Clear : On Error GoTo 0 : Exit Function
    oName.Text = UCase(CLASS_NAME)
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 500
    oSession.findById("wnd[0]/usr/btnPUSH_CHANGE").press
    WScript.Sleep 2000
    Err.Clear : On Error GoTo 0
    HandleOrigLangPopup
    ' Editor open if either the source-based status field or the form tabstrip is present.
    If HasControl("wnd[0]/usr/txtDY0400_STATUS") Or HasControl("wnd[0]/usr/tabsCTS") Then
        OpenClassChange = True
    End If
End Function

' True if the current change editor is the SOURCE-based one (Goto>Properties +
' editable properties live here on S/4HANA 2022).
Function IsSourceBased()
    IsSourceBased = False
    If HasControl("wnd[0]/usr/txtDY0400_STATUS") Then IsSourceBased = True : Exit Function
    On Error Resume Next
    Dim p : p = oSession.Info.Program
    If InStr(p, "SEO_CLASS_EDITOR") > 0 Then IsSourceBased = True
    Err.Clear : On Error GoTo 0
End Function

' Get (and optionally set) the Class Builder "Source-Code-Based" view checkbox.
' Returns the PRIOR Selected state as "True"/"False", or "ERR" if the checkbox
' could not be reached. Always leaves SE24 at the initial screen.
Function ClassBuilderViewSetting(bSet, bValue)
    ClassBuilderViewSetting = "ERR"
    On Error Resume Next
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE24"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 800
    oSession.findById("wnd[0]/mbar/menu[3]/menu[0]").select   ' Utilities > Settings
    WScript.Sleep 1200
    Err.Clear
    ' Best-effort: bring the Class Builder tab forward so its checkbox renders.
    oSession.findById("wnd[1]/usr/tabsG_TABSTRIP/tabp0250").select
    WScript.Sleep 600
    Err.Clear
    Dim w1 : Set w1 = Nothing
    Set w1 = oSession.findById("wnd[1]")
    If Err.Number <> 0 Or w1 Is Nothing Then Err.Clear : On Error GoTo 0 : Exit Function
    Dim cid : cid = FindByName(w1, "RSEUMOD-NEW_EDITOR", "GuiCheckBox")
    If cid = "" Then
        oSession.findById("wnd[1]").sendVKey VKEY_CANCEL
        Err.Clear : On Error GoTo 0
        Exit Function
    End If
    Dim prior : prior = oSession.findById(cid).Selected
    If bSet Then oSession.findById(cid).Selected = bValue
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER   ' confirm
    WScript.Sleep 1000
    If prior Then ClassBuilderViewSetting = "True" Else ClassBuilderViewSetting = "False"
    Err.Clear : On Error GoTo 0
End Function

' Restore the NEW_EDITOR setting if we changed it. Idempotent.
Sub RestoreView()
    If Not bViewRestore Then Exit Sub
    Dim want : want = (sPriorView = "True")
    Dim r : r = ClassBuilderViewSetting(True, want)
    If r <> "ERR" Then
        WScript.Echo "INFO: restored Class Builder view setting (Source-Code-Based=" & want & ")."
    Else
        WScript.Echo "WARN: could not restore Class Builder view setting; set it manually via Utilities > Settings > Class Builder if needed."
    End If
    bViewRestore = False
End Sub

' Centralised failure exit: release lock, restore view, quit 1.
Sub FailExit(sMsg)
    WScript.Echo "ERROR: " & sMsg
    On Error Resume Next
    ReleaseSession oSession, wasLocked
    On Error GoTo 0
    RestoreView
    WScript.Quit 1
End Sub

' --------------------------------------------------------------------------
' 0. No-change short-circuit
' --------------------------------------------------------------------------
If NEW_DESCRIPTION = "" And NEW_STATUS = "" And NEW_CATEGORY = "" Then
    WScript.Echo "INFO: No property values supplied - nothing to change."
    WScript.Echo "DONE: NO_CHANGE"
    WScript.Quit 0
End If

' --------------------------------------------------------------------------
' 1. Attach session
' --------------------------------------------------------------------------
Set oSession = AttachSapSession(SESSION_PATH)

' --------------------------------------------------------------------------
' 2. Open class in CHANGE mode
' --------------------------------------------------------------------------
WScript.Echo "INFO: Opening class in change mode: " & UCase(CLASS_NAME)
If Not OpenClassChange() Then
    FailExit "Could not open class " & UCase(CLASS_NAME) & " in SE24 change mode (does it exist? is it locked?). Status: " & SbarText()
End If

' Lock the session UI for the change + save critical section.
wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the properties change + save critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' --------------------------------------------------------------------------
' 3. Ensure SOURCE-based view (normalise form-based -> source-based)
' --------------------------------------------------------------------------
If Not IsSourceBased() Then
    WScript.Echo "INFO: class opened in form-based view; normalising to source-based for the edit."
    ' Leave change mode cleanly (no edits made yet).
    On Error Resume Next
    oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 600
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    Err.Clear : On Error GoTo 0
    sPriorView = ClassBuilderViewSetting(True, True)   ' set source-based, capture prior
    If sPriorView = "ERR" Then
        FailExit "class opens in form-based Class Builder and the view could not be switched automatically. Switch SE24 to source-based view (Utilities > Settings > Class Builder > check 'Source-Code-Based Class Builder') and re-run."
    End If
    bViewRestore = True
    ' Re-open in change (now source-based).
    If Not OpenClassChange() Then
        FailExit "could not re-open class in change mode after view switch."
    End If
    If Not IsSourceBased() Then
        FailExit "class still not in source-based view after switching the setting; switch manually and re-run."
    End If
End If

' --------------------------------------------------------------------------
' 4. Goto > Properties (opens the modal Properties dialog, display-only)
' --------------------------------------------------------------------------
WScript.Echo "INFO: Opening Properties dialog (Goto > Properties)..."
On Error Resume Next
oSession.findById("wnd[0]/mbar/menu[2]/menu[2]").select
WScript.Sleep 1500
Err.Clear : On Error GoTo 0
HandleOrigLangPopup

Dim w1prop : Set w1prop = Nothing
On Error Resume Next
Set w1prop = oSession.findById("wnd[1]")
Err.Clear : On Error GoTo 0
If w1prop Is Nothing Then
    FailExit "Goto > Properties did not open a dialog (menu layout differs on this release). Re-record with /sap-gui-record."
End If

Dim descId : descId = FindByName(w1prop, "VSEOCLASS-DESCRIPT", "GuiTextField")
If descId = "" Then
    On Error Resume Next
    oSession.findById("wnd[1]").sendVKey VKEY_CANCEL
    Err.Clear : On Error GoTo 0
    FailExit "Properties dialog opened but the description field (VSEOCLASS-DESCRIPT) was not found. Re-record with /sap-gui-record."
End If
WScript.Echo "INFO: Properties dialog open."

' --------------------------------------------------------------------------
' 5. Toggle dialog to change mode if it opened display-only, then re-resolve.
' --------------------------------------------------------------------------
If oSession.findById(descId).Changeable <> True Then
    WScript.Echo "INFO: dialog is display-only; toggling to change (btn[25])..."
    On Error Resume Next
    oSession.findById("wnd[1]/tbar[0]/btn[25]").press
    WScript.Sleep 1500
    Err.Clear : On Error GoTo 0
    HandleOrigLangPopup
    ' Re-resolve the field (handle from any window the dialog now lives on).
    Dim oRoot : Set oRoot = Nothing
    On Error Resume Next
    Set oRoot = oSession.findById("wnd[1]")
    Err.Clear : On Error GoTo 0
    If oRoot Is Nothing Then Set oRoot = oSession.findById("wnd[0]")
    descId = FindByName(oRoot, "VSEOCLASS-DESCRIPT", "GuiTextField")
    If descId = "" Then
        FailExit "Properties dialog field did not re-resolve after the Display<->Change toggle."
    End If
End If

If oSession.findById(descId).Changeable <> True Then
    On Error Resume Next
    oSession.findById("wnd[1]").sendVKey VKEY_CANCEL
    Err.Clear : On Error GoTo 0
    FailExit "Properties dialog stayed display-only (no change authorization, or class locked by another user)."
End If

' --------------------------------------------------------------------------
' 6. Apply the supplied changes.
'    The description field (GuiTextField) is resolved by name. The status /
'    category combo boxes are resolved by DERIVING their path from the
'    description field's subscreen container (all three live in the same
'    ssub...:SAPLSEO_CLASS_EDITOR:0152 subscreen). This is deliberate: a
'    recursive name-walk reliably returns the GuiTextField id but on the tested
'    kernel intermittently yields an empty id for GuiComboBox controls, so the
'    container-derivation is both more robust AND release-tolerant (the prefix
'    comes from the live descId, whatever the container path turns out to be).
' --------------------------------------------------------------------------
Dim sChanges : sChanges = ""
Dim sPropBase : sPropBase = ""
Dim iSlash : iSlash = InStrRev(descId, "/")
If iSlash > 0 Then sPropBase = Left(descId, iSlash)   ' includes trailing "/"

If NEW_DESCRIPTION <> "" Then
    On Error Resume Next
    oSession.findById(descId).Text = NEW_DESCRIPTION
    If Err.Number <> 0 Then FailExit "could not set description: " & Err.Description
    Err.Clear : On Error GoTo 0
    sChanges = sChanges & " description='" & NEW_DESCRIPTION & "'"
End If

If NEW_STATUS <> "" Then
    Dim rstatId : rstatId = sPropBase & "cmbVSEOCLASS-RSTAT"
    If sPropBase = "" Or Not HasControl(rstatId) Then FailExit "status combobox (VSEOCLASS-RSTAT) not found in the Properties dialog."
    On Error Resume Next
    oSession.findById(rstatId).setFocus
    oSession.findById(rstatId).Key = NEW_STATUS
    If Err.Number <> 0 Then FailExit "invalid status code '" & NEW_STATUS & "' (valid: P/K/S/T): " & Err.Description
    Err.Clear : On Error GoTo 0
    sChanges = sChanges & " status='" & NEW_STATUS & "'"
End If

If NEW_CATEGORY <> "" Then
    Dim catId : catId = sPropBase & "cmbVSEOCLASS-CLSCATEG"
    If sPropBase = "" Or Not HasControl(catId) Then FailExit "category combobox (VSEOCLASS-CLSCATEG) not found in the Properties dialog."
    On Error Resume Next
    oSession.findById(catId).setFocus
    oSession.findById(catId).Key = NEW_CATEGORY
    If Err.Number <> 0 Then FailExit "invalid category code '" & NEW_CATEGORY & "': " & Err.Description
    Err.Clear : On Error GoTo 0
    sChanges = sChanges & " category='" & NEW_CATEGORY & "'"
End If

WScript.Echo "INFO: Applying changes:" & sChanges

' --------------------------------------------------------------------------
' 7. Continue (close dialog) -> Save -> Activate
' --------------------------------------------------------------------------
On Error Resume Next
oSession.findById("wnd[1]/tbar[0]/btn[0]").press   ' Continue
WScript.Sleep 1200
Err.Clear : On Error GoTo 0

On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_SAVE
WScript.Sleep 1500
Err.Clear : On Error GoTo 0

Dim sErr : sErr = DrainPopups(4)
If sErr <> "" Then FailExit sErr

Dim st1 : st1 = SbarType()
WScript.Echo "INFO: After Save sbar [" & st1 & "]: " & SbarText()
If LCase(st1) = "e" Or LCase(st1) = "a" Then FailExit "Save failed - " & SbarText()

' Activate so the active version reflects the change (best-effort).
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_ACTIVATE
WScript.Sleep 1800
Err.Clear : On Error GoTo 0
Dim sErr2 : sErr2 = DrainPopups(5)
If sErr2 <> "" Then
    WScript.Echo "WARN: activation popup issue - " & sErr2 & vbCrLf & _
                 "      The property change was saved; re-activate manually if needed."
End If
Dim st2 : st2 = SbarType()
WScript.Echo "INFO: After Activate sbar [" & st2 & "]: " & SbarText()
If LCase(st2) = "a" Then
    ' Abort-level only; activation 'E' is non-fatal (Save already persisted).
    WScript.Echo "WARN: activation aborted - " & SbarText()
End If

' --------------------------------------------------------------------------
' 8. Release lock, restore view, back out, report
' --------------------------------------------------------------------------
On Error Resume Next
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 400
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then oSession.findById("wnd[1]").sendVKey VKEY_ENTER
Err.Clear : On Error GoTo 0

RestoreView

WScript.Echo "SUCCESS: Properties updated for " & UCase(CLASS_NAME) & "."
WScript.Quit 0

' --------------------------------------------------------------------------
' sbar readers (defined after main flow; VBScript hoists Function/Sub)
' --------------------------------------------------------------------------
Function SbarText()
    SbarText = ""
    On Error Resume Next
    SbarText = oSession.findById("wnd[0]/sbar").Text
    Err.Clear : On Error GoTo 0
End Function

Function SbarType()
    SbarType = ""
    On Error Resume Next
    SbarType = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear : On Error GoTo 0
End Function
