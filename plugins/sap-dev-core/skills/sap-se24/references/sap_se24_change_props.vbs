' =============================================================================
' sap_se24_change_props.vbs  -  SAP GUI Scripting: Change SE24 Class Properties
'                                (Description, Program Status, Category, ...)
'
' Generated by the sap-se24 skill.
' Attaches to an existing SAP GUI session, navigates to SE24, opens the
' class in Display mode, then opens the Properties dialog (Goto > Properties
' = wnd[0]/mbar/menu[2]/menu[2]). Toggles the dialog into change mode
' (wnd[1]/tbar[0]/btn[25]), updates the supplied fields on subscreen
' SAPLSEO_CLASS_EDITOR:0152, presses Continue (wnd[1]/tbar[0]/btn[0]),
' then Saves (Ctrl+S on wnd[0]). Handles the conditional original-language
' popup and the post-save Workbench-request popup (per
' /sap-transport-request).
'
' Tokens replaced at run time:
'   %%CLASS_NAME%%   Class name                 e.g. "ZCL_IM_ZHK_PO_001"
'   %%DESCRIPTION%%  New description (max 60). Empty = leave unchanged.
'   %%STATUS%%       New program status (VSEOCLASS-RSTAT). Empty = unchanged.
'                       P = SAP Standard Production
'                       K = Customer Production
'                       S = System Class
'                       T = Test Class
'                       X = SAP Example
'   %%CATEGORY%%     Class category (VSEOCLASS-CLSCCINCL ... actually CLSCATEG)
'                    Empty = unchanged.
'                       0 = General object type
'                       (other codes per SE24 dropdown)
'   %%TRANSPORT%%    TR for the post-save TR popup. Empty when local
'                    ($TMP) or already locked to a modifiable TR.
'
' Recorded baseline (CTempRecord_SE24_ChangeClassProperties.vbs):
'   /nSE24 -> ctxtSEOCLASS-CLSNAME -> Enter -> btnPUSH_DISPLAY
'   mbar/menu[2]/menu[2]  (Goto > Properties)
'   wnd[1]/tbar[0]/btn[25]  (toggle Display->Change)
'   wnd[1]/usr/subDY_0500-SUBSCR:SAPLSEO_CLASS_EDITOR:0152/txtVSEOCLASS-DESCRIPT
'   wnd[1]/usr/subDY_0500-SUBSCR:SAPLSEO_CLASS_EDITOR:0152/cmbVSEOCLASS-RSTAT
'   wnd[1]/tbar[0]/btn[0]  (Continue)
'   wnd[0] sendVKey 11  (Ctrl+S = Save)
'   [optional wnd[1] TR popup -> ctxtKO008-TRKORR -> Enter]
' =============================================================================

Option Explicit

Const CLASS_NAME       = "%%CLASS_NAME%%"
Const NEW_DESCRIPTION  = "%%DESCRIPTION%%"
Const NEW_STATUS       = "%%STATUS%%"
Const NEW_CATEGORY     = "%%CATEGORY%%"
Const SAP_TRANSPORT    = "%%TRANSPORT%%"

Const VKEY_ENTER     = 0
Const VKEY_F11_SAVE  = 11
Const PROP_BASE      = "wnd[1]/usr/subDY_0500-SUBSCR:SAPLSEO_CLASS_EDITOR:0152"

' Include shared session-lock helpers (TryLockSession / ReleaseSession).
' Per language_independence_rules.md Rule 7.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

Dim oSAPGUI, oApp, oSession, oCandidate, oSessIter

' ------ 1. Attach to existing SAP GUI session -------------------------------
On Error Resume Next
Set oSAPGUI = GetObject("SAPGUI")
If Err.Number <> 0 Or oSAPGUI Is Nothing Then
    WScript.Echo "ERROR: SAP GUI is not running."
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

Set oApp = oSAPGUI.GetScriptingEngine
Set oSession = Nothing
On Error Resume Next
For Each oCandidate In oApp.Children
    For Each oSessIter In oCandidate.Children
        Set oSession = oSessIter
        Exit For
    Next
    If Not (oSession Is Nothing) Then Exit For
Next
On Error GoTo 0

If oSession Is Nothing Then
    WScript.Echo "ERROR: No SAP GUI session found. Run the login step first."
    WScript.Quit 1
End If
WScript.Echo "INFO: Session acquired."

' ------ 2. Navigate to SE24 + Display ---------------------------------------
WScript.Echo "INFO: Navigating to SE24..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nSE24"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000
Err.Clear
On Error GoTo 0

On Error Resume Next
Dim oNameField
Set oNameField = oSession.findById("wnd[0]/usr/ctxtSEOCLASS-CLSNAME")
If Err.Number <> 0 Or oNameField Is Nothing Then
    WScript.Echo "ERROR: SE24 class-name field not found (wnd[0]/usr/ctxtSEOCLASS-CLSNAME)."
    WScript.Quit 1
End If
oNameField.Text = UCase(CLASS_NAME)
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500
Err.Clear

WScript.Echo "INFO: Opening class in Display: " & UCase(CLASS_NAME)
oSession.findById("wnd[0]/usr/btnPUSH_DISPLAY").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' --- Lock the SAP session UI for the class properties change + save critical section ---
' Per Rule 7: LockSessionUI blocks user input races inside SAP. No OS-level
' foreground guard needed — this flow only edits Properties dialog fields
' via the Scripting API (no clipboard, no SendKeys). Released after save.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the class properties change + save critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Open the Properties dialog (Goto > Properties = mbar/menu[2]/menu[2]) ----
WScript.Echo "INFO: Opening Properties dialog (Goto > Properties)..."
On Error Resume Next
oSession.findById("wnd[0]/mbar/menu[2]/menu[2]").select
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' Verify the Properties dialog opened
Dim oDescr, bInProps
bInProps = False
On Error Resume Next
Err.Clear
Set oDescr = oSession.findById(PROP_BASE & "/txtVSEOCLASS-DESCRIPT")
If Err.Number = 0 And Not (oDescr Is Nothing) Then bInProps = True
Err.Clear
On Error GoTo 0

If Not bInProps Then
    WScript.Echo "ERROR: Properties dialog (" & PROP_BASE & "/txtVSEOCLASS-DESCRIPT) did not open."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Echo "INFO: Properties dialog open."

' ------ 4. Toggle Display -> Change in the dialog (btn[25]) -----------------
WScript.Echo "INFO: Toggling dialog to change mode (btn[25])..."
On Error Resume Next
oSession.findById("wnd[1]/tbar[0]/btn[25]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 4a. Original-language popup (SAPLSETX, conditional) -----------------
' May appear EITHER as wnd[1] (replacing the Properties dialog) OR as wnd[2]
' (on top of it) depending on SAP version. Detect and dismiss either way.
Sub HandleOrigLangPopup(sWinId)
    Dim oML, oMaintBtn
    On Error Resume Next
    Err.Clear
    Set oML = oSession.findById(sWinId & "/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 And Not (oML Is Nothing) Then
        Err.Clear
        Set oMaintBtn = oSession.findById(sWinId & "/usr/btnPUSH1")
        If Err.Number = 0 And Not (oMaintBtn Is Nothing) Then
            WScript.Echo "INFO: Original-language popup (MASTERLANG=" & _
                         oML.Text & ") - pressing 'Maint. in orig. lang.'."
            oMaintBtn.press
            WScript.Sleep 1500
        End If
    End If
    Err.Clear
    On Error GoTo 0
End Sub

HandleOrigLangPopup "wnd[2]"
HandleOrigLangPopup "wnd[1]"

' Re-resolve the description field after any popup churn (handle may be stale)
On Error Resume Next
Set oDescr = Nothing
Err.Clear
Set oDescr = oSession.findById(PROP_BASE & "/txtVSEOCLASS-DESCRIPT")
If Err.Number <> 0 Or oDescr Is Nothing Then
    WScript.Echo "ERROR: Properties dialog disappeared after change-mode toggle."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

' ------ 5. Apply changes ----------------------------------------------------
Dim sChanges
sChanges = ""

If NEW_DESCRIPTION <> "" Then
    On Error Resume Next
    oDescr.Text = NEW_DESCRIPTION
    If Err.Number <> 0 Then
        WScript.Echo "ERROR: Could not set description (dialog may still be display-only). " & Err.Description
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
    sChanges = sChanges & " description='" & NEW_DESCRIPTION & "'"
End If

If NEW_STATUS <> "" Then
    On Error Resume Next
    Dim oStatus
    Set oStatus = oSession.findById(PROP_BASE & "/cmbVSEOCLASS-RSTAT")
    If Err.Number = 0 And Not (oStatus Is Nothing) Then
        oStatus.setFocus
        oStatus.Key = NEW_STATUS
        If Err.Number <> 0 Then
            WScript.Echo "ERROR: Invalid status code '" & NEW_STATUS & "': " & Err.Description
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        sChanges = sChanges & " status='" & NEW_STATUS & "'"
    Else
        WScript.Echo "ERROR: Status combobox not found (" & PROP_BASE & "/cmbVSEOCLASS-RSTAT)."
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
End If

If NEW_CATEGORY <> "" Then
    On Error Resume Next
    Dim oCat
    Set oCat = oSession.findById(PROP_BASE & "/cmbVSEOCLASS-CLSCATEG")
    If Err.Number = 0 And Not (oCat Is Nothing) Then
        oCat.setFocus
        oCat.Key = NEW_CATEGORY
        If Err.Number <> 0 Then
            WScript.Echo "ERROR: Invalid category code '" & NEW_CATEGORY & "': " & Err.Description
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        sChanges = sChanges & " category='" & NEW_CATEGORY & "'"
    Else
        WScript.Echo "ERROR: Category combobox not found (" & PROP_BASE & "/cmbVSEOCLASS-CLSCATEG)."
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
    Err.Clear
    On Error GoTo 0
End If

If sChanges = "" Then
    WScript.Echo "INFO: No property values supplied - nothing to change."
    WScript.Echo "INFO: Cancelling Properties dialog."
    On Error Resume Next
    oSession.findById("wnd[1]").sendVKey 12   ' F12 = Cancel
    Err.Clear
    On Error GoTo 0
    WScript.Echo "DONE: NO_CHANGE"
    ReleaseSession oSession, wasLocked
    WScript.Quit 0
End If

WScript.Echo "INFO: Applying changes:" & sChanges

' ------ 6. Continue (close Properties dialog) -------------------------------
WScript.Echo "INFO: Pressing Continue (wnd[1]/tbar[0]/btn[0])..."
On Error Resume Next
oSession.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 7. Save (Ctrl+S on main window) -------------------------------------
WScript.Echo "INFO: Saving (Ctrl+S)..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

' ------ 7a. Optional Workbench-request popup --------------------------------
On Error Resume Next
Dim iLoop
For iLoop = 1 To 3
    If InStr(oSession.ActiveWindow.Id, "wnd[1]") = 0 Then Exit For

    Dim oTrField
    Set oTrField = Nothing
    Err.Clear
    Set oTrField = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrField Is Nothing) Then
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SAP prompted for a transport request but TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            On Error Resume Next
            oSession.findById("wnd[1]").sendVKey 12
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        oTrField.Text = SAP_TRANSPORT
        WScript.Echo "INFO: TR popup - entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1200
    Else
        ' Detect Error popup (e.g. lock errors)
        Dim sTitle, oM1, oM2, sM1, sM2
        sTitle = oSession.ActiveWindow.Text
        sM1 = "" : sM2 = ""
        Err.Clear
        Set oM1 = oSession.findById("wnd[1]/usr/txtMESSTXT1")
        If Err.Number = 0 And Not (oM1 Is Nothing) Then sM1 = oM1.Text
        Err.Clear
        Set oM2 = oSession.findById("wnd[1]/usr/txtMESSTXT2")
        If Err.Number = 0 And Not (oM2 Is Nothing) Then sM2 = oM2.Text
        Err.Clear
        If LCase(sTitle) = "error" Or InStr(LCase(sM1 & " " & sM2), "locked") > 0 Then
            WScript.Echo "ERROR: SAP popup [" & sTitle & "] " & Trim(sM1 & " " & sM2)
            On Error Resume Next
            oSession.findById("wnd[1]/tbar[0]/btn[12]").press
            If Err.Number <> 0 Then
                Err.Clear
                oSession.findById("wnd[1]").sendVKey 12
            End If
            Err.Clear
            On Error GoTo 0
            ReleaseSession oSession, wasLocked
            WScript.Quit 1
        End If
        WScript.Echo "INFO: Confirming popup [" & sTitle & "] - pressing Enter."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 1000
    End If
Next
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; status bar read is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 8. Read status bar --------------------------------------------------
Dim sBarText, sBarType
sBarText = "" : sBarType = ""
On Error Resume Next
sBarText = oSession.findById("wnd[0]/sbar").Text
sBarType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Status bar [" & sBarType & "]: " & sBarText
If LCase(sBarType) = "e" Or LCase(sBarType) = "a" Then
    WScript.Echo "ERROR: Save failed - " & sBarText
    WScript.Quit 1
End If

' ------ 9. Back to /n -------------------------------------------------------
On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Properties updated for " & UCase(CLASS_NAME) & "."
WScript.Quit 0
