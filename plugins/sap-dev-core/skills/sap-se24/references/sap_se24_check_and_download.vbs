' =============================================================================
' sap_se24_check_and_download.vbs  -  SAP GUI Scripting: Syntax-check ABAP
'                                     class and download source via SE24
'
' Generated by the sap-se24 skill (check-and-fix mode).
' Attaches to an existing SAP GUI session, navigates to SE24, opens the
' class in display mode (source-code-based view), runs a syntax check
' (Ctrl+F2), reports any errors, then downloads the source via GetLineText.
'
' Tokens replaced at run time:
'   %%CLASS_NAME%%     ABAP class name             e.g. "ZCL_HK_TEST001"
'   %%OUTPUT_FILE%%    Absolute path for downloaded source (UTF-16 LE)
'                      e.g. "C:\sap_dev_work\temp\ZCL_HK_TEST001_from_sap.txt"
'
' Output lines used by the SKILL.md PS1 wrapper:
'   SYNTAX_ERRORS: N error(s) found:   -- followed by  "  Line N: ..." lines
'   RESULT: SYNTAX_ERRORS              -- end marker when errors exist
'   RESULT: SYNTAX_OK                  -- end marker when no errors
'   ERROR: ...                         -- fatal error (non-zero exit)
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const CLASS_NAME   = "%%CLASS_NAME%%"
Const OUTPUT_FILE  = "%%OUTPUT_FILE%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER   = 0
Const VKEY_F3_BACK = 3

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE24 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE24..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE24"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

On Error Resume Next
Dim oClassField
Set oClassField = oSession.findById("wnd[0]/usr/ctxtSEOCLASS-CLSNAME")
If Err.Number <> 0 Or oClassField Is Nothing Then
    WScript.Echo "ERROR: SE24 class name field not found (ID: wnd[0]/usr/ctxtSEOCLASS-CLSNAME)."
    WScript.Quit 1
End If
On Error GoTo 0

' ------ 3. Open class in display mode ---------------------------------------
oClassField.Text = UCase(CLASS_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Opening class in display mode: " & UCase(CLASS_NAME)
oSession.findById("wnd[0]/usr/btnPUSH_DISPLAY").press
WScript.Sleep 2000

' Dismiss any info popup
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Verify source-code-based view (txtDY0400_STATUS present)
On Error Resume Next
Dim oStatusField
Set oStatusField = oSession.findById("wnd[0]/usr/txtDY0400_STATUS")
Dim bSourceView
bSourceView = (Err.Number = 0) And Not (oStatusField Is Nothing)
Err.Clear
On Error GoTo 0

If Not bSourceView Then
    ' Check if in form-based view
    On Error Resume Next
    Dim oTabStrip
    Set oTabStrip = oSession.findById("wnd[0]/usr/tabsCTS")
    Dim bFormView
    bFormView = (Err.Number = 0) And Not (oTabStrip Is Nothing)
    Err.Clear
    On Error GoTo 0

    If bFormView Then
        WScript.Echo "ERROR: Class is in form-based view. Source-code-based view is required." & vbCrLf & _
                     "       Open SE24, go to Utilities > Settings, select 'Source Code-Based' view, then retry."
        WScript.Quit 1
    End If
    WScript.Echo "ERROR: Could not open class: " & UCase(CLASS_NAME) & vbCrLf & _
                 "       Check that the class exists and you have authorization."
    WScript.Quit 1
End If
WScript.Echo "INFO: Class opened in display mode (source-code-based view)."

' ------ 4. Run syntax check (tbar[1]/btn[26] = Ctrl+F2) --------------------
WScript.Echo "INFO: Running syntax check..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[26]").press
WScript.Sleep 3000

' Dismiss any popup
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 500
End If
Err.Clear
On Error GoTo 0

' Read syntax errors from the error grid
' Grid: wnd[0]/shellcont/shell/shellcont[1]/shell
' Columns: MSGTYPE, LINE, TEXT
' Any rows in grid = errors (MSGTYPE may be icon format @5C\QError@)
Dim oSyntaxGrid, nSyntaxRows, bSyntaxOK
bSyntaxOK = True

On Error Resume Next
Set oSyntaxGrid = oSession.findById("wnd[0]/shellcont/shell/shellcont[1]/shell")
If Err.Number = 0 And Not (oSyntaxGrid Is Nothing) Then
    nSyntaxRows = oSyntaxGrid.RowCount
    Err.Clear
    If nSyntaxRows > 0 Then
        bSyntaxOK = False
        WScript.Echo "SYNTAX_ERRORS: " & (nSyntaxRows \ 2) & " error(s) found:"
        Dim iSynRow
        Dim sSynType, sSynLine, sSynText
        For iSynRow = 0 To nSyntaxRows - 1
            sSynType = ""
            sSynLine = ""
            sSynText = ""
            sSynType = oSyntaxGrid.getCellValue(iSynRow, "MSGTYPE")
            Err.Clear
            sSynLine = oSyntaxGrid.getCellValue(iSynRow, "LINE")
            Err.Clear
            sSynText = oSyntaxGrid.getCellValue(iSynRow, "TEXT")
            Err.Clear
            If sSynText <> "" Then
                If sSynLine <> "" Then
                    WScript.Echo "  Line " & sSynLine & ": " & sSynText
                Else
                    WScript.Echo "    -> " & sSynText
                End If
            End If
        Next
    Else
        WScript.Echo "INFO: Syntax check passed -- no findings."
    End If
Else
    Err.Clear
    ' Grid not found -- fall back to status bar
    Dim sSyntaxMsg, sSyntaxType
    sSyntaxMsg  = oSession.findById("wnd[0]/sbar").Text
    sSyntaxType = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear
    If sSyntaxType = "E" Then
        bSyntaxOK = False
        WScript.Echo "SYNTAX_ERRORS: Syntax check failed - " & sSyntaxMsg
    ElseIf sSyntaxMsg = "" Then
        WScript.Echo "INFO: Syntax check -- no findings (sbar empty, AbapEditor may swallow messages)."
    Else
        WScript.Echo "INFO: Syntax check passed."
    End If
End If
On Error GoTo 0

' ------ 5. Download source via Change mode + Download menu -----------------
' Use the same Utilities > More Utilities > Upload/Download menu as upload,
' but select Download (menu[1]) instead of Upload (menu[0]).
WScript.Echo "INFO: Downloading source code..."

On Error Resume Next
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE24"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1500

oSession.findById("wnd[0]/usr/ctxtSEOCLASS-CLSNAME").Text = UCase(CLASS_NAME)
WScript.Sleep 300
oSession.findById("wnd[0]/usr/btnPUSH_CHANGE").press   ' Change mode
WScript.Sleep 3000

' Dismiss any info popup
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Try Download menu -- mirror of upload menu paths, index [1] instead of [0]
Dim bDownloadMenuOK
bDownloadMenuOK = False

On Error Resume Next
oSession.findById("wnd[0]/mbar/menu[3]/menu[8]/menu[2]/menu[1]").select
If Err.Number = 0 Then bDownloadMenuOK = True
Err.Clear
On Error GoTo 0

If Not bDownloadMenuOK Then
    On Error Resume Next
    oSession.findById("wnd[0]/mbar/menu[3]/menu[9]/menu[2]/menu[1]").select
    If Err.Number = 0 Then bDownloadMenuOK = True
    Err.Clear
    On Error GoTo 0
End If

If Not bDownloadMenuOK Then
    On Error Resume Next
    oSession.findById("wnd[0]/mbar/menu[3]/menu[2]/menu[1]").select
    If Err.Number = 0 Then bDownloadMenuOK = True
    Err.Clear
    On Error GoTo 0
End If

If Not bDownloadMenuOK Then
    WScript.Echo "ERROR: Could not find Download menu. Tried menu[3]/menu[8]/menu[2]/menu[1], menu[3]/menu[9]/menu[2]/menu[1], menu[3]/menu[2]/menu[1]."
    WScript.Quit 1
End If
WScript.Echo "INFO: Download menu selected."
WScript.Sleep 2000

' Fill in the download file dialog (same field IDs as upload dialog)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim iSlash, sDir, sFile
    iSlash = InStrRev(OUTPUT_FILE, "\")
    sDir   = Left(OUTPUT_FILE, iSlash)
    sFile  = Mid(OUTPUT_FILE, iSlash + 1)

    oSession.findById("wnd[1]/usr/ctxtDY_PATH").Text     = sDir
    oSession.findById("wnd[1]/usr/ctxtDY_FILENAME").Text = sFile
    WScript.Sleep 300
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 2000

    If Err.Number <> 0 Then
        WScript.Echo "ERROR: Download dialog interaction failed: " & Err.Description
        WScript.Quit 1
    End If
Else
    WScript.Echo "ERROR: Download file dialog did not appear."
    WScript.Quit 1
End If

' Dismiss any "Replace existing file?" confirmation
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' Cancel change mode without saving (F3 back)
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F3_BACK
WScript.Sleep 1000
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.findById("wnd[1]/usr/btnBUTTON_1").press  ' Discard changes
    If Err.Number <> 0 Then
        Err.Clear
        oSession.ActiveWindow.sendVKey VKEY_F3_BACK
    End If
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Source downloaded to: " & OUTPUT_FILE

' ------ 6. Final result marker ----------------------------------------------
If Not bSyntaxOK Then
    WScript.Echo "RESULT: SYNTAX_ERRORS"
    WScript.Quit 0
End If

WScript.Echo "RESULT: SYNTAX_OK"
WScript.Quit 0
