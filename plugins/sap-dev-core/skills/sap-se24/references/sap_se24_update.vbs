' =============================================================================
' sap_se24_update.vbs  -  SAP GUI Scripting: Update existing ABAP class via SE24
'
' Generated by the sap-se24 skill.
' Attaches to an existing SAP GUI session, navigates to SE24, opens the
' class in source-code-based view (change mode), uploads new source code,
' saves, activates, and runs syntax check.
'
' The source file must contain the COMPLETE class source code including
' CLASS ... DEFINITION and CLASS ... IMPLEMENTATION sections.
'
' Tokens replaced at run time:
'   %%CLASS_NAME%%         ABAP class name            e.g. "ZCL_HK_TEST001"
'   %%ABAP_SOURCE_FILE%%   Absolute path to .abap file with full class source
'   %%PACKAGE%%            SAP package (optional, blank = local $TMP)
'   %%TRANSPORT%%          Transport request (optional, blank = local)
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909 (S4D).
' =============================================================================

Option Explicit

Const CLASS_NAME       = "%%CLASS_NAME%%"
Const ABAP_SOURCE_FILE = "%%ABAP_SOURCE_FILE%%"
Const SAP_PACKAGE      = "%%PACKAGE%%"
Const SAP_TRANSPORT    = "%%TRANSPORT%%"
Const SESSION_PATH     = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER    = 0
Const VKEY_F3_BACK  = 3
Const VKEY_F11_SAVE = 11
Const VKEY_F12_CANCEL = 12

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to SE24 -------------------------------------------------
WScript.Echo "INFO: Navigating to SE24..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nSE24"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

On Error Resume Next
Dim oClassField
Set oClassField = oSession.findById("wnd[0]/usr/ctxtSEOCLASS-CLSNAME")
If Err.Number <> 0 Or oClassField Is Nothing Then
    WScript.Echo "ERROR: SE24 class name field not found (ID: wnd[0]/usr/ctxtSEOCLASS-CLSNAME)."
    WScript.Quit 1
End If
On Error GoTo 0

' ------ 3. Enter class name and open in change mode -------------------------
oClassField.Text = UCase(CLASS_NAME)
WScript.Sleep 300

WScript.Echo "INFO: Opening class in change mode: " & UCase(CLASS_NAME)
oSession.findById("wnd[0]/usr/btnPUSH_CHANGE").press
WScript.Sleep 2000

' ------ 3a. Original-language mismatch popup (program SAPLSETX) -------------
' If wnd[1] is the "Different original and logon languages" dialog, press
' "Maint. in orig. lang." (btnPUSH1). Keeps TADIR-MASTERLANG unchanged.
' Fingerprint: ctxtRSETX-MASTERLANG present in wnd[1]/usr.
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oMasterLangFld
    Set oMasterLangFld = Nothing
    Err.Clear
    Set oMasterLangFld = oSession.findById("wnd[1]/usr/ctxtRSETX-MASTERLANG")
    If Err.Number = 0 Then
        If Not (oMasterLangFld Is Nothing) Then
            Dim oMaintBtn
            Set oMaintBtn = Nothing
            Err.Clear
            Set oMaintBtn = oSession.findById("wnd[1]/usr/btnPUSH1")
            If Err.Number = 0 Then
                If Not (oMaintBtn Is Nothing) Then
                    WScript.Echo "INFO: Original-language popup detected (logon != MASTERLANG=" & _
                                 oMasterLangFld.Text & ") — pressing 'Maint. in orig. lang.'."
                    oMaintBtn.press
                    WScript.Sleep 1500
                End If
            End If
        End If
    End If
End If
Err.Clear
On Error GoTo 0

' Dismiss any other info popup
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 4. Detect source-code-based view or form-based view -----------------
' Source-code-based view has txtDY0400_STATUS; form-based has tabsCTS.
' We need source-code-based view for Upload/Download.
Dim bSourceView
bSourceView = False

On Error Resume Next
Dim oStatusField
Set oStatusField = oSession.findById("wnd[0]/usr/txtDY0400_STATUS")
If Err.Number = 0 And Not (oStatusField Is Nothing) Then
    bSourceView = True
End If
Err.Clear
On Error GoTo 0

If Not bSourceView Then
    ' Check if we are in form-based view (tabsCTS present)
    On Error Resume Next
    Dim oTabStrip
    Set oTabStrip = oSession.findById("wnd[0]/usr/tabsCTS")
    Dim bFormView
    bFormView = (Err.Number = 0 And Not (oTabStrip Is Nothing))
    Err.Clear
    On Error GoTo 0

    If Not bFormView Then
        WScript.Echo "ERROR: Could not open class in change mode." & vbCrLf & _
                     "       Check that the class exists and you have authorization."
        WScript.Quit 1
    End If

    WScript.Echo "ERROR: Class is in form-based view. Source-code-based view is required for upload." & vbCrLf & _
                 "       Open SE24, go to Utilities > Settings > Display tab, and select 'Source Code-Based' view." & vbCrLf & _
                 "       Then re-run this script."
    WScript.Quit 1
End If

WScript.Echo "INFO: Class opened in source-code-based change mode."

' ------ 4b. Pre-save TR claim --------------------------------------------------
' Send Ctrl+S to provoke any "Prompt for local Workbench request" popup.
' Outcomes:
'   (a) wnd[1] with field ctxtKO008-TRKORR → fill SAP_TRANSPORT, Enter.
'   (b) Other popup → Enter to dismiss.
'   (c) No popup → object is local ($TMP) or already locked to a modifiable TR.
' If a TR popup appears but SAP_TRANSPORT is empty, abort.
' Diagnostics: TADIR-DEVCLASS, E071, E070-TRSTATUS.
WScript.Echo "INFO: Pre-save (Ctrl+S) to check whether a TR popup appears..."
On Error Resume Next
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 1500
Err.Clear
On Error GoTo 0

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oPreTR
    Set oPreTR = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oPreTR Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT = "" Then
            WScript.Echo "ERROR: SE24 prompted for a transport request but SAP_TRANSPORT is empty." & vbCrLf & _
                         "       Resolve a modifiable TR via /sap-transport-request and re-run."
            WScript.Quit 1
        End If
        oPreTR.Text = SAP_TRANSPORT
        WScript.Echo "INFO: Pre-save TR popup detected — entering " & SAP_TRANSPORT & "."
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: Pre-save popup (no TR field) — pressing Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
Else
    WScript.Echo "INFO: No pre-save popup — object is local ($TMP) or already locked to a modifiable TR."
End If
Err.Clear
On Error GoTo 0

' ------ 5. Verify source file and convert encoding ---------------------------
Dim oFSO
Set oFSO = CreateObject("Scripting.FileSystemObject")
If Not oFSO.FileExists(ABAP_SOURCE_FILE) Then
    WScript.Echo "ERROR: Source file not found: " & ABAP_SOURCE_FILE
    WScript.Quit 1
End If

' Convert UTF-8 source file to appropriate encoding for SAP GUI upload.
' On Unicode SAP systems (codepage 4110), upload UTF-8 directly.
' On non-Unicode systems, convert to the Windows system ANSI codepage.
Dim bIsUnicode
bIsUnicode = False
On Error Resume Next
Dim iSAPCodepage
iSAPCodepage = oSession.Info.Codepage
If Err.Number = 0 And (CStr(iSAPCodepage) = "4110" Or CStr(iSAPCodepage) = "4103") Then
    bIsUnicode = True
End If
Err.Clear
On Error GoTo 0

Dim sUploadFile
If bIsUnicode Then
    sUploadFile = ABAP_SOURCE_FILE
    WScript.Echo "INFO: Unicode SAP system (codepage " & iSAPCodepage & "). Uploading UTF-8 source directly."
Else
    Dim sCodePage
    On Error Resume Next
    Dim oWMI, colOS, oOS
    Set oWMI = GetObject("winmgmts:\\.\root\cimv2")
    Set colOS = oWMI.ExecQuery("SELECT CodeSet FROM Win32_OperatingSystem")
    For Each oOS In colOS
        sCodePage = oOS.CodeSet
    Next
    Err.Clear
    On Error GoTo 0
    If sCodePage = "" Then sCodePage = "1252"

    Dim sCharset
    Select Case sCodePage
        Case "932"   : sCharset = "shift_jis"
        Case "936"   : sCharset = "gb2312"
        Case "949"   : sCharset = "ks_c_5601-1987"
        Case "950"   : sCharset = "big5"
        Case "1250"  : sCharset = "windows-1250"
        Case "1251"  : sCharset = "windows-1251"
        Case "1253"  : sCharset = "windows-1253"
        Case "1254"  : sCharset = "windows-1254"
        Case "1255"  : sCharset = "windows-1255"
        Case "1256"  : sCharset = "windows-1256"
        Case "65001" : sCharset = "utf-8"
        Case Else    : sCharset = "windows-1252"
    End Select

    sUploadFile = ABAP_SOURCE_FILE & ".upload.txt"
    Dim oInStream, oOutStream
    Set oInStream = CreateObject("ADODB.Stream")
    oInStream.Type = 2
    oInStream.Charset = "utf-8"
    oInStream.Open
    oInStream.LoadFromFile ABAP_SOURCE_FILE

    Set oOutStream = CreateObject("ADODB.Stream")
    oOutStream.Type = 2
    oOutStream.Charset = sCharset
    oOutStream.Open

    Dim sAbapContent
    sAbapContent = oInStream.ReadText
    oInStream.Close
    oOutStream.WriteText sAbapContent
    oOutStream.SaveToFile sUploadFile, 2
    oOutStream.Close
    WScript.Echo "INFO: Converted source file from UTF-8 to " & sCharset & " for upload."
End If

' --- Lock the SAP session UI for the source upload + save + activate + syntax check critical section ---
' Per Rule 7: LockSessionUI blocks user input races inside SAP. We do NOT
' need an OS-level foreground guard here (unlike sap-se38) because the
' source is uploaded via SE24's Utilities > Upload menu — the file is
' read from disk by the SAP process; no clipboard, no SendKeys, no
' Windows-foreground race. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the source upload + save + activate + syntax check critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 6. Upload source via menu Upload/Download ----------------------------
' The upload menu path varies by SAP version and language. Try known paths.
WScript.Echo "INFO: Uploading source file: " & ABAP_SOURCE_FILE

Dim bUploadMenuOK
bUploadMenuOK = False

' Try path 1: Utilities > More Utilities > Upload/Download > Upload (S/4HANA source-code view)
On Error Resume Next
oSession.findById("wnd[0]/mbar/menu[3]/menu[8]/menu[2]/menu[0]").select
If Err.Number = 0 Then
    bUploadMenuOK = True
    WScript.Echo "INFO: Upload menu found at menu[3]/menu[8]/menu[2]/menu[0]."
End If
Err.Clear
On Error GoTo 0

' Try path 2: Utilities > More Utilities > Upload/Download > Upload (alternative index)
If Not bUploadMenuOK Then
    On Error Resume Next
    oSession.findById("wnd[0]/mbar/menu[3]/menu[9]/menu[2]/menu[0]").select
    If Err.Number = 0 Then
        bUploadMenuOK = True
        WScript.Echo "INFO: Upload menu found at menu[3]/menu[9]/menu[2]/menu[0]."
    End If
    Err.Clear
    On Error GoTo 0
End If

' Try path 3: Utilities > Upload/Download > Upload (no "More Utilities" submenu)
If Not bUploadMenuOK Then
    On Error Resume Next
    oSession.findById("wnd[0]/mbar/menu[3]/menu[2]/menu[0]").select
    If Err.Number = 0 Then
        bUploadMenuOK = True
        WScript.Echo "INFO: Upload menu found at menu[3]/menu[2]/menu[0]."
    End If
    Err.Clear
    On Error GoTo 0
End If

If Not bUploadMenuOK Then
    WScript.Echo "ERROR: Could not find Upload menu. Tried multiple paths." & vbCrLf & _
                 "       Use SAP GUI Script Recording to find the correct menu path on your system." & vbCrLf & _
                 "       In SE24 source-code-based view, look for: Utilities > More Utilities > Upload/Download > Upload"
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Sleep 2000

' Handle "Save before upload" dialog — press No (don't save current state)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim sDlgTitle
    sDlgTitle = oSession.findById("wnd[1]").Text
    If InStr(sDlgTitle, "Save") > 0 Then
        WScript.Echo "INFO: Save before upload dialog — pressing No..."
        oSession.findById("wnd[1]/usr/btnBUTTON_2").press
        WScript.Sleep 2000
    End If
End If
Err.Clear
On Error GoTo 0

' Fill in the upload file dialog
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim iSlash, sDir, sFile
    iSlash = InStrRev(sUploadFile, "\")
    sDir   = Left(sUploadFile, iSlash)
    sFile  = Mid(sUploadFile, iSlash + 1)

    oSession.findById("wnd[1]/usr/ctxtDY_PATH").Text     = sDir
    oSession.findById("wnd[1]/usr/ctxtDY_FILENAME").Text = sFile
    WScript.Sleep 300
    oSession.findById("wnd[1]").sendVKey VKEY_ENTER
    WScript.Sleep 3000
Else
    WScript.Echo "ERROR: Upload file dialog did not appear." & vbCrLf & _
                 "       SAP GUI Security settings may be blocking access." & vbCrLf & _
                 "       Go to SAP Logon > Options > Security > set 'Open file' to Allow."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

If Err.Number <> 0 Then
    WScript.Echo "ERROR: Upload dialog interaction failed: " & Err.Description
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Source code uploaded."

' ------ 7. Save (Ctrl+S / F11) ----------------------------------------------
' Pre-save in step 4b already locked the object to SAP_TRANSPORT (or it is
' local / already locked), so the TR popup should not reappear. Any popup
' here is a safety net.
WScript.Echo "INFO: Saving..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    Dim oTrField2
    Set oTrField2 = oSession.findById("wnd[1]/usr/ctxtKO008-TRKORR")
    If Err.Number = 0 And Not (oTrField2 Is Nothing) Then
        Err.Clear
        If SAP_TRANSPORT <> "" Then
            oTrField2.Text = SAP_TRANSPORT
            WScript.Echo "INFO: (safety-net) TR popup re-appeared on save — re-entering " & SAP_TRANSPORT & "."
        End If
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        WScript.Sleep 1000
    Else
        Err.Clear
        WScript.Echo "INFO: (safety-net) Save popup (no TR field) — Enter to dismiss."
        oSession.ActiveWindow.sendVKey VKEY_ENTER
        WScript.Sleep 800
    End If
End If
Err.Clear
On Error GoTo 0

WScript.Echo "INFO: Saved."

' ------ 8. Activate (Ctrl+F3) — must activate BEFORE syntax check -----------
' If the class has an inactive version, syntax check may report false errors.
' Activating first resolves this (same pattern as SE37/SE38).
WScript.Echo "INFO: Activating..."
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[27]").press  ' Ctrl+F3 Activate
WScript.Sleep 3000

' Handle "Inactive Objects" list popup — press btn[0] (green check) to activate all
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Inactive objects list — confirming activation..."
    oSession.findById("wnd[1]/tbar[0]/btn[0]").press
    WScript.Sleep 5000
End If

' Handle "Activation errors" popup (wnd[2]) — press Activate to proceed
' Some builds expose btnBUTTON_1, others btnSPOP-VAROPTION1; try both.
If InStr(oSession.ActiveWindow.Id, "wnd[2]") > 0 Then
    WScript.Echo "WARNING: Activation errors — pressing Activate anyway..."
    On Error Resume Next
    oSession.findById("wnd[2]/usr/btnSPOP-VAROPTION1").press
    If Err.Number <> 0 Then
        Err.Clear
        oSession.findById("wnd[2]/usr/btnBUTTON_1").press
    End If
    On Error GoTo 0
    WScript.Sleep 3000
End If
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.findById("wnd[1]").sendVKey VKEY_F12_CANCEL
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' ------ 9. Syntax check (Ctrl+F2) — read error grid -------------------------
' The AbapEditor swallows status bar messages, so we read the error grid.
' Grid: wnd[0]/shellcont/shell/shellcont[1]/shell
' Columns: MSGTYPE (icon format @5C\QError@), LINE, TEXT
' Errors come in pairs: row N has MSGTYPE+LINE+class/section name,
'                       row N+1 has error description
WScript.Echo "INFO: Running syntax check..."
oSession.findById("wnd[0]/tbar[1]/btn[26]").press  ' Ctrl+F2 Check
WScript.Sleep 3000

' Dismiss any popup
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 500
End If
Err.Clear
On Error GoTo 0

Dim oSyntaxGrid, nSyntaxRows, bSyntaxOK
bSyntaxOK = True

On Error Resume Next
Set oSyntaxGrid = oSession.findById("wnd[0]/shellcont/shell/shellcont[1]/shell")
If Err.Number = 0 And Not (oSyntaxGrid Is Nothing) Then
    nSyntaxRows = oSyntaxGrid.RowCount
    Err.Clear
    If nSyntaxRows > 0 Then
        bSyntaxOK = False
        WScript.Echo "ERROR: Syntax check found " & (nSyntaxRows \ 2) & " error(s):"
        Dim iSynRow
        For iSynRow = 0 To nSyntaxRows - 1
            Dim sSynType, sSynLine, sSynText
            sSynType = ""
            sSynLine = ""
            sSynText = ""
            sSynType = oSyntaxGrid.getCellValue(iSynRow, "MSGTYPE")
            Err.Clear
            sSynLine = oSyntaxGrid.getCellValue(iSynRow, "LINE")
            Err.Clear
            sSynText = oSyntaxGrid.getCellValue(iSynRow, "TEXT")
            Err.Clear
            If sSynText <> "" Then
                If sSynLine <> "" Then
                    WScript.Echo "  Line " & sSynLine & ": " & sSynText
                Else
                    WScript.Echo "    -> " & sSynText
                End If
            End If
        Next
    Else
        WScript.Echo "INFO: Syntax check passed — no findings."
    End If
Else
    Err.Clear
    ' Grid not found — fall back to status bar check
    Dim sSyntaxMsg, sSyntaxType
    sSyntaxMsg  = oSession.findById("wnd[0]/sbar").Text
    sSyntaxType = oSession.findById("wnd[0]/sbar").MessageType
    Err.Clear
    If sSyntaxType = "E" Then
        bSyntaxOK = False
        WScript.Echo "ERROR: Syntax check failed - " & sSyntaxMsg
    ElseIf sSyntaxMsg = "" Then
        WScript.Echo "INFO: Syntax check — no findings (sbar empty, AbapEditor may swallow messages)."
    Else
        WScript.Echo "INFO: Syntax check passed."
    End If
End If
On Error GoTo 0

If Not bSyntaxOK Then
    ' Clean up temp file before exiting
    On Error Resume Next
    If oFSO.FileExists(sUploadFile) Then oFSO.DeleteFile sUploadFile
    Err.Clear
    On Error GoTo 0
    WScript.Echo "ERROR: Fix syntax errors and retry."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' --- Release the session UI lock; Step 10 is read-only status check ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 10. Final status check -----------------------------------------------
' Clean up temp upload file
On Error Resume Next
If oFSO.FileExists(sUploadFile) Then oFSO.DeleteFile sUploadFile
Err.Clear
On Error GoTo 0

Dim sFinalMsg, sFinalType
On Error Resume Next
sFinalMsg  = oSession.findById("wnd[0]/sbar").Text
sFinalType = oSession.findById("wnd[0]/sbar").MessageType
On Error GoTo 0

If sFinalType = "E" Then
    WScript.Echo "WARNING: Activation may have errors - " & sFinalMsg
Else
    WScript.Echo "INFO: SAP status: " & sFinalMsg
End If

' Check final activation status from the editor field
On Error Resume Next
Dim sFinalEditorStatus
sFinalEditorStatus = oSession.findById("wnd[0]/usr/txtDY0400_STATUS").Text
WScript.Echo "INFO: Class status: " & sFinalEditorStatus
Err.Clear
On Error GoTo 0

WScript.Echo "SUCCESS: Class " & UCase(CLASS_NAME) & " updated and activated in SAP."
WScript.Quit 0
