' =============================================================================
' sap_function_group_gui_activate.vbs  -  SAP GUI Scripting: Activate a Function Group
'
' Generated by the sap-function-group skill (GUI sub-flow).
' Opens an existing function group via SE37 -> Goto -> Function Groups ->
' Change Group, dismisses any "currently being processed" info popup, then
' activates via toolbar btn[27] (Ctrl+F3). If the "Inactive Objects" list
' appears, presses Select All (btn[9]) then Continue (btn[0]).
'
' Tokens replaced at run time:
'   %%FUGR_ID%%   Function group name (e.g. "ZFUGR001")
'
' Output (last line):
'   DONE FUGR=<ID>
'   ERROR: <message>
'
' Recorded from SAP S/4HANA 1909 (S4D) — Record_SE37_03_ActiveteFUGR.vbs.
' =============================================================================

Option Explicit

Const FUGR_ID = "%%FUGR_ID%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER = 0

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ Attach to existing SAP GUI session (via shared attach helper) -------
Dim oSess
Set oSess = AttachSapSession(SESSION_PATH)

' --- Navigate to SE37 -------------------------------------------------------
oSess.findById("wnd[0]").maximize
Dim oOkcd
Set oOkcd = oSess.findById("wnd[0]/tbar[0]/okcd")
oOkcd.SetFocus
oOkcd.Text = "/nse37"
oSess.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' --- Goto > Function Groups > Change Group ----------------------------------
On Error Resume Next
oSess.findById("wnd[0]/mbar/menu[2]/menu[3]/menu[1]").select
If Err.Number <> 0 Then
    WScript.Echo "ERROR: 'Goto > Function Groups > Change Group' menu not found: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0
WScript.Sleep 800

' --- Enter group name -------------------------------------------------------
On Error Resume Next
oSess.findById("wnd[1]/usr/ctxtRS38L-AREA").Text = UCase(FUGR_ID)
If Err.Number <> 0 Then
    WScript.Echo "ERROR: Change Group popup field RS38L-AREA not found: " & Err.Description
    WScript.Quit 1
End If
Err.Clear
On Error GoTo 0
oSess.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 1500

' --- Optional info popup ("Function group is currently being processed") ----
' Recording showed wnd[1]/tbar[0]/btn[5]; on most systems pressing Continue
' (Enter) is sufficient.
On Error Resume Next
If InStr(oSess.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Info popup detected — pressing Continue."
    oSess.findById("wnd[1]/tbar[0]/btn[5]").press
    If Err.Number <> 0 Then
        Err.Clear
        oSess.findById("wnd[1]").sendVKey VKEY_ENTER
    End If
End If
Err.Clear
On Error GoTo 0
WScript.Sleep 1000

' --- Activate (Ctrl+F3) via toolbar -----------------------------------------
WScript.Echo "INFO: Activating " & UCase(FUGR_ID) & "..."
On Error Resume Next
oSess.findById("wnd[0]/tbar[1]/btn[27]").press
If Err.Number <> 0 Then
    Err.Clear
    oSess.findById("wnd[0]").sendVKey 27
End If
Err.Clear
On Error GoTo 0
WScript.Sleep 2500

' --- Inactive Objects list popup --------------------------------------------
' Buttons: btn[9] Select All, btn[0] Continue
On Error Resume Next
If InStr(oSess.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Inactive Objects list — selecting all and continuing."
    oSess.findById("wnd[1]/tbar[0]/btn[9]").press
    WScript.Sleep 400
    oSess.findById("wnd[1]/tbar[0]/btn[0]").press
    WScript.Sleep 3000
End If
Err.Clear
On Error GoTo 0

' --- Activation errors popup (wnd[2]) ---------------------------------------
On Error Resume Next
If InStr(oSess.ActiveWindow.Id, "wnd[2]") > 0 Then
    WScript.Echo "WARNING: Activation errors popup — pressing Activate anyway."
    oSess.findById("wnd[2]/usr/btnSPOP-VAROPTION1").press
    If Err.Number <> 0 Then
        Err.Clear
        oSess.findById("wnd[2]/usr/btnBUTTON_1").press
    End If
    WScript.Sleep 2000
End If
Err.Clear
On Error GoTo 0

' --- Read sbar --------------------------------------------------------------
Dim sbarType, sbarText
On Error Resume Next
sbarType = oSess.findById("wnd[0]/sbar").MessageType
sbarText = oSess.findById("wnd[0]/sbar").Text
On Error GoTo 0
WScript.Echo "INFO: sbar [" & sbarType & "] " & sbarText

' --- Back to SAP Easy Access ------------------------------------------------
On Error Resume Next
oSess.findById("wnd[0]/tbar[0]/btn[15]").press
WScript.Sleep 300
If InStr(oSess.ActiveWindow.Id, "wnd[1]") > 0 Then
    ' "Object was changed but not saved" — answer No to discard
    oSess.findById("wnd[1]/usr/btnSPOP-OPTION2").press
    If Err.Number <> 0 Then
        Err.Clear
        oSess.findById("wnd[1]").sendVKey VKEY_ENTER
    End If
    WScript.Sleep 500
End If
Err.Clear
On Error GoTo 0

If sbarType = "E" Or sbarType = "A" Then
    WScript.Echo "ERROR: Activation failed: " & sbarText
    WScript.Quit 1
End If

WScript.Echo "DONE FUGR=" & UCase(FUGR_ID)
WScript.Quit 0
