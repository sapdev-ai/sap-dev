' =============================================================================
' sap_function_group_gui_create.vbs  -  SAP GUI Scripting: Create a Function Group via SE37
'
' Generated by the sap-function-group skill (GUI sub-flow).
'
' Tokens replaced at run time:
'   %%FUGR_ID%%      Function group name (Z*/Y* customer namespace), max 26 chars
'   %%FUGR_DESC%%    Short description, max 80 chars
'   %%PACKAGE%%      Development package; empty or "$TMP" -> Local Object
'   %%TRANSPORT%%    Transport request number; empty when PACKAGE is local
'
' Flow:
'   1. /nse37 -> SE37 main screen
'   2. Menu "Goto > Function Groups > Create Group" (mbar/menu[2]/menu[3]/menu[0])
'   3. Enter group ID + description -> Save
'   4. Package dialog: enter PACKAGE (or click Local Object btn[7] if empty)
'   5. Transport dialog: enter TRANSPORT (only if PACKAGE was non-local)
'   6. Confirm; back out.
' =============================================================================

Option Explicit

Const FUGR_ID   = "%%FUGR_ID%%"
Const FUGR_DESC = "%%FUGR_DESC%%"
Const PKG       = "%%PACKAGE%%"
Const TRANSPORT = "%%TRANSPORT%%"
Const SESSION_PATH = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

Const VKEY_ENTER = 0

' Include shared attach helper.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ Attach to existing SAP GUI session (via shared attach helper) -------
Dim oSess
Set oSess = AttachSapSession(SESSION_PATH)

oSess.findById("wnd[0]").maximize
oSess.findById("wnd[0]/tbar[0]/okcd").text = "/nse37"
oSess.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' Goto > Function Groups > Create Group
oSess.findById("wnd[0]/mbar/menu[2]/menu[3]/menu[0]").select
WScript.Sleep 800

' Create-Group popup
oSess.findById("wnd[1]/usr/ctxtTLIBG-AREA").text = UCase(FUGR_ID)
oSess.findById("wnd[1]/usr/txtTLIBT-AREAT").text = FUGR_DESC
oSess.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 1500

' Determine package routing
Dim isLocal
isLocal = (Len(Trim(PKG)) = 0) Or (UCase(Trim(PKG)) = "$TMP")

If isLocal Then
    ' Local Object button on package dialog (wnd[2])
    On Error Resume Next
    oSess.findById("wnd[2]/tbar[0]/btn[7]").press
    If Err.Number <> 0 Then
        Err.Clear
        ' Some releases place the package dialog in wnd[1]
        oSess.findById("wnd[1]/tbar[0]/btn[7]").press
    End If
    Err.Clear
    On Error GoTo 0
    WScript.Sleep 800
    WScript.Echo "INFO: Saved as Local Object ($TMP)."
Else
    ' Package dialog (wnd[2] in recording, but some releases use wnd[1])
    Dim popupBase
    popupBase = "wnd[2]"
    On Error Resume Next
    oSess.findById(popupBase & "/usr/ctxtKO007-L_DEVCLASS").text = UCase(PKG)
    If Err.Number <> 0 Then
        Err.Clear
        popupBase = "wnd[1]"
        oSess.findById(popupBase & "/usr/ctxtKO007-L_DEVCLASS").text = UCase(PKG)
    End If
    Err.Clear
    On Error GoTo 0
    oSess.findById(popupBase & "/tbar[0]/btn[0]").press
    WScript.Sleep 1000

    ' Transport dialog (same window index as package dialog after Enter)
    If Len(Trim(TRANSPORT)) > 0 Then
        On Error Resume Next
        oSess.findById(popupBase & "/usr/ctxtKO008-TRKORR").text = UCase(TRANSPORT)
        If Err.Number <> 0 Then
            Err.Clear
            ' Try alternate window (sometimes shifts down a level)
            popupBase = "wnd[1]"
            oSess.findById(popupBase & "/usr/ctxtKO008-TRKORR").text = UCase(TRANSPORT)
        End If
        Err.Clear
        On Error GoTo 0
        oSess.findById(popupBase & "/tbar[0]/btn[0]").press
        WScript.Sleep 1500
        WScript.Echo "INFO: Saved to package " & PKG & " on transport " & TRANSPORT
    Else
        ' No transport but package non-local: press Enter to accept "Create Request"
        ' or to confirm the dialog as-is
        On Error Resume Next
        oSess.findById(popupBase & "/tbar[0]/btn[0]").press
        Err.Clear
        On Error GoTo 0
        WScript.Echo "WARN: Package supplied without transport; SAP will prompt or default."
    End If
End If

' Read sbar
Dim sbarType, sbarText
On Error Resume Next
sbarType = oSess.findById("wnd[0]/sbar").MessageType
sbarText = oSess.findById("wnd[0]/sbar").Text
On Error GoTo 0
WScript.Echo "INFO: sbar [" & sbarType & "] " & sbarText

' Determine outcome from sbar
Dim outcome
outcome = "UNKNOWN"
If InStr(1, sbarText, "created", 1) > 0 Or InStr(1, sbarText, "Created", 1) > 0 Then
    outcome = "CREATED"
ElseIf sbarType = "E" Or sbarType = "A" Then
    outcome = "ERROR"
End If

If outcome = "ERROR" Then
    WScript.Echo "ERROR: Function group creation failed: " & sbarText
    WScript.Quit 1
End If

' --- Activate the newly created FG ----------------------------------------
' Goto > Function Groups > Change Group  -> Activate (Ctrl+F3) -> Inactive list
WScript.Echo "INFO: Activating " & UCase(FUGR_ID) & " ..."
On Error Resume Next
Dim oOkcd
Set oOkcd = oSess.findById("wnd[0]/tbar[0]/okcd")
oOkcd.SetFocus
oOkcd.Text = "/nse37"
oSess.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

oSess.findById("wnd[0]/mbar/menu[2]/menu[3]/menu[1]").select
WScript.Sleep 800
oSess.findById("wnd[1]/usr/ctxtRS38L-AREA").Text = UCase(FUGR_ID)
oSess.findById("wnd[1]/tbar[0]/btn[0]").press
WScript.Sleep 1500

' Optional info popup
If InStr(oSess.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSess.findById("wnd[1]/tbar[0]/btn[5]").press
    If Err.Number <> 0 Then
        Err.Clear
        oSess.findById("wnd[1]").sendVKey VKEY_ENTER
    End If
    WScript.Sleep 800
End If

' Activate via toolbar
oSess.findById("wnd[0]/tbar[1]/btn[27]").press
If Err.Number <> 0 Then
    Err.Clear
    oSess.findById("wnd[0]").sendVKey 27
End If
WScript.Sleep 2500

' Inactive Objects list popup
If InStr(oSess.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSess.findById("wnd[1]/tbar[0]/btn[9]").press
    WScript.Sleep 400
    oSess.findById("wnd[1]/tbar[0]/btn[0]").press
    WScript.Sleep 3000
End If

' Activation errors popup
If InStr(oSess.ActiveWindow.Id, "wnd[2]") > 0 Then
    oSess.findById("wnd[2]/usr/btnSPOP-VAROPTION1").press
    If Err.Number <> 0 Then
        Err.Clear
        oSess.findById("wnd[2]/usr/btnBUTTON_1").press
    End If
    WScript.Sleep 2000
End If
Err.Clear
On Error GoTo 0

' Activation sbar
Dim aType, aText
On Error Resume Next
aType = oSess.findById("wnd[0]/sbar").MessageType
aText = oSess.findById("wnd[0]/sbar").Text
On Error GoTo 0
WScript.Echo "INFO: activate sbar [" & aType & "] " & aText

' Back to SAP Easy Access
On Error Resume Next
oSess.findById("wnd[0]/tbar[0]/btn[15]").press
WScript.Sleep 300
If InStr(oSess.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSess.findById("wnd[1]/usr/btnSPOP-OPTION2").press
    If Err.Number <> 0 Then
        Err.Clear
        oSess.findById("wnd[1]").sendVKey VKEY_ENTER
    End If
    WScript.Sleep 500
End If
On Error GoTo 0

WScript.Echo "DONE FUGR=" & UCase(FUGR_ID)
WScript.Quit 0
