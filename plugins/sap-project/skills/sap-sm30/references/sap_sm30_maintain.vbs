' =============================================================================
' sap_sm30_maintain.vbs  --  SAP GUI Scripting: SM30 generic table-control
'                            maintain (add / update) for one-step views
'
' Generated by the /sap-sm30 skill (add / update mode). Attaches to the pinned
' SAP GUI session, opens SM30 in Maintain mode for a view/table, and drives the
' *generated* one-step maintenance dialog through a GENERIC GuiTableControl
' driver: the overview program is the per-view generated SAPL<AREA>, so the
' table-control id (tblSAPL<AREA>TCTRL_<TABLE>) is NEVER hardcoded -- it is
' discovered as the sole GuiTableControl under wnd[0]/usr, and its columns are
' mapped by the DD27S FIELDNAME embedded in each cell id
' (txt/ctxt<VIEW>-<FIELD>[col,row]), never by a fixed column index.
'
'   add    -- New Entries (wnd[0]/tbar[1]/btn[5]); fill each TSV data row into
'             blank table-control rows, paging verticalScrollbar past
'             VisibleRowCount when needed; Save (sendVKey 11).
'   update -- Position (wnd[0]/usr/btnVIM_POSI_PUSH) per row into the SAPLSPO4
'             "Another entry" popup (screen 300); fill the key value(s) into the
'             discovered SVALD-VALUE cell(s) in key order; Continue
'             (wnd[1]/tbar[0]/btn[0]); overwrite the non-key cells on the
'             positioned row 0; Save (sendVKey 11).
'
' The Customizing-TR (KO008) popup is GUARDED after Save: filled from TRKORR
' when non-empty, else the run releases and reports SM30_TR_REQUIRED (the popup
' is NEVER blind-Enter'd). It did not fire on the S4D/100 capture but a
' customizing-recording client will show it.
'
' Language independence (shared/rules/language_independence_rules.md): every
' control is addressed by component ID + DDIC field name; every verdict reads
' wnd[0]/sbar.MessageType (S / W / E / A), never translated .Text / .Tooltip /
' window titles. Popups are detected by wnd[1] + a DDIC control id
' (ctxtKO008-TRKORR = the TR prompt, SVALD-VALUE = the Position popup).
' Localised status text is echoed for diagnostics only.
'
' Any screen/popup that does not match the captured contract at a decision
' point -> "SM30: NEEDS_RECORDING step=<label>", clean abort (ReleaseSession
' does the F12 sweep), Quit 3 -- never a guessed click.
'
' Reference flow captured live on S4D (S/4HANA 1909, kernel 754, 2026-07-12)
' against scratch view ZSAPDEV_SM30 (function group ZSMDEVAI, overview 0010);
' both New Entries and Position/edit RFC-verified.
'
' Tokens replaced at run time:
'   %%SESSION_PATH%%     /app/con[N]/ses[M] pin (empty = auto-resolve)
'   %%ATTACH_LIB_VBS%%   abs path to shared sap_attach_lib.vbs
'   %%SESSION_LOCK_VBS%% abs path to shared sap_session_lock.vbs
'   %%PARAMS_FILE%%      KEY=VALUE lines: VIEW=<name> MODE=add|update
'                        DATA_FILE=<abs path> TRKORR=<tr-or-empty>
'   %%OUTPUT_FILE%%      abs path of the result JSON to write
'
' DATA_FILE = TSV; header row = DD27S FIELDNAMEs, each later row = one entry's
' values. MANDT/CLIENT columns are auto and skipped. COLUMN-ORDER CONTRACT for
' update: the view's key fields lead (in key order), then the non-key fields --
' the key field COUNT is discovered live from the Position popup cell count, so
' the leading N columns are treated as the key.
'
' Outputs:
'   OUTPUT_FILE JSON: {"view","mode","rows_written","status","messages":[..]}
'     status in OK | SM30_TR_REQUIRED | SM30_KEY_NOT_FOUND | SM30_SAVE_FAILED |
'     NEEDS_RECORDING   (UTF-8, no BOM)
'   stdout:  SM30: view=<v> mode=<m> rows=<n>     STATUS: <status>
'   Exit:    0 OK | 1 TR_REQUIRED/KEY_NOT_FOUND/SAVE_FAILED | 2 input error |
'            3 NEEDS_RECORDING
' =============================================================================

Option Explicit

Const SESSION_PATH  = "%%SESSION_PATH%%"    ' empty / unsubstituted = use default
Const PARAMS_FILE   = "%%PARAMS_FILE%%"
Const OUTPUT_FILE   = "%%OUTPUT_FILE%%"

Const VKEY_ENTER  = 0
Const VKEY_SAVE   = 11

' Include shared helpers. Order matters: attach FIRST (the session-lock lib's
' pre-unlock popup sweep reads from oSession), then the session-lock lib.
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ Module state --------------------------------------------------------
Dim oSession, oFSO
Dim VIEW, sMode, DATA_FILE, gTrkorr
Dim gHeader, gEffCols, gRows, nData
Dim gColMap, gPrefixMap, gCellStruct
Dim gRowsWritten, gMessagesJson, wasLocked, gKeyCount
Dim gSvaldByRow, gSvaldOrder

VIEW = "" : sMode = "" : DATA_FILE = "" : gTrkorr = ""
gRowsWritten = 0 : gMessagesJson = "" : wasLocked = False : gKeyCount = -1
Set gColMap = Nothing : Set gPrefixMap = Nothing : gCellStruct = ""
Set gSvaldByRow = Nothing : gSvaldOrder = Array()

Set oFSO = CreateObject("Scripting.FileSystemObject")

' ------ 1. Read + validate params (before any GUI action) -------------------
ReadParams
If VIEW = "" Then WScript.Echo "ERROR: VIEW missing in params file." : WScript.Quit 2
If sMode <> "add" And sMode <> "update" Then _
    WScript.Echo "ERROR: MODE must be add|update (got '" & sMode & "')." : WScript.Quit 2
ReadData

' ------ 2. Attach to the pinned SAP GUI session -----------------------------
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 3. Navigate to SM30, enter the view, open Maintain -------------------
On Error Resume Next
oSession.findById("wnd[0]").maximize
Err.Clear
On Error GoTo 0

Dim oOk : Set oOk = F("wnd[0]/tbar[0]/okcd")
If oOk Is Nothing Then NeedsRecording "sm30_initial"
On Error Resume Next
oOk.Text = "/nSM30"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
Err.Clear
On Error GoTo 0
WScript.Sleep 1000

Dim oView : Set oView = F("wnd[0]/usr/ctxtVIEWNAME")
If oView Is Nothing Then NeedsRecording "sm30_initial"
On Error Resume Next
oView.Text = VIEW
Err.Clear
On Error GoTo 0

Dim oMaint : Set oMaint = F("wnd[0]/usr/btnUPDATE_PUSH")
If oMaint Is Nothing Then NeedsRecording "sm30_initial"
On Error Resume Next
oMaint.press
Err.Clear
On Error GoTo 0
WScript.Sleep 1500

' Benign info popup on open (e.g. the cross-client caution). Dismissed with
' Enter; a TR popup at THIS point is unexpected -> NEEDS_RECORDING (never
' blind-committed here -- the TR is guarded only at Save).
DismissOpenInfoPopups

' ------ 4. Lock the write critical section ----------------------------------
wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: session UI locked for the SM30 " & sMode & " critical section."
Else
    WScript.Echo "INFO: LockSessionUI unavailable on this SAP GUI build; continuing without lock."
End If

' ------ 5. Drive the generic table control ----------------------------------
If sMode = "add" Then
    DoAdd
Else
    DoUpdate
End If

' ------ 6. Save + Customizing-TR guard + verdict (terminates via Finish) -----
DoSaveAndFinish

' ============================================================================
'  Add / Update flows
' ============================================================================

Sub DoAdd()
    ' -- New Entries: toolbar btn[5], fall back to the index-stable menu path.
    Dim pressed : pressed = False
    Dim oBtn : Set oBtn = F("wnd[0]/tbar[1]/btn[5]")
    If Not (oBtn Is Nothing) Then
        On Error Resume Next
        oBtn.press
        If Err.Number = 0 Then pressed = True
        Err.Clear
        On Error GoTo 0
    End If
    If Not pressed Then
        Dim oMenu : Set oMenu = F("wnd[0]/mbar/menu[1]/menu[0]")
        If Not (oMenu Is Nothing) Then
            On Error Resume Next
            oMenu.select
            If Err.Number = 0 Then pressed = True
            Err.Clear
            On Error GoTo 0
        End If
    End If
    If Not pressed Then NeedsRecording "sm30_overview_new_entries"
    WScript.Sleep 800
    DismissOpenInfoPopups

    ' -- Discover the sole GuiTableControl + its DD27S column map.
    Dim oTable : Set oTable = FindTableOnUsr()
    If oTable Is Nothing Then NeedsRecording "new_entries_overview"
    BuildColMap oTable
    If gColMap Is Nothing Then NeedsRecording "new_entries_columns"
    If gColMap.Count = 0 Then NeedsRecording "new_entries_columns"

    ' -- Fill each TSV data row; page the vertical scrollbar past VisibleRowCount.
    Dim vis : vis = SafeVisibleRows(oTable)
    Dim topRow : topRow = 0
    Dim r, i, visRow, hIdx, fld, val, wroteAny
    For r = 0 To nData - 1
        If vis > 0 And r >= topRow + vis Then
            topRow = r
            On Error Resume Next
            oTable.verticalScrollbar.Position = topRow
            Err.Clear
            On Error GoTo 0
            WScript.Sleep 250
            Set oTable = FindTableOnUsr()
            If oTable Is Nothing Then NeedsRecording "new_entries_scroll"
        End If
        visRow = r - topRow
        wroteAny = False
        For i = 0 To UBound(gEffCols)
            hIdx = gEffCols(i)
            fld = gHeader(hIdx)
            val = CellVal(r, hIdx)
            If WriteCell(oTable, fld, visRow, val) Then
                wroteAny = True
            Else
                AddMsg "add: cell not written (row=" & r & " field=" & fld & ")"
            End If
        Next
        If wroteAny Then gRowsWritten = gRowsWritten + 1
    Next
End Sub

Sub DoUpdate()
    Dim oTable, r, i, hIdx, fld, val
    For r = 0 To nData - 1
        ' -- Open the Position ("Another entry") popup.
        Dim oPos : Set oPos = F("wnd[0]/usr/btnVIM_POSI_PUSH")
        If oPos Is Nothing Then NeedsRecording "sm30_overview_position"
        On Error Resume Next
        oPos.press
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 700

        Dim oW1 : Set oW1 = F("wnd[1]")
        If oW1 Is Nothing Then NeedsRecording "sm30_position_popup"

        ' -- Discover the SVALD-VALUE key cell(s), ordered by row (= key order).
        Dim cnt : cnt = DiscoverSvald()
        If cnt = 0 Then NeedsRecording "sm30_position_popup"
        If gKeyCount = -1 Then
            gKeyCount = cnt
            If gKeyCount > (UBound(gEffCols) + 1) Then gKeyCount = UBound(gEffCols) + 1
        End If

        ' -- Fill key value(s) from the leading gKeyCount effective columns into
        '    the discovered key cells (ordered by their popup row index = key order).
        Dim oKeyCell
        For i = 0 To gKeyCount - 1
            If i <= cnt - 1 Then
                hIdx = gEffCols(i)
                val = CellVal(r, hIdx)
                Set oKeyCell = Nothing
                On Error Resume Next
                Set oKeyCell = gSvaldByRow(gSvaldOrder(i))
                If Not (oKeyCell Is Nothing) Then oKeyCell.Text = val
                Err.Clear
                On Error GoTo 0
            End If
        Next

        ' -- Continue.
        Dim oCont : Set oCont = F("wnd[1]/tbar[0]/btn[0]")
        On Error Resume Next
        If oCont Is Nothing Then
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        Else
            oCont.press
        End If
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 700

        ' -- Verdict: SM30 does NOT reliably emit an "S" sbar after Position.
        '    "One entry chosen" (S) appears only when the position narrows to a
        '    single row; a plain scroll-to-key on a multi-row view leaves the
        '    sbar EMPTY (verified live 2026-07-12). So success is confirmed by
        '    (a) the popup being dismissed AND (b) row 0's key matching the
        '    requested key -- NEVER by the sbar message type.
        If Not (F("wnd[1]") Is Nothing) Then
            AddMsg "update: position popup did not dismiss row=" & r
            NeedsRecording "sm30_position_unconfirmed"
        End If

        ' -- Locate the table + column map for the positioned overview.
        Set oTable = FindTableOnUsr()
        If oTable Is Nothing Then NeedsRecording "sm30_overview_table"
        If gColMap Is Nothing Then
            BuildColMap oTable
        ElseIf gColMap.Count = 0 Then
            BuildColMap oTable
        End If

        ' -- Confirm the positioned row 0 carries the requested key(s). A missing
        '    key makes SM30 scroll to the NEAREST entry, so a row-0 key mismatch
        '    means the requested key is not present -> SM30_KEY_NOT_FOUND.
        Dim kmatch, ki, kfld, kwant, kgot
        kmatch = True
        For ki = 0 To gKeyCount - 1
            kfld = gHeader(gEffCols(ki))
            kwant = Trim(CellVal(r, gEffCols(ki)))
            kgot = Trim(ReadCell(oTable, kfld, 0))
            If StrComp(kgot, kwant, 1) <> 0 Then kmatch = False
        Next
        If Not kmatch Then
            AddMsg "update: row 0 key mismatch row=" & r & " (requested key not present)"
            Finish "SM30_KEY_NOT_FOUND", 1
        End If

        ' -- Overwrite non-key cells on the positioned row 0.
        For i = gKeyCount To UBound(gEffCols)
            hIdx = gEffCols(i)
            fld = gHeader(hIdx)
            val = CellVal(r, hIdx)
            If Not WriteCell(oTable, fld, 0, val) Then _
                AddMsg "update: cell not written (row=" & r & " field=" & fld & ")"
        Next
        gRowsWritten = gRowsWritten + 1
    Next
End Sub

Sub DoSaveAndFinish()
    ' -- Save the maintenance buffer.
    On Error Resume Next
    oSession.findById("wnd[0]").sendVKey VKEY_SAVE
    Err.Clear
    On Error GoTo 0
    WScript.Sleep 1200

    ' -- Save-time popups: the Customizing-TR (KO008) popup is the only one we
    '    drive (fill TRKORR + Enter, or release + SM30_TR_REQUIRED when empty).
    '    ANY other popup at this write-commit point -> NEEDS_RECORDING (never
    '    blind-dismissed -- the save state would be unknown).
    Dim iP, oW1, oTr, oOkBtn
    For iP = 1 To 5
        Set oW1 = Nothing
        Set oW1 = F("wnd[1]")
        If oW1 Is Nothing Then Exit For
        Set oTr = F("wnd[1]/usr/ctxtKO008-TRKORR")
        If oTr Is Nothing Then NeedsRecording "save_popup"
        If gTrkorr = "" Then
            AddMsg "save: Customizing TR (KO008) required but TRKORR empty"
            Finish "SM30_TR_REQUIRED", 1
        End If
        On Error Resume Next
        oTr.Text = gTrkorr
        Err.Clear
        On Error GoTo 0
        Set oOkBtn = F("wnd[1]/tbar[0]/btn[0]")
        On Error Resume Next
        If oOkBtn Is Nothing Then
            oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        Else
            oOkBtn.press
        End If
        Err.Clear
        On Error GoTo 0
        AddMsg "save: filled Customizing TR " & gTrkorr
        WScript.Sleep 800
    Next

    ' -- Verdict from the status bar (read BEFORE releasing the lock). Decide on
    '    the MessageType CODE only; the text is diagnostic. Authoritative
    '    confirmation is the skill's RFC re-read (SM30_VERIFY_MISMATCH catches a
    '    false OK).
    Dim stype : stype = SbarType()
    Dim stext : stext = SbarText()
    AddMsg "save sbar [" & stype & "] " & stext
    If stype = "E" Or stype = "A" Then Finish "SM30_SAVE_FAILED", 1
    Finish "OK", 0
End Sub

' ============================================================================
'  Table-control discovery + cell writing
' ============================================================================

Function FindTableOnUsr()
    Set FindTableOnUsr = Nothing
    Dim oUsr : Set oUsr = F("wnd[0]/usr")
    If oUsr Is Nothing Then Exit Function
    Set FindTableOnUsr = FindTable(oUsr)
End Function

' Recursive: return the FIRST GuiTableControl under a container (the capture
' guarantees a SOLE table control on the SM30 overview).
Function FindTable(oContainer)
    Set FindTable = Nothing
    Dim ch
    On Error Resume Next
    Set ch = oContainer.Children
    If Err.Number <> 0 Then Err.Clear : Exit Function
    On Error GoTo 0
    If ch Is Nothing Then Exit Function

    Dim j, c, cType, found
    For j = 0 To ch.Count - 1
        Set c = Nothing
        On Error Resume Next
        Set c = ch(CLng(j))
        cType = "" : cType = c.Type
        On Error GoTo 0
        If Not (c Is Nothing) Then
            If cType = "GuiTableControl" Then
                Set FindTable = c
                Exit Function
            End If
            If cType = "GuiSimpleContainer" Or cType = "GuiScrollContainer" Or _
               cType = "GuiContainer" Or cType = "GuiCustomControl" Or _
               cType = "GuiTabStrip" Or cType = "GuiTab" Then
                Set found = FindTable(c)
                If Not (found Is Nothing) Then Set FindTable = found : Exit Function
            End If
        End If
    Next
End Function

Function SafeVisibleRows(oTable)
    Dim n : n = 0
    On Error Resume Next
    n = oTable.VisibleRowCount
    On Error GoTo 0
    If n < 1 Then n = 0    ' 0 => treat as "no vertical scrolling" (fill in place)
    SafeVisibleRows = n
End Function

' Build FIELDNAME -> column index (+ txt/ctxt prefix) from the table control's
' child cell ids (txt/ctxt<STRUCT>-<FIELD>[col,row]); fall back to GetCell(0,c).
' Name when a build does not expose parseable child ids. Sets gCellStruct to the
' authoritative <STRUCT> segment from the live ids.
Sub BuildColMap(oTable)
    Set gColMap = CreateObject("Scripting.Dictionary")
    gColMap.CompareMode = 1        ' TextCompare (case-insensitive field names)
    Set gPrefixMap = CreateObject("Scripting.Dictionary")
    gPrefixMap.CompareMode = 1
    gCellStruct = ""

    Dim ch
    On Error Resume Next
    Set ch = oTable.Children
    On Error GoTo 0
    Dim i, c, cType, sId, sLeaf, sPrefix, sBody, iBr, sNameCol, sBrk, iDash
    Dim sStruct, sField, iCol
    If Not (ch Is Nothing) Then
        For i = 0 To ch.Count - 1
            Set c = Nothing
            On Error Resume Next
            Set c = ch(CLng(i))
            cType = "" : cType = c.Type
            sId = "" : sId = c.Id
            On Error GoTo 0
            If Not (c Is Nothing) Then
                If cType = "GuiTextField" Or cType = "GuiCTextField" Or cType = "GuiComboBox" Then
                    sLeaf = LeafOf(sId)
                    sPrefix = ""
                    If Left(sLeaf, 4) = "ctxt" Then
                        sPrefix = "ctxt" : sBody = Mid(sLeaf, 5)
                    ElseIf Left(sLeaf, 3) = "txt" Then
                        sPrefix = "txt" : sBody = Mid(sLeaf, 4)
                    ElseIf Left(sLeaf, 3) = "cmb" Then
                        sPrefix = "cmb" : sBody = Mid(sLeaf, 4)
                    End If
                    If sPrefix <> "" Then
                        iBr = InStr(sBody, "[")
                        If iBr > 0 Then
                            sNameCol = Left(sBody, iBr - 1)
                            sBrk = Mid(sBody, iBr)
                            iDash = InStr(sNameCol, "-")
                            If iDash > 0 Then
                                sStruct = Left(sNameCol, iDash - 1)
                                sField = UCase(Mid(sNameCol, iDash + 1))
                                iCol = BracketNums(sBrk, 0)
                                If iCol >= 0 And sField <> "" Then
                                    If gCellStruct = "" Then gCellStruct = sStruct
                                    If Not gColMap.Exists(sField) Then
                                        gColMap.Add sField, iCol
                                        gPrefixMap.Add sField, sPrefix
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        Next
    End If

    ' Fallback: map by GetCell(0,col).Name = <STRUCT>-<FIELD> if id-parse found none.
    If gColMap.Count = 0 Then
        Dim nc, cc, nm, dash2, st2, fl2
        nc = -1
        On Error Resume Next
        nc = oTable.Columns.Count
        On Error GoTo 0
        For cc = 0 To nc - 1
            nm = ""
            On Error Resume Next
            nm = oTable.GetCell(0, cc).Name
            On Error GoTo 0
            dash2 = InStr(nm, "-")
            If dash2 > 0 Then
                st2 = Left(nm, dash2 - 1)
                fl2 = UCase(Mid(nm, dash2 + 1))
                If gCellStruct = "" Then gCellStruct = st2
                If fl2 <> "" And Not gColMap.Exists(fl2) Then
                    gColMap.Add fl2, cc
                    gPrefixMap.Add fl2, "txt"
                End If
            End If
        Next
    End If

    If gCellStruct = "" Then gCellStruct = VIEW
End Sub

' Write one cell by DD27S field name at a visible row. Primary path = the
' captured id form <TC>/<prefix><STRUCT>-<FIELD>[col,visRow]; falls back to the
' other prefix, then to GetCell(visRow,col). Returns True on a successful write.
Function WriteCell(oTable, sField, visRow, sVal)
    WriteCell = False
    If gColMap Is Nothing Then Exit Function
    If Not gColMap.Exists(sField) Then Exit Function
    Dim col, pref, alt, oCell
    col = gColMap(sField)
    pref = "txt"
    If gPrefixMap.Exists(sField) Then pref = gPrefixMap(sField)

    If SetCellById(oTable, pref, sField, col, visRow, sVal) Then WriteCell = True : Exit Function
    alt = "ctxt"
    If pref = "ctxt" Then alt = "txt"
    If SetCellById(oTable, alt, sField, col, visRow, sVal) Then WriteCell = True : Exit Function

    On Error Resume Next
    Set oCell = oTable.GetCell(visRow, col)
    If Not (oCell Is Nothing) Then
        oCell.Text = sVal
        If Err.Number = 0 Then WriteCell = True
    End If
    Err.Clear
    On Error GoTo 0
End Function

Function SetCellById(oTable, pref, sField, col, visRow, sVal)
    SetCellById = False
    Dim sId, o
    sId = oTable.Id & "/" & pref & gCellStruct & "-" & sField & "[" & col & "," & visRow & "]"
    Set o = F(sId)
    If o Is Nothing Then Exit Function
    On Error Resume Next
    o.Text = sVal
    If Err.Number = 0 Then SetCellById = True
    Err.Clear
    On Error GoTo 0
End Function

' Read one cell's text by DD27S field name at a visible row (read-only mirror of
' WriteCell). Used to confirm a Position landed on the requested key. Returns ""
' when the cell can't be resolved.
Function ReadCell(oTable, sField, visRow)
    ReadCell = ""
    If gColMap Is Nothing Then Exit Function
    If Not gColMap.Exists(sField) Then Exit Function
    Dim col, pref, alt, sId, o, oCell
    col = gColMap(sField)
    pref = "txt"
    If gPrefixMap.Exists(sField) Then pref = gPrefixMap(sField)
    sId = oTable.Id & "/" & pref & gCellStruct & "-" & sField & "[" & col & "," & visRow & "]"
    Set o = F(sId)
    If o Is Nothing Then
        alt = "ctxt"
        If pref = "ctxt" Then alt = "txt"
        sId = oTable.Id & "/" & alt & gCellStruct & "-" & sField & "[" & col & "," & visRow & "]"
        Set o = F(sId)
    End If
    If Not (o Is Nothing) Then
        On Error Resume Next
        ReadCell = o.Text
        On Error GoTo 0
        Exit Function
    End If
    On Error Resume Next
    Set oCell = oTable.GetCell(visRow, col)
    If Not (oCell Is Nothing) Then ReadCell = oCell.Text
    On Error GoTo 0
End Function

' ============================================================================
'  Position popup (SAPLSPO4 screen 300) key-cell discovery
' ============================================================================

' Collect wnd[1] descendant cells whose id leaf contains "SVALD-VALUE" into the
' module Dictionary gSvaldByRow (keyed by their [col,row] ROW index), publish the
' ascending-sorted row indices to gSvaldOrder (= key order top-to-bottom), and
' return the count.
Function DiscoverSvald()
    ' Accumulate into a module Dictionary (rowIndex -> cell control) so the
    ' recursive walk needs no module-array ReDim. Then publish the sorted row
    ' indices (ascending = key order) to gSvaldOrder by plain assignment.
    Set gSvaldByRow = CreateObject("Scripting.Dictionary")
    gSvaldOrder = Array()
    Dim oRoot : Set oRoot = F("wnd[1]")
    If oRoot Is Nothing Then DiscoverSvald = 0 : Exit Function
    WalkCollectSvald oRoot, 0

    Dim ks, a, b, tmp
    ks = gSvaldByRow.Keys
    For a = 0 To UBound(ks) - 1
        For b = a + 1 To UBound(ks)
            If ks(b) < ks(a) Then
                tmp = ks(a) : ks(a) = ks(b) : ks(b) = tmp
            End If
        Next
    Next
    gSvaldOrder = ks
    DiscoverSvald = gSvaldByRow.Count
End Function

Sub WalkCollectSvald(ctrl, depth)
    If depth > 12 Then Exit Sub
    Dim ty, sId, sLeaf, iBr, sBrk, rowIx, kids, i, child
    ty = "" : sId = ""
    On Error Resume Next
    ty = ctrl.Type
    sId = ctrl.Id
    On Error GoTo 0
    If ty = "GuiTextField" Or ty = "GuiCTextField" Then
        sLeaf = LeafOf(sId)
        If InStr(sLeaf, "SVALD-VALUE") > 0 Then
            iBr = InStr(sLeaf, "[")
            If iBr > 0 Then
                sBrk = Mid(sLeaf, iBr)
                rowIx = BracketNums(sBrk, 1)
                If rowIx < 0 Then rowIx = 100000 + gSvaldByRow.Count
                If Not gSvaldByRow.Exists(rowIx) Then gSvaldByRow.Add rowIx, ctrl
            End If
        End If
    End If
    Set kids = Nothing
    On Error Resume Next
    Set kids = ctrl.Children
    On Error GoTo 0
    If Not (kids Is Nothing) Then
        For i = 0 To kids.Count - 1
            Set child = Nothing
            On Error Resume Next
            Set child = kids(CLng(i))
            On Error GoTo 0
            If Not (child Is Nothing) Then WalkCollectSvald child, depth + 1
        Next
    End If
End Sub

' ============================================================================
'  Popup handling / verdict helpers
' ============================================================================

Sub DismissOpenInfoPopups()
    ' Lenient PRE-write popup handling: dismiss a benign SM30 info popup (e.g.
    ' the cross-client caution) with Enter. NEVER auto-dismiss the Customizing-TR
    ' popup here -- if it appears now (unusual, pre-Save) bail to NEEDS_RECORDING
    ' rather than blind-commit.
    Dim iP, oW1, oTr
    For iP = 1 To 3
        Set oW1 = Nothing
        Set oW1 = F("wnd[1]")
        If oW1 Is Nothing Then Exit Sub
        Set oTr = F("wnd[1]/usr/ctxtKO008-TRKORR")
        If Not (oTr Is Nothing) Then NeedsRecording "maintain_open_tr_popup"
        On Error Resume Next
        oSession.findById("wnd[1]").sendVKey VKEY_ENTER
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 500
    Next
End Sub

Function SbarType()
    SbarType = ""
    Dim o : Set o = F("wnd[0]/sbar")
    If Not (o Is Nothing) Then
        On Error Resume Next
        SbarType = o.MessageType
        On Error GoTo 0
    End If
End Function

Function SbarText()
    SbarText = ""
    Dim o : Set o = F("wnd[0]/sbar")
    If Not (o Is Nothing) Then
        On Error Resume Next
        SbarText = o.Text
        On Error GoTo 0
    End If
End Function

' Every findById is funnelled through F() so a missing control returns Nothing
' instead of crashing.
Function F(sId)
    Set F = Nothing
    On Error Resume Next
    Set F = oSession.findById(sId, False)
    On Error GoTo 0
End Function

' ============================================================================
'  Terminal + output helpers
' ============================================================================

Sub NeedsRecording(stepName)
    AddMsg "NEEDS_RECORDING step=" & stepName
    WScript.Echo "SM30: NEEDS_RECORDING step=" & stepName
    Finish "NEEDS_RECORDING", 3
End Sub

' Central terminal: release the lock (its sweep F12-cancels leftover modals =
' clean abort), write the result JSON, echo the machine-readable lines, quit.
Sub Finish(status, code)
    ReleaseSession oSession, wasLocked
    WriteOutput status
    WScript.Echo "SM30: view=" & VIEW & " mode=" & sMode & " rows=" & gRowsWritten
    WScript.Echo "STATUS: " & status
    WScript.Quit code
End Sub

Sub WriteOutput(status)
    Dim j
    j = "{" & _
        JKV("view", VIEW) & "," & _
        JKV("mode", sMode) & "," & _
        """rows_written"":" & gRowsWritten & "," & _
        JKV("status", status) & "," & _
        """messages"":[" & gMessagesJson & "]}"
    WriteFileUtf8 OUTPUT_FILE, j
End Sub

Sub AddMsg(s)
    If gMessagesJson <> "" Then gMessagesJson = gMessagesJson & ","
    gMessagesJson = gMessagesJson & """" & JsonEsc(s) & """"
    WScript.Echo "INFO: " & s
End Sub

' ============================================================================
'  Parsing helpers
' ============================================================================

Sub ReadParams()
    If Not oFSO.FileExists(PARAMS_FILE) Then
        WScript.Echo "ERROR: params file not found: " & PARAMS_FILE
        WScript.Quit 2
    End If
    Dim sAll, aLn, i, ln, p, k, v
    sAll = ReadAllUtf8(PARAMS_FILE)
    sAll = Replace(sAll, vbCrLf, vbLf)
    sAll = Replace(sAll, vbCr, vbLf)
    aLn = Split(sAll, vbLf)
    For i = 0 To UBound(aLn)
        ln = aLn(i)
        If i = 0 And Len(ln) > 0 Then
            If Left(ln, 1) = ChrW(&HFEFF) Then ln = Mid(ln, 2)
        End If
        ln = Trim(ln)
        p = InStr(ln, "=")
        If p > 0 Then
            k = UCase(Trim(Left(ln, p - 1)))
            v = Trim(Mid(ln, p + 1))
            Select Case k
                Case "VIEW"      : VIEW = UCase(v)
                Case "MODE"      : sMode = LCase(v)
                Case "DATA_FILE" : DATA_FILE = v
                Case "TRKORR"    : gTrkorr = UCase(v)
            End Select
        End If
    Next
End Sub

Sub ReadData()
    If DATA_FILE = "" Then WScript.Echo "ERROR: DATA_FILE not set in params." : WScript.Quit 2
    If Not oFSO.FileExists(DATA_FILE) Then _
        WScript.Echo "ERROR: data file not found: " & DATA_FILE : WScript.Quit 2

    Dim sAll, aLn, i
    sAll = ReadAllUtf8(DATA_FILE)
    sAll = Replace(sAll, vbCrLf, vbLf)
    sAll = Replace(sAll, vbCr, vbLf)
    aLn = Split(sAll, vbLf)
    If UBound(aLn) >= 0 Then
        If Len(aLn(0)) > 0 Then
            If Left(aLn(0), 1) = ChrW(&HFEFF) Then aLn(0) = Mid(aLn(0), 2)
        End If
    End If

    ' Keep non-blank lines.
    Dim keep(), nk
    nk = 0 : ReDim keep(0)
    For i = 0 To UBound(aLn)
        If Trim(aLn(i)) <> "" Then
            ReDim Preserve keep(nk)
            keep(nk) = aLn(i)
            nk = nk + 1
        End If
    Next
    If nk < 2 Then _
        WScript.Echo "ERROR: data file needs a header row + at least 1 data row." : WScript.Quit 2

    ' Header (uppercased DD27S field names). Build a LOCAL array, then publish to
    ' the module var by plain assignment -- ReDim of a module-scope array from
    ' inside a Sub is avoided throughout (it can shadow the module var as a
    ' local); local dynamic arrays are resized then copied out.
    Dim hdr, j
    hdr = Split(keep(0), vbTab)
    For j = 0 To UBound(hdr)
        hdr(j) = UCase(Trim(hdr(j)))
    Next
    gHeader = hdr

    ' Effective columns: skip MANDT/CLIENT (auto) and blank headers.
    Dim eff(), ne
    ne = 0 : ReDim eff(0)
    For j = 0 To UBound(gHeader)
        If gHeader(j) <> "" And gHeader(j) <> "MANDT" And gHeader(j) <> "CLIENT" Then
            ReDim Preserve eff(ne)
            eff(ne) = j
            ne = ne + 1
        End If
    Next
    If ne = 0 Then _
        WScript.Echo "ERROR: no maintainable columns in the header (only MANDT/CLIENT?)." : WScript.Quit 2
    gEffCols = eff

    ' Data rows (local jagged array, then publish).
    Dim rowsL()
    nData = nk - 1
    ReDim rowsL(nData - 1)
    For i = 1 To nk - 1
        rowsL(i - 1) = Split(keep(i), vbTab)
    Next
    gRows = rowsL
End Sub

Function CellVal(rowIdx, hIdx)
    Dim arr
    arr = gRows(rowIdx)
    If hIdx <= UBound(arr) Then
        CellVal = arr(hIdx) & ""
    Else
        CellVal = ""
    End If
End Function

Function LeafOf(sId)
    Dim p
    p = InStrRev(sId, "/")
    If p > 0 Then
        LeafOf = Mid(sId, p + 1)
    Else
        LeafOf = sId
    End If
End Function

' Parse a "[col,row]" bracket: which=0 -> col, which=1 -> row. -1 on failure.
Function BracketNums(sBrk, which)
    BracketNums = -1
    Dim s, p
    s = Replace(sBrk, "[", "")
    s = Replace(s, "]", "")
    p = Split(s, ",")
    If which <= UBound(p) Then
        If IsNumeric(Trim(p(which))) Then BracketNums = CLng(Trim(p(which)))
    End If
End Function

Function ReadAllUtf8(sPath)
    ReadAllUtf8 = ""
    Dim st, s
    On Error Resume Next
    Set st = CreateObject("ADODB.Stream")
    st.Type = 2                 ' adTypeText
    st.Charset = "utf-8"        ' decodes BOM-less + BOM'd UTF-8; CJK-safe
    st.Open
    st.LoadFromFile sPath
    s = st.ReadText
    st.Close
    On Error GoTo 0
    ReadAllUtf8 = s
End Function

' ============================================================================
'  JSON helpers (mirror sap_gateway_errlog_deep.vbs)
' ============================================================================

Function JsonEsc(s)
    Dim t : t = s & ""
    t = Replace(t, "\", "\\")
    t = Replace(t, """", "\""")
    t = Replace(t, vbCr, " ")
    t = Replace(t, vbLf, " ")
    t = Replace(t, vbTab, " ")
    JsonEsc = t
End Function

Function JKV(k, v)
    JKV = """" & k & """:""" & JsonEsc(v) & """"
End Function

Sub WriteFileUtf8(sPath, sText)
    ' UTF-8 without BOM (repo convention for VBS-emitted data files, per
    ' sap_log_lib.vbs / sap_gateway_errlog_deep.vbs); falls back to an FSO
    ' Unicode write if ADODB.Stream is unavailable.
    Dim st, bin, okStream
    okStream = False
    On Error Resume Next
    Set st = CreateObject("ADODB.Stream")
    st.Type = 2 : st.Charset = "utf-8" : st.Open
    st.WriteText sText
    st.Position = 3            ' skip the UTF-8 BOM (EF BB BF)
    Set bin = CreateObject("ADODB.Stream")
    bin.Type = 1 : bin.Open
    st.CopyTo bin
    st.Flush : st.Close
    bin.SaveToFile sPath, 2   ' adSaveCreateOverWrite
    bin.Flush : bin.Close
    If Err.Number = 0 Then okStream = True
    Err.Clear
    On Error GoTo 0
    If Not okStream Then
        On Error Resume Next
        Dim o
        Set o = oFSO.CreateTextFile(sPath, True, True)
        o.Write sText : o.Close
        On Error GoTo 0
    End If
End Sub
