' =============================================================================
' sap_bp_check.vbs  -  SAP GUI Scripting: Check if Business Partner exists
'
' Generated by the sap-bp skill.
' Attaches to an existing SAP GUI session, navigates to BP transaction,
' uses the Open BP dialog to determine whether the partner number exists.
'
' Locale-independent contract (language_independence_rules.md):
'   * Screen identity via control-ID probes only:
'       - Open BP dialog ...... wnd[1]/usr/ctxtBUS_JOEL_MAIN-OPEN_NUMBER
'         (a nonexistent number keeps the dialog OPEN with an sbar E;
'          an accepted number CLOSES the dialog and opens the partner)
'   * Status decisions via sbar MessageType codes; MessageId/MessageNumber
'     are echoed on every verdict so an auth/lock message that shows up in
'     the dialog-open E position can be pinned later.
'   * Window titles / status texts are echoed for diagnostics only --
'     control flow never branches on them.
'
' Output (last line of stdout, parseable by skill):
'   EXIST / NOT_EXIST / ERROR: ...
'   Failing to reach the BP transaction or the Open dialog (e.g. missing
'   transaction authorization) is reported as ERROR, never as NOT_EXIST.
'
' Tokens replaced at run time:
'   %%BP_NUMBER%%  Business Partner number  e.g. "14"
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const BP_NUMBER  = "%%BP_NUMBER%%"
Const VKEY_ENTER = 0
Const VKEY_F12   = 12
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()

' ------ Helper: True when a control id resolves ------------------------------
Function ProbeId(oSess, sId)
    Dim o
    ProbeId = False
    On Error Resume Next
    Set o = Nothing
    Set o = oSess.findById(sId)
    If Err.Number = 0 And Not (o Is Nothing) Then ProbeId = True
    Err.Clear
    On Error GoTo 0
End Function

' ------ Helper: one-line sbar diagnostic ([type] id no - text) ---------------
Function SbarDiag(oSess)
    Dim t, i, n, x
    t = "" : i = "" : n = "" : x = ""
    On Error Resume Next
    t = oSess.findById("wnd[0]/sbar").MessageType
    i = oSess.findById("wnd[0]/sbar").MessageId
    n = oSess.findById("wnd[0]/sbar").MessageNumber
    x = oSess.findById("wnd[0]/sbar").Text
    Err.Clear
    On Error GoTo 0
    SbarDiag = "[" & t & "] " & i & " " & n & " - " & x
End Function

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Navigate to BP ---------------------------------------------------
WScript.Echo "INFO: Navigating to BP transaction..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nBP"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 3. Open BP popup and enter number -----------------------------------
WScript.Echo "INFO: Checking Business Partner: " & BP_NUMBER
On Error Resume Next
oSession.findById("wnd[0]/tbar[1]/btn[17]").Press  ' Open BP (Shift+F5)
Err.Clear
On Error GoTo 0
WScript.Sleep 500

' Screen-identity gate: if the Open BP dialog did not appear (e.g. missing
' transaction authorization left us outside BP), that is ERROR -- a silent
' fall-through to NOT_EXIST here would route the skill into Create against
' an undetermined state.
If Not ProbeId(oSession, "wnd[1]/usr/ctxtBUS_JOEL_MAIN-OPEN_NUMBER") Then
    WScript.Echo "ERROR: Did not reach the BP Open dialog (BUS_JOEL_MAIN-OPEN_NUMBER not found)."
    WScript.Echo "       Status (diagnostic): " & SbarDiag(oSession)
    WScript.Quit 1
End If

oSession.findById("wnd[1]/usr/ctxtBUS_JOEL_MAIN-OPEN_NUMBER").Text = BP_NUMBER
oSession.findById("wnd[1]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 4. Determine result -------------------------------------------------
' Structural verdict:
'   * dialog CLOSED, no E .... partner accepted and opened -> EXIST
'   * dialog still OPEN + E .. number rejected -> NOT_EXIST
'   * anything else .......... unknown state -> ERROR
Dim sStatusType
sStatusType = ""
On Error Resume Next
sStatusType = oSession.findById("wnd[0]/sbar").MessageType
Err.Clear
On Error GoTo 0

If ProbeId(oSession, "wnd[1]/usr/ctxtBUS_JOEL_MAIN-OPEN_NUMBER") Then
    ' Dialog still open: SAP rejected the number.
    If sStatusType = "E" Then
        WScript.Echo "INFO: Not found -- " & SbarDiag(oSession)
        On Error Resume Next
        oSession.findById("wnd[1]").sendVKey VKEY_F12  ' Cancel the dialog
        Err.Clear
        On Error GoTo 0
        WScript.Sleep 300
        WScript.Echo "NOT_EXIST"
        WScript.Quit 0
    End If
    On Error Resume Next
    oSession.findById("wnd[1]").sendVKey VKEY_F12
    Err.Clear
    On Error GoTo 0
    WScript.Echo "ERROR: Open BP dialog stayed open without an E message -- cannot determine existence."
    WScript.Echo "       Status (diagnostic): " & SbarDiag(oSession)
    WScript.Quit 1
End If

If sStatusType = "E" Or sStatusType = "A" Then
    WScript.Echo "ERROR: Dialog closed but SAP reported an error -- cannot determine existence."
    WScript.Echo "       Status (diagnostic): " & SbarDiag(oSession)
    WScript.Quit 1
End If

' Dialog closed and no error: the partner was opened.
WScript.Echo "INFO: Business Partner " & BP_NUMBER & " exists (Open dialog accepted the number)."
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/nBP"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500
WScript.Echo "EXIST"
WScript.Quit 0
