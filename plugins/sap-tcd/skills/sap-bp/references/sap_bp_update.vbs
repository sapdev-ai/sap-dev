' =============================================================================
' sap_bp_update.vbs  -  SAP GUI Scripting: Update Business Partner via BP
'
' Generated by the sap-bp skill.
' Attaches to an existing SAP GUI session, navigates to BP transaction,
' opens the partner for change, switches to General Data view, fills
' field values from a definition file, and saves.
'
' Definition file format (tab-separated, one field per line):
'   TAB_01	BUT000-NAME_ORG1	Updated Company Name
'   TAB_01	ADDR1_DATA-CITY1	Shanghai
'
' Sections: TAB_01-TAB_14 (tab panels in General Data view)
' Lines starting with # are comments. Blank lines are skipped.
'
' Tokens replaced at run time:
'   %%BP_NUMBER%%       Business Partner number
'   %%DEFINITION_FILE%% Path to field definitions
'
' Locale-independent contract (language_independence_rules.md): screens are
' identified by control ids / Changeable probes (BUT000-NAME_ORG1), results
' by sbar MessageType; titles / status texts are echoed for diagnostics
' only. On success a machine-readable "BP: <number>" line is echoed before
' the final SUCCESS line.
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const BP_NUMBER       = "%%BP_NUMBER%%"
Const DEFINITION_FILE = "%%DEFINITION_FILE%%"

Const VKEY_ENTER    = 0
Const VKEY_F11_SAVE = 11
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ Helper: Find input field by name within a container (recursive) -----
Function FindField(oContainer, sFieldName)
    Set FindField = Nothing
    On Error Resume Next
    Dim ch
    Set ch = oContainer.Children
    If Err.Number <> 0 Then
        Err.Clear
        Exit Function
    End If
    On Error GoTo 0

    Dim j, c, cName, cType
    For j = 0 To ch.Count - 1
        Set c = ch(CLng(j))
        On Error Resume Next
        cName = c.Name
        cType = c.Type
        Err.Clear
        On Error GoTo 0

        If cName = sFieldName Then
            If cType = "GuiTextField" Or cType = "GuiCTextField" Or _
               cType = "GuiComboBox" Or cType = "GuiCheckBox" Then
                Set FindField = c
                Exit Function
            End If
        End If

        If cType = "GuiSimpleContainer" Or cType = "GuiScrollContainer" Or _
           cType = "GuiTabStrip" Or cType = "GuiTab" Then
            Dim found
            Set found = FindField(c, sFieldName)
            If Not (found Is Nothing) Then
                Set FindField = found
                Exit Function
            End If
        End If
    Next
End Function

' ------ Helper: Find and select a tab by name (recursive) -------------------
Function SelectTab(oContainer, sTabName)
    SelectTab = False
    On Error Resume Next
    Dim ch
    Set ch = oContainer.Children
    If Err.Number <> 0 Then
        Err.Clear
        Exit Function
    End If
    On Error GoTo 0

    Dim j, c, cName, cType
    For j = 0 To ch.Count - 1
        Set c = ch(CLng(j))
        On Error Resume Next
        cName = c.Name
        cType = c.Type
        Err.Clear
        On Error GoTo 0

        If cName = sTabName And cType = "GuiTab" Then
            c.Select
            SelectTab = True
            Exit Function
        End If

        If cType = "GuiSimpleContainer" Or cType = "GuiScrollContainer" Or _
           cType = "GuiTabStrip" Then
            If SelectTab(c, sTabName) Then
                SelectTab = True
                Exit Function
            End If
        End If
    Next
End Function

' ------ Helper: Set field value based on control type -----------------------
Sub SetFieldValue(oField, sValue)
    Select Case oField.Type
        Case "GuiTextField", "GuiCTextField"
            oField.Text = sValue
        Case "GuiComboBox"
            oField.Key = sValue
        Case "GuiCheckBox"
            If UCase(sValue) = "X" Or sValue = "1" Or UCase(sValue) = "TRUE" Then
                oField.Selected = True
            Else
                oField.Selected = False
            End If
    End Select
End Sub

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Read definition file ---------------------------------------------
Dim oFSO, sLine
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If

' Parse into arrays: section, field name, value
' NOTE: read via ADODB.Stream with explicit Charset="utf-8". FSO.OpenTextFile
' decodes bytes with the system code page (cp932 on Japanese Windows, cp1252
' on Western), which mangles UTF-8 multi-byte sequences -- JA/ZH values would
' mojibake INTO the saved business record. ADODB.Stream decodes to the
' Unicode that the SAP GUI controls expect.
Dim arrSections(), arrFields(), arrValues()
Dim iCount
iCount = 0

Dim oStream, sAll, arrLines, iLine
Set oStream = CreateObject("ADODB.Stream")
oStream.Type = 2                    ' adTypeText
oStream.Charset = "utf-8"
oStream.Open
oStream.LoadFromFile DEFINITION_FILE
sAll = oStream.ReadText
oStream.Close

sAll = Replace(sAll, vbCrLf, vbLf)
sAll = Replace(sAll, vbCr,   vbLf)
arrLines = Split(sAll, vbLf)

For iLine = 0 To UBound(arrLines)
    sLine = arrLines(iLine)
    ' Strip a residual BOM character on the first line (belt and braces --
    ' ADODB.Stream normally consumes the UTF-8 BOM itself).
    If iLine = 0 And Len(sLine) > 0 Then
        If Left(sLine, 1) = ChrW(&HFEFF) Then sLine = Mid(sLine, 2)
    End If

    sLine = Trim(sLine)

    If Len(sLine) > 0 And Left(sLine, 1) <> "#" Then
        Dim iParts
        iParts = InStr(sLine, vbTab)

        If iParts > 0 Then
            Dim sSection, sRest
            sSection = Trim(Left(sLine, iParts - 1))
            sRest = Mid(sLine, iParts + 1)

            Dim iParts2
            iParts2 = InStr(sRest, vbTab)

            If iParts2 > 0 Then
                Dim sField, sValue
                sField = Trim(Left(sRest, iParts2 - 1))
                sValue = Mid(sRest, iParts2 + 1)

                ReDim Preserve arrSections(iCount)
                ReDim Preserve arrFields(iCount)
                ReDim Preserve arrValues(iCount)
                arrSections(iCount) = UCase(sSection)
                arrFields(iCount) = sField
                arrValues(iCount) = sValue
                iCount = iCount + 1
            End If
        End If
    End If
Next

WScript.Echo "INFO: Read " & iCount & " field definitions from file."

' --- Lock the SAP session UI for the BP multi-tab input + save critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after the save.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the BP multi-tab input + save critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Navigate to BP and open partner ----------------------------------
WScript.Echo "INFO: Navigating to BP transaction..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nBP"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' Open BP popup and enter number
WScript.Echo "INFO: Opening Business Partner: " & BP_NUMBER
oSession.findById("wnd[0]/tbar[1]/btn[17]").Press  ' Open BP (Shift+F5)
WScript.Sleep 500

oSession.findById("wnd[1]/usr/ctxtBUS_JOEL_MAIN-OPEN_NUMBER").Text = BP_NUMBER
oSession.findById("wnd[1]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' Check for errors (BP doesn't exist)
Dim sStatus
sStatus = oSession.findById("wnd[0]/sbar").Text
If oSession.findById("wnd[0]/sbar").MessageType = "E" Then
    ' Close popup
    On Error Resume Next
    oSession.findById("wnd[1]").sendVKey 12
    Err.Clear
    On Error GoTo 0
    WScript.Echo "ERROR: " & sStatus
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ 4. Switch to Change mode --------------------------------------------
WScript.Echo "INFO: Switching to Change mode..."
oSession.findById("wnd[0]/tbar[1]/btn[6]").Press   ' Switch Display/Change (F6)
WScript.Sleep 1000

' Locale-independent gate: an authorization / lock failure surfaces as an E
' in the status bar (the partner stays in display mode).
Dim sSwStatus, sSwType
sSwStatus = oSession.findById("wnd[0]/sbar").Text
sSwType = oSession.findById("wnd[0]/sbar").MessageType
If sSwType = "E" Or sSwType = "A" Then
    WScript.Echo "ERROR: Failed to switch to Change mode. " & sSwStatus
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ 5. Switch to General Data view --------------------------------------
WScript.Echo "INFO: Switching to General Data view..."
oSession.findById("wnd[0]/tbar[1]/btn[25]").Press   ' General Data (Ctrl+F1)
WScript.Sleep 1000

' ------ 6. Fill tab fields --------------------------------------------------
Dim oUsr
Set oUsr = oSession.findById("wnd[0]/usr")

' Verify the partner is actually editable -- locale-independent: probe a
' General Data field's Changeable property instead of the translated title.
Dim oProbeField
Set oProbeField = FindField(oUsr, "BUT000-NAME_ORG1")
If Not (oProbeField Is Nothing) Then
    Dim bEditable
    bEditable = False
    On Error Resume Next
    bEditable = oProbeField.Changeable
    Err.Clear
    On Error GoTo 0
    If Not bEditable Then
        WScript.Echo "ERROR: Business Partner is still in display mode (BUT000-NAME_ORG1 not changeable)."
        WScript.Echo "       Check locks / authorizations. Status (diagnostic): " & oSession.findById("wnd[0]/sbar").Text
        ReleaseSession oSession, wasLocked
        WScript.Quit 1
    End If
Else
    WScript.Echo "INFO: BUT000-NAME_ORG1 not found on the current tab; skipping the change-mode probe."
End If

' Collect unique tab IDs in order
Dim arrTabs()
Dim iTabCount
iTabCount = 0

Dim iTmp
For iTmp = 0 To iCount - 1
    Dim bFound
    bFound = False
    Dim iChk
    For iChk = 0 To iTabCount - 1
        If arrTabs(iChk) = arrSections(iTmp) Then
            bFound = True
            Exit For
        End If
    Next
    If Not bFound Then
        ReDim Preserve arrTabs(iTabCount)
        arrTabs(iTabCount) = arrSections(iTmp)
        iTabCount = iTabCount + 1
    End If
Next

WScript.Echo "INFO: Processing " & iTabCount & " tabs..."

Dim iTab
For iTab = 0 To iTabCount - 1
    Dim sTabSection
    sTabSection = arrTabs(iTab)

    ' Convert TAB_XX to SCREEN_1100_TAB_XX for tab selection
    Dim sTabName
    sTabName = "SCREEN_1100_" & sTabSection

    ' Select the tab
    If Not SelectTab(oUsr, sTabName) Then
        WScript.Echo "WARNING: Tab " & sTabSection & " not found, trying to set fields anyway."
    Else
        WScript.Echo "INFO: Selected tab: " & sTabSection
    End If
    WScript.Sleep 500

    ' Set fields for this tab
    Dim iFld
    For iFld = 0 To iCount - 1
        If arrSections(iFld) = sTabSection Then
            Dim oField
            Set oField = FindField(oUsr, arrFields(iFld))
            If oField Is Nothing Then
                WScript.Echo "WARNING:   Field not found: " & arrFields(iFld)
            Else
                On Error Resume Next
                SetFieldValue oField, arrValues(iFld)
                If Err.Number <> 0 Then
                    WScript.Echo "WARNING:   Error setting " & arrFields(iFld) & ": " & Err.Description
                    Err.Clear
                Else
                    WScript.Echo "INFO:   " & arrFields(iFld) & " = " & arrValues(iFld)
                End If
                On Error GoTo 0
            End If
        End If
    Next
Next

' Press Enter to commit inline edits
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' ------ 7. Save -------------------------------------------------------------
WScript.Echo "INFO: Saving Business Partner..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle warning: press Enter to acknowledge, then save again
Dim sSaveStatus, sSaveType
sSaveStatus = oSession.findById("wnd[0]/sbar").Text
sSaveType = oSession.findById("wnd[0]/sbar").MessageType
If sSaveType = "W" Then
    WScript.Echo "INFO: Warning after save: " & sSaveStatus & " - acknowledging..."
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
    WScript.Sleep 2000
End If

' ------ 7b. Post-save popup guard --------------------------------------------
' The BP transaction never raises a workbench transport popup -- business
' partners are not workbench objects. Any modal at this point is unexpected:
' fail loud instead of blind-dismissing (a guessed keypress on a REAL
' business record could commit or discard the wrong thing). ReleaseSession
' sweeps the modal (F12) so the operator gets a clean session back.
Dim sPopId, sPopTitle
sPopId = ""
On Error Resume Next
sPopId = oSession.ActiveWindow.Id
Err.Clear
On Error GoTo 0
If InStr(sPopId, "wnd[1]") > 0 Then
    sPopTitle = ""
    On Error Resume Next
    sPopTitle = oSession.ActiveWindow.Text   ' diagnostic only
    Err.Clear
    On Error GoTo 0
    WScript.Echo "ERROR: Unexpected popup after save: " & sPopId & " -- title (diagnostic): " & sPopTitle
    WScript.Echo "       Refusing to blind-dismiss. Resolve the popup manually, then re-run."
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' --- Release the session UI lock; result check is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 8. Check result -----------------------------------------------------
sStatus = oSession.findById("wnd[0]/sbar").Text
Dim sStatusType
sStatusType = oSession.findById("wnd[0]/sbar").MessageType

' Navigate back to a clean state unconditionally (locale-independent; the
' data-loss confirm, if any, is dismissed by its SPOP control id).
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500
On Error Resume Next
oSession.findById("wnd[1]/usr/btnSPOP-OPTION1").Press
Err.Clear
On Error GoTo 0
WScript.Sleep 500

WScript.Echo "INFO: Status (" & sStatusType & "): " & sStatus

If sStatusType = "E" Or sStatusType = "A" Then
    WScript.Echo "ERROR: Business Partner update failed. " & sStatus
    WScript.Quit 1
End If

' Fail loud on anything but a positive success message: an empty or
' unrecognized status after Save must never be reported as SUCCESS.
If sStatusType <> "S" Then
    WScript.Echo "ERROR: Could not confirm the save -- status bar type is '" & sStatusType & "' (expected S). Message: " & sStatus
    WScript.Quit 1
End If

WScript.Echo "BP: " & BP_NUMBER
WScript.Echo "SUCCESS: Business Partner " & BP_NUMBER & " updated in SAP."
WScript.Quit 0
