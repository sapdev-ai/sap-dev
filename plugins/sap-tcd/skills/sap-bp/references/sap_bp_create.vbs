' =============================================================================
' sap_bp_create.vbs  -  SAP GUI Scripting: Create Business Partner (Organization)
'
' Generated by the sap-bp skill.
' Attaches to an existing SAP GUI session, navigates to BP transaction,
' creates a new Business Partner (Organization type) with the given role
' and grouping, fills field values from a definition file, and saves.
'
' Definition file format (tab-separated, one field per line):
'   TAB_01	BUT000-NAME_ORG1	Test Company Ltd
'   TAB_01	ADDR1_DATA-COUNTRY	CN
'   TAB_01	ADDR1_DATA-CITY1	Beijing
'   TAB_01	SZA1_D0100-SMTP_ADDR	test@company.com
'
' Sections: TAB_01-TAB_09 (tab panels in General Data view)
' Lines starting with # are comments. Blank lines are skipped.
'
' Tokens replaced at run time:
'   %%BP_NUMBER%%       External BP number (blank = auto-assign)
'   %%BP_ROLE%%         BP Role key (e.g. "FLCU01" for Customer)
'   %%BP_GROUPING%%     BP Grouping key (blank = default)
'   %%DEFINITION_FILE%% Path to field definitions
'
' Component IDs recorded from SAP GUI 7.60 on S/4HANA 1909.
' =============================================================================

Option Explicit

Const BP_NUMBER       = "%%BP_NUMBER%%"
Const BP_ROLE         = "%%BP_ROLE%%"
Const BP_GROUPING     = "%%BP_GROUPING%%"
Const DEFINITION_FILE = "%%DEFINITION_FILE%%"

Const VKEY_ENTER    = 0
Const VKEY_F11_SAVE = 11
Const SESSION_PATH  = "%%SESSION_PATH%%"   ' empty / unsubstituted = use default

' Include shared helpers (attach first; session-lock's pre-unlock sweep
' reads from oSession).
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%ATTACH_LIB_VBS%%", 1).ReadAll()
ExecuteGlobal CreateObject("Scripting.FileSystemObject") _
    .OpenTextFile("%%SESSION_LOCK_VBS%%", 1).ReadAll()

' ------ Helper: Find input field by name within a container (recursive) -----
Function FindField(oContainer, sFieldName)
    Set FindField = Nothing
    On Error Resume Next
    Dim ch
    Set ch = oContainer.Children
    If Err.Number <> 0 Then
        Err.Clear
        Exit Function
    End If
    On Error GoTo 0

    Dim j, c, cName, cType
    For j = 0 To ch.Count - 1
        Set c = ch(CLng(j))
        On Error Resume Next
        cName = c.Name
        cType = c.Type
        Err.Clear
        On Error GoTo 0

        If cName = sFieldName Then
            If cType = "GuiTextField" Or cType = "GuiCTextField" Or _
               cType = "GuiComboBox" Or cType = "GuiCheckBox" Then
                Set FindField = c
                Exit Function
            End If
        End If

        If cType = "GuiSimpleContainer" Or cType = "GuiScrollContainer" Or _
           cType = "GuiTabStrip" Or cType = "GuiTab" Then
            Dim found
            Set found = FindField(c, sFieldName)
            If Not (found Is Nothing) Then
                Set FindField = found
                Exit Function
            End If
        End If
    Next
End Function

' ------ Helper: Find and select a tab by name (recursive) -------------------
Function SelectTab(oContainer, sTabName)
    SelectTab = False
    On Error Resume Next
    Dim ch
    Set ch = oContainer.Children
    If Err.Number <> 0 Then
        Err.Clear
        Exit Function
    End If
    On Error GoTo 0

    Dim j, c, cName, cType
    For j = 0 To ch.Count - 1
        Set c = ch(CLng(j))
        On Error Resume Next
        cName = c.Name
        cType = c.Type
        Err.Clear
        On Error GoTo 0

        If cName = sTabName And cType = "GuiTab" Then
            c.Select
            SelectTab = True
            Exit Function
        End If

        If cType = "GuiSimpleContainer" Or cType = "GuiScrollContainer" Or _
           cType = "GuiTabStrip" Then
            If SelectTab(c, sTabName) Then
                SelectTab = True
                Exit Function
            End If
        End If
    Next
End Function

' ------ Helper: Set field value based on control type -----------------------
Sub SetFieldValue(oField, sValue)
    Select Case oField.Type
        Case "GuiTextField", "GuiCTextField"
            oField.Text = sValue
        Case "GuiComboBox"
            oField.Key = sValue
        Case "GuiCheckBox"
            If UCase(sValue) = "X" Or sValue = "1" Or UCase(sValue) = "TRUE" Then
                oField.Selected = True
            Else
                oField.Selected = False
            End If
    End Select
End Sub

' ------ 1. Attach to existing SAP GUI session (via shared attach helper) ----
Dim oSession
Set oSession = AttachSapSession(SESSION_PATH)

' ------ 2. Read definition file ---------------------------------------------
Dim oFSO, oFile, sLine
Set oFSO = CreateObject("Scripting.FileSystemObject")

If Not oFSO.FileExists(DEFINITION_FILE) Then
    WScript.Echo "ERROR: Definition file not found: " & DEFINITION_FILE
    WScript.Quit 1
End If

Dim arrSections(), arrFields(), arrValues()
Dim iCount
iCount = 0

Set oFile = oFSO.OpenTextFile(DEFINITION_FILE, 1, False)
Do While Not oFile.AtEndOfStream
    sLine = oFile.ReadLine
    ' Strip UTF-8 BOM if present on first line
    If iCount = 0 And Len(sLine) > 0 Then
        Do While Len(sLine) > 0 And Asc(Left(sLine, 1)) > 127
            sLine = Mid(sLine, 2)
        Loop
    End If

    sLine = Trim(sLine)

    If Len(sLine) > 0 And Left(sLine, 1) <> "#" Then
        Dim iParts
        iParts = InStr(sLine, vbTab)

        If iParts > 0 Then
            Dim sSection, sRest
            sSection = Trim(Left(sLine, iParts - 1))
            sRest = Mid(sLine, iParts + 1)

            Dim iParts2
            iParts2 = InStr(sRest, vbTab)

            If iParts2 > 0 Then
                Dim sField, sValue
                sField = Trim(Left(sRest, iParts2 - 1))
                sValue = Mid(sRest, iParts2 + 1)

                ReDim Preserve arrSections(iCount)
                ReDim Preserve arrFields(iCount)
                ReDim Preserve arrValues(iCount)
                arrSections(iCount) = UCase(sSection)
                arrFields(iCount) = sField
                arrValues(iCount) = sValue
                iCount = iCount + 1
            End If
        End If
    End If
Loop
oFile.Close

WScript.Echo "INFO: Read " & iCount & " field definitions from file."

' --- Lock the SAP session UI for the BP multi-tab input + save critical section ---
' Defence in depth (Rule 7): AppActivate guards external focus stealing;
' LockSessionUI guards in-session input races. Released after activation.
Dim wasLocked : wasLocked = TryLockSession(oSession)
If wasLocked Then
    WScript.Echo "INFO: Session UI locked for the BP multi-tab input + save critical section."
Else
    WScript.Echo "INFO: LockSessionUI not available on this SAP GUI build; continuing without lock."
End If

' ------ 3. Navigate to BP and Create Organization ---------------------------
WScript.Echo "INFO: Navigating to BP transaction..."
oSession.findById("wnd[0]").maximize
oSession.findById("wnd[0]/tbar[0]/okcd").text = "/nBP"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

WScript.Echo "INFO: Creating new Business Partner (Organization)..."
oSession.findById("wnd[0]/tbar[1]/btn[29]").Press  ' Create Organization
WScript.Sleep 1000

' Verify we are on Create screen
Dim sTitle
sTitle = oSession.findById("wnd[0]").Text
If InStr(sTitle, "Create") = 0 Then
    WScript.Echo "ERROR: Failed to enter Create mode. Title: " & sTitle
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If
WScript.Echo "INFO: Create screen reached: " & sTitle

' ------ 4. Set header fields (Role, Grouping, BP Number) --------------------
' IMPORTANT: Setting a non-default role triggers a popup "Change to another BP
' role in create mode". Pressing the popup's "Create" button refreshes the
' screen with the chosen role and editable fields.  If role is empty or the
' default "000000", we skip the role change to avoid making fields read-only.
Dim oUsr
Set oUsr = oSession.findById("wnd[0]/usr")

If BP_ROLE <> "" And BP_ROLE <> "000000" Then
    Dim oRole
    Set oRole = FindField(oUsr, "BUS_JOEL_MAIN-PARTNER_ROLE")
    If Not (oRole Is Nothing) Then
        oRole.Key = BP_ROLE
        WScript.Sleep 500

        ' Handle the "Change to another BP role" popup
        On Error Resume Next
        Dim oPopup
        Set oPopup = oSession.findById("wnd[1]")
        If Err.Number = 0 And Not (oPopup Is Nothing) Then
            oSession.findById("wnd[1]/usr/btnBUTTON_1").Press   ' "Create" button
            WScript.Sleep 2000
            Err.Clear
        End If
        On Error GoTo 0

        ' Re-acquire oUsr after screen refresh
        Set oUsr = oSession.findById("wnd[0]/usr")
        WScript.Echo "INFO: Role set to: " & BP_ROLE
    Else
        WScript.Echo "WARNING: Role field not found."
    End If
End If

If BP_GROUPING <> "" Then
    Dim oGrp
    Set oGrp = FindField(oUsr, "BUS_JOEL_MAIN-CREATION_GROUP")
    If Not (oGrp Is Nothing) Then
        oGrp.Key = BP_GROUPING
        WScript.Echo "INFO: Grouping set to: " & BP_GROUPING
    Else
        WScript.Echo "WARNING: Grouping field not found."
    End If
End If

If BP_NUMBER <> "" Then
    Dim oBpNum
    Set oBpNum = FindField(oUsr, "BUS_JOEL_MAIN-CREATION_NUMBER")
    If Not (oBpNum Is Nothing) Then
        oBpNum.Text = BP_NUMBER
        WScript.Echo "INFO: BP Number set to: " & BP_NUMBER
    Else
        WScript.Echo "WARNING: BP Number field not found."
    End If
End If

' ------ 5. Fill tab fields --------------------------------------------------
' Re-acquire oUsr to ensure it references the current screen
Set oUsr = oSession.findById("wnd[0]/usr")

' Collect unique tab IDs in order
Dim arrTabs()
Dim iTabCount
iTabCount = 0

Dim iTmp
For iTmp = 0 To iCount - 1
    Dim bFound
    bFound = False
    Dim iChk
    For iChk = 0 To iTabCount - 1
        If arrTabs(iChk) = arrSections(iTmp) Then
            bFound = True
            Exit For
        End If
    Next
    If Not bFound Then
        ReDim Preserve arrTabs(iTabCount)
        arrTabs(iTabCount) = arrSections(iTmp)
        iTabCount = iTabCount + 1
    End If
Next

WScript.Echo "INFO: Processing " & iTabCount & " tabs..."

Dim iTab
For iTab = 0 To iTabCount - 1
    Dim sTabSection
    sTabSection = arrTabs(iTab)

    ' Convert TAB_XX to SCREEN_1100_TAB_XX for tab selection
    Dim sTabName
    sTabName = "SCREEN_1100_" & sTabSection

    ' Select the tab
    If Not SelectTab(oUsr, sTabName) Then
        WScript.Echo "WARNING: Tab " & sTabSection & " not found, trying to set fields anyway."
    Else
        WScript.Echo "INFO: Selected tab: " & sTabSection
    End If
    WScript.Sleep 500

    ' Set fields for this tab
    Dim iFld
    For iFld = 0 To iCount - 1
        If arrSections(iFld) = sTabSection Then
            Dim oField
            Set oField = FindField(oUsr, arrFields(iFld))
            If oField Is Nothing Then
                WScript.Echo "WARNING:   Field not found: " & arrFields(iFld)
            Else
                On Error Resume Next
                SetFieldValue oField, arrValues(iFld)
                If Err.Number <> 0 Then
                    WScript.Echo "WARNING:   Error setting " & arrFields(iFld) & ": " & Err.Description
                    Err.Clear
                Else
                    WScript.Echo "INFO:   " & arrFields(iFld) & " = " & arrValues(iFld)
                End If
                On Error GoTo 0
            End If
        End If
    Next
Next

' Press Enter to commit inline edits
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 1000

' Check for errors after enter
Dim sStatus
sStatus = oSession.findById("wnd[0]/sbar").Text
If oSession.findById("wnd[0]/sbar").MessageType = "E" Then
    WScript.Echo "ERROR: Validation error: " & sStatus
    ReleaseSession oSession, wasLocked
    WScript.Quit 1
End If

' ------ 6. Save -------------------------------------------------------------
WScript.Echo "INFO: Saving Business Partner..."
oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
WScript.Sleep 2000

' Handle warning: press Enter to acknowledge, then save again
Dim sSaveStatus, sSaveType
sSaveStatus = oSession.findById("wnd[0]/sbar").Text
sSaveType = oSession.findById("wnd[0]/sbar").MessageType
If sSaveType = "W" Then
    WScript.Echo "INFO: Warning after save: " & sSaveStatus & " - acknowledging..."
    oSession.findById("wnd[0]").sendVKey VKEY_ENTER
    WScript.Sleep 1000
    oSession.findById("wnd[0]").sendVKey VKEY_F11_SAVE
    WScript.Sleep 2000
End If

' Handle popups (transport, etc.)
On Error Resume Next
If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    WScript.Echo "INFO: Popup detected."
    oSession.findById("wnd[1]/tbar[0]/btn[7]").Press  ' Local Object
    If Err.Number <> 0 Then
        Err.Clear
        oSession.ActiveWindow.sendVKey VKEY_ENTER
    End If
    WScript.Sleep 2000
End If

If InStr(oSession.ActiveWindow.Id, "wnd[1]") > 0 Then
    oSession.ActiveWindow.sendVKey VKEY_ENTER
    WScript.Sleep 1000
End If
Err.Clear
On Error GoTo 0

' --- Release the session UI lock; result check is read-only ---
ReleaseSession oSession, wasLocked
If wasLocked Then WScript.Echo "INFO: Session UI lock released."

' ------ 7. Check result -----------------------------------------------------
sStatus = oSession.findById("wnd[0]/sbar").Text
Dim sStatusType
sStatusType = oSession.findById("wnd[0]/sbar").MessageType

' Capture the title which may contain the created BP number
sTitle = oSession.findById("wnd[0]").Text

' Navigate back to clean state
oSession.findById("wnd[0]/tbar[0]/okcd").Text = "/n"
oSession.findById("wnd[0]").sendVKey VKEY_ENTER
WScript.Sleep 500
On Error Resume Next
oSession.findById("wnd[1]/usr/btnSPOP-OPTION1").Press
Err.Clear
On Error GoTo 0
WScript.Sleep 500

WScript.Echo "INFO: Status (" & sStatusType & "): " & sStatus

If sStatusType = "E" Or sStatusType = "A" Then
    WScript.Echo "ERROR: Business Partner creation failed. " & sStatus
    WScript.Quit 1
End If

WScript.Echo "SUCCESS: Business Partner created in SAP. " & sStatus
WScript.Quit 0
